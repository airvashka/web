# Directus backend URL (vyplníme po nasazení Directus na Railway)
PUBLIC_DIRECTUS_URL=https://your-directus.up.railway.app

# Optional — pokud má Directus chráněné endpoints (placeholder pro budoucnost)
DIRECTUS_TOKEN=

# Anthropic API key — pro /admin/cenik PDF parsing
# Vygeneruj na console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Google Places API — pro fetch Google recenzí při build-time (free tier 100 calls/day)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID_PRODEJ=
GOOGLE_PLACE_ID_SERVIS=
