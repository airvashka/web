# ============================================================
#  SFR Motor web — vzor ENV proměnných
#  Zkopíruj do .env a doplň hodnoty (z password manageru).
#  .env je v .gitignore — NIKDY necommituj reálné hodnoty.
#  Plný popis přístupů: docs/HANDOVER.md
# ============================================================

# ---- Directus (CMS) ----
# PUBLIC_* jde i na klienta. Pro lokální vývoj stačí tahle jedna (ukáže na živá data).
PUBLIC_DIRECTUS_URL=https://admin.sfr-motor.cz
DIRECTUS_URL=https://admin.sfr-motor.cz
DIRECTUS_STATIC_TOKEN=       # server-side čtení (build, API)
DIRECTUS_LEAD_TOKEN=         # zápis poptávek z /api/lead

# ---- Cloudflare Turnstile (antispam na formulářích) ----
PUBLIC_TURNSTILE_SITE_KEY=   # veřejný sitekey (v HTML)
TURNSTILE_SECRET=            # server-only verifikace
TURNSTILE_STRICT=false       # true = odmítnout, když Turnstile selže

# ---- UCL / UniCredit Leasing (kalkulačka) ----
PUBLIC_UCL_PROXY_URL=/api/leasing
UNICREDIT_AUTH_URL=
UNICREDIT_CALC_URL=
UNICREDIT_INIT_URL=
UNICREDIT_INIT_HOST=
UNICREDIT_CLIENT_SECRET=
UNICREDIT_USERNAME=
UNICREDIT_PASSWORD=

# ---- Anthropic (AI parsing ceníků + chat) ----
ANTHROPIC_API_KEY=

# ---- Ecomail (newsletter) ----
ECOMAIL_API_KEY=
ECOMAIL_HASH=
ECOMAIL_LIST_ID=

# ---- Google (mapy + recenze) ----
PUBLIC_GOOGLE_MAPS_API_KEY=  # OMEZIT na referrer *.sfr-motor.cz + Maps Embed API!
GOOGLE_PLACES_API_KEY=       # server-side (fetch recenzí při buildu)
GOOGLE_PLACE_ID_PRODEJ=
GOOGLE_PLACE_ID_SERVIS=

# ---- Zálohy / cron ----
CRON_SECRET=                 # Bearer auth pro /api/cron/backup (vygeneruj: crypto.randomUUID())
VERCEL_DEPLOY_HOOK=          # URL deploy hooku (rebuild po stock syncu)

# ============================================================
#  Pozn.: proměnné pro VPS skripty (DATABASE_URL, DIRECTUS_ADMIN_TOKEN,
#  DIRECTUS_EMAIL/PASSWORD, UCL_PROXY_URL…) patří do
#  /opt/sfr-motor/vps-setup/.env na serveru, ne sem.
# ============================================================
