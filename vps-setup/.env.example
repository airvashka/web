# ─────────────────────────────────────────────────────────────────────────────
# SFR Motor VPS — ENV proměnné
#
# Zkopíruj na: cp .env.example .env
# Pak vyplň všechny `VYPLŇ_*` placeholdery. Po uložení ten soubor NIKDY
# nepushuj na GitHub — je v .gitignore.
#
# Vygenerování bezpečných hesel (na svém Windows v PowerShellu):
#   -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | % {[char]$_})
# Nebo na serveru: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# ═══ DOMÉNY ════════════════════════════════════════════════════════════════
ADMIN_DOMAIN=admin.sfr-motor.cz
API_DOMAIN=api.sfr-motor.cz

# ═══ POSTGRES ══════════════════════════════════════════════════════════════
POSTGRES_DB=directus
POSTGRES_USER=directus
POSTGRES_PASSWORD=VYPLŇ_postgres_heslo_min_32_znaků

# ═══ REDIS ═════════════════════════════════════════════════════════════════
REDIS_PASSWORD=VYPLŇ_redis_heslo_min_32_znaků

# ═══ DIRECTUS ══════════════════════════════════════════════════════════════
# KEY a SECRET — interní podpisové klíče (oba MUSÍ být uuid v4 nebo random 32+)
DIRECTUS_KEY=VYPLŇ_uuidv4_napriklad_z_uuidgen
DIRECTUS_SECRET=VYPLŇ_random_64_znaků
DIRECTUS_ADMIN_EMAIL=admin@sfr-motor.cz
DIRECTUS_ADMIN_PASSWORD=VYPLŇ_silné_heslo_pro_admin_login

# Public URL — sem se hlásí frontend (Vercel) a admin browser
DIRECTUS_PUBLIC_URL=https://admin.sfr-motor.cz

# CORS — odkud smí volat (Vercel preview + prod)
DIRECTUS_CORS_ENABLED=true
DIRECTUS_CORS_ORIGIN=https://sfr-motor.cz,https://www.sfr-motor.cz,https://beta.sfr-motor.cz,https://sfr-motor-web.vercel.app

# Rate limiting (přes Redis)
DIRECTUS_RATE_LIMITER_ENABLED=true
DIRECTUS_RATE_LIMITER_POINTS=50
DIRECTUS_RATE_LIMITER_DURATION=1

# ═══ MINIO (S3-compatible storage — nahrazuje Cloudflare R2) ═══════════════
# Root credentials — používá Directus pro upload fotek
MINIO_ROOT_USER=sfradmin
MINIO_ROOT_PASSWORD=VYPLŇ_minio_heslo_min_32_znaků
MINIO_BUCKET=sfr-motor-uploads
MINIO_REGION=eu-central-1

# Directus storage config — používá MinIO přes S3 protocol
STORAGE_LOCATIONS=minio
STORAGE_MINIO_DRIVER=s3
STORAGE_MINIO_KEY=sfradmin
STORAGE_MINIO_SECRET=${MINIO_ROOT_PASSWORD}
STORAGE_MINIO_BUCKET=sfr-motor-uploads
STORAGE_MINIO_REGION=eu-central-1
STORAGE_MINIO_ENDPOINT=http://minio:9000
STORAGE_MINIO_FORCE_PATH_STYLE=true

# ═══ UCL LEASING (UniCredit) ═══════════════════════════════════════════════
# PREPROD (default):
UNICREDIT_AUTH_URL=https://kalkulator-prep.unicreditleasing.sk/keycloak/realms/uclkalk/protocol/openid-connect/token
UNICREDIT_CALC_URL=https://kalkulator-prep.unicreditleasing.sk/api/v1/calculation/calculation/
UNICREDIT_USERNAME=sfr_test
UNICREDIT_PASSWORD=SFR_tst_2026
UNICREDIT_CLIENT_SECRET=NREaypamuCMq1iPaEYyxw21HHDNBqvS5

# PROD (až dorazí real credentials od Jiřího Vintra):
# UNICREDIT_AUTH_URL=https://kalkulator.unicreditleasing.sk/keycloak/realms/uclkalk/protocol/openid-connect/token
# UNICREDIT_CALC_URL=https://kalkulator.unicreditleasing.sk/api/v1/calculation/calculation/
# UNICREDIT_USERNAME=VYPLŇ_prod_username
# UNICREDIT_PASSWORD=VYPLŇ_prod_password
# UNICREDIT_CLIENT_SECRET=VYPLŇ_prod_client_secret

# Origin whitelist pro UCL proxy (kdo smí volat /leasing/calculate).
# Server.js používá .includes() — stačí substring (matchne i podsubdomény, www, http/https).
UCL_PROXY_ALLOWED_ORIGINS=sfr-motor.cz,localhost,127.0.0.1,vercel.app

# ═══ BACKUP ════════════════════════════════════════════════════════════════
# WebGlobe drží 7denní snapshoty automaticky. Tohle je navíc — pg_dump local.
BACKUP_RETENTION_DAYS=14
