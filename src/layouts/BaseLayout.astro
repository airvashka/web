---
import '@/styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import MobileBottomBar from '@components/MobileBottomBar.astro';
import { directusGet, directusAsset } from '@lib/directus';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  mainClass?: string;
}

const {
  title,
  description = 'SFR Motor — autorizovaný dealer KGM, OMODA & JAECOO a Farizon. Skladové vozy, servis pro všechny značky, prodej a doplňkové služby. Praha-Ďáblice.',
  ogImage,
  canonical,
  mainClass,
} = Astro.props;

const siteName = 'SFR Motor';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;

/* Canonical URL — normalizovaná (bez koncového lomítka, vyjma rootu) na produkční
   doméně (astro.config `site`). Řeší duplicitní indexaci /sklad vs /sklad/ atd.
   Volitelný prop `canonical` umožní override (např. paginace, filtry). */
const siteBase = Astro.site ?? new URL('https://sfr-motor.cz');
const canonicalPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const canonicalUrl = canonical ?? new URL(canonicalPath, siteBase).href;

/* OG image — default branded fallback (fotka prodejny), když stránka nepošle vlastní. */
const ogImageUrl = ogImage ?? new URL('/og-default.jpg', siteBase).href;

/* Favicon — UUID z site_settings.favicon, fallback /favicon.svg.
   - Fetcheme jen UUID (žádný .type expand) — bezpečné v prefetch cache
   - V <link> ne uvádíme type → browser auto-detect z Directus Content-Type response */
let faviconHref = '/favicon.svg';
let faviconIsLocal = true;
try {
  const settingsList = await directusGet<any>('site_settings', { limit: 1, fields: ['*'] });
  const fav = settingsList?.[0]?.favicon;
  // favicon může být: plain UUID string | object {id} | object {directus_files_id}
  const favId = typeof fav === 'string' ? fav : (fav?.id ?? fav?.directus_files_id ?? null);
  if (favId) {
    faviconHref = directusAsset(favId);
    faviconIsLocal = false;
  }
} catch {
  /* site_settings nebo favicon ještě neexistuje → fallback */
}
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="cs_CZ" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:alt" content={fullTitle} />

  <!-- Fonts —
       Noto Sans (universal Latin) místo Noto Sans KR — má plnou českou podporu
       (Latin Extended-A: ř, č, ž, š, ě, ť, ď, ů…). Stejná rodina, ale Korean
       varianta postrádá glyphy pro Czech diacritics → browser fallbackoval na
       sys font, takže háčkované znaky vypadaly jinak než zbytek. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap&subset=latin-ext"
    rel="stylesheet"
  />

  <!-- Favicons —
       Local fallback (/favicon.svg) má fixed type. Directus asset → browser auto-detect
       z Content-Type response (Directus posílá správný mime). -->
  {faviconIsLocal ? (
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
  ) : (
    <>
      <link rel="icon" href={faviconHref} />
      <link rel="shortcut icon" href={faviconHref} />
      <link rel="apple-touch-icon" href={faviconHref} />
    </>
  )}
  <meta name="theme-color" content="#FAFAF7" />
  <meta name="color-scheme" content="only light" />

  <!-- GTM placeholder (doplníme po nasazení) -->
  <script>window.dataLayer = window.dataLayer || [];</script>
</head>
<body>
  <Header />

  <main id="main" class={mainClass}>
    <slot />
  </main>

  <Footer />
  <MobileBottomBar />

  <!-- ===== GLOBÁLNÍ DPH PŘEPÍNAČ — logika ====
       UI prvek je v Header (VatToggle component). Body class `vat-private` /
       `vat-company` přepíná zobrazení (::after labels, hide kalkulačky).
       JS přepočítává ceny inline z S DPH → bez DPH (÷1.21).
       Persistuje v localStorage. -->
  <script is:inline>
    (function initVatToggle() {
      console.log('[vat-toggle] init started');
      const STORAGE_KEY = 'sfr-vat-mode';
      const VAT_RATE = 0.21;
      // Selectors všech elementů kde jsou ceny S DPH (z DB).
      // POZOR: některé jsou span uvnitř, jiné celý element. Přepočítáváme jen
      // pure-text obsah (řezání HTML značky uvnitř by rozbilo strike spans atd.).
      const PRICE_SELECTORS = [
        '.scard .price > span:last-child',
        '.scard .amount',
        '.trim-price',
        '.trim-price--promo',
        '.price-val',
        '.price-val--promo',
        '.compare-trim-price',
        '.compare-trim-price--promo',
        '.compare-price',
        '.info-price .amount',
        '.sticky-cta .price',
        '.scard .price-before',
        '.compare-trim-list-strike',
        '.price-strike',
        '.a-price-val',
        '.a-price-old',
        '.info-price-before .strike',
        '.info-price-before .save',
      ];

      function parsePrice(text) {
        const match = String(text || '').match(/([\d\s ]+)\s*Kč?/i);
        if (!match) return null;
        const num = parseInt(match[1].replace(/[\s ]/g, ''), 10);
        return Number.isFinite(num) && num > 0 ? num : null;
      }

      function fmtPrice(n, withSuffix) {
        return n.toLocaleString('cs-CZ') + (withSuffix ? ' Kč' : '');
      }

      function applyMode(mode) {
        // Body class přepíná CSS ::after labels (vč. DPH / bez DPH)
        document.body.classList.toggle('vat-private', mode === 'private');
        document.body.classList.toggle('vat-company', mode === 'company');
        // Toggle button states
        document.querySelectorAll('[data-vat-mode]').forEach((btn) => {
          const active = btn.dataset.vatMode === mode;
          btn.classList.toggle('is-active', active);
          btn.setAttribute('aria-pressed', String(active));
        });
        // Přepočítej všechny ceny v DOM
        document.querySelectorAll(PRICE_SELECTORS.join(',')).forEach((el) => {
          // Při prvním běhu ulož original text do data-orig
          if (!el.dataset.vatOrig) el.dataset.vatOrig = el.textContent;
          const origText = el.dataset.vatOrig;
          if (mode === 'company') {
            const num = parsePrice(origText);
            if (!num) return;
            const noVat = Math.round(num / (1 + VAT_RATE));
            // Zachovej formát originálního textu (s/bez "Kč" suffixu)
            const hasKc = /Kč/i.test(origText);
            el.textContent = fmtPrice(noVat, hasKc);
          } else {
            // Zpět na original
            el.textContent = origText;
          }
        });
      }

      // Init: read localStorage, default 'private'
      let initialMode = 'private';
      try { initialMode = localStorage.getItem(STORAGE_KEY) || 'private'; } catch {}
      // Apply hned (před první paint pokud možno)
      if (document.body) applyMode(initialMode);
      else document.addEventListener('DOMContentLoaded', () => applyMode(initialMode));

      // Event delegation — toggle buttons jsou v Header
      const toggleButtons = document.querySelectorAll('[data-vat-mode]');
      console.log('[vat-toggle] found', toggleButtons.length, 'toggle buttons');
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-vat-mode]');
        if (!btn) return;
        const mode = btn.dataset.vatMode;
        if (mode !== 'private' && mode !== 'company') return;
        console.log('[vat-toggle] click — switching to', mode);
        try { localStorage.setItem(STORAGE_KEY, mode); } catch {}
        applyMode(mode);
      });

      // Re-apply na SPA navigaci (Astro view transitions — pokud zapnuto)
      document.addEventListener('astro:page-load', () => {
        const m = (() => { try { return localStorage.getItem(STORAGE_KEY) || 'private'; } catch { return 'private'; } })();
        applyMode(m);
      });
    })();
  </script>
</body>
</html>
