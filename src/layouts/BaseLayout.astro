---
import '@/styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import MobileBottomBar from '@components/MobileBottomBar.astro';
import { directusGet, directusAsset } from '@lib/directus';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'SFR Motor — autorizovaný dealer KGM, OMODA & JAECOO a Farizon. Skladové vozy, servis pro všechny značky, prodej a doplňkové služby. Praha-Ďáblice.',
  ogImage,
} = Astro.props;

const siteName = 'SFR Motor';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;

/* Favicon — fetch z site_settings.favicon (M2O directus_files), fallback /favicon.svg.
   Try/catch ať se build nezhroutí, pokud field ještě neexistuje (před migrací). */
let faviconHref = '/favicon.svg';
let faviconType: string | null = null;
try {
  const settingsList = await directusGet<any>('site_settings', { limit: 1, fields: ['favicon.id', 'favicon.type'] });
  const fav = settingsList?.[0]?.favicon;
  const favId = fav?.id ?? (typeof fav === 'string' ? fav : null);
  if (favId) {
    faviconHref = directusAsset(favId);
    if (fav?.type) faviconType = fav.type;
  }
} catch {
  /* site_settings.favicon ještě neexistuje → použijeme fallback */
}
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="cs_CZ" />
  <meta property="og:site_name" content={siteName} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Favicons -->
  {faviconType ? (
    <link rel="icon" type={faviconType} href={faviconHref} />
  ) : (
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
  )}
  <meta name="theme-color" content="#FAFAF7" />

  <!-- GTM placeholder (doplníme po nasazení) -->
  <script>window.dataLayer = window.dataLayer || [];</script>
</head>
<body>
  <Header />

  <main id="main">
    <slot />
  </main>

  <Footer />
  <MobileBottomBar />
</body>
</html>
