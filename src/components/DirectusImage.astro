---
/**
 * DirectusImage — komponenta pro fotky uložené v Directusu.
 *
 * Použití:
 *   <DirectusImage src={model.hero_image} alt="Korando" />
 *   <DirectusImage src={...} alt="..." loading="eager" fetchpriority="high" />
 *
 * Vygeneruje <img> s:
 *  • WebP formátem (lehčí o ~40 % proti JPG)
 *  • responsive srcset (3 widths)
 *  • lazy loading + async decoding
 *  • fetchpriority hint pro hero fotky
 *  • Directus transforms on-demand
 *
 * Pozn.: AVIF jsme zkusili ale Directus na Railway hobby instance je
 * příliš pomalý na on-demand generování (5–10× pomalejší než WebP).
 * WebP fallback na JPG je v praxi dost — WebP má podporu >97 % browserů.
 */
import { directusAsset } from '@lib/directus';

interface Props {
  src: string | null | undefined;     // UUID souboru v Directusu
  alt: string;
  widths?: number[];                  // např. [400, 800, 1600]
  sizes?: string;                     // CSS sizes hint pro browser
  aspectRatio?: string;               // "16/10", "4/3", "1/1"
  fit?: 'cover' | 'contain';
  fill?: boolean;                     // true = vyplní celý parent (width+height 100%), object-fit: cover
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  fallbackGradient?: string;          // pokud src je null, ukáže gradient
}

const {
  src,
  alt,
  widths = [480, 960, 1600],
  sizes = '(max-width: 700px) 100vw, (max-width: 1200px) 50vw, 33vw',
  aspectRatio,
  fit = 'cover',
  fill = false,
  loading = 'lazy',
  fetchpriority,
  class: className = '',
  fallbackGradient,
} = Astro.props;

const styleParts: string[] = [];
if (aspectRatio) styleParts.push(`aspect-ratio: ${aspectRatio}`);
if (fit) styleParts.push(`object-fit: ${fit}`);
if (fill) {
  // Fill mode — vyplní celý parent. Použij pro absolutně pozicované hero pozadí.
  styleParts.push('width: 100%', 'height: 100%');
}
const style = styleParts.join('; ');

const hasSrc = !!src;
const mid = widths[Math.floor(widths.length / 2)];

const mainSrc = hasSrc ? directusAsset(src!, { width: mid, format: 'webp', quality: 80 }) : '';
const srcset = hasSrc
  ? widths.map((w) => `${directusAsset(src!, { width: w, format: 'webp', quality: 80 })} ${w}w`).join(', ')
  : '';
---

{hasSrc ? (
  <img
    src={mainSrc}
    srcset={srcset}
    sizes={sizes}
    alt={alt}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    class={className}
    style={style}
  />
) : (
  <div
    class={`directus-image-placeholder ${className}`}
    style={`${style}; background: ${fallbackGradient ?? 'linear-gradient(135deg, #2a2a30, #56565d)'};`}
    aria-label={alt}
    role="img"
  />
)}

<style>
  img { display: block; width: 100%; height: auto; }
  .directus-image-placeholder { width: 100%; }
</style>
