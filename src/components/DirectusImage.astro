---
/**
 * DirectusImage — komponenta pro fotky uložené v Directusu.
 *
 * Použití:
 *   <DirectusImage src={model.hero_image} alt="Korando" />
 *   <DirectusImage src={...} alt="..." loading="eager" fetchpriority="high" />
 *
 * Vygeneruje <picture> s:
 *  • AVIF formátem (nejlepší komprese, ~50 % oproti JPG)
 *  • WebP fallback (širší podpora, ~40 % oproti JPG)
 *  • JPG fallback pro very old browsers
 *  • srcset (responsive widths)
 *  • lazy loading + async decoding
 *  • fetchpriority hint pro hero fotky
 *  • Directus transforms on-demand
 */
import { directusAsset } from '@lib/directus';

interface Props {
  src: string | null | undefined;     // UUID souboru v Directusu
  alt: string;
  widths?: number[];                  // např. [400, 800, 1600]
  sizes?: string;                     // CSS sizes hint pro browser
  aspectRatio?: string;               // "16/10", "4/3", "1/1"
  fit?: 'cover' | 'contain';
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  fallbackGradient?: string;          // pokud src je null, ukáže gradient
}

const {
  src,
  alt,
  widths = [480, 960, 1600],
  sizes = '(max-width: 700px) 100vw, (max-width: 1200px) 50vw, 33vw',
  aspectRatio,
  fit = 'cover',
  loading = 'lazy',
  fetchpriority,
  class: className = '',
  fallbackGradient,
} = Astro.props;

const styleParts: string[] = [];
if (aspectRatio) styleParts.push(`aspect-ratio: ${aspectRatio}`);
if (fit) styleParts.push(`object-fit: ${fit}`);
const style = styleParts.join('; ');

const hasSrc = !!src;
const mid = widths[Math.floor(widths.length / 2)];

// Helper: vygeneruje srcset pro daný formát
function buildSrcset(format: 'avif' | 'webp' | 'jpg'): string {
  if (!hasSrc) return '';
  return widths
    .map((w) => `${directusAsset(src!, { width: w, format, quality: format === 'avif' ? 70 : 80 })} ${w}w`)
    .join(', ');
}

const avifSrcset = buildSrcset('avif');
const webpSrcset = buildSrcset('webp');
const jpgSrcset = buildSrcset('jpg');
const fallbackSrc = hasSrc ? directusAsset(src!, { width: mid, format: 'jpg', quality: 80 }) : '';
---

{hasSrc ? (
  <picture>
    {avifSrcset && <source type="image/avif" srcset={avifSrcset} sizes={sizes} />}
    {webpSrcset && <source type="image/webp" srcset={webpSrcset} sizes={sizes} />}
    <img
      src={fallbackSrc}
      srcset={jpgSrcset}
      sizes={sizes}
      alt={alt}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
      class={className}
      style={style}
    />
  </picture>
) : (
  <div
    class={`directus-image-placeholder ${className}`}
    style={`${style}; background: ${fallbackGradient ?? 'linear-gradient(135deg, #2a2a30, #56565d)'};`}
    aria-label={alt}
    role="img"
  />
)}

<style>
  picture, img { display: block; width: 100%; height: auto; }
  .directus-image-placeholder { width: 100%; }
</style>
