---
/**
 * FuelIcon — barevný kruhový badge pro stock cards (overlay v rohu fotky).
 *
 * 4 varianty podle fuel_type:
 *   - petrol / diesel → hnědý kruh + bílá pumpa (ICE)
 *   - hybrid          → modrý kruh + bílá pumpa s modrým bleskem uvnitř (HEV)
 *   - phev            → modrý kruh + bílá pumpa + zelený blesk + bílá zástrčka (PHEV)
 *   - ev              → zelený kruh + bílý blesk (EV)
 *
 * Použití: <FuelIcon type={v.model.fuel_type} />
 * Vrací empty fragment pokud type nematchuje.
 */
type FuelType = 'petrol' | 'diesel' | 'hybrid' | 'phev' | 'ev' | string;
interface Props {
  type?: FuelType | null;
  class?: string;
}
const { type = '', class: className = '' } = Astro.props;

const isICE = type === 'petrol' || type === 'diesel';
const isHEV = type === 'hybrid';
const isPHEV = type === 'phev';
const isEV = type === 'ev';

const label = isICE ? (type === 'diesel' ? 'Diesel' : 'Benzín')
            : isHEV ? 'Hybrid'
            : isPHEV ? 'Plug-in hybrid'
            : isEV ? 'Elektro' : '';
---

{isICE && (
  <span class={`fuel-icon fuel-icon--ice ${className}`} title={label} aria-label={label}>
    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      {/* Pumpa — bílá */}
      <path d="M16 14c0-2.2 1.8-4 4-4h16c2.2 0 4 1.8 4 4v36H16V14z" fill="#fff"/>
      <rect x="20" y="16" width="16" height="12" rx="1.5" fill="#8B6F5C"/>
      {/* Hadice s tryskou */}
      <path d="M40 22h4l5 5v16c0 2.2 1.8 4 4 4s4-1.8 4-4V32" stroke="#fff" stroke-width="3" fill="none" stroke-linecap="round"/>
    </svg>
  </span>
)}
{isHEV && (
  <span class={`fuel-icon fuel-icon--hev ${className}`} title={label} aria-label={label}>
    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M16 14c0-2.2 1.8-4 4-4h16c2.2 0 4 1.8 4 4v36H16V14z" fill="#fff"/>
      <rect x="20" y="16" width="16" height="10" rx="1.5" fill="#1F6FEB"/>
      <path d="M40 22h4l5 5v16c0 2.2 1.8 4 4 4s4-1.8 4-4V32" stroke="#fff" stroke-width="3" fill="none" stroke-linecap="round"/>
      {/* Modrý blesk uvnitř */}
      <polygon points="30,30 22,42 28,42 26,52 34,40 28,40 30,30" fill="#1F6FEB"/>
    </svg>
  </span>
)}
{isPHEV && (
  <span class={`fuel-icon fuel-icon--phev ${className}`} title={label} aria-label={label}>
    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      {/* Pumpa */}
