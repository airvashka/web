---
/**
 * FuelIcon — barevný kruhový badge (fuel-type overlay v rohu stock card fotky).
 * Používá PNG ikony z /public/fuel-icons/ (kreslené Jardou, nahradily SVG).
 * Varianty: ICE (petrol/diesel) | HEV (hybrid) | PHEV (plug-in) | EV (elektro).
 */
type FuelType = 'petrol' | 'diesel' | 'hybrid' | 'phev' | 'ev' | string;
interface Props {
  type?: FuelType | null;
  class?: string;
}
const { type = '', class: className = '' } = Astro.props;

const TYPE_MAP: Record<string, { file: string; label: string }> = {
  petrol:  { file: 'ice.png',  label: 'Benzín' },
  diesel:  { file: 'ice.png',  label: 'Diesel' },
  hybrid:  { file: 'hev.png',  label: 'Hybrid (HEV)' },
  phev:    { file: 'phev.png', label: 'Plug-in hybrid (PHEV)' },
  ev:      { file: 'ev.png',   label: 'Elektro (EV)' },
};

const cfg = TYPE_MAP[type as string];
---

{cfg && (
  <img
    src={`/fuel-icons/${cfg.file}`}
    alt={cfg.label}
    title={cfg.label}
    class={`fuel-icon ${className}`}
    loading="lazy"
    width="44"
    height="44"
  />
)}

<style is:global>
  .fuel-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: inline-block;
    object-fit: cover;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.20);
  }
</style>
