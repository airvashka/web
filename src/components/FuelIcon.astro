---
/**
 * FuelIcon — malá ikonka pohonu pro stock cards (overlay bottom-right na fotce).
 * Vrací odpovídající SVG podle fuel type: ICE (benzín/diesel), HEV (hybrid),
 * PHEV (plug-in hybrid), EV (elektro).
 *
 * Použití: <FuelIcon type={v.model.fuel_type} />
 * Vrací empty fragment pokud type nematchuje (žádná ikonka se nezobrazí).
 */
type FuelType = 'petrol' | 'diesel' | 'hybrid' | 'phev' | 'ev' | string;
interface Props {
  type?: FuelType | null;
  class?: string;
}
const { type = '', class: className = '' } = Astro.props;
---

{type === 'petrol' || type === 'diesel' ? (
  <span class={`fuel-icon fuel-icon--ice ${className}`} title={type === 'diesel' ? 'Diesel' : 'Benzín'} aria-label={type === 'diesel' ? 'Diesel' : 'Benzín'}>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="22" x2="15" y2="22"/>
      <line x1="4" y1="9" x2="14" y2="9"/>
      <path d="M14 22V4a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v18"/>
      <path d="M14 13h2a2 2 0 0 1 2 2v2a2 2 0 0 0 2 2h0a2 2 0 0 0 2-2V9.83a2 2 0 0 0-.59-1.42L18 5"/>
    </svg>
  </span>
) : type === 'hybrid' ? (
  <span class={`fuel-icon fuel-icon--hev ${className}`} title="Hybrid" aria-label="Hybrid">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22c-4.4 0-8-3.6-8-8 0-4 4-9 8-12 4 3 8 8 8 12 0 4.4-3.6 8-8 8z"/>
      <path d="M9 14l2 2 4-4"/>
    </svg>
  </span>
) : type === 'phev' ? (
  <span class={`fuel-icon fuel-icon--phev ${className}`} title="Plug-in hybrid" aria-label="Plug-in hybrid">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 2v3"/>
      <path d="M15 2v3"/>
      <path d="M7 5h10v6a4 4 0 0 1-4 4h-2a4 4 0 0 1-4-4V5z"/>
      <path d="M12 15v3"/>
      <path d="M9 22h6"/>
      <path d="M12 18l-1 4h3l-1-4"/>
    </svg>
  </span>
) : type === 'ev' ? (
  <span class={`fuel-icon fuel-icon--ev ${className}`} title="Elektro" aria-label="Elektro">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" fill="currentColor"/>
    </svg>
  </span>
) : null}
