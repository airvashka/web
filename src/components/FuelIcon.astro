---
/**
 * FuelIcon — barevný kruhový badge (fuel-type overlay v rohu stock card fotky).
 * Varianty: ICE (hnědý), HEV (modrý+modrý blesk), PHEV (modrý+zelený blesk+zástrčka), EV (zelený).
 */
type FuelType = 'petrol' | 'diesel' | 'hybrid' | 'phev' | 'ev' | string;
interface Props {
  type?: FuelType | null;
  class?: string;
}
const { type = '', class: className = '' } = Astro.props;

const isICE = type === 'petrol' || type === 'diesel';
const isHEV = type === 'hybrid';
const isPHEV = type === 'phev';
const isEV = type === 'ev';

const label = isICE ? (type === 'diesel' ? 'Diesel' : 'Benzín')
            : isHEV ? 'Hybrid'
            : isPHEV ? 'Plug-in hybrid'
            : isEV ? 'Elektro' : '';
---

{isICE && (
  <span class={`fuel-icon fuel-icon--ice ${className}`} title={label} aria-label={label}>
    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M16 14c0-2.2 1.8-4 4-4h16c2.2 0 4 1.8 4 4v36H16V14z" fill="#fff"/>
      <rect x="20" y="16" width="16" height="12" rx="1.5" fill="#8B6F5C"/>
      <path d="M40 22h4l5 5v16c0 2.2 1.8 4 4 4s4-1.8 4-4V32" stroke="#fff" stroke-width="3" fill="none" stroke-linecap="round"/>
    </svg>
  </span>
)}
{isHEV && (
  <span class={`fuel-icon fuel-icon--hev ${className}`} title={label} aria-label={label}>
    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M16 14c0-2.2 1.8-4 4-4h16c2.2 0 4 1.8 4 4v36H16V14z" fill="#fff"/>
      <rect x="20" y="16" width="16" height="10" rx="1.5" fill="#1F6FEB"/>
      <path d="M40 22h4l5 5v16c0 2.2 1.8 4 4 4s4-1.8 4-4V32" stroke="#fff" stroke-width="3" fill="none" stroke-linecap="round"/>
      <polygon points="30,30 22,42 28,42 26,52 34,40 28,40 30,30" fill="#1F6FEB"/>
    </svg>
  </span>
)}
{isPHEV && (
  <span class={`fuel-icon fuel-icon--phev ${className}`} title={label} aria-label={label}>
    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M10 14c0-2.2 1.8-4 4-4h12c2.2 0 4 1.8 4 4v36H10V14z" fill="#fff"/>
      <rect x="14" y="16" width="12" height="10" rx="1.5" fill="#1F6FEB"/>
      <path d="M30 22h2v8" stroke="#fff" stroke-width="3" fill="none" stroke-linecap="round"/>
      <polygon points="40,12 30,30 38,30 34,52 48,28 40,28 44,12" fill="#5BC23A"/>
      <rect x="44" y="16" width="14" height="10" rx="2" fill="#fff"/>
      <rect x="46" y="13" width="2.5" height="4" fill="#fff"/>
      <rect x="53" y="13" width="2.5" height="4" fill="#fff"/>
    </svg>
  </span>
)}
{isEV && (
  <span class={`fuel-icon fuel-icon--ev ${className}`} title={label} aria-label={label}>
    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <polygon points="36,8 18,34 30,34 26,56 46,28 34,28 38,8" fill="#fff"/>
    </svg>
  </span>
)}

<style is:global>
  .fuel-icon {
    display: inline-grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }
  .fuel-icon svg { width: 100%; height: 100%; display: block; }
  .fuel-icon--ice  { background: #8B6F5C; }
  .fuel-icon--hev  { background: #1F6FEB; }
  .fuel-icon--phev { background: #1F6FEB; }
  .fuel-icon--ev   { background: #5BC23A; }
</style>
