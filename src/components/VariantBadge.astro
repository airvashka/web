---
/**
 * VariantBadge — kruhový PNG badge pro variant switcher na detailu modelu.
 * Používá Jardovy PNG ikony z /public/fuel-icons/ (stejné jako StockCard FuelIcon).
 *
 * Mapování:
 *   ICE  → ice.png  (benzín / diesel — spalovací)
 *   HEV  → hev.png  (hybrid)
 *   PHEV → phev.png (plug-in hybrid)
 *   EVX  → ev.png   (elektromobil)
 *
 * Použití:
 *   <VariantBadge kind="ICE" size={48} />
 *   <VariantBadge kind="HEV" />
 *   <VariantBadge kind="EVX" size={32} />
 */
interface Props {
  kind: 'ICE' | 'HEV' | 'PHEV' | 'EVX' | string | null | undefined;
  size?: number;
  ariaLabel?: string;
}

const { kind, size = 48, ariaLabel } = Astro.props;
const k = String(kind ?? '').toUpperCase();

const FILES: Record<string, string> = {
  ICE:  'ice.png',
  HEV:  'hev.png',
  PHEV: 'phev.png',
  EVX:  'ev.png',
};

const LABELS: Record<string, string> = {
  ICE:  'Spalovací motor',
  HEV:  'Hybrid',
  PHEV: 'Plug-in hybrid',
  EVX:  'Elektromobil',
};

const file = FILES[k];
const label = ariaLabel ?? LABELS[k] ?? '';
---

{file && (
  <img
    src={`/fuel-icons/${file}`}
    alt={label}
    title={label}
    class="variant-badge"
    style={`width:${size}px;height:${size}px`}
    loading="lazy"
  />
)}

<style is:global>
  .variant-badge {
    border-radius: 50%;
    object-fit: cover;
    display: block;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
  }
</style>
