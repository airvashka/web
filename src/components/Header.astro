---
import { FALLBACK_SALES_PHONE, FALLBACK_SERVICE_PHONE, telLink, getDealerContacts } from '@lib/contacts';
import googleData from '../data/google-reviews.json';
import VatToggle from './VatToggle.astro';

interface Props {
  active?: 'kgm' | 'omoda-jaecoo' | 'farizon' | 'sklad' | 'servis' | 'magazin' | 'kontakt';
}

const { active } = Astro.props;

// Build-time fetch všech prodejců — embeddujeme jako JSON do DOM,
// client-side JS pak randomně vybere telefon při každém načtení.
// Důvod: Astro middleware (Astro.locals) nefunguje pro static prerendered stránky,
// takže SSR-based rotaci jsme museli nahradit client-side.
const contacts = await getDealerContacts();
const salesPhonesJson = JSON.stringify(contacts.sales.map((c) => c.phone));
// Server-side default (zobrazí se před tím než JS rotuje)
const defaultPhone = contacts.sales[0]?.phone ?? FALLBACK_SALES_PHONE;
const defaultPhoneLink = telLink(defaultPhone);
const servisPhone = contacts.service[0]?.phone ?? FALLBACK_SERVICE_PHONE;
const servisPhoneLink = telLink(servisPhone);

// Oteviraci doba pro topbar - strukturovane periody obou pobocek (Prodejna + Servis).
// Stav otevreno/zavreno se pocita client-side v case Evropa/Praha; svatky a vyjimecne
// dny resi Google pres current_opening_hours (data se obnovuji 3x/den pres stock-sync deploy).
const gd = googleData as any;
const openingJson = JSON.stringify({
  prodejna: gd?.prodej?.hours_periods ?? null,
  servis: gd?.servis?.hours_periods ?? null,
});

const navItems: Array<{ label: string; href: string; key: NonNullable<Props['active']> }> = [
  { label: 'KGM', href: '/kgm', key: 'kgm' },
  { label: 'Omoda & Jaecoo', href: '/omoda-jaecoo', key: 'omoda-jaecoo' },
  { label: 'Farizon', href: '/farizon', key: 'farizon' },
  { label: 'Skladové vozy', href: '/sklad', key: 'sklad' },
  { label: 'Servis', href: '/servis', key: 'servis' },
  { label: 'Magazín', href: '/magazin', key: 'magazin' },
  { label: 'Kontakt', href: '/kontakt', key: 'kontakt' },
];
---

<!-- Topbar -->
<div class="topbar">
  <div class="container topbar-inner">
    <span class="topbar-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Ďáblická 553/2, Praha 8
    </span>
    <span class="topbar-item topbar-hours" data-opening-status>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span data-opening-text>Prodejna Po–Pá 8–18 (Čt do 20) · Servis Po–Pá 8–17</span>
    </span>
    <a class="topbar-item" href={`tel:${defaultPhoneLink}`} data-sales-phone style="text-decoration:none;color:inherit;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.86 19.86 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span data-sales-phone-text>{defaultPhone}</span>
    </a>
    <span class="topbar-spacer"></span>
    <VatToggle />
  </div>
</div>

<!-- Main nav -->
<header class="nav">
  <div class="container nav-inner">
    <a class="nav-logo" href="/" aria-label="SFR Motor — domů">
      <img src="/sfr-logo.svg" alt="SFR Motor" />
    </a>
    <nav class="nav-links" aria-label="Hlavní navigace">
      {navItems.map((item, i) => (
        <Fragment>
          {i > 0 && <span class="nav-sep">·</span>}
          <a
            class={`nav-link${active === item.key ? ' is-active' : ''}`}
            href={item.href}
          >{item.label}</a>
        </Fragment>
      ))}
    </nav>
    <VatToggle />
    <button class="nav-menu-toggle" aria-label="Otevřít menu" aria-expanded="false" data-menu-toggle>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile drawer (zobrazuje se po kliknutí na hamburger, < 960px) -->
<div class="mobile-drawer" data-mobile-drawer aria-hidden="true" inert>
  <div class="mobile-drawer-head">
    <a class="mobile-drawer-logo" href="/" aria-label="SFR Motor — domů">
      <img src="/sfr-logo.svg" alt="SFR Motor" />
    </a>
    <button class="mobile-drawer-close" aria-label="Zavřít menu" data-menu-close>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <nav class="mobile-drawer-nav" aria-label="Hlavní navigace (mobile)">
    {navItems.map((item) => (
      <a
        class={`mobile-drawer-link${active === item.key ? ' is-active' : ''}`}
        href={item.href}
      >{item.label}</a>
    ))}
  </nav>
  <div class="mobile-drawer-cta">
    <a class="btn btn-primary" href="/kontakt#poptavka">Mám zájem o vůz</a>
    <a class="btn btn-outline" href="/servis#objednat">Objednat servis</a>
  </div>
  <div class="mobile-drawer-phones">
    <a class="mobile-drawer-phone" href={`tel:${defaultPhoneLink}`} data-sales-phone>
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.86 19.86 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span class="mdp-label">Prodej</span>
      <span class="mdp-num" data-sales-phone-text>{defaultPhone}</span>
    </a>
    <a class="mobile-drawer-phone" href={`tel:${servisPhoneLink}`}>
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.86 19.86 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span class="mdp-label">Servis</span>
      <span class="mdp-num">{servisPhone}</span>
    </a>
  </div>
  <div class="mobile-drawer-info">
    <div class="mobile-drawer-info-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Ďáblická 553/2, Praha 8
    </div>
    <div class="mobile-drawer-info-item" data-opening-status>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span data-opening-text>Prodejna Po–Pá 8–18 (Čt do 20) · Servis Po–Pá 8–17</span>
    </div>
  </div>
</div>
<button class="mobile-drawer-backdrop" data-menu-close aria-label="Zavřít menu" tabindex="-1"></button>

<!-- Client-side phone rotation data — JSON pool prodejních telefonů z Directus.
     JS níže random-pickne a updatne všechny data-sales-phone elementy. -->
<script type="application/json" id="sales-phones-data" set:html={salesPhonesJson}></script>
<!-- Oteviraci doba - strukturovane periody obou pobocek (Google), stav se pocita client-side. -->
<script type="application/json" id="opening-data" set:html={openingJson}></script>

<script>
  // ===== Sales phone rotation =====
  (function () {
    try {
      const dataEl = document.getElementById('sales-phones-data');
      if (!dataEl) return;
      const phones = JSON.parse(dataEl.textContent || '[]');
      if (!Array.isArray(phones) || phones.length === 0) return;
      // Random pick
      const phone = phones[Math.floor(Math.random() * phones.length)];
      const telLink = phone.replace(/[^\d+]/g, '');
      // Update všechny data-sales-phone <a> elementy
      document.querySelectorAll('[data-sales-phone]').forEach((el) => {
        if (el instanceof HTMLAnchorElement) el.href = 'tel:' + telLink;
      });
      // Update všechny data-sales-phone-text elementy
      document.querySelectorAll('[data-sales-phone-text]').forEach((el) => {
        el.textContent = phone;
      });
    } catch (err) {
      // Fallback default zůstane — žádný break
      console.warn('[phones] rotation failed', err);
    }
  })();

  // ===== Oteviraci doba: stav otevreno/zavreno (cas Evropa/Praha) =====
  // Pocita z Google period (current_opening_hours -> svatky zohledneny) obou pobocek.
  (function () {
    const dataEl = document.getElementById('opening-data');
    if (!dataEl) return;
    let data;
    try { data = JSON.parse(dataEl.textContent || '{}'); } catch (e) { return; }

    const DAY_NEXT = ['v neděli', 'v pondělí', 'v úterý', 've středu', 've čtvrtek', 'v pátek', 'v sobotu']; // index = Google day (0=Ne)

    function nowPrague() {
      const p = new Intl.DateTimeFormat('en-GB', {
        timeZone: 'Europe/Prague', hour12: false,
        weekday: 'short', hour: '2-digit', minute: '2-digit',
      }).formatToParts(new Date());
      const m = {};
      p.forEach((x) => { m[x.type] = x.value; });
      const wd = { Sun: 0, Mon: 1, Tue: 2, Wed: 3, Thu: 4, Fri: 5, Sat: 6 }[m.weekday] ?? 0;
      let hh = parseInt(m.hour, 10); if (hh === 24) hh = 0;
      return { dow: wd, min: hh * 60 + parseInt(m.minute, 10) };
    }

    function toMin(t) { // "HHMM" -> minuty od pulnoci
      const s = String(t).padStart(4, '0');
      return parseInt(s.slice(0, 2), 10) * 60 + parseInt(s.slice(2), 10);
    }
    function fmt(t) { // "HHMM" -> "H:MM"
      const s = String(t).padStart(4, '0');
      return parseInt(s.slice(0, 2), 10) + ':' + s.slice(2);
    }

    function statusFor(periods, now) {
      if (!Array.isArray(periods) || periods.length === 0) return null;
      // Nonstop: jediny period s open 0000 a bez close
      if (periods.length === 1 && periods[0].open && !periods[0].close
          && String(periods[0].open.time) === '0000') {
        return { open: true, text: 'otevřeno nonstop' };
      }
      const nowWM = now.dow * 1440 + now.min;
      let nextOpenWM = Infinity, nextOpen = null;
      for (const per of periods) {
        if (!per.open || !per.close) continue;
        const oWM = per.open.day * 1440 + toMin(per.open.time);
        let cWM = per.close.day * 1440 + toMin(per.close.time);
        if (cWM <= oWM) cWM += 7 * 1440; // pres pulnoc / prelom tydne
        // otevreno ted? (i s posunem o tyden kvuli wrapu Ne)
        if ((oWM <= nowWM && nowWM < cWM) || (oWM <= nowWM + 7 * 1440 && nowWM + 7 * 1440 < cWM)) {
          return { open: true, text: 'otevřeno do ' + fmt(per.close.time) };
        }
        let cand = oWM; if (cand < nowWM) cand += 7 * 1440;
        if (cand < nextOpenWM) { nextOpenWM = cand; nextOpen = per.open; }
      }
      if (!nextOpen) return { open: false, text: 'zavřeno' };
      const sameDay = nextOpen.day === now.dow && nextOpenWM < (now.dow * 1440 + 1440);
      if (sameDay) return { open: false, text: 'zavřeno · otevře v ' + fmt(nextOpen.time) };
      return { open: false, text: 'zavřeno · otevře ' + DAY_NEXT[nextOpen.day] + ' ' + fmt(nextOpen.time) };
    }

    function render() {
      const now = nowPrague();
      const branches = [['Prodejna', data.prodejna], ['Servis', data.servis]];
      const parts = [];
      for (const [label, periods] of branches) {
        const st = statusFor(periods, now);
        if (!st) continue;
        const cls = st.open ? 'oh-open' : 'oh-closed';
        const lbl = label.replace(/&/g, '&amp;').replace(/</g, '&lt;');
        const txt = st.text.replace(/&/g, '&amp;').replace(/</g, '&lt;');
        parts.push('<span class="oh-branch"><span class="oh-dot ' + cls + '"></span>'
          + lbl + ': ' + txt + '</span>');
      }
      if (parts.length === 0) return; // nech staticky fallback
      const html = parts.join('<span class="oh-sep">·</span>');
      document.querySelectorAll('[data-opening-text]').forEach((el) => { el.innerHTML = html; });
    }

    try {
      render();
      // Prepocitej kazdou minutu (prechod otevreno<->zavreno bez reloadu)
      setInterval(render, 60 * 1000);
    } catch (e) {
      console.warn('[opening-hours] render failed', e);
    }
  })();

  // ===== Mobile drawer toggle =====
  (function () {
    const toggle = document.querySelector('[data-menu-toggle]');
    const drawer = document.querySelector('[data-mobile-drawer]');
    const backdrop = document.querySelector('.mobile-drawer-backdrop');
    const closes = document.querySelectorAll('[data-menu-close]');
    if (!toggle || !drawer) return;

    function openDrawer() {
      drawer.classList.add('is-open');
      drawer.removeAttribute('inert');
      drawer.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      document.body.classList.add('drawer-open');
      backdrop?.classList.add('is-visible');
    }
    function closeDrawer() {
      drawer.classList.remove('is-open');
      drawer.setAttribute('inert', '');
      drawer.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.classList.remove('is-open');
      document.body.style.overflow = '';
      document.body.classList.remove('drawer-open');
      backdrop?.classList.remove('is-visible');
    }
    toggle.addEventListener('click', function (e) {
      e.stopPropagation();
      if (drawer.classList.contains('is-open')) closeDrawer();
      else openDrawer();
    });
    closes.forEach(function (el) { el.addEventListener('click', closeDrawer); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeDrawer();
    });
  })();

  // ===== Smart hide-on-scroll header =====
  // Track scroll direction → toggle html.scrolled-down / scrolled-up
  // CSS animuje translateY na .nav (subnav zůstává nezměněn).
  (function () {
    let lastY = window.scrollY;
    let ticking = false;
    const THRESHOLD = 100;  // px from top — pod tím žádné hide/show; klid
    const DELTA = 5;        // min px scroll change před změnou state (anti-thrash)
    const root = document.documentElement;

    function update() {
      const y = window.scrollY;
      const diff = y - lastY;
      if (Math.abs(diff) < DELTA) {
        ticking = false;
        return;
      }
      if (y < THRESHOLD) {
        // Near top — neutral state, no animations
        root.classList.remove('scrolled-down');
        root.classList.remove('scrolled-up');
      } else if (diff > 0) {
        root.classList.add('scrolled-down');
        root.classList.remove('scrolled-up');
      } else {
        root.classList.remove('scrolled-down');
        root.classList.add('scrolled-up');
      }
      lastY = y;
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

<style is:global>
  /* ===== Oteviraci doba (topbar + mobile drawer) ===== */
  .oh-branch { display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; }
  .oh-sep { margin: 0 9px; opacity: 0.45; }
  .oh-dot {
    width: 7px; height: 7px; border-radius: 50%; flex: none; display: inline-block;
    background: #9aa0a6;
  }
  .oh-dot.oh-open { background: #37c46b; box-shadow: 0 0 0 3px rgba(55, 196, 107, 0.18); }
  .oh-dot.oh-closed { background: #e0564f; box-shadow: 0 0 0 3px rgba(224, 86, 79, 0.16); }
  .topbar-hours [data-opening-text] { display: inline-flex; align-items: center; flex-wrap: wrap; }
  .mobile-drawer-info-item[data-opening-status] [data-opening-text] {
    display: flex; flex-direction: column; align-items: flex-start; gap: 4px;
  }
  .mobile-drawer-info-item[data-opening-status] .oh-sep { display: none; }

  /* Smart hide-on-scroll — MOBILE (fixed pozice) + DESKTOP (headroom přes sticky).
     Mobile: position fixed + transform (iOS Safari friendly).
     Desktop: nav je sticky a při scroll-down klesne mimo viewport přes transform,
     na scroll-up se vrátí — JS přepíná html.scrolled-down/scrolled-up. */
  @media (max-width: 960px) {
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      transition: transform 0.28s cubic-bezier(0.2, 0.7, 0.2, 1),
                  box-shadow 0.2s ease;
      will-change: transform;
    }
    html.scrolled-up .nav,
    html.scrolled-down .nav {
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
    html.scrolled-down .nav {
      transform: translateY(-100%);
    }
    body {
      padding-top: 64px;
    }
  }

  /* DPH přepínač: desktop = v nav; mobil (≤960) = v topbaru vedle otevírací doby. */
  @media (max-width: 960px) {
    .nav .vat-toggle { display: none; }
  }
  /* Topbar varianta přepínače (tmavý pruh) — jen mobil */
  .topbar .vat-toggle { display: none; background: rgba(255,255,255,0.14) !important; }
  .topbar .vat-toggle-btn { color: #DCDCDC !important; }
  .topbar .vat-toggle-btn.is-active { background: #fff !important; color: var(--ink) !important; }
  @media (max-width: 960px) {
    .topbar .vat-toggle { display: inline-flex; margin-left: auto; flex-shrink: 0; }
  }
  /* DPH přepínač v mobile draweru */
  .mobile-drawer-vat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 4px 20px 12px;
  }
  .mobile-drawer-vat-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    color: var(--text-muted, #6b7280);
  }
  .mobile-drawer .vat-toggle { display: inline-flex; }

  /* DESKTOP headroom — sticky + transform při scroll-down */
  @media (min-width: 961px) {
    html.scrolled-down .nav {
      transform: translateY(-110%);
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
    html.scrolled-up .nav {
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav,
    .mobile-drawer,
    .mobile-drawer-backdrop { transition: none !important; }
    html.scrolled-down .nav { transform: none; }
  }
</style>
