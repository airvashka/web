---
import Disclaimer from '@components/Disclaimer.astro';
import BrandLogo from '@components/BrandLogo.astro';
const year = new Date().getFullYear();
---

<footer class="footer footer-ext">
  <div class="container">
    <div class="footer-newsletter">
      <div class="fn-text">
        <strong>Novinky do schránky</strong>
        <span>Akce, novinky ze showroomu a tipy. Jednou měsíčně, žádný spam.</span>
      </div>
      <form class="fn-form" data-footer-newsletter>
        <input type="email" name="email" placeholder="vas@email.cz" required maxlength="200" aria-label="Váš e-mail" />
        <input type="text" name="_hp_website" tabindex="-1" autocomplete="off" class="honeypot" aria-hidden="true" />
        <button type="submit">Přihlásit</button>
        <span class="fn-status" data-footer-news-status></span>
      </form>
    </div>

    <div class="footer-grid">
      <div>
        <img src="/sfr-logo.svg" alt="SFR Motor" class="footer-logo" />
        <div class="footer-text">
          Autorizovaný prodej a servis vozů KGM, OMODA &amp; JAECOO a FARIZON. Vaše cesta začíná u nás.
        </div>
        <div class="footer-social">
          <a href="https://www.facebook.com/SFR-Motor-106817477406828/" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.5-3.9 3.78-3.9 1.1 0 2.24.2 2.24.2v2.47H15.2c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.45 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/></svg>
          </a>
          <a href="https://www.instagram.com/sfr_motor/" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
          <a href="https://www.youtube.com/@sfrmotor" target="_blank" rel="noopener" aria-label="YouTube">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.5-.4-5.2c-.3-1-1-1.7-2-2C18.9 4.5 12 4.5 12 4.5s-6.9 0-8.6.3c-1 .3-1.7 1-2 2C1 8.5 1 12 1 12s0 3.5.4 5.2c.3 1 1 1.7 2 2 1.7.3 8.6.3 8.6.3s6.9 0 8.6-.3c1-.3 1.7-1 2-2 .4-1.7.4-5.2.4-5.2zM10 15.5v-7l6 3.5-6 3.5z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h5>Nové vozy</h5>
        <ul>
          <li><a href="/kgm">KGM</a></li>
          <li><a href="/omoda-jaecoo">Omoda &amp; Jaecoo</a></li>
          <li><a href="/farizon">Farizon</a></li>
          <li><a href="/sklad">Skladové vozy</a></li>
        </ul>
      </div>

      <div>
        <h5>Servis</h5>
        <ul>
          <li><a href="/servis">Servisní služby</a></li>
          <li><a href="/servis">Objednání servisu</a></li>
          <li><a href="/servis#kde-nas-najdete">Najdete nás</a></li>
          <li><a href="/servis#manualy">Manuály</a></li>
        </ul>
      </div>

      <div>
        <h5>Společnost</h5>
        <ul>
          <li><a href="/o-nas">O nás</a></li>
          <li><a href="/kariera">Kariéra</a></li>
          <li><a href="/magazin">Aktuality</a></li>
          <li><a href="/partneri">Partneři</a></li>
        </ul>
      </div>

      <div>
        <h5>Důležité</h5>
        <ul>
          <li><a href="/kontakt">Kontakty</a></li>
          <li><a href="/kontakt#otevreni">Otevírací doba</a></li>
          <li><a href="/informace/podminky">Obchodní podmínky</a></li>
          <li><a href="/informace/ochrana-udaju">GDPR</a></li>
          <li><a href="/informace/cookies">Cookies</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-brands">
      <div class="footer-brands-label">Autorizovaný prodejce a servis značek</div>
      <div class="footer-brands-row">
        <a href="/kgm" class="footer-brand" aria-label="KGM">
          <BrandLogo slug="kgm" variant="light" />
        </a>
        <a href="/omoda-jaecoo" class="footer-brand" aria-label="OMODA & JAECOO">
          <BrandLogo slug="omoda-jaecoo" variant="light" />
        </a>
        <a href="/farizon" class="footer-brand" aria-label="Farizon">
          <BrandLogo slug="farizon" variant="light" />
        </a>
      </div>
    </div>

    <div class="footer-disclaimer">
      <Disclaimer kind="full" />
    </div>

    <div class="footer-bottom">
      <span>© {year} SFR Motor s.r.o. · IČO 08263523</span>
      <span><a href="/informace/cookies">Cookies</a> · <a href="/informace/ochrana-udaju">GDPR</a></span>
    </div>
  </div>
</footer>

<script is:inline>
  (function () {
    var f = document.querySelector('[data-footer-newsletter]');
    if (!f) return;
    f.addEventListener('submit', async function (e) {
      e.preventDefault();
      var statusEl = f.querySelector('[data-footer-news-status]');
      var btn = f.querySelector('button[type=submit]');
      var fd = new FormData(f);
      if (statusEl) statusEl.textContent = 'Odesílám…';
      try {
        var res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: fd.get('email'), _hp_website: fd.get('_hp_website') || '' }),
        });
        var r = await res.json().catch(function () { return { ok: false, error: 'Network error' }; });
        if (!res.ok || !r.ok) throw new Error(r.error || ('HTTP ' + res.status));
        if (statusEl) statusEl.textContent = '✓ Děkujeme! Zkontrolujte schránku.';
        if (btn) { btn.textContent = 'Přihlášeno'; btn.disabled = true; }
      } catch (err) {
        if (statusEl) statusEl.textContent = err && err.message ? '✗ ' + err.message : '✗ Nepodařilo se. Zkuste to znovu.';
      }
    });
  })();
</script>

<style is:global>
  /* Footer brand strip CSS → global.css (řádky ~3044-3088) */

  /* Newsletter pruh nahoře v patičce */
  .footer-newsletter {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px 32px;
    flex-wrap: wrap;
    padding-bottom: 28px;
    margin-bottom: 28px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
  }
  .footer-newsletter .fn-text { display: flex; flex-direction: column; gap: 3px; min-width: 220px; }
  .footer-newsletter .fn-text strong { color: #fff; font-size: 17px; font-weight: 600; }
  .footer-newsletter .fn-text span { color: rgba(255, 255, 255, 0.55); font-size: 13px; }
  .footer-newsletter .fn-form {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    flex: 1 1 320px; max-width: 460px;
  }
  .footer-newsletter .fn-form input[type="email"] {
    flex: 1 1 200px; min-width: 0; padding: 11px 14px; border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.18); background: rgba(255, 255, 255, 0.06);
    color: #fff; font-size: 14px;
  }
  .footer-newsletter .fn-form input[type="email"]::placeholder { color: rgba(255, 255, 255, 0.4); }
  .footer-newsletter .fn-form input[type="email"]:focus { outline: none; border-color: rgba(255, 255, 255, 0.4); background: rgba(255, 255, 255, 0.1); }
  .footer-newsletter .fn-form button {
    padding: 11px 20px; border-radius: 8px; border: none; background: var(--accent, #F25C1B);
    color: #fff; font-size: 14px; font-weight: 600; cursor: pointer; white-space: nowrap; transition: filter 0.15s;
  }
  .footer-newsletter .fn-form button:hover { filter: brightness(1.08); }
  .footer-newsletter .fn-form button:disabled { opacity: 0.6; cursor: default; }
  .footer-newsletter .fn-status { flex-basis: 100%; font-size: 12.5px; color: rgba(255, 255, 255, 0.7); min-height: 1em; }
  .footer-newsletter .honeypot { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  @media (max-width: 640px) {
    .footer-newsletter { flex-direction: column; align-items: stretch; gap: 14px; }
    .footer-newsletter .fn-form { max-width: none; }
  }

  /* ===== Servisni akce (service_campaigns) — globalni, nacita se pres footer ===== */
  .svc-promo { padding: 8px 0 0; }
  .svc-promo-card {
    display: grid; grid-template-columns: 420px 1fr; background: #fff;
    border: 1px solid var(--line, #E7E6E2); border-radius: 16px; overflow: hidden;
    text-decoration: none; color: inherit; box-shadow: 0 6px 24px rgba(0,0,0,0.06);
    transition: box-shadow .2s, transform .2s;
  }
  .svc-promo-card:hover { box-shadow: 0 10px 32px rgba(0,0,0,0.12); transform: translateY(-2px); }
  .svc-promo-media { position: relative; min-height: 220px; background: #f2f2f2; }
  .svc-promo-body { padding: 28px 32px; display: flex; flex-direction: column; align-items: flex-start; gap: 10px; }
  .svc-promo-eyebrow { font-size: 12px; letter-spacing: .08em; text-transform: uppercase; color: var(--accent, #F25C1B); font-weight: 700; }
  .svc-promo-title { font-family: var(--font-display); font-size: 26px; line-height: 1.15; margin: 0; }
  .svc-promo-price { font-size: 20px; font-weight: 700; color: var(--accent, #F25C1B); }
  .svc-promo-perex { font-size: 15px; line-height: 1.55; color: #555; margin: 0; }
  .svc-promo-cta { margin-top: 8px; pointer-events: none; }
  @media (max-width: 780px) {
    .svc-promo-card { grid-template-columns: 1fr; }
    .svc-promo-media { min-height: 180px; }
    .svc-promo-body { padding: 22px 20px; }
    .svc-promo-title { font-size: 22px; }
  }

  .svc-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 18px; }
  .svc-list-card {
    display: flex; flex-direction: column; background: #fff; border: 1px solid var(--line, #E7E6E2);
    border-radius: 14px; overflow: hidden; text-decoration: none; color: inherit;
    transition: box-shadow .2s, transform .2s;
  }
  .svc-list-card:hover { box-shadow: 0 8px 26px rgba(0,0,0,0.10); transform: translateY(-2px); }
  .svc-list-media { position: relative; aspect-ratio: 16 / 9; background: #f2f2f2; }
  .svc-list-body { padding: 18px 20px 22px; display: flex; flex-direction: column; gap: 7px; flex: 1; }
  .svc-list-brand { font-size: 12px; letter-spacing: .05em; text-transform: uppercase; color: #888; font-weight: 600; }
  .svc-list-title { font-family: var(--font-display); font-size: 19px; line-height: 1.2; margin: 0; }
  .svc-list-price { font-weight: 700; color: var(--accent, #F25C1B); }
  .svc-list-perex { font-size: 14px; line-height: 1.5; color: #555; margin: 0; }
  .svc-list-cta { margin-top: auto; padding-top: 10px; font-weight: 600; color: var(--accent, #F25C1B); }

  .svc-detail { padding: 40px 0 64px; }
  .svc-detail-item { max-width: 820px; margin: 0 auto 48px; }
  .svc-detail-media { position: relative; aspect-ratio: 16 / 9; border-radius: 16px; overflow: hidden; background: #f2f2f2; margin-bottom: 24px; }
  .svc-detail-eyebrow { font-size: 13px; letter-spacing: .08em; text-transform: uppercase; color: var(--accent, #F25C1B); font-weight: 700; margin-bottom: 6px; }
  .svc-detail-title { font-family: var(--font-display); font-size: 32px; line-height: 1.12; margin: 0 0 8px; }
  .svc-detail-price { font-size: 22px; font-weight: 700; color: var(--accent, #F25C1B); margin-bottom: 6px; }
  .svc-detail-valid { font-size: 13px; color: #888; margin-bottom: 20px; }
  .svc-detail-body { font-size: 16px; line-height: 1.7; color: #333; }
  .svc-detail-body h2, .svc-detail-body h3 { margin: 1.4em 0 .4em; line-height: 1.2; }
  .svc-detail-body p { margin: 0 0 1em; }
  .svc-detail-body ul, .svc-detail-body ol { margin: 0 0 1em; padding-left: 1.4em; }
  .svc-detail-body li { margin: 0 0 .3em; }
  .svc-detail-cta { margin-top: 28px; display: flex; gap: 12px; flex-wrap: wrap; }

  .footer-disclaimer {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .footer-disclaimer .disclaimer {
    color: rgba(255, 255, 255, 0.45);
    font-size: 11px;
    max-width: none;
    margin: 0;
  }
</style>
