---
/**
 * HighlightsPanel — "lákadlo" panel pod Představením.
 *
 * 1:1 podle designu (_design-draft-blog/.../torres-evx.jsx → <Highlights>):
 *   - 3-sloupcový grid (na mobilu 1 sloupec)
 *   - Karta = ikona vlevo (48px square s soft pozadím) + text (popisek + velká hodnota + nota)
 *   - Levý okraj karty = barevný proužek (theme color)
 *
 * Theme dle variant_badge_kind modelu (nebo brand fallback):
 *   - ice → oranžová/hnědá
 *   - hev → teal
 *   - evx → zelená
 *   - default → značková (var(--accent))
 *
 * Použití:
 *   <HighlightsPanel items={model.highlights_panel} theme="evx" />
 */
interface HighlightItem {
  icon_kind?: string;
  big?: string;
  lab?: string;
  note?: string;
}
interface Props {
  items: HighlightItem[] | null | undefined;
  theme?: 'ice' | 'hev' | 'evx' | null | string;
}

const { items, theme: themeProp } = Astro.props;
const list = Array.isArray(items) ? items.filter((i) => i && (i.big || i.lab || i.note)) : [];
if (list.length === 0) {
  // Nic se neukáže — komponenta vrací prázdno
}
const theme = (themeProp ?? '').toLowerCase();
const themeClass = ['ice', 'hev', 'evx'].includes(theme) ? `theme-${theme}` : '';
---

{list.length > 0 && (
  <div class={`highlights ${themeClass}`}>
    {list.map((h) => (
      <div class="hlight">
        <span class="hl-icon">
          {/* range — clock */}
          {h.icon_kind === 'range' && (
            <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="hi">
              <circle cx="16" cy="16" r="11" class="hi-bg"/>
              <path d="M16 8v8l6 3"/>
              <circle cx="16" cy="16" r="1.6" class="hi-dot"/>
            </svg>
          )}
          {/* charge — battery + bolt */}
          {h.icon_kind === 'charge' && (
            <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="hi">
              <rect x="5" y="10" width="18" height="12" rx="2.5" class="hi-bg"/>
              <rect x="23" y="13" width="3" height="6" rx="1" class="hi-dot"/>
              <path d="M14 12l-3 5h3l-1 4 4-5h-3l1.5-4z" fill="#FFB100" stroke="currentColor" stroke-width="1.2"/>
            </svg>
          )}
          {/* heatpump — waves */}
          {h.icon_kind === 'heatpump' && (
            <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="hi">
              <circle cx="16" cy="16" r="11" class="hi-bg"/>
              <path d="M10 18c1.5-2 3-2 4 0s2.5 2 4 0 3-2 4 0"/>
              <path d="M10 14c1.5-2 3-2 4 0s2.5 2 4 0 3-2 4 0" opacity="0.55"/>
            </svg>
          )}
          {/* selfcharge — recycle + bolt */}
          {h.icon_kind === 'selfcharge' && (
            <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="hi">
              <circle cx="16" cy="16" r="11" class="hi-bg"/>
              <path d="M22 11.5a8 8 0 1 0 2.5 9"/>
              <polyline points="22 7 22 11.5 17.5 11.5"/>
              <path d="M15 14l-2.5 4h2.5L14 22l3.5-4.5H15L16 14z" fill="#FFB100" stroke="currentColor" stroke-width="1.2"/>
            </svg>
          )}
          {/* fuel — gas can */}
          {h.icon_kind === 'fuel' && (
            <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="hi">
              <path d="M9 24V11a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v13" class="hi-bg"/>
              <line x1="9" y1="24" x2="19" y2="24"/>
              <line x1="9" y1="15" x2="19" y2="15"/>
              <path d="M19 16h2a1.5 1.5 0 0 1 1.5 1.5v2a1.5 1.5 0 0 0 3 0V14l-2.5-2.5"/>
            </svg>
          )}
          {/* awd — 4 wheels */}
          {h.icon_kind === 'awd' && (
            <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="hi">
              <circle cx="8" cy="10" r="3" class="hi-bg"/>
              <circle cx="24" cy="10" r="3" class="hi-bg"/>
              <circle cx="8" cy="22" r="3" class="hi-bg"/>
              <circle cx="24" cy="22" r="3" class="hi-bg"/>
              <line x1="11" y1="10" x2="21" y2="10"/>
              <line x1="11" y1="22" x2="21" y2="22"/>
              <line x1="16" y1="10" x2="16" y2="22"/>
              <circle cx="16" cy="16" r="2" class="hi-dot"/>
            </svg>
          )}
          {/* tow — car + trailer hook */}
          {h.icon_kind === 'tow' && (
            <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="hi">
              <rect x="5" y="10" width="14" height="9" rx="1.5" class="hi-bg"/>
              <circle cx="9" cy="22" r="2.5" fill="#fff"/>
              <circle cx="22" cy="22" r="2.5" fill="#fff"/>
              <path d="M19 14h5l3 3v2h-3"/>
              <circle cx="27" cy="19" r="1.5" class="hi-dot"/>
            </svg>
          )}
          {/* transmission — gearbox */}
          {h.icon_kind === 'transmission' && (
            <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="hi">
              <circle cx="16" cy="16" r="11" class="hi-bg"/>
              <path d="M10 10v12M16 10v12M22 10v12"/>
              <circle cx="10" cy="10" r="1.6" class="hi-dot"/>
              <circle cx="16" cy="10" r="1.6" class="hi-dot"/>
              <circle cx="22" cy="10" r="1.6" class="hi-dot"/>
              <circle cx="22" cy="22" r="1.6" class="hi-dot"/>
            </svg>
          )}
        </span>
        <div class="hl-text">
          {h.lab && <div class="hl-lab">{h.lab}</div>}
          {h.big && <div class="hl-big">{h.big}</div>}
          {h.note && <div class="hl-note">{h.note}</div>}
        </div>
      </div>
    ))}
  </div>
)}

<style>
  .highlights {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    /* Odstup od Představení (fotky) — i kdyz je popis kratky, boxy se nelepi na foto */
    margin-top: clamp(40px, 5vw, 72px);
    margin-bottom: 56px;
    --theme: var(--accent, #1F6FEB);
    --theme-soft: color-mix(in srgb, var(--theme) 14%, white);
  }
  .highlights.theme-ice  { --theme: #B4762E; --theme-soft: #FBF2E2; }
  .highlights.theme-hev  { --theme: #2A7A8F; --theme-soft: #E7F2F4; }
  .highlights.theme-evx  { --theme: #2F9B5C; --theme-soft: #E5F4EB; }

  .hlight {
    position: relative;
    background: #fff;
    border: 1px solid var(--line, #e5e5e5);
    border-radius: var(--radius, 14px);
    padding: 22px 22px 22px 26px;
    display: flex;
    gap: 18px;
    align-items: flex-start;
    overflow: hidden;
    transition: transform .15s ease, border-color .15s ease, box-shadow .15s ease;
  }
  .hlight::before {
    content: "";
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: var(--theme);
    border-radius: 0 3px 3px 0;
  }
  .hlight:hover {
    border-color: var(--theme);
    transform: translateY(-2px);
    box-shadow: 0 12px 24px -16px color-mix(in srgb, var(--theme) 60%, transparent);
  }

  .hl-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--theme-soft);
    color: var(--theme);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .hl-icon .hi-bg { fill: var(--theme-soft); }
  .hl-icon .hi-dot { fill: currentColor; stroke: none; }

  .hl-text { min-width: 0; }
  .hl-lab {
    font-family: var(--font-display, inherit);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted, #6b7280);
    margin-bottom: 4px;
  }
  .hl-big {
    font-family: var(--font-display, inherit);
    font-weight: 600;
    font-size: 22px;
    letter-spacing: -0.02em;
    color: var(--theme);
    line-height: 1.05;
    margin-bottom: 6px;
  }
  .hl-note {
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--text-muted, #6b7280);
  }

  @media (max-width: 900px) {
    .highlights {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-bottom: 36px;
    }
  }
</style>
