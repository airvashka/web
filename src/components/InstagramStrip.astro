---
/**
 * InstagramStrip — embed @sfr_motor přes Elfsight widget.
 *
 * Konfigurace widgetu (počet fotek, layout, hover, atd.) se mění v
 * Elfsight admin: https://apps.elfsight.com/dashboard/applications
 * App ID: c25f100f-e184-4c0b-a73e-dc42341867fc
 *
 * Lazy-load: `data-elfsight-app-lazy` — widget se načte až když na něj
 * uživatel scrolluje. Šetří první-load performance.
 */
const PROFILE_URL = 'https://www.instagram.com/sfr_motor/';
---

<section class="ig-section" data-screen-label="Instagram">
  <div class="container">
    <div class="ig-head">
      <div>
        <div class="section-eyebrow">Instagram</div>
        <h2>Sledujte nás na <a href={PROFILE_URL} target="_blank" rel="noopener" class="ig-handle">@sfr_motor</a></h2>
      </div>
      <a class="head-link" href={PROFILE_URL} target="_blank" rel="noopener">
        Otevřít profil
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>
    </div>

    <!-- Elfsight Instagram Feed @sfr_motor -->
    <div class="elfsight-app-c25f100f-e184-4c0b-a73e-dc42341867fc" data-elfsight-app-lazy></div>
  </div>
</section>

<!-- Elfsight platform skript — načte se 1× na stránku, async -->
<script is:inline src="https://elfsightcdn.com/platform.js" async></script>

<style>
  .ig-section {
    padding: 0 0 120px;
    background: #fff;
  }
  .ig-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: end;
    margin-bottom: 36px;
  }
  .ig-head h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(28px, 3vw, 40px);
    letter-spacing: -0.02em;
    margin: 12px 0 0;
  }
  .ig-handle {
    color: var(--accent);
    border-bottom: 2px solid transparent;
    transition: border-color .15s;
  }
  .ig-handle:hover { border-bottom-color: var(--accent); }

  /* Min-height pro lazy-load placeholder — aby se layout nestřídal při načtení widgetu */
  .ig-section [class^="elfsight-app-"] {
    min-height: 320px;
  }

  @media (max-width: 960px) {
    .ig-head { grid-template-columns: 1fr; gap: 16px; align-items: start; }
    .ig-section { padding: 0 0 80px; }
  }
</style>
