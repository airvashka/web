---
// Sticky mobile bottom bar — kritické pro 75 % mobil traffic
// Telefon se rotuje client-side přes Header.astro JS (data-sales-phone selektor).
import { FALLBACK_SALES_PHONE, telLink, getDealerContacts } from '@lib/contacts';
const contacts = await getDealerContacts();
const defaultPhone = contacts.sales[0]?.phone ?? FALLBACK_SALES_PHONE;
const defaultPhoneLink = telLink(defaultPhone);
---

<div class="mbb" aria-label="Rychlé akce">
  <a href={`tel:${defaultPhoneLink}`} class="mbb__item" data-sales-phone>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
    </svg>
    <span>Zavolat</span>
  </a>
  <a href="/servis" class="mbb__item">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
    </svg>
    <span>Servis</span>
  </a>
  <a href="/sklad" class="mbb__item mbb__item--accent">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M5 17h14M3 17V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10M3 17h18M8 17v-7m4 7v-4m4 4v-7" />
    </svg>
    <span>Skladovka</span>
  </a>
</div>
