---
/**
 * BrandLogo — vykreslí logo značky jako wordmark.
 *
 * Použití:
 *   <BrandLogo slug="kgm" variant="light" height={48} />
 *   <BrandLogo slug="omoda-jaecoo" variant="dark" />
 *   <BrandLogo slug="farizon" />
 *
 * - `slug` = brand.slug z Directusu (kgm | omoda-jaecoo | farizon)
 * - `variant` = "dark" (default — černé logo pro světlé pozadí) | "light" (bílé pro tmavé)
 * - `height` = výška v px (default 48)
 *
 * SEO note: logo je VŽDY doplněno o `aria-label` se jménem značky, takže
 * čtečky obrazovky i Google bot vědí co je v obrázku. H1 textový zůstává.
 */

import { directusGet, directusAsset } from '@lib/directus';

interface Props {
  slug: string;
  variant?: 'dark' | 'light';
  height?: number;
  class?: string;
}

const { slug, variant = 'dark', height, class: className = '' } = Astro.props;

const BRAND_LABELS: Record<string, string> = {
  'kgm': 'KGM',
  'omoda-jaecoo': 'OMODA & JAECOO',
  'farizon': 'Farizon',
};
const label = BRAND_LABELS[slug] ?? slug.toUpperCase();

// Logo z Directusu (brands.logo) — co nahraješ v adminu. Fallback na statický
// /brand-logos/{slug}.svg, kdyby u značky logo nebylo nahrané.
let logoSrc = `/brand-logos/${slug}.svg`;
try {
  const rows = await directusGet<any>('brands', { filter: { slug: { _eq: slug } }, limit: 1, fields: ['slug', 'logo'] });
  const lg = rows?.[0]?.logo;
  const logoId = typeof lg === 'string' ? lg : (lg?.id ?? lg?.directus_files_id ?? null);
  if (logoId) logoSrc = directusAsset(logoId);
} catch { /* nech statický fallback */ }

// Pouze pokud caller explicitně předá height, aplikujeme inline style.
// Jinak nech CSS pravidla (clamp v global.css) volnou ruku.
const heightStyle = height ? `height: ${height}px;` : '';
---

<!-- Mask-based logo — funguje s libovolným SVG/PNG bez ohledu na transparency.
     Logo slouží jako stencil, barva přijde z `background-color`. -->
<span
  class={`brand-logo brand-logo--single brand-logo--${slug} ${className} variant-${variant}`}
  style={`${heightStyle} -webkit-mask-image: url('${logoSrc}'); mask-image: url('${logoSrc}');`}
  role="img"
  aria-label={label}
></span>

<style is:global>
  .brand-logo {
    display: inline-block;
    line-height: 1;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }
  .brand-logo--single {
    width: 100%;
    max-width: 100%;
  }
  .brand-logo.variant-dark { background-color: #0B0B0C; }
  .brand-logo.variant-light { background-color: #FFFFFF; }
</style>
