---
/**
 * YouTubeSection — pruh 4 videí z kanálu @sfrmotor
 *
 * Pro update: edituj pole VIDEOS níže. Každé video potřebuje YouTube ID
 * (z URL: https://youtube.com/watch?v=XXX → XXX) a název.
 *
 * Thumbnail se generuje automaticky z YouTube CDN:
 *   https://img.youtube.com/vi/<ID>/hqdefault.jpg  (480×360, vždy existuje)
 *   https://img.youtube.com/vi/<ID>/maxresdefault.jpg (1280×720, jen pokud video je HD)
 *
 * TODO (později): přesunout VIDEOS do Directus collection `youtube_videos`
 * (id, title, category, sort, status) a fetchovat při buildu.
 */

interface VideoItem {
  id: string;             // YouTube video ID
  title: string;
  category?: string;      // "Test", "Servis", "Novinky" atd.
  duration?: string;      // např. "4:32" — volitelně
}

// ===== Videa z kanálu @sfrmotor =====
// Title je placeholder — uprav podle reálného názvu videa (nebo nech, klik vede na YouTube)
const VIDEOS: VideoItem[] = [
  { id: 'piG8UO24WUk', title: 'SFR Motor — video 1', category: 'SFR Motor' },
  { id: 'eSfJXjNV8Mg', title: 'SFR Motor — video 2', category: 'SFR Motor' },
  { id: 'SybpHjEJP1s', title: 'SFR Motor — video 3', category: 'SFR Motor' },
  { id: 'S9tdBpkwX_4', title: 'SFR Motor — video 4', category: 'SFR Motor' },
];

const CHANNEL_URL = 'https://www.youtube.com/@sfrmotor';
---

<section class="yt-section" data-screen-label="YouTube">
  <div class="container">
    <div class="magazin-head">
      <div>
        <div class="section-eyebrow">YouTube</div>
        <h2>Naše videa</h2>
      </div>
      <a class="head-link" href={CHANNEL_URL} target="_blank" rel="noopener">
        @sfrmotor kanál
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>
    </div>
    <div class="yt-grid">
      {VIDEOS.map((v) => (
        <a
          class="yt-card"
          href={`https://www.youtube.com/watch?v=${v.id}`}
          target="_blank"
          rel="noopener"
          aria-label={`Přehrát video: ${v.title}`}
        >
          <div class="pic">
            <img
              src={`https://img.youtube.com/vi/${v.id}/hqdefault.jpg`}
              alt={v.title}
              loading="lazy"
            />
            <span class="play-overlay" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <polygon points="6 4 20 12 6 20 6 4"/>
              </svg>
            </span>
            {v.duration && <span class="duration">{v.duration}</span>}
          </div>
          {v.category && <div class="yt-tag">{v.category}</div>}
          <div class="yt-title">{v.title}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .yt-section {
    padding: 0 0 120px;
    background: #fff;
  }

  .yt-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }
  @media (max-width: 1100px) { .yt-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .yt-grid { grid-template-columns: 1fr; } }

  .yt-card {
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition: transform .2s;
  }
  .yt-card:hover { transform: translateY(-2px); }

  .yt-card .pic {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--bg-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 16px;
  }
  .yt-card .pic img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }
  .yt-card:hover .pic img { transform: scale(1.04); }

  .yt-card .play-overlay {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 60px; height: 60px;
    border-radius: 999px;
    background: rgba(242, 92, 27, 0.92);
    color: #fff;
    display: grid; place-items: center;
    transition: transform .2s, background .2s;
    box-shadow: 0 4px 14px rgba(0,0,0,0.3);
  }
  .yt-card:hover .play-overlay {
    background: var(--accent);
    transform: translate(-50%, -50%) scale(1.08);
  }

  .yt-card .duration {
    position: absolute;
    bottom: 10px; right: 10px;
    background: rgba(0,0,0,0.78);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 4px 8px;
    border-radius: 4px;
  }

  .yt-tag {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .yt-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .yt-card:hover .yt-title { color: var(--accent); }
</style>
