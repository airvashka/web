---
/**
 * ModelChatWidget — plovoucí AI chat asistent na model stránce.
 *
 * Použití na /model/[slug]:
 *   <ModelChatWidget modelSlug={rawModel.slug} modelName={rawModel.name} brandName={brand.name} />
 *
 * Co dělá:
 *   - Floating tlačítko vpravo dole otevírá chat panel
 *   - Posílá zprávy na /api/chat/model (POST)
 *   - AI odpovídá z context (model data, trims, technical data, sklad)
 *   - Když AI rozpozná intent (test drive, koupit), zeptá se na kontakt
 *     a uloží do leads (form_type='ai_chat')
 */

interface Props {
  modelSlug: string;
  modelName: string;
  brandName: string;
}

const { modelSlug, modelName, brandName } = Astro.props;
---

<div class="chat-widget" data-model-slug={modelSlug} data-model-name={modelName} data-brand-name={brandName}>
  <!-- Toggle button (closed state) -->
  <button class="chat-toggle" type="button" aria-label="Otevřít AI asistenta" data-chat-toggle>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <span>Zeptat se na {modelName}</span>
  </button>

  <!-- Chat panel (open state) -->
  <div class="chat-panel chat-panel--closed" data-chat-panel>
    <div class="chat-header">
      <div class="chat-header-title">
        <span class="chat-ai-dot" aria-hidden="true"></span>
        <div>
          <div class="chat-header-name">AI asistent · {brandName} {modelName}</div>
          <div class="chat-header-sub">Ptáte se, odpovídám</div>
        </div>
      </div>
      <button class="chat-close" type="button" aria-label="Minimalizovat chat" title="Minimalizovat" data-chat-close>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </div>

    <div class="chat-disclaimer">
      Informace od AI jsou orientační. Závaznou nabídku poskytujeme po konzultaci s prodejcem.
    </div>

    <div class="chat-messages" data-chat-messages>
      <div class="chat-msg chat-msg--assistant">
        <span class="chat-avatar chat-avatar--ai" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </span>
        <div class="chat-bubble">
          Ahoj! Jsem AI asistent SFR Motor. Můžu vám odpovědět na otázky o <strong>{brandName} {modelName}</strong> — výbavy, ceny, technická data, dostupnost skladem. Co vás zajímá?
        </div>
      </div>
    </div>

    <div class="chat-suggestions" data-chat-suggestions>
      <button class="chat-chip" data-prompt="Jaké jsou ceny a výbavy?">Ceny a výbavy</button>
      <button class="chat-chip" data-prompt="Co tenhle model umí?">Co umí</button>
      <button class="chat-chip" data-prompt="Kolik kusů máte skladem?">Skladem</button>
      <button class="chat-chip" data-prompt="Chci si domluvit testovací jízdu.">Test drive</button>
    </div>

    <form class="chat-input-row" data-chat-form>
      <input
        type="text"
        class="chat-input"
        placeholder="Napište otázku…"
        maxlength="500"
        autocomplete="off"
        data-chat-input
        required
      />
      <button class="chat-send" type="submit" aria-label="Odeslat" data-chat-send>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </form>
  </div>
</div>

<script>
  // ── State ──
  const root = document.querySelector('.chat-widget') as HTMLElement | null;
  if (root) {
    const slug = root.dataset.modelSlug!;
    const toggleBtn = root.querySelector('[data-chat-toggle]') as HTMLButtonElement;
    const closeBtn = root.querySelector('[data-chat-close]') as HTMLButtonElement;
    const panel = root.querySelector('[data-chat-panel]') as HTMLElement;
    const messagesEl = root.querySelector('[data-chat-messages]') as HTMLElement;
    const form = root.querySelector('[data-chat-form]') as HTMLFormElement;
    const input = root.querySelector('[data-chat-input]') as HTMLInputElement;
    const sendBtn = root.querySelector('[data-chat-send]') as HTMLButtonElement;
    const suggestions = root.querySelector('[data-chat-suggestions]') as HTMLElement;
    const chips = root.querySelectorAll('[data-prompt]');

    let history: { role: 'user' | 'assistant'; content: string }[] = [];
    let busy = false;

    // Open / close — používáme třídu místo `hidden` atributu, protože
    // .chat-panel má `display: flex` které má vyšší specifitu než UA [hidden] {display:none}.
    function openChat() {
      panel.classList.remove('chat-panel--closed');
      toggleBtn.style.display = 'none';
      setTimeout(() => input.focus(), 50);
    }
    function closeChat() {
      panel.classList.add('chat-panel--closed');
      toggleBtn.style.display = '';
    }
    toggleBtn.addEventListener('click', openChat);
    closeBtn.addEventListener('click', closeChat);

    function escapeHtml(s: string): string {
      const div = document.createElement('div');
      div.textContent = s;
      return div.innerHTML;
    }

    const AI_AVATAR_SVG = '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>';

    const USER_AVATAR_SVG = '<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4,22 C4,16 7.5,13 12,13 C16.5,13 20,16 20,22 Z"/></svg>';

    function markdownToHtml(text: string): string {
      let s = escapeHtml(text);
      // Markdown links — [text](url) → <a href="url">text</a>
      // Interní (začínají /) → stejný tab, externí → nový tab
      s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_m, label: string, url: string) => {
        const isInternal = url.startsWith('/') || url.includes('sfr-motor');
        const target = isInternal ? '' : ' target="_blank" rel="noopener"';
        return `<a class="chat-link" href="${url}"${target}>${label}</a>`;
      });
      // Bold + italic
      s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
      s = s.replace(/(?<!\*)\*([^*]+)\*(?!\*)/g, '<em>$1</em>');
      // Line breaks
      s = s.replace(/\n/g, '<br />');
      return s;
    }

    function appendMessage(role: 'user' | 'assistant', text: string) {
      const wrap = document.createElement('div');
      wrap.className = `chat-msg chat-msg--${role}`;
      const avatar = document.createElement('span');
      avatar.className = `chat-avatar chat-avatar--${role === 'assistant' ? 'ai' : 'user'}`;
      avatar.setAttribute('aria-hidden', 'true');
      avatar.innerHTML = role === 'assistant' ? AI_AVATAR_SVG : USER_AVATAR_SVG;
      const bubble = document.createElement('div');
      bubble.className = 'chat-bubble';
      bubble.innerHTML = markdownToHtml(text);
      // Order: AI msg → avatar | bubble. User msg → bubble | avatar
      if (role === 'assistant') {
        wrap.appendChild(avatar);
        wrap.appendChild(bubble);
      } else {
        wrap.appendChild(bubble);
        wrap.appendChild(avatar);
      }
      messagesEl.appendChild(wrap);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function appendTyping(): HTMLElement {
      const wrap = document.createElement('div');
      wrap.className = 'chat-msg chat-msg--assistant chat-typing-wrap';
      wrap.innerHTML = `<span class="chat-avatar chat-avatar--ai" aria-hidden="true">${AI_AVATAR_SVG}</span><div class="chat-bubble chat-typing"><span></span><span></span><span></span></div>`;
      messagesEl.appendChild(wrap);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return wrap;
    }

    async function send(text: string) {
      if (busy || !text.trim()) return;
      busy = true;
      sendBtn.disabled = true;
      input.disabled = true;
      suggestions.style.display = 'none';

      appendMessage('user', text);
      history.push({ role: 'user', content: text });
      const typing = appendTyping();

      try {
        const r = await fetch('/api/chat/model', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, messages: history }),
        });
        const j = await r.json();
        typing.remove();
        if (!r.ok) throw new Error(j?.error || `HTTP ${r.status}`);
        const reply = j.content || 'Omlouvám se, něco se pokazilo. Zkuste to znovu.';
        appendMessage('assistant', reply);
        history.push({ role: 'assistant', content: reply });
        if (j.lead_created) {
          // Track conversion v dataLayer
          if ((window as any).dataLayer) {
            (window as any).dataLayer.push({ event: 'generate_lead', form_name: 'ai_chat' });
          }
        }
      } catch (e: any) {
        typing.remove();
        appendMessage('assistant', `Omlouvám se, technický problém: ${e.message}. Zavolejte prosím Petrovi Pasekovi: +420 771 235 458.`);
      } finally {
        busy = false;
        sendBtn.disabled = false;
        input.disabled = false;
        input.focus();
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text) return;
      input.value = '';
      send(text);
    });

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const prompt = (chip as HTMLElement).dataset.prompt!;
        send(prompt);
      });
    });
  }
</script>

<style is:global>
  /* ===== FLOATING TOGGLE BUTTON ===== */
  .chat-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
  }
  .chat-toggle {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--accent, #B4762E) 0%, #d18b3a 100%);
    color: #fff;
    border: none;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 10px 28px rgba(180, 118, 46, 0.35), 0 2px 6px rgba(0,0,0,0.1);
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .chat-toggle:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(180, 118, 46, 0.45), 0 4px 10px rgba(0,0,0,0.12);
  }
  .chat-toggle svg { flex-shrink: 0; }

  /* ===== CHAT PANEL ===== */
  .chat-panel {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 380px;
    max-width: calc(100vw - 32px);
    height: 560px;
    max-height: calc(100vh - 48px);
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25), 0 4px 16px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: chatSlideUp .25s ease-out;
  }
  /* Closed state — !important kvůli přebití .chat-panel { display: flex } */
  .chat-panel.chat-panel--closed {
    display: none !important;
  }
  @keyframes chatSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Header */
  .chat-header {
    background: linear-gradient(135deg, #1a1a1f 0%, #2a2a30 100%);
    color: #fff;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .chat-header-title {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .chat-ai-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7);
    animation: chatPulse 2s cubic-bezier(0.66, 0, 0.34, 1) infinite;
    flex-shrink: 0;
  }
  @keyframes chatPulse {
    0%   { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7); }
    70%  { box-shadow: 0 0 0 8px rgba(74, 222, 128, 0); }
    100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
  }
  .chat-header-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    line-height: 1.2;
  }
  .chat-header-sub {
    font-size: 11px;
    opacity: 0.7;
    margin-top: 2px;
  }
  .chat-close {
    background: transparent;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    transition: background .15s;
    min-width: 40px;
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: rgba(255,255,255,0.2);
    flex-shrink: 0;
  }
  .chat-close:hover,
  .chat-close:active { background: rgba(255,255,255,0.15); }

  .chat-disclaimer {
    font-size: 10.5px;
    color: var(--text-muted, #6B6B72);
    padding: 8px 18px;
    background: #f8f8f5;
    border-bottom: 1px solid #ececea;
    line-height: 1.4;
    font-style: italic;
  }

  /* Messages list */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #fff;
  }
  .chat-msg {
    display: flex;
    max-width: 100%;
    gap: 8px;
    align-items: flex-end;
  }
  .chat-msg--user {
    justify-content: flex-end;
  }
  .chat-bubble {
    max-width: 78%;
    padding: 9px 13px;
    border-radius: 16px;
    font-size: 14px;
    line-height: 1.45;
    word-wrap: break-word;
    overflow-wrap: anywhere;
  }
  .chat-msg--assistant .chat-bubble {
    background: #f1f1ee;
    color: #1a1a1f;
    border-bottom-left-radius: 5px;
  }
  .chat-msg--user .chat-bubble {
    background: var(--accent, #B4762E);
    color: #fff;
    border-bottom-right-radius: 5px;
  }

  /* Avatary — kruhové, malé */
  .chat-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: 2px;
  }
  .chat-avatar--ai {
    background: linear-gradient(135deg, var(--accent, #B4762E) 0%, #d18b3a 100%);
    color: #fff;
  }
  .chat-avatar--user {
    background: #e6e6e3;
    color: #6B6B72;
  }

  /* Markdown linky v bublině */
  .chat-bubble .chat-link {
    color: var(--accent, #B4762E);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 500;
  }
  .chat-bubble .chat-link:hover {
    color: #9a6826;
  }
  .chat-msg--user .chat-bubble .chat-link {
    color: #fff;
    text-decoration: underline;
  }

  /* Typing animation */
  .chat-typing { display: flex; gap: 4px; padding: 12px 14px; }
  .chat-typing span {
    width: 7px; height: 7px; border-radius: 50%; background: #999;
    animation: chatTypingDot 1.2s infinite;
  }
  .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes chatTypingDot {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30%           { transform: translateY(-4px); opacity: 1; }
  }

  /* Suggestion chips */
  .chat-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 16px 10px;
  }
  .chat-chip {
    font-size: 12px;
    padding: 6px 11px;
    background: transparent;
    border: 1px solid #ddd;
    border-radius: 999px;
    color: #1a1a1f;
    cursor: pointer;
    transition: all .15s;
    font-family: var(--font-body);
  }
  .chat-chip:hover {
    background: var(--accent, #B4762E);
    color: #fff;
    border-color: var(--accent, #B4762E);
  }

  /* Input row */
  .chat-input-row {
    display: flex;
    gap: 8px;
    padding: 12px 14px;
    background: #fff;
    border-top: 1px solid #ececea;
  }
  .chat-input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid #ddd;
    border-radius: 999px;
    font-size: 14px;
    outline: none;
    font-family: var(--font-body);
    transition: border-color .15s;
  }
  .chat-input:focus {
    border-color: var(--accent, #B4762E);
  }
  .chat-send {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--accent, #B4762E);
    color: #fff;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background .15s, transform .15s;
  }
  .chat-send:hover:not(:disabled) {
    background: #9a6826;
    transform: scale(1.05);
  }
  .chat-send:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Mobile — chat panel slide-in from right (ne fullscreen) */
  @media (max-width: 640px) {
    .chat-widget {
      bottom: 12px;
      right: 12px;
    }
    .chat-toggle {
      padding: 12px;
      font-size: 0; /* skryje text, ponechá svg */
      width: 48px;
      height: 48px;
      justify-content: center;
    }
    .chat-toggle span {
      display: none;
    }
    .chat-toggle svg {
      width: 24px;
      height: 24px;
    }
    .chat-panel {
      width: calc(100vw - 24px);
      max-width: 100%;
      height: calc(100vh - 24px);
      max-height: calc(100vh - 24px);
      bottom: 12px;
      right: 12px;
      border-radius: 16px;
      /* slide from right místo from bottom */
      animation: chatSlideIn .25s ease-out;
    }
  }
  @keyframes chatSlideIn {
    from { opacity: 0; transform: translateX(40px); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>
