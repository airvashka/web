---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import JsonLd from '@components/JsonLd.astro';
import GoogleReviews from '@components/GoogleReviews.astro';
import TeamCard from '@components/TeamCard.astro';
import TurnstileWidget from '@components/TurnstileWidget.astro';
import { directusGet } from '@lib/directus';
import { FALLBACK_SERVICE_PHONE, telLink } from '@lib/contacts';
import { autoRepairSchema } from '@lib/schemas';
import googleReviews from '../data/google-reviews.json';
import type { Employee } from '@lib/types';

/* ============================================================
   SERVIS — 1:1 podle _design-draft/servis.jsx
   Sections: Hero · ServicesAndForm (2 col)
   ============================================================ */

// Dynamický servisní telefon (z middleware, fallback)
const serviceContact = (Astro.locals as any).serviceContact;
const servicePhone = serviceContact?.phone ?? FALLBACK_SERVICE_PHONE;
const servicePhoneLink = telLink(servicePhone);

const SERVICES = [
  { t: 'Pravidelný servis', s: 'výměna oleje, filtry, brzdy, kapaliny' },
  { t: 'Roční prohlídka', s: 'kontrola dle servisního plánu výrobce' },
  { t: 'STK + emise', s: 'připravíme vůz a doprovodíme' },
  { t: 'Pneuservis', s: 'sezónní přezutí, uskladnění, opravy' },
  { t: 'Karosárna a lakovna', s: 'od drobných oprav po havárie' },
  { t: 'Diagnostika', s: 'autorizované diagnostické přístroje' },
  { t: 'Originální náhradní díly', s: 'KGM, OMODA & JAECOO, Farizon, Dacia, Renault' },
  { t: 'Geometrie', s: 'čištění klimatizace, čištění automatické převodovky' },
];

// ── Servis tým — fetch z Directus, mapování per kategorie podle emailu ──
const allEmployees = await directusGet<Employee>('employees', {
  sort: ['sort', 'full_name'],
  fields: ['id', 'full_name', 'role', 'department', 'email', 'phone', 'photo'],
});
const byEmail = new Map(allEmployees.map((e) => [e.email, e]));

const TEAM_KGM     = ['hertl@sfr-motor.cz', 'marik@sfr-motor.cz', 'zaruba@sfr-motor.cz']
  .map((e) => byEmail.get(e)).filter(Boolean) as Employee[];
const TEAM_DACIA   = ['melisek@sfr-motor.cz']
  .map((e) => byEmail.get(e)).filter(Boolean) as Employee[];
const TEAM_NEHODY  = ['bursik@sfr-motor.cz']
  .map((e) => byEmail.get(e)).filter(Boolean) as Employee[];
const TEAM_DILY    = ['patzelt@sfr-motor.cz', 'zelenka@sfr-motor.cz']
  .map((e) => byEmail.get(e)).filter(Boolean) as Employee[];

const SERVIS_TEAM_BLOCKS = [
  { title: 'KGM, OMODA & JAECOO', tag: 'Servis',         tagClass: 'tag-service', people: TEAM_KGM },
  { title: 'Dacia, Renault',      tag: 'Servis',         tagClass: 'tag-service', people: TEAM_DACIA },
  { title: 'Nehody a pojistné události', tag: 'Pojistné',  tagClass: 'tag-service', people: TEAM_NEHODY },
  { title: 'Náhradní díly',       tag: 'Díly',           tagClass: 'tag-parts',   people: TEAM_DILY },
].filter((b) => b.people.length > 0);
---

<BaseLayout title="Servis" description="Autorizovaný servis pro KGM, OMODA & JAECOO, Farizon, Dacia, Renault. Praha-Ďáblice.">
  <JsonLd data={autoRepairSchema(googleReviews.servis)} />
  <Breadcrumbs items={[{ label: 'Servis' }]} />

  <!-- ===== HERO ===== -->
  <section class="phero" data-screen-label="01 Hero">
    <div class="container">
      <div class="section-eyebrow">Autorizovaný servis</div>
      <h1>Servis pro všechny značky</h1>
      <p class="lead">Specializujeme se na KGM, OMODA &amp; JAECOO, Farizon a navíc Dacia a Renault. Pneuservis, karosárna, lakovna, originální díly — všechno na jednom místě v Praze-Ďáblicích.</p>
    </div>
  </section>

  <!-- ===== SERVICES + FORM ===== -->
  <section class="serv-services" data-screen-label="02 Co umíme">
    <div class="container serv-grid">
      <div class="serv-list-wrap">
        <h2>Co umíme</h2>
        <div class="serv-list">
          {SERVICES.map((s) => (
            <div class="serv-item">
              <div>
                <span class="t">{s.t}</span>
                <span class="s">— {s.s}</span>
              </div>
            </div>
          ))}
        </div>
        <div class="hours-card" id="cenik">
          <h3>Otevírací doba servisu</h3>
          <div class="hours-row"><span class="d">Pondělí – Pátek</span><span class="h">8:00 – 17:00</span></div>
          <div class="hours-row"><span class="d">Sobota</span><span class="h closed">zavřeno</span></div>
          <div class="hours-row"><span class="d">Neděle</span><span class="h closed">zavřeno</span></div>
          <div class="hours-foot">
            <span>Telefon: <a href={`tel:${servicePhoneLink}`}>{servicePhone}</a></span>
            <span>Email: <a href="mailto:servis@sfr-motor.cz">servis@sfr-motor.cz</a></span>
          </div>
        </div>
      </div>

      <form class="fcard" style="align-self: start;" data-lead-form data-form-type="service">
        <h3>Objednat termín servisu</h3>
        <div class="fgrid">
          <div class="field full">
            <label>Vaše jméno <span class="req">*</span></label>
            <input type="text" name="customer_name" required minlength="2" maxlength="200" />
          </div>
          <div class="field">
            <label>E-mail <span class="req">*</span></label>
            <input type="email" name="customer_email" required maxlength="200" />
          </div>
          <div class="field">
            <label>Telefon</label>
            <input type="tel" name="customer_phone" maxlength="50" pattern="[+0-9\s\-()]+" />
          </div>
          <div class="field full">
            <label>Vůz (značka, model, SPZ)</label>
            <input type="text" name="vehicle" placeholder="např. KGM Torres EVX, 1AB 2345" maxlength="200" />
          </div>
          <div class="field">
            <label>Preferovaný termín</label>
            <input type="date" name="preferred_date" />
          </div>
          <div class="field">
            <label>Typ úkonu</label>
            <input type="text" name="service_type" placeholder="Pravidelný servis, STK…" maxlength="200" />
          </div>
          <div class="field full">
            <label>Zpráva (nepovinné)</label>
            <textarea name="message" maxlength="2000"></textarea>
          </div>
        </div>
        <input type="text" name="_hp_website" tabindex="-1" autocomplete="off" class="honeypot" />
        <TurnstileWidget />
        <label class="check">
          <input type="checkbox" required />
          Souhlasím se zpracováním osobních údajů dle <a href="/informace/ochrana-udaju">GDPR</a>
        </label>
        <button class="btn btn-primary" type="submit">Odeslat poptávku</button>
        <div class="lead-status" data-lead-status></div>
      </form>
    </div>
  </section>

  <!-- ===== SERVIS TÝM ===== -->
  {SERVIS_TEAM_BLOCKS.length > 0 && (
    <section class="serv-team" data-screen-label="03 Tym">
      <div class="container">
        <div class="serv-team-intro">
          <div class="section-eyebrow">Náš servis tým</div>
          <h2>Komu se ozvat</h2>
          <p class="lead">Volejte přímo svého servisního poradce — podle značky vozu nebo úkonu.</p>
        </div>

        {SERVIS_TEAM_BLOCKS.map((block) => (
          <div class="serv-team-block">
            <div class="serv-team-head">
              <h3>{block.title}</h3>
            </div>
            <div class="serv-team-grid">
              {block.people.map((p) => <TeamCard person={p} tagLabel={block.tag} tagClass={block.tagClass} />)}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ===== GOOGLE RECENZE SERVIS ===== -->
  <section class="reviews-section" data-screen-label="04 Recenze">
    <div class="container">
      <div class="section-eyebrow">⭐ Hodnocení servisu</div>
      <GoogleReviews business="servis" layout="cards" limit={5} headingText="Co o servisu říkají zákazníci" />
    </div>
  </section>

  <script>
        document.querySelectorAll('[data-lead-form]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const statusEl = form.querySelector('[data-lead-status]');
        const submitBtn = form.querySelector('button[type=submit]');
        if (statusEl) statusEl.textContent = 'Odesílám...';

        const data = new FormData(form);
        const turnstileInput = form.querySelector('input[name="cf-turnstile-response"]');
        const payload = {
          form_type: form.dataset.formType || 'contact',
          customer_name: data.get('customer_name'),
          customer_email: data.get('customer_email'),
          customer_phone: data.get('customer_phone'),
          message: data.get('message'),
          source_page: window.location.pathname,
          source_url: window.location.href,
          _hp_website: data.get('_hp_website') || '',
          turnstile_token: turnstileInput ? turnstileInput.value : '',
        };
        try {
          const res = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const result = await res.json().catch(() => ({ ok: false, error: 'Network error' }));
          if (!res.ok || !result.ok) throw new Error(result.error || ('HTTP ' + res.status));
          if (statusEl) { statusEl.textContent = '✓ Děkujeme! Brzy se vám ozveme.'; statusEl.style.color = 'var(--ok)'; }
          if (submitBtn) submitBtn.disabled = true;
          if (window.dataLayer) window.dataLayer.push({ event: 'generate_lead', form_name: payload.form_type });
        } catch (err) {
          if (statusEl) {
            statusEl.textContent = err.message
              ? '✗ ' + err.message
              : 'Něco se nepodařilo. Zkuste znovu, nebo zavolejte +420 771 235 458.';
            statusEl.style.color = 'var(--danger)';
          }
        }
      });
    });
  </script>

  <style>
    .lead-status { min-height: 24px; font-size: 13px; margin-top: 8px; }

    /* ===== Servis tým ===== */
    .serv-team {
      padding: 72px 0 88px;
      background: var(--bg-soft);
    }
    .serv-team-intro {
      max-width: 60ch;
      margin: 0 0 40px;
      text-align: left;
    }
    .serv-team-intro h2 {
      font-family: var(--font-display);
      font-size: clamp(26px, 3vw, 36px);
      font-weight: 700;
      margin: 4px 0 10px;
      letter-spacing: -0.01em;
    }
    .serv-team-intro .lead {
      color: var(--text-muted);
      font-size: 15px;
      line-height: 1.6;
      margin: 0;
    }
    .serv-team-block {
      margin-bottom: 40px;
    }
    .serv-team-block:last-child { margin-bottom: 0; }
    .serv-team-head {
      margin-bottom: 18px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }
    .serv-team-head h3 {
      font-family: var(--font-display);
      font-size: clamp(18px, 2vw, 22px);
      font-weight: 600;
      margin: 0;
      letter-spacing: -0.005em;
    }
    .serv-team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 14px;
    }
    @media (max-width: 640px) {
      .serv-team { padding: 48px 0 64px; }
      .serv-team-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
    }
  </style>
</BaseLayout>
