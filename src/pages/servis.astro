---
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadForm from '@components/LeadForm.astro';
---

<BaseLayout title="Servis" description="Autorizovaný servis pro KGM, OMODA & JAECOO, Farizon, Dacia, Renault. Praha-Ďáblice.">
  <section class="section servis-hero">
    <div class="container">
      <p class="eyebrow eyebrow-accent">Autorizovaný servis</p>
      <h1>Servis pro&nbsp;všechny&nbsp;značky</h1>
      <p class="lead">
        Specializujeme se na KGM, OMODA &amp; JAECOO, Farizon a navíc Dacia a Renault.
        Pneuservis, karosárna, lakovna, originální díly — všechno na jednom místě v&nbsp;Praze-Ďáblicích.
      </p>
    </div>
  </section>

  <section class="container servis-grid">
    <div class="servis-grid__info">
      <h2>Co umíme</h2>
      <ul class="services">
        <li><strong>Pravidelný servis</strong> — výměna oleje, filtry, brzdy, kapaliny</li>
        <li><strong>Roční prohlídka</strong> — kontrola dle servisního plánu výrobce</li>
        <li><strong>STK + emise</strong> — připravíme vůz a doprovodíme</li>
        <li><strong>Pneuservis</strong> — sezónní přezutí, uskladnění, opravy</li>
        <li><strong>Karosárna a lakovna</strong> — od drobných oprav po havárie</li>
        <li><strong>Diagnostika</strong> — autorizované diagnostické přístroje</li>
        <li><strong>Originální náhradní díly</strong> — KGM, OMODA & JAECOO, Farizon, Dacia, Renault</li>
        <li><strong>Geometrie</strong>, čištění klimatizace, čištění automatické převodovky</li>
      </ul>

      <div class="hours-card">
        <h3>Otevírací doba servisu</h3>
        <table>
          <tr><td>Pondělí – Pátek</td><td class="font-mono">8:00 – 17:00</td></tr>
          <tr><td>Sobota</td><td class="font-mono">9:00 – 12:00</td></tr>
          <tr><td>Neděle</td><td class="font-mono">zavřeno</td></tr>
        </table>
        <p style="margin-top: 16px;">
          <span class="text-muted">Telefon:</span>
          <a href="tel:+420771259323" class="font-mono">+420 771 259 323</a>
        </p>
        <p>
          <span class="text-muted">Email:</span>
          <a href="mailto:servis@sfr-motor.cz">servis@sfr-motor.cz</a>
        </p>
      </div>
    </div>

    <div class="servis-grid__form">
      <LeadForm formType="service" title="Objednat termín servisu" />
    </div>
  </section>
</BaseLayout>

<style>
  .servis-hero {
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-soft) 100%);
    padding-block: clamp(48px, 7vw, 96px);
  }
  .servis-hero h1 { margin-block: 8px 16px; }

  .servis-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-bottom: var(--section-pad);
  }
  @media (min-width: 900px) {
    .servis-grid { grid-template-columns: 1.2fr 1fr; }
  }

  .servis-grid__info h2 { margin-bottom: 16px; }
  .services { list-style: none; display: flex; flex-direction: column; gap: 10px; padding: 0; margin-bottom: 32px; }
  .services li { padding-left: 24px; position: relative; }
  .services li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-weight: 700; }

  .hours-card { background: var(--bg-card); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 24px; }
  .hours-card h3 { margin-bottom: 16px; }
  .hours-card table { width: 100%; border-collapse: collapse; }
  .hours-card td { padding: 6px 0; border-bottom: 1px solid var(--line-soft); }
  .hours-card td:last-child { text-align: right; }
  .hours-card tr:last-child td { border-bottom: 0; }
  .hours-card a { color: var(--ink); border-bottom: 1px solid var(--line); }
  .hours-card a:hover { color: var(--accent); border-bottom-color: var(--accent); }
</style>
