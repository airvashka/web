---
import BaseLayout from '@layouts/BaseLayout.astro';

/* ============================================================
   SERVIS — 1:1 podle _design-draft/servis.jsx
   Sections: Hero · ServicesAndForm (2 col)
   ============================================================ */

const SERVICES = [
  { t: 'Pravidelný servis', s: 'výměna oleje, filtry, brzdy, kapaliny' },
  { t: 'Roční prohlídka', s: 'kontrola dle servisního plánu výrobce' },
  { t: 'STK + emise', s: 'připravíme vůz a doprovodíme' },
  { t: 'Pneuservis', s: 'sezónní přezutí, uskladnění, opravy' },
  { t: 'Karosárna a lakovna', s: 'od drobných oprav po havárie' },
  { t: 'Diagnostika', s: 'autorizované diagnostické přístroje' },
  { t: 'Originální náhradní díly', s: 'KGM, OMODA & JAECOO, Farizon, Dacia, Renault' },
  { t: 'Geometrie', s: 'čištění klimatizace, čištění automatické převodovky' },
];
---

<BaseLayout title="Servis" description="Autorizovaný servis pro KGM, OMODA & JAECOO, Farizon, Dacia, Renault. Praha-Ďáblice.">
  <!-- ===== HERO ===== -->
  <section class="phero" data-screen-label="01 Hero">
    <div class="container">
      <div class="section-eyebrow">Autorizovaný servis</div>
      <h1>Servis pro všechny značky</h1>
      <p class="lead">Specializujeme se na KGM, OMODA &amp; JAECOO, Farizon a navíc Dacia a Renault. Pneuservis, karosárna, lakovna, originální díly — všechno na jednom místě v Praze-Ďáblicích.</p>
    </div>
  </section>

  <!-- ===== SERVICES + FORM ===== -->
  <section class="serv-services" data-screen-label="02 Co umíme">
    <div class="container serv-grid">
      <div class="serv-list-wrap">
        <h2>Co umíme</h2>
        <div class="serv-list">
          {SERVICES.map((s) => (
            <div class="serv-item">
              <div>
                <span class="t">{s.t}</span>
                <span class="s">— {s.s}</span>
              </div>
            </div>
          ))}
        </div>
        <div class="hours-card" id="cenik">
          <h3>Otevírací doba servisu</h3>
          <div class="hours-row"><span class="d">Pondělí – Pátek</span><span class="h">8:00 – 17:00</span></div>
          <div class="hours-row"><span class="d">Sobota</span><span class="h">9:00 – 12:00</span></div>
          <div class="hours-row"><span class="d">Neděle</span><span class="h closed">zavřeno</span></div>
          <div class="hours-foot">
            <span>Telefon: <a href="tel:+420771259323">+420 771 259 323</a></span>
            <span>Email: <a href="mailto:servis@sfr-motor.cz">servis@sfr-motor.cz</a></span>
          </div>
        </div>
      </div>

      <form class="fcard" style="align-self: start;" data-lead-form data-form-type="service">
        <h3>Objednat termín servisu</h3>
        <div class="fgrid">
          <div class="field full">
            <label>Vaše jméno <span class="req">*</span></label>
            <input type="text" name="customer_name" required minlength="2" maxlength="200" />
          </div>
          <div class="field">
            <label>E-mail <span class="req">*</span></label>
            <input type="email" name="customer_email" required maxlength="200" />
          </div>
          <div class="field">
            <label>Telefon</label>
            <input type="tel" name="customer_phone" maxlength="50" pattern="[+0-9\s\-()]+" />
          </div>
          <div class="field full">
            <label>Vůz (značka, model, SPZ)</label>
            <input type="text" name="vehicle" placeholder="např. KGM Torres EVX, 1AB 2345" maxlength="200" />
          </div>
          <div class="field">
            <label>Preferovaný termín</label>
            <input type="date" name="preferred_date" />
          </div>
          <div class="field">
            <label>Typ úkonu</label>
            <input type="text" name="service_type" placeholder="Pravidelný servis, STK…" maxlength="200" />
          </div>
          <div class="field full">
            <label>Zpráva (nepovinné)</label>
            <textarea name="message" maxlength="2000"></textarea>
          </div>
        </div>
        <input type="text" name="_hp_website" tabindex="-1" autocomplete="off" class="honeypot" />
        <div class="fnote">Odesláním souhlasíte se zpracováním osobních údajů.</div>
        <button class="btn btn-primary" type="submit">Odeslat poptávku</button>
        <div class="lead-status" data-lead-status></div>
      </form>
    </div>
  </section>

  <script>
    const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL;
    document.querySelectorAll('[data-lead-form]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const statusEl = form.querySelector('[data-lead-status]');
        const hp = form.querySelector('[name=_hp_website]')?.value;
        if (hp) { if (statusEl) statusEl.textContent = 'Děkujeme! Brzy se ozveme.'; form.reset(); return; }
        const data = new FormData(form);
        // Sestavit message s detaily o autu / termínu / službě
        const parts = [];
        const veh = data.get('vehicle');
        const date = data.get('preferred_date');
        const stype = data.get('service_type');
        const msg = data.get('message');
        if (veh) parts.push(`Vůz: ${veh}`);
        if (stype) parts.push(`Typ úkonu: ${stype}`);
        if (date) parts.push(`Preferovaný termín: ${date}`);
        if (msg) parts.push(`Zpráva: ${msg}`);
        const payload = {
          form_type: form.dataset.formType,
          customer_name: data.get('customer_name'),
          customer_email: data.get('customer_email'),
          customer_phone: data.get('customer_phone'),
          message: parts.join('\n'),
          source_page: window.location.pathname,
        };
        try {
          const res = await fetch(`${DIRECTUS_URL}/items/leads`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          if (statusEl) { statusEl.textContent = '✓ Děkujeme! Ozveme se do 24 hodin.'; statusEl.style.color = 'var(--ok)'; }
          form.querySelector('button[type=submit]').disabled = true;
          if (window.dataLayer) window.dataLayer.push({ event: 'generate_lead', form_name: 'service' });
        } catch (err) {
          if (statusEl) { statusEl.textContent = 'Něco se nepodařilo. Zkuste znovu nebo zavolejte +420 771 259 323.'; statusEl.style.color = 'var(--danger)'; }
        }
      });
    });
  </script>

  <style>
    .lead-status { min-height: 24px; font-size: 13px; margin-top: 8px; }
  </style>
</BaseLayout>
