---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import JsonLd from '@components/JsonLd.astro';
import GoogleReviews from '@components/GoogleReviews.astro';
import TeamCard from '@components/TeamCard.astro';
import TurnstileWidget from '@components/TurnstileWidget.astro';
import { directusGet, directusAsset } from '@lib/directus';
import { autoDealerSchema, autoRepairSchema } from '@lib/schemas';
import googleReviews from '../data/google-reviews.json';
import type { Branch, Employee } from '@lib/types';

// KONTAKT — Hero + ContactInfo (map + card) + Team (4 departments) + Form

const branches = await directusGet<Branch>('branches');
const branch = branches[0];

const employees = await directusGet<Employee>('employees', {
  sort: ['sort', 'full_name'],
  fields: ['id', 'full_name', 'role', 'department', 'email', 'phone', 'photo'],
});

const management = employees.filter((e) => e.department === 'management');
const sales      = employees.filter((e) => e.department === 'sales');
const service    = employees.filter((e) => e.department === 'service');
const parts      = employees.filter((e) => e.department === 'parts');

// Konfigurace bloků — labels, tagy, ikony barev
const TEAM_BLOCKS: { key: string; title: string; tag: string; people: Employee[]; tagClass: string }[] = [
  { key: 'management', title: 'Vedení společnosti', tag: 'Vedení',         people: management, tagClass: 'tag-mgmt' },
  { key: 'sales',      title: 'Prodej nových vozů', tag: 'Prodej',         people: sales,      tagClass: 'tag-sales' },
  { key: 'service',    title: 'Servis',             tag: 'Servis',         people: service,    tagClass: 'tag-service' },
  { key: 'parts',      title: 'Náhradní díly',      tag: 'Náhradní díly',  people: parts,      tagClass: 'tag-parts' },
].filter((b) => b.people.length > 0);

const branchName = branch?.name ?? 'SFR Motor s.r.o.';
const branchAddress = branch?.address ?? 'Ďáblická 553/2';
const branchPostal = branch?.postal_code ?? '182 00';
const branchCity = branch?.city ?? 'Praha 8';

// Mapa: přes Maps Embed API přesný business pin (place_id z env), fallback na adresu když klíč chybí.
const GMAPS_KEY = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? '';
const GMAPS_PLACE_PRODEJ = import.meta.env.GOOGLE_PLACE_ID_PRODEJ ?? '';
const mapEmbedUrl = (GMAPS_KEY && GMAPS_PLACE_PRODEJ)
  ? `https://www.google.com/maps/embed/v1/place?key=${GMAPS_KEY}&q=place_id:${GMAPS_PLACE_PRODEJ}&zoom=16&language=cs&region=CZ`
  : 'https://maps.google.com/maps?q=%C4%8Eablicka+553%2F2%2C+182+00+Praha+8&output=embed';

// ── Hero z nastavení webu (site_settings) — foto + nadpis + podnadpis, s fallbackem ──
const settingsList = await directusGet<any>('site_settings', { limit: 1, fields: ['*'] }).catch(() => []);
const settings = (settingsList && settingsList[0]) ? settingsList[0] : {};
const heroImg = settings.kontakt_hero_image
  ? directusAsset(settings.kontakt_hero_image, { width: 2000, format: 'webp', quality: 80 })
  : '';
const heroTitle = settings.kontakt_hero_title || 'Najdete nás v Praze-Ďáblicích';
const heroSubtitle = settings.kontakt_hero_subtitle || 'Prodej, servis i příslušenství pod jednou střechou. Stavte se osobně, nebo nám napište — odpovídáme do 24 hodin.';

// ── Fakturační údaje — obě firmy (výpis z OR, Městský soud v Praze) ──
const COMPANIES = [
  { name: 'SFR Motor s.r.o.', role: 'Prodej vozů', ico: '08263523', spis: 'C 315925, Městský soud v Praze', seat: 'Petrská 1426/1, Nové Město, 110 00 Praha 1' },
  { name: 'SFR Motor servis s.r.o.', role: 'Servis a náhradní díly', ico: '08263370', spis: 'C 315922, Městský soud v Praze', seat: 'Petrská 1426/1, Nové Město, 110 00 Praha 1' },
];
---

<BaseLayout title="Kontakt" description="Kontaktujte SFR Motor — autorizovaný dealer v Praze-Ďáblicích. Prodej, servis, doplňkové služby.">
  <JsonLd data={[autoDealerSchema(googleReviews.prodej), autoRepairSchema(googleReviews.servis)]} />
  <Breadcrumbs items={[{ label: 'Kontakt' }]} />
  {heroImg ? (
    <section class="phero phero-photo" style={`background-image: linear-gradient(rgba(15,15,18,0.55), rgba(15,15,18,0.45)), url('${heroImg}')`} data-screen-label="01 Hero">
      <div class="container">
        <div class="section-eyebrow light">Kontakt</div>
        <h1>{heroTitle}</h1>
        <p class="lead">{heroSubtitle}</p>
      </div>
    </section>
  ) : (
    <section class="phero" data-screen-label="01 Hero">
      <div class="container">
        <div class="section-eyebrow">Kontakt</div>
        <h1>{heroTitle}</h1>
        <p class="lead">{heroSubtitle}</p>
      </div>
    </section>
  )}

  <section class="kinfo" data-screen-label="02 Adresa">
    <div class="container kinfo-grid">
      <div class="kinfo-map">
        <iframe
          src={mapEmbedUrl}
          width="100%"
          height="100%"
          style="border:0; min-height:420px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa SFR Motor"
        ></iframe>
      </div>
      <div class="kinfo-card">
        <h3>{branchName}</h3>
        <div class="kinfo-row">
          <span class="icbox">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <div>
            <div class="lab">Adresa</div>
            <div class="val">{branchAddress}<br />{branchPostal} {branchCity}</div>
          </div>
        </div>
        <div class="kinfo-row">
          <span class="icbox">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.86 19.86 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </span>
          <div>
            <div class="lab">Telefon</div>
            <div class="val">
              <a href="tel:+420771235458">+420 771 235 458</a> · prodej<br />
              <a href="tel:+420771259323">+420 771 259 323</a> · servis
            </div>
          </div>
        </div>
        <div class="kinfo-row">
          <span class="icbox">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2 6 12 13 22 6"/></svg>
          </span>
          <div>
            <div class="lab">E-mail</div>
            <div class="val"><a href="mailto:info@sfr-motor.cz">info@sfr-motor.cz</a></div>
          </div>
        </div>
        <div class="kinfo-row" id="otevreni">
          <span class="icbox">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <div>
            <div class="lab">Otevírací doba</div>
            <div class="val">Prodej: Po–Pá 8:00–18:00 (Čt do 20:00) · So–Ne zavřeno<br />Servis: Po–Pá 8:00–17:00 · So–Ne zavřeno</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="formpanel" id="poptavka" data-screen-label="05 Form">
    <div class="container formpanel-grid">
      <div>
        <div class="section-eyebrow">Napište nám</div>
        <h2>Máte dotaz nebo poptávku?</h2>
        <p class="lead">Vyplňte krátký formulář — ozveme se do 24 hodin. Nebo zvolte konkrétního prodejce / technika výše a napište mu přímo.</p>
      </div>
      <form class="fcard" data-lead-form data-form-type="contact" data-context-aware>
        <h3>Kontaktní formulář</h3>
        <div class="fgrid">
          <div class="field full">
            <label>Vaše jméno <span class="req">*</span></label>
            <input type="text" name="customer_name" required minlength="2" maxlength="200" />
          </div>
          <div class="field">
            <label>E-mail <span class="req">*</span></label>
            <input type="email" name="customer_email" required maxlength="200" />
          </div>
          <div class="field">
            <label>Telefon</label>
            <input type="tel" name="customer_phone" maxlength="50" pattern="[+0-9\s\-()]+" />
          </div>
          <div class="field full">
            <label>Téma zprávy</label>
            <input type="text" name="subject" placeholder="Např. zájem o Torres EVX" maxlength="200" />
          </div>
          <div class="field full">
            <label>Zpráva (nepovinné)</label>
            <textarea name="message" maxlength="2000"></textarea>
          </div>
        </div>
        <input type="text" name="_hp_website" tabindex="-1" autocomplete="off" class="honeypot" />
        <TurnstileWidget />
        <label class="check">
          <input type="checkbox" required />
          Souhlasím se zpracováním osobních údajů dle <a href="/informace/ochrana-udaju">GDPR</a>
        </label>
        <button class="btn btn-primary" type="submit">Odeslat zprávu</button>
        <div class="lead-status" data-lead-status></div>
      </form>
    </div>
  </section>

  <!-- ===== FAKTURAČNÍ ÚDAJE (obě firmy) ===== -->
  <section class="legal-panel" data-screen-label="06 Firmy">
    <div class="container">
      <div class="section-eyebrow">Fakturační údaje</div>
      <h2>Naše společnosti</h2>
      <div class="legal-grid">
        {COMPANIES.map((c) => (
          <div class="legal-card">
            <div class="legal-role">{c.role}</div>
            <h3>{c.name}</h3>
            <dl class="legal-dl">
              <div><dt>IČO</dt><dd>{c.ico}</dd></div>
              <div><dt>Sídlo</dt><dd>{c.seat}</dd></div>
              <div><dt>Zápis v OR</dt><dd>{c.spis}</dd></div>
            </dl>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="team-v2" data-screen-label="03 Tym">
    <div class="container">
      <div class="team-intro">
        <div class="section-eyebrow">Náš tým</div>
        <h2>Komu se ozvete</h2>
        <p class="lead">Jsme malý sehraný tým. Najděte si svou kontaktní osobu — telefon a e-mail vedou přímo na konkrétního kolegu.</p>
      </div>

      {TEAM_BLOCKS.map((block) => {
        const n = block.people.length;
        const label = n === 1 ? 'osoba' : n > 4 ? 'osob' : 'osoby';
        return (
          <div class="team-block-v2">
            <div class="team-head-v2">
              <h3>{block.title}</h3>
              <span class="team-count">{n} {label}</span>
            </div>
            <div class="team-grid-v2">
              {block.people.map((p) => <TeamCard person={p} tagLabel={block.tag} tagClass={block.tagClass} />)}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ===== GOOGLE RECENZE — full list před formem ===== -->
  <section class="reviews-section" data-screen-label="04 Recenze">
    <div class="container">
      <div class="section-eyebrow">⭐ Google hodnocení</div>
      <GoogleReviews business="prodej" layout="full" headingText="Hodnocení od zákazníků" />
    </div>
  </section>


  <script>
    // Parse URL params (?form=test_drive&model=korando&brand=kgm)
    // Pre-fill form-type + uloží kontext do dataset attributů pro payload
    (function () {
      const params = new URLSearchParams(window.location.search);
      const formType = params.get('form');
      const model = params.get('model');
      const brand = params.get('brand');
      const vehicle = params.get('vehicle');

      const form = document.querySelector('[data-context-aware]');
      if (!form) return;

      const ALLOWED = ['contact', 'test_drive', 'service', 'stock_inquiry', 'model_inquiry', 'akce', 'prislusenstvi'];
      if (formType && ALLOWED.includes(formType)) form.dataset.formType = formType;
      if (model) form.dataset.modelSlug = model;
      if (brand) form.dataset.brandSlug = brand;
      if (vehicle) form.dataset.vehicleVin = vehicle;

      // Update form title + subject + message prefill (UX hint).
      // Texty pre-fill přesně reflektují textaci CTA tlačítka, ze kterého uživatel přišel
      // — když klikl "Testovací jízda", titulek/zpráva mluví o testovací jízdě. Atd.
      const titleEl = form.querySelector('h3');
      const subjectInput = form.querySelector('input[name="subject"]');
      const messageTextarea = form.querySelector('textarea[name="message"]');
      const modelUC = model ? model.toUpperCase() : '';
      const BRAND_NAMES = { kgm: 'KGM', 'omoda-jaecoo': 'OMODA & JAECOO', farizon: 'Farizon' };
      const brandName = brand ? (BRAND_NAMES[brand] || brand.toUpperCase()) : '';
      // Popisek vozu: konkrétní model > značka > obecně (ať dealer pozná původ poptávky)
      const vozLabel = model ? `vůz ${modelUC}` : (brandName ? `vůz značky ${brandName}` : '');
      const PRESETS = {
        test_drive: {
          title: model ? `Testovací jízda — ${modelUC}` : (brandName ? `Testovací jízda — ${brandName}` : 'Žádost o testovací jízdu'),
          subject: model ? `Žádost o testovací jízdu (${model})` : (brandName ? `Žádost o testovací jízdu — ${brandName}` : 'Žádost o testovací jízdu'),
          message: vozLabel
            ? `Rád/a bych si vyzkoušel/a ${vozLabel} na testovací jízdě. Prosím o kontakt pro domluvení termínu.`
            : 'Rád/a bych si vyzkoušel/a některý z vašich vozů na testovací jízdě. Prosím o kontakt.',
        },
        model_inquiry: {
          title: model ? `Poptávka vozu — ${modelUC}` : (brandName ? `Poptávka — ${brandName}` : 'Poptávka vozu'),
          subject: model ? `Poptávka vozu ${model}` : (brandName ? `Poptávka vozů — ${brandName}` : 'Poptávka vozu'),
          message: model
            ? `Mám zájem o model ${model}. Prosím o zaslání aktuální nabídky a bližších informací.`
            : (brandName
              ? `Mám zájem o vozy značky ${brandName}. Prosím o zaslání aktuální nabídky a bližších informací.`
              : 'Mám zájem o váš vůz. Prosím o zaslání aktuální nabídky.'),
        },
        akce: {
          title: model ? `Poptávka — akce ${modelUC}` : (brandName ? `Akce — ${brandName}` : 'Poptávka — aktuální akce'),
          subject: model ? `Poptávka — akce ${model}` : (brandName ? `Akce — ${brandName}` : 'Poptávka — aktuální akce'),
          message: model
            ? `Mám zájem o aktuální akci na vůz ${model}. Prosím o zaslání bližších informací o akčních podmínkách.`
            : (brandName
              ? `Mám zájem o aktuální akce na vozy ${brandName}. Prosím o zaslání bližších informací.`
              : 'Mám zájem o vaše aktuální akce. Prosím o zaslání bližších informací.'),
        },
        stock_inquiry: {
          title: vehicle ? `Poptávka vozu (VIN ${vehicle})` : 'Poptávka skladového vozu',
          subject: vehicle ? `Poptávka skladového vozu (VIN ${vehicle})` : 'Poptávka skladového vozu',
          message: vehicle
            ? `Mám zájem o konkrétní vůz s VIN ${vehicle}. Prosím o bližší informace a dostupnost.`
            : 'Hledám konkrétní vůz ve vašem skladu. Prosím o kontakt s aktuální nabídkou.',
        },
        service: {
          title: 'Objednávka servisu',
          subject: 'Objednávka servisu',
          message: 'Chtěl/a bych objednat servis. Prosím o kontakt pro domluvení termínu.',
        },
        prislusenstvi: {
          title: 'Originální příslušenství',
          subject: 'Mám zájem o originální příslušenství',
          message: 'Mám zájem o originální příslušenství (střešní boxy, nosiče kol, koberce, alu kola apod.). Prosím o nabídku a dostupnost.',
        },
      };
      const preset = PRESETS[formType];
      if (preset) {
        if (titleEl) titleEl.textContent = preset.title;
        if (subjectInput instanceof HTMLInputElement && !subjectInput.value) {
          subjectInput.value = preset.subject;
        }
        if (messageTextarea instanceof HTMLTextAreaElement && !messageTextarea.value) {
          messageTextarea.value = preset.message;
        }
      }

      // Když uživatel přišel s kontextem (z tlačítka na /model nebo /sklad),
      // odscrolluj rovnou k formuláři místo zůstat nahoře na stránce.
      if (formType || model || vehicle) {
        const panel = form.closest('.formpanel');
        if (panel) requestAnimationFrame(() =>
          setTimeout(() => panel.scrollIntoView({ behavior: 'smooth', block: 'start' }), 80)
        );
      }
    })();

    document.querySelectorAll('[data-lead-form]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const statusEl = form.querySelector('[data-lead-status]');
        const submitBtn = form.querySelector('button[type=submit]');
        if (statusEl) statusEl.textContent = 'Odesílám...';

        const data = new FormData(form);
        const turnstileInput = form.querySelector('input[name="cf-turnstile-response"]');
        const subjectVal = data.get('subject');
        const messageVal = data.get('message');
        // Pokud uživatel zadal téma + zprávu, spojíme je
        const combinedMessage = subjectVal && messageVal ? subjectVal + '\n\n' + messageVal
                              : subjectVal ? subjectVal
                              : messageVal;
        const payload = {
          form_type: form.dataset.formType || 'contact',
          customer_name: data.get('customer_name'),
          customer_email: data.get('customer_email'),
          customer_phone: data.get('customer_phone'),
          message: combinedMessage,
          source_page: window.location.pathname,
          source_url: window.location.href,
          source_model_slug: form.dataset.modelSlug || undefined,
          source_vehicle_vin: form.dataset.vehicleVin || undefined,
          _hp_website: data.get('_hp_website') || '',
          turnstile_token: turnstileInput ? turnstileInput.value : '',
        };
        try {
          const res = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const result = await res.json().catch(() => ({ ok: false, error: 'Network error' }));
          if (!res.ok || !result.ok) throw new Error(result.error || ('HTTP ' + res.status));
          if (statusEl) { statusEl.textContent = '✓ Děkujeme! Brzy se vám ozveme.'; statusEl.style.color = 'var(--ok)'; }
          if (submitBtn) submitBtn.disabled = true;
          if (window.dataLayer) window.dataLayer.push({ event: 'generate_lead', form_name: payload.form_type });
        } catch (err) {
          if (statusEl) {
            statusEl.textContent = err.message
              ? '✗ ' + err.message
              : 'Něco se nepodařilo. Zkuste znovu, nebo zavolejte +420 771 235 458.';
            statusEl.style.color = 'var(--danger)';
          }
        }
      });
    });
  </script>

  <style>
    .lead-status { min-height: 24px; font-size: 13px; margin-top: 8px; }

    /* ===== TEAM V2 — Kontakt page redesign ===== */
    .team-v2 {
      padding: var(--section-pad) 0;
      background: var(--bg-soft);
    }
    .team-intro {
      max-width: 64ch;
      margin: 0 0 28px;
      text-align: left;
    }
    .team-intro h2 {
      font-family: var(--font-display);
      font-size: clamp(28px, 3.2vw, 40px);
      font-weight: 700;
      margin: 4px 0 12px;
      letter-spacing: -0.01em;
    }
    .team-intro .lead {
      color: var(--text-muted);
      font-size: 16px;
      line-height: 1.6;
      margin: 0;
    }

    .team-block-v2 {
      margin-bottom: 28px;
    }
    .team-block-v2:last-child { margin-bottom: 0; }
    .team-head-v2 {
      display: flex;
      align-items: baseline;
      gap: 14px;
      margin-bottom: 12px;
      padding-bottom: 8px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }
    .team-head-v2 h3 {
      font-family: var(--font-display);
      font-size: clamp(20px, 2.2vw, 26px);
      font-weight: 600;
      margin: 0;
      letter-spacing: -0.005em;
    }
    .team-count {
      font-size: 13px;
      color: var(--text-muted);
      font-weight: 500;
    }

    .team-grid-v2 {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(168px, 1fr));
      gap: 12px;
    }
    @media (max-width: 640px) {
      .team-v2 { padding: 56px 0 72px; }
      .team-grid-v2 { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
    }

    /* ===== Hero foto (kontakt) ===== */
    .phero-photo { background-size: cover; background-position: center; min-height: 580px; display: flex; flex-direction: column; justify-content: center; padding: 64px 0; }
    .phero-photo .container { width: 100%; }  /* aby text seděl vlevo jako ostatní hero (ne vycentrovaný flexem) */
    .phero-photo h1 { color: #fff; }
    .phero-photo .lead { color: rgba(255,255,255,0.92); }
    .phero-photo .section-eyebrow.light { color: rgba(255,255,255,0.85); }

    /* ===== Fakturační údaje (obě firmy) ===== */
    .legal-panel { padding: var(--section-pad) 0; background: var(--bg); }
    .legal-panel h2 {
      font-family: var(--font-display); font-weight: 600;
      font-size: clamp(26px, 3vw, 38px); letter-spacing: -0.02em; margin: 6px 0 28px;
    }
    .legal-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
    .legal-card {
      background: #fff; border: 1px solid var(--line);
