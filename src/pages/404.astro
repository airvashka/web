---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Stránka nenalezena" description="Hledaná stránka neexistuje. Zkuste se vrátit na úvodní stránku.">
  <section class="container" style="padding-block: clamp(80px, 12vw, 160px); text-align: center;">
    <p class="eyebrow eyebrow-accent">404</p>
    <h1 style="margin-block: 12px 16px;">Stránka neexistuje</h1>
    <p class="lead" style="margin-inline: auto; max-width: 50ch;">
      Adresa kterou hledáte se možná přesunula nebo byla smazána.
    </p>
    <div style="margin-top: 28px; display: inline-flex; gap: 12px; flex-wrap: wrap; justify-content: center;">
      <a href="/" class="btn btn--primary">Na úvod</a>
      <a href="/sklad" class="btn btn--ghost">Skladové vozy</a>
    </div>
  </section>
</BaseLayout>
