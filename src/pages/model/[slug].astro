      <div class="gallery-modal-image" data-gallery-image>
        {galleryFileIds.map((id, i) => (
          <div class="gallery-modal-slide" data-slide-index={i} hidden={i !== 0}>
            <DirectusImage src={id} alt={`${rawModel.name} — foto ${i + 1}`} aspectRatio="auto" widths={[1200, 2000]} loading="eager" />
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- ===== BARVY (vizuální výběr konkrétní specifikace) ===== -->
  {hasConfigurator && (
    <section class="config" id="barvy">
      <div class="container">
        <div class="config-head">
          <div class="section-eyebrow">Barevné kombinace</div>
          <h2 class="section-title" style="margin-bottom: 0;">Barvy</h2>
        </div>

        {colorOptions.length > 0 && (
          <div class="colors-block">
            <div class="colors-block-head">
              <h3>Exteriér</h3>
              <span class="count">{
                colorOptions.length === 1 ? '1 barva'
                : colorOptions.length < 5 ? `${colorOptions.length} barvy`
                : `${colorOptions.length} barev`
              }</span>
            </div>

            {/* KGM-style configurator — velká fotka + selector POD fotkou */}
            <div class="cs-wrap" data-cs-stage>
              <div class="cs-stage">
                {colorOptions.map((c, i) => {
                  const photoId = c.photo ?? c.photo_file ?? null;
                  const hex = (c.hex ?? '').trim();
                  return (
                    <div class={`cs-photo${i === 0 ? ' is-active' : ''}`} data-idx={i}>
                      {photoId ? (
                        <DirectusImage src={photoId} alt={c.name ?? ''} aspectRatio="21/9" widths={[800, 1400, 2000]} loading={i === 0 ? 'eager' : 'lazy'} />
                      ) : (
                        <span class="cs-photo-fallback" style={hex ? `background:${hex}` : ''}></span>
