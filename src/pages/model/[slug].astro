  {/* Tech grid sekce přesunuta hned za Představení — viz výše. */}
  {/* Galerie a Modal byly přesunuty nahoru, před Barvy (lepší user flow). */}

  <!-- ===== TRIMS / CENY A VÝBAVY ===== -->
  {trims.length > 0 && (
    <section class="section" id="ceny" style="background: var(--bg-soft);">
      <div class="container">
        <div class="section-eyebrow">Ceny a výbavové stupně</div>
        <h2 class="section-title">Dostupné výbavové stupně a pakety</h2>
        {(() => {
          // Pre-compute flat features set per trim (lowercased + trimmed for diff)
          const flatPerTrim = trims.map((t) => {
            const groups = getGroupedFeatures((t as any).features);
            const flat: string[] = [];
            for (const g of groups) for (const item of g.items) flat.push(item);
            return flat;
          });
          const normSet = (arr: string[]) => new Set(arr.map((s) => s.trim().toLowerCase()));
          return (
            <div class={`trims trims-${trims.length}`}>
              {trims.map((t, i) => {
                // Manuální highlight: trim.is_highlighted (Directus toggle).
                // Backwards compat: pokud žádný trim nemá is_highlighted nastaveno
                // a je víc než 1 trim, zvýrazni poslední (původní auto chování).
                const anyHighlighted = trims.some((x) => (x as any).is_highlighted);
                const isRecommended = anyHighlighted
                  ? !!(t as any).is_highlighted
                  : (i === trims.length - 1 && trims.length > 1);
                const highlightLabel = ((t as any).highlight_label || '').trim() || 'Doporučujeme';
                const cls = isRecommended ? 'trim dark' : 'trim light';
                const price = t.promo_price ?? t.list_price ?? 0;
                const trimFeatureCount = countFeatures((t as any).features);
                const flat = flatPerTrim[i];

                let teaserLabel = 'Z výbavy například:';
                let teaserItems: string[] = [];
                let extraCount = 0;

                if (i === 0) {
                  // První trim → top 5 features
                  teaserItems = flat.slice(0, 5);
                } else {
                  // Vyšší trim → diff oproti předchozímu
                  const prevSet = normSet(flatPerTrim[i - 1]);
                  const diff = flat.filter((f) => !prevSet.has(f.trim().toLowerCase()));
                  teaserLabel = `Navíc oproti ${trims[i - 1].name}:`;
                  teaserItems = diff.slice(0, 5);
                  extraCount = Math.max(0, diff.length - teaserItems.length);
                }

                const highlightNote = isRecommended ? ((t as any).highlight_note || '').trim() : '';
                return (
                  <div class={cls}>
                    {isRecommended && <div class="trim-badge">{highlightLabel}</div>}
                    {highlightNote && <div class="trim-highlight-note">{highlightNote}</div>}
                    <div class="trim-name">{t.name}</div>
                    <div class="trim-price">{price.toLocaleString('cs-CZ')} Kč</div>
                    <div class="trim-teaser">
                      {teaserItems.length > 0 ? (
                        <>
                          <div class="trim-teaser-label">{teaserLabel}</div>
                          <ul class="trim-list">
                            {teaserItems.map((f) => (
                              <li>
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>{f}</span>
                              </li>
                            ))}
                          </ul>
                          {i === 0 ? (
                            <div class="trim-teaser-count">+ celkem {trimFeatureCount} prvků výbavy</div>
                          ) : extraCount > 0 ? (
                            <div class="trim-teaser-count">+ dalších {extraCount} novinek (celkem {trimFeatureCount} prvků)</div>
                          ) : (
                            <div class="trim-teaser-count">celkem {trimFeatureCount} prvků výbavy</div>
                          )}
                        </>
                      ) : (
                        <div class="trim-feature-empty">Specifikace doplníme.</div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          );
        })()}

        {/* ===== Doplňkové pakety — hned pod trim kartami, bez orange eyebrow ===== */}
        {optionPackages.length > 0 && (
          <div class="packages-block" style="margin-top: 56px;">
