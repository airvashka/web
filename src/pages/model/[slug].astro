  {/* ===== CO UMÍ <MODEL> — wrap Technologie / Bezpečnost / Komfort do jedné dark section ===== */}
  {(() => {
    const modelHighlights = Array.isArray((rawModel as any).highlights) ? (rawModel as any).highlights : [];
    if (modelHighlights.length === 0) return null;

    const CATEGORIES = [
      { key: 'technologie', label: 'Technologie' },
      { key: 'bezpecnost', label: 'Bezpečnost' },
      { key: 'komfort',    label: 'Komfort' },
    ];

    const sorted = [...modelHighlights].sort((a: any, b: any) => (a.sort ?? 0) - (b.sort ?? 0));

    const groups = CATEGORIES
      .map((cat) => ({
        ...cat,
        items: sorted.filter((h: any) => (h.category ?? 'technologie') === cat.key).slice(0, 4),
      }))
      .filter((g) => g.items.length > 0);

    if (groups.length === 0) return null;

    return (
      <section class="section tech-section-dark" id="tech-technologie">
        <div class="container">
          <div class="section-eyebrow">Co umí {rawModel.name}</div>

