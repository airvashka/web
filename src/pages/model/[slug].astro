---
import BaseLayout from '@layouts/BaseLayout.astro';
import DirectusImage from '@components/DirectusImage.astro';
import { directusGet } from '@lib/directus';
import type { Brand, Model, ModelYear, TrimLevel } from '@lib/types';

/* ============================================================
   MODEL DETAIL — 1:1 podle _design-draft/torres-evx.jsx
   Sections: ModelHero · SubNav · Intro · (config TODO) · Tech · Trims · Stock · Tdata · CTA banner
   ============================================================ */

export async function getStaticPaths() {
  const models = await directusGet<Model>('models', {
    fields: ['slug'],
    filter: { status: { _eq: 'published' } },
  });
  return models.map((m) => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;

type ModelRaw = Model & { brand?: number | null; sub_brand?: number | null; hero_image?: string; gallery?: Array<{ directus_files_id: string }> };

const rawModels = await directusGet<ModelRaw>('models', {
  filter: { slug: { _eq: slug } },
  limit: 1,
  fields: ['*', 'gallery.directus_files_id'],
});
const rawModel = rawModels[0];
if (!rawModel) return Astro.redirect('/404');

const brands = rawModel.brand
  ? await directusGet<Brand>('brands', { filter: { id: { _eq: rawModel.brand } }, limit: 1 })
  : [];
const brand = brands[0];
if (!brand) return Astro.redirect('/404');

const modelYears = await directusGet<ModelYear>('model_years', {
  filter: { model: { _eq: rawModel.id }, status: { _eq: 'published' } },
  sort: ['-year'],
  fields: ['*'],
});
const latestYear = modelYears[0];

const trims: TrimLevel[] = latestYear
  ? await directusGet<TrimLevel>('trim_levels', {
      filter: { model_year: { _eq: latestYear.id }, status: { _eq: 'published' } },
      sort: ['sort'],
      fields: ['*'],
    })
  : [];

// Skladové vozy tohoto modelu
const stockOfModel = await directusGet<any>('stock_vehicles', {
  filter: { model: { _eq: rawModel.id }, status: { _eq: 'published' }, availability: { _in: ['in_stock', 'on_the_way'] } },
  sort: ['-listed_at'],
  limit: 3,
  fields: [
    'id', 'condition', 'km', 'list_price', 'promo_price', 'trim_level_snapshot',
    'photos.directus_files_id', 'model_year.year', 'color_code',
  ],
});

// Mapování
const fuelLabels: Record<string, string> = {
  petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro',
};

// Technická data — Directus může držet buď array of {label,value} nebo object
type TechRow = [string, string];
let tdataRows: TechRow[] = [];
if (latestYear?.technical_data) {
  const td: any = latestYear.technical_data;
  if (Array.isArray(td)) {
    tdataRows = td.map((r: any) =>
      Array.isArray(r) ? (r as TechRow) : [r.label ?? r.k ?? '', String(r.value ?? r.v ?? '')]
    ).filter(([k]) => !!k);
  } else if (typeof td === 'object') {
    tdataRows = Object.entries(td).map(([k, v]) => [k, String(v)]);
  }
}

// Hero stats — vyber 4 nejdůležitější (TODO: chytřejší extrakce)
const STAT_KEYS = ['Výkon', 'Dojezd', 'Spotřeba', 'Zrychlení 0-100', 'Záruka', 'Točivý moment', 'Spotřeba (komb.)'];
const heroStats = STAT_KEYS
  .map((kw) => {
    const found = tdataRows.find(([k]) => k.toLowerCase().includes(kw.toLowerCase()));
    return found ? { lab: found[0], val: found[1] } : null;
  })
  .filter(Boolean)
  .slice(0, 4) as Array<{ lab: string; val: string }>;

const priceFrom = rawModel.price_from ? `${rawModel.price_from.toLocaleString('cs-CZ')} Kč` : '—';
const fuelTagClass: Record<string, string> = {
  petrol: 'benzin', diesel: 'diesel', hybrid: 'hybrid', phev: 'phev', ev: 'elektro',
};
const fuelKey = (rawModel as any).fuel_type ?? '';
const badgeText = fuelKey === 'ev' ? 'Elektrické SUV' : fuelKey === 'hybrid' || fuelKey === 'phev' ? 'Hybridní SUV' : 'SUV';

// Intro foto = první z gallery, nebo hero_image
const galleryImages: string[] = (rawModel.gallery ?? []).map((g) => g?.directus_files_id).filter(Boolean) as string[];
const introImg = galleryImages[0] ?? rawModel.hero_image;

// Description rozdělené na odstavce
const introCopy = (rawModel.description ?? '').split(/\n\s*\n/).filter(Boolean);
---

<BaseLayout
  title={`${brand.name} ${rawModel.name}`}
  description={rawModel.tagline ?? `${brand.name} ${rawModel.name} u SFR Motor — autorizovaný dealer v Praze-Ďáblicích.`}
>
  <!-- ===== MODEL HERO (dark, full-bleed) ===== -->
  <section class="mhero" data-screen-label="01 Hero">
    <div class="mhero-bg">
      {rawModel.hero_image && <DirectusImage src={rawModel.hero_image} alt={`${brand.name} ${rawModel.name}`} aspectRatio="auto" />}
    </div>
    <div class="container mhero-inner">
      <div class="mhero-eyebrow">
        <span>{brand.name}</span>
        <span class="sep">·</span>
        <span>{badgeText}</span>
      </div>
      <h1 class="mhero-title">{rawModel.name}</h1>
      <p class="mhero-tagline">{rawModel.tagline ?? ''}</p>
    </div>
    {heroStats.length > 0 && (
      <div class="mhero-stats">
        <div class="container mhero-stats-inner">
          {heroStats.map((s) => (
            <div class="mstat">
              <div class="lab">{s.lab}</div>
              <div class="val">{s.val}</div>
            </div>
          ))}
          <div class="mhero-price">Cena od <strong>{priceFrom}</strong></div>
          <a class="btn btn-primary" href="/kontakt">Testovací jízda</a>
        </div>
      </div>
    )}
  </section>

  <!-- ===== SUBNAV ===== -->
  <div class="subnav">
    <div class="container subnav-inner">
      <a class="subnav-link is-active" href="#predstaveni">Představení</a>
      <span class="subnav-sep">·</span>
      <a class="subnav-link" href="#technologie">Technologie</a>
      <span class="subnav-sep">·</span>
      <a class="subnav-link" href="#ceny">Ceny a výbavy</a>
      <span class="subnav-sep">·</span>
      <a class="subnav-link" href="#skladem">Skladem</a>
      <span class="subnav-sep">·</span>
      <a class="subnav-link" href="#data">Technické údaje</a>
    </div>
  </div>

  <!-- ===== INTRO ===== -->
  <section class="section" id="predstaveni">
    <div class="container">
      <div class="intro">
        <div class="intro-image">
          {introImg && <DirectusImage src={introImg} alt={`${rawModel.name} interiér`} aspectRatio="1/1" />}
        </div>
        <div class="intro-copy">
          <div class="section-eyebrow">Představení</div>
          <h2>{rawModel.tagline ?? `${rawModel.name} — moderní SUV`}</h2>
          {introCopy.length > 0 ? (
            introCopy.map((p) => <p>{p}</p>)
          ) : (
            <p>{rawModel.description ?? `${brand.name} ${rawModel.name} — model dostupný u SFR Motor.`}</p>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TECH GRID (placeholder pro highlights) ===== -->
  {trims.length > 0 && (
    <section class="section" id="technologie">
      <div class="container">
        <div class="section-eyebrow">Technologie</div>
        <h2 class="section-title">Co umí {rawModel.name}</h2>
        <div class="tech-grid">
          {/* TODO: dedicated model_highlights collection. Pro teď extrahujeme top 4 features z prvního trimu */}
          {(trims[0]?.features ?? []).slice(0, 4).map((feat) => (
            <div class="tech-card">
              <div class="pic">
                {/* TODO: image per highlight */}
              </div>
              <div class="tech-card-body">
                <div class="t">{feat}</div>
                <div class="s">Součást základní výbavy</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== TRIMS / CENY A VÝBAVY ===== -->
  {trims.length > 0 && (
    <section class="section" id="ceny" style="background: var(--bg-soft);">
      <div class="container">
        <div class="section-eyebrow">Ceny a výbavy</div>
        <h2 class="section-title">{trims.length === 1 ? 'Výbava' : `${trims.length} výbavové stupně`}, jasná cena.</h2>
        <div class="trims">
          {trims.slice(0, 2).map((t, i) => {
            const isRecommended = i === trims.length - 1; // poslední (nejvyšší) trim = doporučujeme
            const cls = isRecommended ? 'trim dark' : 'trim light';
            const price = t.promo_price ?? t.list_price ?? 0;
            return (
              <div class={cls}>
                {isRecommended && <div class="trim-badge">Doporučujeme</div>}
                <div class="trim-name">{t.name}{i === 0 ? ' — Základní výbava' : ' — Vyšší výbava'}</div>
                <div class="trim-price">{price.toLocaleString('cs-CZ')} Kč</div>
                <ul class="trim-list">
                  {(t.features ?? []).slice(0, 8).map((f) => (
                    <li>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
                <a class="btn" href="/kontakt">
                  Konfigurovat
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ===== STOCK (3 cars of this model) ===== -->
  {stockOfModel.length > 0 && (
    <section class="section" id="skladem">
      <div class="container">
        <div class="section-head-row">
          <div class="section-eyebrow-inline">
            <span>Ihned k odběru</span>
            <span class="muted">— {rawModel.name} skladem</span>
          </div>
          <a class="section-link" href={`/sklad?model=${rawModel.slug}`}>
            Všechny {rawModel.name} skladem
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="cars">
          {stockOfModel.map((v: any) => {
            const photoId = v.photos?.[0]?.directus_files_id;
            const trim = v.trim_level_snapshot?.name ?? '';
            const carYear = v.model_year?.year ?? '';
            const meta = `${(v.km ?? 0).toLocaleString('cs-CZ')} km · ${carYear}`;
            const price = v.promo_price ?? v.list_price;
            return (
              <article class="car-card">
                <div class="pic">
                  <span class="tag">Skladem</span>
                  {photoId && <DirectusImage src={photoId} alt={`${rawModel.name} ${trim}`} aspectRatio="4/3" />}
                </div>
                <div class="car-body">
                  <div class="car-name">{rawModel.name} {trim}</div>
                  <div class="car-meta">{meta}</div>
                  <hr />
                  <div class="car-price">{price ? `${price.toLocaleString('cs-CZ')} Kč` : '—'}</div>
                  <a class="btn btn-outline" style="padding: 12px 20px; font-size: 12px;" href={`/sklad/${v.id}`}>
                    Detail vozu
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ===== TECHNICKÉ ÚDAJE ===== -->
  {tdataRows.length > 0 && (
    <section class="section" id="data">
      <div class="container">
        <div class="section-eyebrow">Technické údaje</div>
        <h2 class="section-title">Specifikace</h2>
        <div class="tdata">
          {tdataRows.map(([k, v]) => (
            <div class="tdata-row">
              <div class="k">{k}</div>
              <div class="v">{v}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== CLOSING CTA BANNER ===== -->
  <section class="cta-banner">
    <div class="cta-banner-bg">
      {rawModel.hero_image && <DirectusImage src={rawModel.hero_image} alt="" aspectRatio="auto" />}
    </div>
    <div class="container cta-banner-inner">
      <h2>Připraveni na zkušební jízdu {rawModel.name}?</h2>
      <p>Rezervujte si testovací jízdu a zažijte vůz na vlastní kůži.</p>
      <div class="cta-banner-actions">
        <a class="btn btn-primary" href="/kontakt">
          Testovací jízda
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a class="btn btn-outline" href="/kontakt">Poptat vůz</a>
      </div>
    </div>
  </section>
</BaseLayout>
