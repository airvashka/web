                  );
                })}
              </div>

              <div class="cs-selector">
                <h3 class="cs-name" data-cs-name>{colorOptions[0]?.name ?? ''}</h3>
                <div class="cs-swatches" role="radiogroup" aria-label="Vyberte barvu">
                  {colorOptions.map((c, i) => {
                    const swatchId = (c as any).swatch ?? null;
                    const hex = (c.hex ?? '').trim();
                    return (
                      <button
                        type="button"
