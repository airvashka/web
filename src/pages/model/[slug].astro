---
import BaseLayout from '@layouts/BaseLayout.astro';
import DirectusImage from '@components/DirectusImage.astro';
import VideoStrip from '@components/VideoStrip.astro';
import { directusGet } from '@lib/directus';
import type { Brand, Model, ModelYear, TrimLevel } from '@lib/types';

/* ============================================================
   MODEL DETAIL — 1:1 podle _design-draft/torres-evx.jsx
   Sections: ModelHero · SubNav · Intro · (config TODO) · Tech · Trims · Stock · Tdata · CTA banner
   ============================================================ */

export async function getStaticPaths() {
  const models = await directusGet<Model>('models', {
    fields: ['slug'],
    filter: { status: { _eq: 'published' } },
  });
  return models.map((m) => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;

type ModelRaw = Model & { brand?: number | null; sub_brand?: number | null; hero_image?: string; gallery?: Array<{ directus_files_id: string }> };

const rawModels = await directusGet<ModelRaw>('models', {
  filter: { slug: { _eq: slug } },
  limit: 1,
  fields: ['*', 'gallery.directus_files_id'],
});
const rawModel = rawModels[0];
if (!rawModel) return Astro.redirect('/404');

const brands = rawModel.brand
  ? await directusGet<Brand>('brands', { filter: { id: { _eq: rawModel.brand } }, limit: 1 })
  : [];
const brand = brands[0];
if (!brand) return Astro.redirect('/404');

const modelYears = await directusGet<ModelYear>('model_years', {
  filter: { model: { _eq: rawModel.id }, status: { _eq: 'published' } },
  sort: ['-year'],
  fields: ['*'],
});
const latestYear = modelYears[0];

const trims: TrimLevel[] = latestYear
  ? await directusGet<TrimLevel>('trim_levels', {
      filter: { model_year: { _eq: latestYear.id }, status: { _eq: 'published' } },
      sort: ['sort'],
      fields: ['*'],
    })
  : [];

// Option packages (paketové výbavy) — bez status a sort, collection je nemá
const optionPackages = latestYear
  ? await directusGet<any>('option_packages', {
      filter: { model_year: { _eq: latestYear.id } },
      sort: ['name'],
      fields: ['*'],
    })
  : [];

// Skladové vozy tohoto modelu
const stockOfModel = await directusGet<any>('stock_vehicles', {
  filter: { model: { _eq: rawModel.id }, status: { _eq: 'published' }, availability: { _in: ['in_stock', 'on_the_way'] } },
  sort: ['-listed_at'],
  limit: 3,
  fields: [
    'id', 'condition', 'km', 'list_price', 'promo_price', 'trim_level_snapshot',
    'photos.directus_files_id', 'model_year.year', 'color_code',
  ],
});

// Mapování
const fuelLabels: Record<string, string> = {
  petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro',
};

// Technická data — Directus může držet buď array of {label,value} nebo object
type TechRow = [string, string];
let tdataRows: TechRow[] = [];
if (latestYear?.technical_data) {
  const td: any = latestYear.technical_data;
  if (Array.isArray(td)) {
    tdataRows = td.map((r: any) =>
      Array.isArray(r) ? (r as TechRow) : [r.label ?? r.k ?? '', String(r.value ?? r.v ?? '')]
    ).filter(([k]) => !!k);
  } else if (typeof td === 'object') {
    tdataRows = Object.entries(td).map(([k, v]) => [k, String(v)]);
  }
}

const fuelKey = (rawModel as any).fuel_type ?? '';
const badgeText = fuelKey === 'ev' ? 'Elektrické SUV'
  : fuelKey === 'hybrid' ? 'Hybridní SUV'
  : fuelKey === 'phev' ? 'Plug-in hybrid SUV'
  : fuelKey === 'diesel' ? 'SUV · Diesel'
  : 'SUV';

// ===== Hero stats — extrakce 4 nejdůležitějších s aliasy + jednotky =====
// Najde podle více alternativních klíčů, normalizuje hodnotu (přidá jednotku pokud chybí)
function findStat(aliases: string[], unit?: string): string | null {
  const lowerAliases = aliases.map((a) => a.toLowerCase());
  for (const [k, v] of tdataRows) {
    const lk = k.toLowerCase();
    if (lowerAliases.some((a) => lk.includes(a))) {
      const val = String(v).trim();
      // Přidat jednotku, pokud zatím není v hodnotě
      if (unit && val && !val.includes(unit) && /^[0-9.,\s]+$/.test(val)) {
        return `${val} ${unit}`;
      }
      return val;
    }
  }
  return null;
}

// Fallback záruka per brand (když není v tdata)
const WARRANTY_BY_BRAND: Record<string, string> = {
  kgm: '5 let / 100 000 km',
  'omoda-jaecoo': '7 let / 150 000 km',
  farizon: '7 let / 150 000 km',
};

// Stats per fuel type — různé highlighty pro elektro vs spalovák
type StatDef = { label: string; aliases: string[]; unit?: string };
const STAT_SETS: Record<string, StatDef[]> = {
  petrol: [
    { label: 'Výkon', aliases: ['čistý výkon motoru', 'systémový výkon', 'výkon'], unit: 'kW' },
    { label: 'Točivý moment', aliases: ['maximální točivý moment', 'točivý moment'], unit: 'Nm' },
    { label: 'Spotřeba (komb.)', aliases: ['průměrná spotřeba paliva', 'spotřeba (komb.)', 'spotřeba'], unit: 'l/100 km' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
  diesel: [
    { label: 'Výkon', aliases: ['čistý výkon motoru', 'výkon'], unit: 'kW' },
    { label: 'Točivý moment', aliases: ['maximální točivý moment', 'točivý moment'], unit: 'Nm' },
    { label: 'Spotřeba (komb.)', aliases: ['průměrná spotřeba paliva', 'spotřeba'], unit: 'l/100 km' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
  hybrid: [
    { label: 'Systémový výkon', aliases: ['systémový výkon', 'výkon'], unit: 'kW' },
    { label: 'Spotřeba (komb.)', aliases: ['průměrná spotřeba paliva', 'spotřeba (komb.)', 'spotřeba'], unit: 'l/100 km' },
    { label: 'Emise CO₂', aliases: ['emise co₂', 'emise co2'], unit: 'g/km' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
  phev: [
    { label: 'Systémový výkon', aliases: ['systémový výkon', 'výkon'], unit: 'kW' },
    { label: 'Dojezd EV', aliases: ['dojezd ev', 'dojezd elektro', 'elektrický dojezd'], unit: 'km' },
    { label: 'Spotřeba (komb.)', aliases: ['průměrná spotřeba paliva', 'spotřeba'], unit: 'l/100 km' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
  ev: [
    { label: 'Dojezd WLTP', aliases: ['dojezd wltp', 'dojezd'], unit: 'km' },
    { label: 'Výkon', aliases: ['čistý výkon motoru', 'výkon'], unit: 'kW' },
    { label: 'Zrychlení 0–100', aliases: ['zrychlení 0-100', 'zrychlení 0–100', 'zrychlení'], unit: 's' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
};
const statsForFuel = STAT_SETS[fuelKey] ?? STAT_SETS.petrol;

// Pravidlo: vždy max 3 stats z STAT_SETS a 4. je vždy "Cena od" (pokud existuje).
const heroStats: Array<{ lab: string; val: string }> = [];
for (const def of statsForFuel) {
  let val = findStat(def.aliases, def.unit);
  if (!val && def.label === 'Záruka') val = WARRANTY_BY_BRAND[brand.slug] ?? null;
  if (val) heroStats.push({ lab: def.label, val });
  if (heroStats.length >= 3) break;
}
// Fallback pokud chybí data: doplň palivo + karoserie
if (heroStats.length < 2) {
  const fuelLabel = fuelLabels[fuelKey] ?? '—';
  const bodyType = (rawModel as any).body_type;
  if (fuelLabel !== '—') heroStats.push({ lab: 'Palivo', val: fuelLabel });
  if (bodyType) heroStats.push({ lab: 'Karoserie', val: String(bodyType).toUpperCase() });
}
// Cena od — vždy poslední stat (pokud máme price_from)
if (rawModel.price_from) {
  heroStats.push({ lab: 'Cena od', val: `${rawModel.price_from.toLocaleString('cs-CZ')} Kč` });
}

const priceFrom = rawModel.price_from ? `${rawModel.price_from.toLocaleString('cs-CZ')} Kč` : '—';
const fuelTagClass: Record<string, string> = {
  petrol: 'benzin', diesel: 'diesel', hybrid: 'hybrid', phev: 'phev', ev: 'elektro',
};

// ===== Variant switcher — modely se stejnou base (Torres / Torres HEV / Torres EVX) =====
// TODO: přesunout do Directus jako field `variants_group` na models. Pro teď hardcoded mapping.
const VARIANT_GROUPS: string[][] = [
  // KGM Torres family
  ['torres', 'torres-hev', 'torres-evx'],
  // KGM Actyon family
  ['actyon', 'actyon-hev'],
  // Omoda 5 family (Benzín / Superhybrid / Elektro)
  ['omoda-5', 'omoda-5-shs-h', 'omoda-5-ev'],
  // Omoda 9 family
  ['omoda-9', 'omoda-9-shs'],
  // Jaecoo 5 family (zatím jen 1 — switcher se nezobrazí)
  ['jaecoo-5'],
  // Jaecoo 7 family
  ['jaecoo-7', 'jaecoo-7-shs'],
];
const variantGroup = VARIANT_GROUPS.find((g) => g.includes(slug ?? ''));
let variantModels: Array<{ slug: string; name: string; fuel_type?: string; description?: string }> = [];
if (variantGroup && variantGroup.length > 1) {
  variantModels = await directusGet<any>('models', {
    filter: { slug: { _in: variantGroup }, status: { _eq: 'published' } },
    fields: ['slug', 'name', 'fuel_type', 'tagline'],
  });
  // Seřadit dle pořadí v VARIANT_GROUPS (ICE/HEV/PHEV/EVX/SHS)
  variantModels.sort((a, b) => variantGroup.indexOf(a.slug) - variantGroup.indexOf(b.slug));
}

const variantFuelSub: Record<string, string> = {
  petrol: 'Benzín · spalovací',
  diesel: 'Diesel',
  hybrid: 'Plný hybrid',
  phev: 'Plug-in hybrid',
  ev: 'Elektromobil',
};

// Ostatní modely stejné značky (kromě aktuálního a kromě variant rodiny)
const otherModelsRaw = await directusGet<any>('models', {
  filter: {
    brand: { _eq: brand.id },
    status: { _eq: 'published' },
    slug: { _neq: slug ?? '' },
  },
  fields: ['id', 'slug', 'name', 'tagline', 'price_from', 'fuel_type', 'body_type', 'hero_image'],
  sort: ['sort'],
  limit: 12,
});
const siblingSlugs = new Set(variantGroup ?? []);
const otherModels = otherModelsRaw.filter((m: any) => !siblingSlugs.has(m.slug)).slice(0, 6);

const fuelTagLabel: Record<string, string> = {
  petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro',
};

// Videa modelu (z model.youtube_video_ids field — pokud existuje)
const modelVideoIds: string[] = Array.isArray((rawModel as any).youtube_video_ids)
  ? (rawModel as any).youtube_video_ids
  : [];

// Barvy karoserie + interiéru (z model_year)
type ColorOpt = { code?: string; name?: string; name_en?: string; hex?: string; type?: string; swatch_image?: string; monotone_only?: boolean };
type InteriorOpt = { code?: string; name?: string; material?: string; hex?: string; swatch_image?: string };
const colorOptions: ColorOpt[] = Array.isArray((latestYear as any)?.color_options) ? (latestYear as any).color_options : [];
const interiorOptions: InteriorOpt[] = Array.isArray((latestYear as any)?.interior_options) ? (latestYear as any).interior_options : [];
const hasConfigurator = colorOptions.length > 0 || interiorOptions.length > 0;

// Intro foto = první z gallery, nebo hero_image
const galleryImages: string[] = (rawModel.gallery ?? []).map((g) => g?.directus_files_id).filter(Boolean) as string[];
const introImg = galleryImages[0] ?? rawModel.hero_image;

// Description rozdělené na odstavce
const introCopy = (rawModel.description ?? '').split(/\n\s*\n/).filter(Boolean);
---

<BaseLayout
  title={`${brand.name} ${rawModel.name}`}
  description={rawModel.tagline ?? `${brand.name} ${rawModel.name} u SFR Motor — autorizovaný dealer v Praze-Ďáblicích.`}
>
  <!-- ===== MODEL HERO (dark, full-bleed) ===== -->
  <section class="mhero" data-screen-label="01 Hero">
    <div class="mhero-bg">
      {rawModel.hero_image && <DirectusImage src={rawModel.hero_image} alt={`${brand.name} ${rawModel.name}`} aspectRatio="auto" />}
    </div>
    <div class="container mhero-inner">
      <div class="mhero-eyebrow">
        <span>{brand.name}</span>
        <span class="sep">·</span>
        <span>{badgeText}</span>
      </div>
      <h1 class="mhero-title">{rawModel.name}</h1>
      <p class="mhero-tagline">{rawModel.tagline ?? ''}</p>
    </div>
    {heroStats.length > 0 && (
      <div class="mhero-stats">
        <div class="container mhero-stats-inner">
          {heroStats.map((s) => (
            <div class="mstat">
              <div class="lab">{s.lab}</div>
              <div class="val">{s.val}</div>
            </div>
          ))}
          <div class="mhero-spacer"></div>
          <a class="btn btn-primary" href="/kontakt">Testovací jízda</a>
        </div>
      </div>
    )}
  </section>

  <!-- ===== SUBNAV ===== -->
  <div class="subnav">
    <div class="container subnav-inner">
      <a class="subnav-link is-active" href="#predstaveni">Představení</a>
      {variantModels.length > 1 && (<><span class="subnav-sep">·</span><a class="subnav-link" href="#varianty">Varianty</a></>)}
      {hasConfigurator && (<><span class="subnav-sep">·</span><a class="subnav-link" href="#konfigurator">Konfigurátor</a></>)}
      <span class="subnav-sep">·</span>
      <a class="subnav-link" href="#technologie">Technologie</a>
      <span class="subnav-sep">·</span>
      <a class="subnav-link" href="#ceny">Ceny a výbavy</a>
      <span class="subnav-sep">·</span>
      <a class="subnav-link" href="#skladem">Skladem</a>
      <span class="subnav-sep">·</span>
      <a class="subnav-link" href="#data">Technické údaje</a>
    </div>
  </div>

  <!-- ===== VARIANT SWITCHER ===== -->
  {variantModels.length > 1 && (
    <section class="section tight" id="varianty">
      <div class="container">
        <div class="section-eyebrow">Vyberte si pohon</div>
        <h2 class="section-title" style="margin-bottom: 32px;">{
          variantGroup?.[0] === 'torres' ? 'Torres'
          : variantGroup?.[0] === 'actyon' ? 'Actyon'
          : variantGroup?.[0] === 'omoda-5' ? 'Omoda 5'
          : variantGroup?.[0] === 'omoda-9' ? 'Omoda 9'
          : variantGroup?.[0] === 'jaecoo-7' ? 'Jaecoo 7'
          : rawModel.name
        } {variantModels.length === 3 ? 've třech provedeních' : variantModels.length === 2 ? 've dvou provedeních' : ''}</h2>
        <div class="variants">
          {variantModels.map((vm) => {
            const isActive = vm.slug === slug;
            const fuelType = (vm as any).fuel_type ?? '';
            return (
              <a class={`variant-pill${isActive ? ' is-active' : ''}`} href={`/model/${vm.slug}`}>
                <span class="icbox">
                  {fuelType === 'ev' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
                  {(fuelType === 'hybrid' || fuelType === 'phev') && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-3.3 16.1-9.2 17.04Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>}
                  {(fuelType === 'petrol' || fuelType === 'diesel' || !fuelType) && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="22" x2="15" y2="22"/><line x1="4" y1="9" x2="14" y2="9"/><path d="M14 22V4a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v18"/><path d="M14 13h2a2 2 0 0 1 2 2v2a2 2 0 0 0 2 2 2 2 0 0 0 2-2V9.83a2 2 0 0 0-.59-1.42L18 5"/></svg>}
                </span>
                <div>
                  <div class="vn">{vm.name}</div>
                  <div class="vs">{variantFuelSub[fuelType] ?? fuelLabels[fuelType] ?? '—'}</div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ===== INTRO ===== -->
  <section class="section" id="predstaveni">
    <div class="container">
      <div class="intro">
        <div class="intro-image">
          {introImg && <DirectusImage src={introImg} alt={`${rawModel.name} interiér`} aspectRatio="1/1" />}
        </div>
        <div class="intro-copy">
          <div class="section-eyebrow">Představení</div>
          <h2>{rawModel.tagline ?? `${rawModel.name} — moderní SUV`}</h2>
          {introCopy.length > 0 ? (
            introCopy.map((p) => <p>{p}</p>)
          ) : (
            <p>{rawModel.description ?? `${brand.name} ${rawModel.name} — model dostupný u SFR Motor.`}</p>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== KONFIGURÁTOR (color picker + interior) ===== -->
  {hasConfigurator && (
    <section class="config" id="konfigurator">
      <div class="container">
        <div class="config-head">
          <div class="section-eyebrow">Konfigurátor</div>
          <h2 class="section-title" style="margin-bottom: 0;">Vyberte si svou barvu</h2>
        </div>

        {colorOptions.length > 0 && (
          <>
            <div class="config-car" data-config-preview>
              {rawModel.hero_image && <DirectusImage src={rawModel.hero_image} alt={`${rawModel.name} — náhled`} aspectRatio="16/7" />}
            </div>

            <div class="color-row">
              {colorOptions.map((c, i) => (
                <button
                  type="button"
                  class={`swatch-item${i === 0 ? ' is-active' : ''}`}
                  data-color-btn
                  data-color-index={i}
                  data-color-name={c.name ?? ''}
                  data-color-type={c.type ?? ''}
                  data-color-hex={c.hex ?? ''}
                >
                  <span class="ring">
                    <span class="swatch-fill" style={`background:${c.hex ?? '#888'}; ${(c.hex ?? '').toLowerCase() === '#f0eee9' || (c.hex ?? '').toLowerCase() === '#f4f1ec' ? 'border:1px solid var(--line-2);' : ''}`}></span>
                  </span>
                  <span class="name">{c.name}</span>
                  <span class="delta">{c.type === 'základní' ? 'V ceně' : 'Příplatek'}</span>
                </button>
              ))}
            </div>
          </>
        )}

        {interiorOptions.length > 0 && (
          <div class="config-bottom">
            <div class="interior-block">
              <div class="lab">Barva interiéru:</div>
              <div class="interior-row">
                {interiorOptions.map((it, i) => (
                  <button
                    type="button"
                    class={`interior-item${i === 0 ? ' is-active' : ''}`}
                    data-interior-btn
                    data-interior-index={i}
                    data-interior-name={it.name ?? ''}
                    data-interior-material={it.material ?? ''}
                  >
                    <span class="interior-fill" style={`background:${it.hex ?? '#888'}`}></span>
                    <span class="name">{it.name}</span>
                  </button>
                ))}
              </div>
            </div>
            <a class="btn btn-primary" href="/kontakt">
              Poptat tuto konfiguraci
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ===== TECH GRID (placeholder pro highlights) ===== -->
  {trims.length > 0 && (
    <section class="section" id="technologie">
      <div class="container">
        <div class="section-eyebrow">Technologie</div>
        <h2 class="section-title">Co umí {rawModel.name}</h2>
        <div class="tech-grid">
          {/* TODO: dedicated model_highlights collection. Pro teď extrahujeme top 4 features z prvního trimu */}
          {(trims[0]?.features ?? []).slice(0, 4).map((feat) => (
            <div class="tech-card">
              <div class="pic">
                {/* TODO: image per highlight */}
              </div>
              <div class="tech-card-body">
                <div class="t">{feat}</div>
                <div class="s">Součást základní výbavy</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== TRIMS / CENY A VÝBAVY ===== -->
  {trims.length > 0 && (
    <section class="section" id="ceny" style="background: var(--bg-soft);">
      <div class="container">
        <div class="section-eyebrow">Ceny a výbavy</div>
        <h2 class="section-title">
          {trims.length === 1 ? 'Jeden výbavový stupeň' : trims.length === 2 ? 'Dva výbavové stupně' : trims.length === 3 ? 'Tři výbavové stupně' : `${trims.length} výbavových stupňů`}, jasná cena.
        </h2>
        <div class={`trims trims-${trims.length}`}>
          {trims.map((t, i) => {
            // Nejvyšší trim = "Doporučujeme" tmavý
            const isRecommended = i === trims.length - 1 && trims.length > 1;
            const cls = isRecommended ? 'trim dark' : 'trim light';
            const price = t.promo_price ?? t.list_price ?? 0;
            return (
              <div class={cls}>
                {isRecommended && <div class="trim-badge">Doporučujeme</div>}
                <div class="trim-name">{t.name}</div>
                <div class="trim-price">{price.toLocaleString('cs-CZ')} Kč</div>
                <ul class="trim-list">
                  {(t.features ?? []).slice(0, 10).map((f) => (
                    <li>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      <span>{f}</span>
                    </li>
                  ))}
                  {(t.features?.length ?? 0) > 10 && (
                    <li style="opacity: 0.7; font-size: 13px;">
                      <span></span>
                      <span>+ {(t.features?.length ?? 0) - 10} dalších položek</span>
                    </li>
                  )}
                </ul>
                <a class="btn" href="/kontakt">
                  Konfigurovat
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            );
          })}
        </div>

        {/* ===== Paketové výbavy ===== */}
        {optionPackages.length > 0 && (
          <div class="packages-block">
            <div class="section-eyebrow" style="margin-top: 64px;">Paketové výbavy</div>
            <h3 style="font-family: var(--font-display); font-weight: 600; font-size: clamp(28px, 2.8vw, 36px); letter-spacing: -0.02em; margin: 0 0 32px;">
              Doplňkové pakety
            </h3>
            <div class="packages-grid">
              {optionPackages.map((pkg: any) => (
                <div class="pkg-card">
                  <div class="pkg-name">{pkg.name}</div>
                  {pkg.description && <p class="pkg-desc">{pkg.description}</p>}
                  {Array.isArray(pkg.features) && pkg.features.length > 0 && (
                    <ul class="pkg-list">
                      {pkg.features.slice(0, 8).map((f: string) => (
                        <li>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                          <span>{f}</span>
                        </li>
                      ))}
                      {pkg.features.length > 8 && (
                        <li class="pkg-more">+ {pkg.features.length - 8} dalších</li>
                      )}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ===== STOCK (3 cars of this model) ===== -->
  {stockOfModel.length > 0 && (
    <section class="section" id="skladem">
      <div class="container">
        <div class="section-head-row">
          <div class="section-eyebrow-inline">
            <span>Ihned k odběru</span>
            <span class="muted">— {rawModel.name} skladem</span>
          </div>
          <a class="section-link" href={`/sklad?model=${rawModel.slug}`}>
            Všechny {rawModel.name} skladem
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="cars">
          {stockOfModel.map((v: any) => {
            const photoId = v.photos?.[0]?.directus_files_id;
            const trim = v.trim_level_snapshot?.name ?? '';
            const carYear = v.model_year?.year ?? '';
            const meta = `${(v.km ?? 0).toLocaleString('cs-CZ')} km · ${carYear}`;
            const price = v.promo_price ?? v.list_price;
            return (
              <article class="car-card">
                <div class="pic">
                  <span class="tag">Skladem</span>
                  {photoId && <DirectusImage src={photoId} alt={`${rawModel.name} ${trim}`} aspectRatio="4/3" />}
                </div>
                <div class="car-body">
                  <div class="car-name">{rawModel.name} {trim}</div>
                  <div class="car-meta">{meta}</div>
                  <hr />
                  <div class="car-price">{price ? `${price.toLocaleString('cs-CZ')} Kč` : '—'}</div>
                  <a class="btn btn-outline" style="padding: 12px 20px; font-size: 12px;" href={`/sklad/${v.id}`}>
                    Detail vozu
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ===== TECHNICKÉ ÚDAJE ===== -->
  {tdataRows.length > 0 && (
    <section class="section" id="data">
      <div class="container">
        <div class="section-eyebrow">Technické údaje</div>
        <h2 class="section-title">Specifikace</h2>
        <div class="tdata">
          {tdataRows.map(([k, v]) => (
            <div class="tdata-row">
              <div class="k">{k}</div>
              <div class="v">{v}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== DALŠÍ MODELY ZNAČKY ===== -->
  {otherModels.length > 0 && (
    <section class="section" style="background: var(--bg-cream);">
      <div class="container">
        <div class="section-head-row">
          <div>
            <div class="section-eyebrow">Další modely {brand.name}</div>
            <h2 class="section-title" style="margin-bottom: 0;">Možná vás zaujme i…</h2>
          </div>
          <a class="head-link" href={`/${brand.slug}`}>
            Všechny modely {brand.name}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="models-grid" style="margin-top: 40px;">
          {otherModels.map((m: any) => {
            const fk = m.fuel_type ?? '';
            const tagCls = fuelTagClass[fk] ?? 'benzin';
            const tagLab = fuelTagLabel[fk] ?? '';
            return (
              <a class="model-card" href={`/model/${m.slug}`}>
                <div class="pic">
                  {tagLab && <span class={`fuel-tag ${tagCls}`}>{tagLab}</span>}
                  {m.hero_image && <DirectusImage src={m.hero_image} alt={`${brand.name} ${m.name}`} aspectRatio="4/3" />}
                </div>
                <div class="model-body">
                  <div class="model-name">{m.name}</div>
                  <p class="model-desc">{m.tagline ?? ''}</p>
                  <div class="model-foot">
                    <div>
                      <div class="price-lab">Cena od</div>
                      <div class="price-val">{m.price_from ? `${m.price_from.toLocaleString('cs-CZ')} Kč` : '—'}</div>
                    </div>
                    <span class="more">
                      Prozkoumat
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ===== VIDEA MODELU ===== -->
  <VideoStrip
    ids={modelVideoIds}
    eyebrow={`Videa ${rawModel.name}`}
    title={`${rawModel.name} v pohybu`}
    background="white"
  />

  <!-- ===== CLOSING CTA BANNER ===== -->
  <section class="cta-banner">
    <div class="cta-banner-bg">
      {rawModel.hero_image && <DirectusImage src={rawModel.hero_image} alt="" aspectRatio="auto" />}
    </div>
    <div class="container cta-banner-inner">
      <h2>Připraveni na zkušební jízdu {rawModel.name}?</h2>
      <p>Rezervujte si testovací jízdu a zažijte vůz na vlastní kůži.</p>
      <div class="cta-banner-actions">
        <a class="btn btn-primary" href="/kontakt">
          Testovací jízda
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a class="btn btn-outline" href="/kontakt">Poptat vůz</a>
      </div>
    </div>
  </section>

  <script>
    // ===== Konfigurátor — color & interior picker =====
    document.querySelectorAll('[data-color-btn]').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-color-btn]').forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        // Volitelně: změnit hue / overlay na config-preview podle hex (basic vizuální feedback)
        const preview = document.querySelector('[data-config-preview]');
        if (preview) {
          const hex = btn.dataset.colorHex;
          if (hex) preview.style.boxShadow = `inset 0 0 0 4px ${hex}33`;
        }
      });
    });
    document.querySelectorAll('[data-interior-btn]').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-interior-btn]').forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
      });
    });
  </script>
</BaseLayout>
