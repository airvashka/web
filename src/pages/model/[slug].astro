        {/* ===== CTA na srovnání + plný ceník — úplně na konci sekce ===== */}
        <div class="trims-cta-row" style="margin-top: 56px;">
          <a class="trims-cta" href={`/model/${rawModel.slug}/vybavy`}>
            <div>
              <div class="trims-cta-eyebrow">Srovnání výbavových stupňů</div>
              <div class="trims-cta-title">Kompletní matrice — vidíte přesně co kde je</div>
              <div class="trims-cta-sub">Sloupce výbavových stupňů × řádky všech prvků výbavy + paketové ceny + barvy.</div>
            </div>
            <span class="trims-cta-arrow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        </div>

        <Disclaimer kind="price" />
      </div>
    </section>
  )}

  <!-- ===== STOCK (3 cars of this model) ===== -->
  {stockOfModel.length > 0 && (
    <section class="section" id="skladem">
      <div class="container">
        <div class="section-head-row">
          <div class="section-eyebrow-inline">
            <span>Ihned k odběru</span>
            <span class="muted">— {rawModel.name} skladem</span>
          </div>
          <a class="section-link" href={`/sklad?model=${rawModel.slug}`}>
            Všechny {rawModel.name} skladem
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="skladovka-grid" data-stock-shuffle data-visible-count="4">
          {stockOfModel.map((v: any) => {
            const photoId = v.photos?.[0]?.directus_files_id;
            const trim = v.trim_level?.name ?? v.trim_level_snapshot?.name ?? '';
            const carYear = v.model_year?.year ?? '';
            const isNew = v.condition === 'new';
            const isHl = v.highlighted;
            const customLabel = (v.highlight_label ?? '').toString().trim();
            const conditionLabel = v.condition === 'new' ? 'Nové' : v.condition === 'demo' ? 'Předváděcí' : 'Ojeté';
            const fuelType = rawModel.fuel_type ?? '';
            const fuelLabelMap = { petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro' };
            const fuelLabel = fuelLabelMap[fuelType] ?? '';
            const transmissionLabel = v.transmission === 'manual' ? 'Manuál' : v.transmission === 'automatic' ? 'Automat' : '';
            const is4wd = v.drivetrain === '4wd' || v.drivetrain === 'awd';
            const conditionCls = v.condition === 'new' ? 'new' : v.condition === 'demo' ? 'demo' : 'used';
            // Promo akce (z rawModel)
            const today = new Date().toISOString().slice(0, 10);
            const modelPromoActive = !!(rawModel as any)?.promo_active
              && (((rawModel as any)?.promo_label) || ((rawModel as any)?.promo_discount_amount))
              && (!((rawModel as any)?.promo_valid_to) || String((rawModel as any).promo_valid_to) >= today);
            const modelPromoLabel = ((rawModel as any)?.promo_label ?? '').toString().trim();
            const modelPromoDiscount = Number((rawModel as any)?.promo_discount_amount ?? 0) || 0;
            // Pill: PROMO (z modelu) nebo Highlight (z vozu)
            let pillLabel = '';
            if (modelPromoActive && modelPromoLabel) pillLabel = modelPromoLabel;
            else if (isHl && customLabel) pillLabel = customLabel;
            else if (isHl) pillLabel = 'Novinka';
            // Cena: stock.promo > model promo (jen pro nové) > list
            const baseList = v.list_price;
            let price = v.promo_price ?? baseList;
            let priceBefore: number | null = null;
            if (v.promo_price && baseList && v.promo_price < baseList) priceBefore = baseList;
            else if (modelPromoActive && modelPromoDiscount > 0 && baseList && isNew) {
              price = baseList - modelPromoDiscount;
              priceBefore = baseList;
            }
            const fmtPrice = (n?: number | null) => (n ? `${n.toLocaleString('cs-CZ')} Kč` : '—');
            const fmtKm = (n?: number | null) => (n === 0 || !n ? '0 km' : `${n.toLocaleString('cs-CZ')} km`);
            return (
              <a class="scard" href={`/sklad/${buildStockSlug(v, brand, rawModel, v.trim_level ?? { name: trim })}`} data-fuel={fuelType}>
                <div class="pic">
                  {photoId && <DirectusImage src={photoId} alt={`${rawModel.name} ${trim}`} aspectRatio="4/3" />}
                  <div class="pill-stack">
                    {pillLabel && <span class="pill pill--promo">{pillLabel}</span>}
                    <span class={`pill pill--${conditionCls}`}>{conditionLabel}</span>
                  </div>
                  <FuelIcon type={fuelType} />
                </div>
                <div class="body">
                  <div class="nm">{brand.name} {rawModel.name}</div>
                  {trim && <div class="var">{trim}</div>}
                  <div class="specs">
                    {fuelLabel && <span class="fuel">{fuelLabel}</span>}
                    {transmissionLabel && <span>{transmissionLabel}</span>}
                    {is4wd && <span>4×4</span>}
                    {carYear && <span>{carYear}</span>}
                  </div>
                  <div class="foot">
                    <span class="km">{fmtKm(v.km)}</span>
                    <div class="price">
                      {priceBefore && <span class="price-before">{fmtPrice(priceBefore)}</span>}
                      <span>{fmtPrice(price)}</span>
                    </div>
                  </div>
                  <div class="stock-state">Skladem v Praze</div>
                </div>
              </a>
            );
          })}
        </div>
        <script>
          (() => {
            const grid = document.querySelector('#skladem [data-stock-shuffle]');
            if (!grid) return;
            const cards = Array.from(grid.children).filter((c) => c.tagName === 'A');
            for (let i = cards.length - 1; i > 0; i--) {
              const j = Math.floor(Math.random() * (i + 1));
              [cards[i], cards[j]] = [cards[j], cards[i]];
            }
            cards.forEach((c) => grid.appendChild(c));
          })();
        </script>
      </div>
    </section>
  )}

  <!-- ===== TECHNICKÉ ÚDAJE ===== -->
  {tdataRows.length > 0 && (
    <section class="section" id="data" style="background: var(--bg-soft);">
      <div class="container">
        <div class="section-eyebrow">Technické údaje</div>
        <h2 class="section-title">Specifikace</h2>
        <div class="tdata">
          {tdataRows.map(([k, v]) => (
            <div class="tdata-row">
              <div class="k">{k}</div>
              <div class="v">{v}</div>
            </div>
          ))}
        </div>
        <Disclaimer kind="tech" />
      </div>
    </section>
  )}

  <!-- ===== DALŠÍ MODELY ZNAČKY ===== -->
  {otherModels.length > 0 && (
    <section class="section" style="background: var(--bg-cream);">
      <div class="container">
        <div class="section-head-row">
          <div>
            <div class="section-eyebrow">Další modely {brand.name}</div>
            <h2 class="section-title" style="margin-bottom: 0;">Možná vás zaujme i…</h2>
          </div>
          <a class="head-link" href={`/${brand.slug}`}>
            Všechny modely {brand.name}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="models-grid" style="margin-top: 40px;">
          {otherModels.map((m: any) => {
            const fk = m.fuel_type ?? '';
            const tagCls = fuelTagClass[fk] ?? 'benzin';
            const tagLab = fuelTagLabel[fk] ?? '';
            return (
              <a class={`model-card${m.variant_badge_kind ? ` model-card--${String(m.variant_badge_kind).toLowerCase()}` : ''}`} href={`/model/${m.slug}`}>
                <div class="pic">
                  {tagLab && <span class={`fuel-tag ${tagCls}`}>{tagLab}</span>}
                  {(m.hero_image_card || m.hero_image) && <DirectusImage src={m.hero_image_card || m.hero_image} alt={`${brand.name} ${m.name}`} aspectRatio="4/3" />}
                </div>
                <div class="model-body">
                  <div class="model-name">{m.name}</div>
                  <p class="model-desc">{m.tagline ?? ''}</p>
                  <div class="model-foot">
                    <div>
                      <div class="price-lab">Cena od</div>
                      <div class="price-val">{m.price_from ? `${m.price_from.toLocaleString('cs-CZ')} Kč` : '—'}</div>
                    </div>
                    <span class="more">
                      Prozkoumat
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ===== VIDEA MODELU ===== -->
  <VideoStrip
    ids={modelVideoIds}
    eyebrow={`Videa ${rawModel.name}`}
    title={`${rawModel.name} v pohybu`}
    background="white"
  />

  <!-- ===== KE STAŽENÍ — multi-dokumenty (brožury + ceníky). Pro detailisty co se vrátí. ===== -->
  {docsList.length > 0 && (
    <section class="section downloads-section" id="ke-stazeni" style="background: var(--bg-soft); padding: 60px 0;">
      <div class="container">
        <div class="downloads-header">
          <div class="section-eyebrow">Ke stažení</div>
          <h2 class="downloads-title">Brožura, ceník a další dokumenty</h2>
        </div>
        <div class="downloads-grid">
          {docsList.map((d) => (
            <a class={`dl-card dl-card--${d.type.replace('_', '-')}`} href={d.url} target="_blank" rel="noopener">
              <span class="dl-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="12" y1="18" x2="12" y2="12"/>
                  <polyline points="9 15 12 18 15 15"/>
                </svg>
              </span>
              <span class="dl-card-body">
                <span class="dl-card-type">
                  {TYPE_LABELS[d.type] ?? 'Dokument'}
                  {d.type === 'price_list_promo' && <span class="dl-badge">Akce</span>}
                </span>
                <span class="dl-card-title">{d.title}</span>
                {(d.valid_from || d.valid_to) && (
                  <span class="dl-card-validity">
                    Platí{d.valid_from ? ` od ${new Date(d.valid_from).toLocaleDateString('cs-CZ')}` : ''}
                    {d.valid_to ? ` do ${new Date(d.valid_to).toLocaleDateString('cs-CZ')}` : ''}
                  </span>
                )}
              </span>
              <span class="dl-card-action">PDF
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== CLOSING CTA BANNER (conversion trigger jako úplně poslední, vždy viditelný) ===== -->
  <section class="cta-banner">
    <div class="cta-banner-bg">
      {rawModel.hero_image && <DirectusImage src={rawModel.hero_image} alt="" aspectRatio="auto" />}
    </div>
    <div class="container cta-banner-inner">
      <h2>Připraveni na zkušební jízdu {rawModel.name}?</h2>
      <p>Rezervujte si testovací jízdu a zažijte vůz na vlastní kůži.</p>
      <div class="cta-banner-actions">
        <a class="btn btn-primary" href="/kontakt">
          Testovací jízda
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a class="btn btn-outline" href="/kontakt">Poptat vůz</a>
      </div>
    </div>
  </section>

  <script>
    // ===== Gallery lightbox =====
    const modal = document.querySelector('[data-gallery-modal]');
    const counter = document.querySelector('[data-gallery-counter]');
    const slides = document.querySelectorAll('[data-slide-index]');
    const total = slides.length;
    let current = 0;

    function showSlide(idx) {
      if (!modal || total === 0) return;
      current = ((idx % total) + total) % total;
      slides.forEach((s) => (s.hidden = Number(s.dataset.slideIndex) !== current));
      if (counter) counter.textContent = `${String(current + 1).padStart(2, '0')} / ${String(total).padStart(2, '0')}`;
    }

    function openModal(idx) {
      if (!modal) return;
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      showSlide(idx);
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('[data-gallery-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => openModal(Number(btn.dataset.index)));
    });
    document.querySelector('[data-gallery-close]')?.addEventListener('click', closeModal);
    document.querySelector('[data-gallery-prev]')?.addEventListener('click', () => showSlide(current - 1));
    document.querySelector('[data-gallery-next]')?.addEventListener('click', () => showSlide(current + 1));
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => {
      if (!modal?.classList.contains('is-open')) return;
      if (e.key === 'Escape') closeModal();
      if (e.key === 'ArrowLeft') showSlide(current - 1);
      if (e.key === 'ArrowRight') showSlide(current + 1);
    });

    /* === Hero video — Safari autoplay pojistka ===
       Safari (zvláště iOS) občas přeskočí autoplay i u muted+playsinline videí.
       Force-play s retry; pokud i tak Safari odmítne, ponecháme poster + AI fallback. */
    document.querySelectorAll('video[data-autoplay-hero]').forEach((v) => {
      // Force muted property (atribut nemusí stačit ve všech iOS verzích)
      try { v.muted = true; v.setAttribute('muted', ''); } catch {}
      const tryPlay = () => {
        const p = v.play();
        if (p && typeof p.then === 'function') {
          p.catch(() => {
            // Safari odmítl autoplay. Zkus znovu po user interactionu (jednou).
            const onInteract = () => {
              v.play().catch(() => {});
              document.removeEventListener('touchstart', onInteract);
              document.removeEventListener('click', onInteract);
            };
            document.addEventListener('touchstart', onInteract, { once: true, passive: true });
            document.addEventListener('click', onInteract, { once: true });
          });
        }
      };
      if (v.readyState >= 2) tryPlay();
      else v.addEventListener('loadeddata', tryPlay, { once: true });
    });

    /* === Color selector — swap aktivní fotky + jména po kliknutí na swatch === */
    document.querySelectorAll('[data-cs-stage]').forEach((stage) => {
      const photos = stage.querySelectorAll('.cs-photo');
      const swatches = stage.querySelectorAll('.cs-swatch');
      const nameEl = stage.querySelector('[data-cs-name]');
      swatches.forEach((sw) => {
        sw.addEventListener('click', () => {
          const idx = sw.dataset.idx;
          const name = sw.dataset.name || '';
          photos.forEach((p) => p.classList.toggle('is-active', p.dataset.idx === idx));
          swatches.forEach((s) => {
            const on = s.dataset.idx === idx;
            s.classList.toggle('is-active', on);
            s.setAttribute('aria-checked', on ? 'true' : 'false');
          });
          if (nameEl) nameEl.textContent = name;
        });
      });
    });
  </script>

  <!-- ===== AI ASISTENT (floating widget) — JEN PRO KGM MODELY ===== -->
  {brand.slug === 'kgm' && (
    <ModelChatWidget
      brandSlug={brand.slug}
      brandName={brand.name}
      modelSlug={rawModel.slug}
      modelName={rawModel.name}
    />
  )}
</BaseLayout>
