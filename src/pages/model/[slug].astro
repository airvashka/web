---
import BaseLayout from '@layouts/BaseLayout.astro';
import FuelIcon from '@components/FuelIcon.astro';
import DirectusImage from '@components/DirectusImage.astro';
import VideoStrip from '@components/VideoStrip.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import JsonLd from '@components/JsonLd.astro';
import HighlightsPanel from '@components/HighlightsPanel.astro';
import VariantBadge from '@components/VariantBadge.astro';
import Disclaimer from '@components/Disclaimer.astro';
import ModelChatWidget from '@components/ModelChatWidget.astro';
import { directusGet, directusAsset } from '@lib/directus';
import { buildStockSlug } from '@lib/stockSlug';
import { getGroupedFeatures, countFeatures } from '@lib/features';
import { modelSchema } from '@lib/schemas';
import type { Brand, Model, ModelYear, TrimLevel } from '@lib/types';

/* ============================================================
   MODEL DETAIL — 1:1 podle _design-draft/torres-evx.jsx
   Sections: ModelHero · SubNav · Intro · (config TODO) · Tech · Trims · Stock · Tdata · CTA banner
   ============================================================ */

export async function getStaticPaths() {
  const models = await directusGet<Model>('models', {
    fields: ['slug'],
    filter: { status: { _eq: 'published' } },
  });
  return models.map((m) => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;

type ModelRaw = Model & {
  brand?: number | null;
  sub_brand?: number | null;
  hero_image?: string;
  gallery?: Array<{ directus_files_id: string }>;
  color_exterior?: Array<any>;
  color_interior?: Array<any>;
  highlights?: Array<any>;
  documents?: Array<any>; // O2M na model_documents collection (brožury + ceníky)
};

const rawModels = await directusGet<ModelRaw>('models', {
  filter: { slug: { _eq: slug } },
  limit: 1,
  fields: [
    '*',
    'highlights_panel',
    'variant_badge_kind',
    'hero_video',         // explicit UUID file ref (some Directus versions don't include in *)
    'hero_image_card',
    'gallery.directus_files_id',
    'color_exterior.*',
    'color_interior.*',
    'highlights.*',
    // Explicitní expand polí pro documents O2M (některé Directus instance neexpand přes .*)
    'documents.id',
    'documents.title',
    'documents.type',
    'documents.file',
    'documents.valid_from',
    'documents.valid_to',
    'documents.featured',
    'documents.sort',
  ],
});
const rawModel = rawModels[0];
if (!rawModel) return Astro.redirect('/404');

const brands = rawModel.brand
  ? await directusGet<Brand>('brands', { filter: { id: { _eq: rawModel.brand } }, limit: 1 })
  : [];
const brand = brands[0];
if (!brand) return Astro.redirect('/404');

const modelYears = await directusGet<ModelYear>('model_years', {
  filter: { model: { _eq: rawModel.id }, status: { _eq: 'published' } },
  sort: ['-year'],
  fields: ['*'],
});
const latestYear = modelYears[0];

// VŠECHNY trimy modelového roku — pro srovnávací podstránku
const allTrims: TrimLevel[] = latestYear
  ? await directusGet<TrimLevel>('trim_levels', {
      filter: { model_year: { _eq: latestYear.id }, status: { _eq: 'published' } },
      sort: ['sort'],
      fields: ['*'],
    })
  : [];
// Featured trimy — pro teaser karty na model stránce (default true pokud field neexistuje)
const trims: TrimLevel[] = allTrims.filter((t: any) =>
  t.featured_on_model_page === undefined || t.featured_on_model_page === null || t.featured_on_model_page === true
);

// Option packages (paketové výbavy) — bez status a sort, collection je nemá
const optionPackages = latestYear
  ? await directusGet<any>('option_packages', {
      filter: { model_year: { _eq: latestYear.id } },
      sort: ['name'],
      fields: ['*'],
    })
  : [];

// Skladové vozy tohoto modelu (pool pro shuffle — 5 viditelných z 16)
const stockOfModel = await directusGet<any>('stock_vehicles', {
  filter: { model: { _eq: rawModel.id }, status: { _eq: 'published' }, availability: { _in: ['in_stock', 'on_the_way'] } },
  sort: ['-listed_at'],
  limit: 16,
  fields: [
    'id', 'condition', 'km', 'list_price', 'promo_price', 'trim_level_snapshot',
    'highlighted', 'highlight_label', 'transmission', 'drivetrain',
    'photos.directus_files_id', 'model_year.year', 'color_code', 'color_category',
    'trim_level.name',
  ],
});

// Mapování
const fuelLabels: Record<string, string> = {
  petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro',
};

// Technická data — priorita models.technical_data > model_years.technical_data (legacy)
// Akceptujeme array [{label, value}] (nový formát) i object {key: value} (legacy)
type TechRow = [string, string];
function parseTdata(td: any): TechRow[] {
  if (!td) return [];
  if (Array.isArray(td)) {
    return td.map((r: any) =>
      Array.isArray(r) ? (r as TechRow) : [r.label ?? r.k ?? '', String(r.value ?? r.v ?? '')]
    ).filter(([k]) => !!k);
  }
  if (typeof td === 'object') {
    return Object.entries(td).map(([k, v]) => [k, String(v)] as TechRow);
  }
  return [];
}
const modelTdata = parseTdata((rawModel as any)?.technical_data);
const yearTdata = parseTdata(latestYear?.technical_data);
const tdataRows: TechRow[] = modelTdata.length > 0 ? modelTdata : yearTdata;

const fuelKey = (rawModel as any).fuel_type ?? '';
const badgeText = fuelKey === 'ev' ? 'Elektrické SUV'
  : fuelKey === 'hybrid' ? 'Hybridní SUV'
  : fuelKey === 'phev' ? 'Plug-in hybrid SUV'
  : fuelKey === 'diesel' ? 'SUV · Diesel'
  : 'SUV';

// ===== Hero stats — extrakce 4 nejdůležitějších s aliasy + jednotky =====
// Najde podle více alternativních klíčů, normalizuje a ZKRÁTÍ hodnotu (jen klíčové číslo + jednotka)
function shortenStat(raw: string, preferUnit?: string): string {
  const val = raw.trim();
  // 1) Pokud máme preferUnit, hledej "číslo + jednotka" a vrať jen to
  if (preferUnit) {
    // Pattern: number (with optional space/comma/dot) + optional spaces + unit
    const re = new RegExp(`([0-9]+[\\s.,0-9]*?)\\s*${preferUnit.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')}`, 'i');
    const m = val.match(re);
    if (m) return `${m[1].replace(/\s+$/, '').trim()} ${preferUnit}`;
  }
  // 2) Pokud obsahuje závorky / lomítka, vzít jen první kus
  const beforeSlash = val.split(/\s*\/\s*/)[0];
  const beforeParen = beforeSlash.replace(/\s*\([^)]*\)/g, '').trim();
  // 3) Max 18 znaků, jinak truncate
  if (beforeParen.length > 18) return beforeParen.substring(0, 16) + '…';
  return beforeParen;
}

function findStat(aliases: string[], unit?: string): string | null {
  const lowerAliases = aliases.map((a) => a.toLowerCase());
  for (const [k, v] of tdataRows) {
    const lk = k.toLowerCase();
    if (lowerAliases.some((a) => lk.includes(a))) {
      const val = String(v).trim();
      // Přidat jednotku, pokud zatím není v hodnotě a hodnota je čistě číselná
      if (unit && val && !val.includes(unit) && /^[0-9.,\s]+$/.test(val)) {
        return `${val} ${unit}`;
      }
      // Jinak zkrátit (oříznout závorky, vzít před lomítkem)
      return shortenStat(val, unit);
    }
  }
  return null;
}

// Fallback záruka per brand (když není v tdata)
const WARRANTY_BY_BRAND: Record<string, string> = {
  kgm: '5 let / 100 000 km',
  'omoda-jaecoo': '7 let / 150 000 km',
  farizon: '7 let / 150 000 km',
};

// Stats per fuel type — různé highlighty pro elektro vs spalovák
type StatDef = { label: string; aliases: string[]; unit?: string };
const STAT_SETS: Record<string, StatDef[]> = {
  petrol: [
    { label: 'Výkon', aliases: ['čistý výkon motoru', 'systémový výkon', 'výkon'], unit: 'kW' },
    { label: 'Točivý moment', aliases: ['maximální točivý moment', 'točivý moment'], unit: 'Nm' },
    { label: 'Spotřeba (komb.)', aliases: ['průměrná spotřeba paliva', 'spotřeba (komb.)', 'spotřeba'], unit: 'l/100 km' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
  diesel: [
    { label: 'Výkon', aliases: ['čistý výkon motoru', 'výkon'], unit: 'kW' },
    { label: 'Točivý moment', aliases: ['maximální točivý moment', 'točivý moment'], unit: 'Nm' },
    { label: 'Spotřeba (komb.)', aliases: ['průměrná spotřeba paliva', 'spotřeba'], unit: 'l/100 km' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
  hybrid: [
    { label: 'Systémový výkon', aliases: ['systémový výkon', 'výkon'], unit: 'kW' },
    { label: 'Spotřeba (komb.)', aliases: ['průměrná spotřeba paliva', 'spotřeba (komb.)', 'spotřeba'], unit: 'l/100 km' },
    { label: 'Emise CO₂', aliases: ['emise co₂', 'emise co2'], unit: 'g/km' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
  phev: [
    { label: 'Systémový výkon', aliases: ['systémový výkon', 'výkon'], unit: 'kW' },
    { label: 'Dojezd EV', aliases: ['dojezd ev', 'dojezd elektro', 'elektrický dojezd'], unit: 'km' },
    { label: 'Spotřeba (komb.)', aliases: ['průměrná spotřeba paliva', 'spotřeba'], unit: 'l/100 km' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
  ev: [
    { label: 'Dojezd WLTP', aliases: ['dojezd wltp', 'dojezd'], unit: 'km' },
    { label: 'Výkon', aliases: ['čistý výkon motoru', 'výkon'], unit: 'kW' },
    { label: 'Zrychlení 0–100', aliases: ['zrychlení 0-100', 'zrychlení 0–100', 'zrychlení'], unit: 's' },
    { label: 'Záruka', aliases: ['záruka'] },
  ],
};
const statsForFuel = STAT_SETS[fuelKey] ?? STAT_SETS.petrol;

// ===== Priorita: models.hero_stats > model_years.hero_stats (legacy) > auto-extract =====
type AdminStat = { label?: string; value?: string };
const modelHeroStats: AdminStat[] = Array.isArray((rawModel as any)?.hero_stats) ? (rawModel as any).hero_stats : [];
const yearHeroStats: AdminStat[] = Array.isArray((latestYear as any)?.hero_stats) ? (latestYear as any).hero_stats : [];
const adminHeroStats: AdminStat[] = modelHeroStats.length > 0 ? modelHeroStats : yearHeroStats;
let heroStats: Array<{ lab: string; val: string }> = [];

if (adminHeroStats.length > 0) {
  // Admin upravil → použij hodnoty 1:1
  heroStats = adminHeroStats
    .filter((s) => s && s.label && s.value)
    .map((s) => ({ lab: String(s.label), val: String(s.value) }));
} else {
  // Fallback: auto-extract z technical_data
  for (const def of statsForFuel) {
    let val = findStat(def.aliases, def.unit);
    if (!val && def.label === 'Záruka') val = WARRANTY_BY_BRAND[brand.slug] ?? null;
    if (val) heroStats.push({ lab: def.label, val });
    if (heroStats.length >= 3) break;
  }
  if (heroStats.length < 2) {
    const fuelLabel = fuelLabels[fuelKey] ?? '—';
    const bodyType = (rawModel as any).body_type;
    if (fuelLabel !== '—') heroStats.push({ lab: 'Palivo', val: fuelLabel });
    if (bodyType) heroStats.push({ lab: 'Karoserie', val: String(bodyType).toUpperCase() });
  }
  if (rawModel.price_from) {
    heroStats.push({ lab: 'Cena od', val: `${rawModel.price_from.toLocaleString('cs-CZ')} Kč` });
  }
}

const priceFrom = rawModel.price_from ? `${rawModel.price_from.toLocaleString('cs-CZ')} Kč` : '—';
const fuelTagClass: Record<string, string> = {
  petrol: 'benzin', diesel: 'diesel', hybrid: 'hybrid', phev: 'phev', ev: 'elektro',
};

// ===== Variant switcher — modely se stejnou base (Torres / Torres HEV / Torres EVX) =====
// TODO: přesunout do Directus jako field `variants_group` na models. Pro teď hardcoded mapping.
const VARIANT_GROUPS: string[][] = [
  // KGM Torres family
  ['torres', 'torres-hev', 'torres-evx'],
  // KGM Actyon family
  ['actyon', 'actyon-hev'],
  // Omoda 5 family (Benzín / Superhybrid / Elektro)
  ['omoda-5', 'omoda-5-shs-h', 'omoda-5-ev'],
  // Omoda 9 family
  ['omoda-9', 'omoda-9-shs'],
  // Jaecoo 5 family (zatím jen 1 — switcher se nezobrazí)
  ['jaecoo-5'],
  // Jaecoo 7 family
  ['jaecoo-7', 'jaecoo-7-shs'],
];
const variantGroup = VARIANT_GROUPS.find((g) => g.includes(slug ?? ''));
let variantModels: Array<{ slug: string; name: string; fuel_type?: string; description?: string }> = [];
if (variantGroup && variantGroup.length > 1) {
  variantModels = await directusGet<any>('models', {
    filter: { slug: { _in: variantGroup }, status: { _eq: 'published' } },
    fields: ['slug', 'name', 'fuel_type', 'tagline'],
  });
  // Seřadit dle pořadí v VARIANT_GROUPS (ICE/HEV/PHEV/EVX/SHS)
  variantModels.sort((a, b) => variantGroup.indexOf(a.slug) - variantGroup.indexOf(b.slug));
}

const variantFuelSub: Record<string, string> = {
  petrol: 'Benzín · spalovací',
  diesel: 'Diesel',
  hybrid: 'Plný hybrid',
  phev: 'Plug-in hybrid',
  ev: 'Elektromobil',
};

/* Mapování fuel_type → VariantBadge kind a theme color */
function fuelTypeToVariantKind(ft?: string): 'ICE' | 'HEV' | 'EVX' {
  if (ft === 'ev') return 'EVX';
  if (ft === 'hybrid' || ft === 'phev') return 'HEV';
  return 'ICE'; // petrol / diesel / prázdný
}
function fuelTypeToVariantTheme(ft?: string): 'ice' | 'hev' | 'evx' {
  if (ft === 'ev') return 'evx';
  if (ft === 'hybrid' || ft === 'phev') return 'hev';
  return 'ice';
}

// Ostatní modely stejné značky (kromě aktuálního a kromě variant rodiny)
const otherModelsRaw = await directusGet<any>('models', {
  filter: {
    brand: { _eq: brand.id },
    status: { _eq: 'published' },
    slug: { _neq: slug ?? '' },
  },
  fields: ['id', 'slug', 'name', 'tagline', 'price_from', 'fuel_type', 'body_type', 'hero_image', 'hero_image_card', 'variant_badge_kind'],
  sort: ['sort'],
  limit: 12,
});
const siblingSlugs = new Set(variantGroup ?? []);
const otherModels = otherModelsRaw.filter((m: any) => !siblingSlugs.has(m.slug)).slice(0, 6);

const fuelTagLabel: Record<string, string> = {
  petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro',
};

// Videa modelu (z model.youtube_video_ids field — pokud existuje)
const modelVideoIds: string[] = Array.isArray((rawModel as any).youtube_video_ids)
  ? (rawModel as any).youtube_video_ids
  : [];

// Galerie modelu — M2M relace `gallery` na directus_files (zatím už načítáme přes fields=['*', 'gallery.directus_files_id'])
const galleryFileIds: string[] = Array.isArray((rawModel as any).gallery)
  ? (rawModel as any).gallery.map((g: any) => typeof g === 'string' ? g : g?.directus_files_id).filter(Boolean) as string[]
  : [];

// PDF ke stažení — priorita models > latestYear (legacy fallback)
const DIRECTUS_BASE = import.meta.env.PUBLIC_DIRECTUS_URL ?? '';
// Dokumenty — priorita O2M `documents` (multi), fallback na legacy single fieldy
const TYPE_LABELS: Record<string, string> = {
  brochure: 'Brožura',
  price_list: 'Ceník',
  price_list_promo: 'Akční ceník',
  datasheet: 'Technický list',
  other: 'Dokument',
};
type DocItem = { type: string; title: string; url: string; valid_from?: string; valid_to?: string; featured?: boolean };
const today = new Date().toISOString().slice(0, 10);
const docsRaw = Array.isArray((rawModel as any)?.documents) ? (rawModel as any).documents : [];
const docsList: DocItem[] = docsRaw
  .filter((d: any) => d?.file)
  // Filter platnost — pokud má valid_from > today, schovat; valid_to < today, schovat
  .filter((d: any) => {
    if (d.valid_from && d.valid_from > today) return false;
    if (d.valid_to && d.valid_to < today) return false;
    return true;
  })
  .map((d: any) => ({
    type: d.type ?? 'other',
    title: d.title ?? TYPE_LABELS[d.type] ?? 'Dokument',
    url: `${DIRECTUS_BASE}/assets/${d.file}?download`,
    valid_from: d.valid_from,
    valid_to: d.valid_to,
    featured: !!d.featured,
  }))
  // Sort: featured první, pak podle type group
  .sort((a: DocItem, b: DocItem) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0));

// Legacy fallback odstraněn — staré single-file fieldy brochure_file/price_list_file
// jsou pryč, vše jde přes model_documents O2M collection.

// Barvy karoserie + interiéru (z model_year)
type ColorOpt = { code?: string; name?: string; name_en?: string; hex?: string; type?: string; price_type?: string; swatch_image?: string; swatch_file?: string; photo_file?: string; photo?: string; monotone_only?: boolean };
type InteriorOpt = { code?: string; name?: string; material?: string; hex?: string; swatch_image?: string; swatch_file?: string; preview_image?: string; preview_file?: string; photo_file?: string; photo?: string };

// Priorita: nové O2M collections > legacy JSON na models > legacy JSON na model_years
// Nové collections (color_exterior/color_interior) mají field 'photo' (M2O na directus_files)
const colorExteriorNew: ColorOpt[] = Array.isArray((rawModel as any)?.color_exterior) ? (rawModel as any).color_exterior : [];
const colorInteriorNew: InteriorOpt[] = Array.isArray((rawModel as any)?.color_interior) ? (rawModel as any).color_interior : [];

const colorOptions: ColorOpt[] = colorExteriorNew.length > 0
  ? colorExteriorNew
  : Array.isArray((rawModel as any)?.color_options) && (rawModel as any).color_options.length > 0
    ? (rawModel as any).color_options
    : Array.isArray((latestYear as any)?.color_options) ? (latestYear as any).color_options : [];

const interiorOptions: InteriorOpt[] = colorInteriorNew.length > 0
  ? colorInteriorNew
  : Array.isArray((rawModel as any)?.interior_options) && (rawModel as any).interior_options.length > 0
    ? (rawModel as any).interior_options
    : Array.isArray((latestYear as any)?.interior_options) ? (latestYear as any).interior_options : [];

const hasConfigurator = colorOptions.length > 0 || interiorOptions.length > 0;

// Intro foto = první z gallery, nebo hero_image
const galleryImages: string[] = (rawModel.gallery ?? []).map((g) => g?.directus_files_id).filter(Boolean) as string[];
const introImg = galleryImages[0] ?? rawModel.hero_image;

// Description rozdělené na odstavce
const introCopy = (rawModel.description ?? '').split(/\n\s*\n/).filter(Boolean);

// ===== AKCE / PROMO =====
// Aktivní pouze pokud promo_active=true a (volitelně) promo_valid_to není v minulosti.
const todayDate = new Date().toISOString().slice(0, 10);
const promoActive: boolean = !!(rawModel as any).promo_active
  && ((rawModel as any).promo_label || (rawModel as any).promo_discount_amount)
  && (!(rawModel as any).promo_valid_to || String((rawModel as any).promo_valid_to) >= todayDate);
const promoLabel: string = ((rawModel as any).promo_label ?? '').toString().trim();
const promoDiscountAmount: number = Number((rawModel as any).promo_discount_amount ?? 0) || 0;
const promoValidTo: string | null = (rawModel as any).promo_valid_to ?? null;
const promoDescription: string = (rawModel as any).promo_description ?? '';
// Render markdown pro popis akce (lehký inline marked import — pokud chybí, fallback na plain text)
let promoDescriptionHtml: string = '';
if (promoActive && promoDescription) {
  try {
    const { marked } = await import('marked');
    promoDescriptionHtml = marked.parse(promoDescription) as string;
  } catch {
    promoDescriptionHtml = `<p>${promoDescription.replace(/\n/g, '</p><p>')}</p>`;
  }
}
---

<BaseLayout
  title={`${brand.name} ${rawModel.name}`}
  description={rawModel.tagline ?? `${brand.name} ${rawModel.name} u SFR Motor — autorizovaný dealer v Praze-Ďáblicích.`}
>
  <JsonLd data={modelSchema({
    url: `https://sfr-motor.cz${Astro.url.pathname}`,
    brand: brand.name,
    name: rawModel.name,
    description: rawModel.tagline ?? (rawModel.description ?? '').slice(0, 300),
    image: rawModel.hero_image ? directusAsset(rawModel.hero_image, { width: 1200, format: 'jpg', quality: 85 }) : null,
    priceFromCzk: (trims[0]?.promo_price ?? trims[0]?.list_price ?? null) as number | null,
  })} />
  <Breadcrumbs items={[
    { label: brand.name, href: `/${brand.slug}` },
    { label: rawModel.name },
  ]} />

  <!-- ===== MODEL HERO (dark, full-bleed) ===== -->
  <section class="mhero" data-screen-label="01 Hero">
    <div class="mhero-bg">
      {(() => {
        // hero_video může být UUID string (default M2O) NEBO object { id, type, ... } (s expandem)
        const hv = (rawModel as any).hero_video;
        const videoId = typeof hv === 'string' ? hv : hv?.id;
        const videoType = hv?.type || 'video/mp4';
        if (videoId) {
          return (
            <video
              class="mhero-video"
              autoplay
              muted
              loop
              playsinline
              webkit-playsinline
              x5-playsinline
              disablepictureinpicture
              preload="auto"
              data-autoplay-hero
              poster={rawModel.hero_image ? directusAsset(rawModel.hero_image, { width: 1600, format: 'jpg', quality: 80 }) : undefined}
            >
              <source src={directusAsset(videoId)} type={videoType} />
              {/* Fallback pro browsery bez video support */}
              {rawModel.hero_image && <img src={directusAsset(rawModel.hero_image, { width: 1600 })} alt={`${brand.name} ${rawModel.name}`} />}
            </video>
          );
        }
        return rawModel.hero_image
          ? <DirectusImage src={rawModel.hero_image} alt={`${brand.name} ${rawModel.name}`} fill widths={[1280, 1920, 2560, 3200]} sizes="100vw" loading="eager" fetchpriority="high" />
          : null;
      })()}
    </div>
    <div class="container mhero-inner">
      <div class="mhero-eyebrow">
        <span>{brand.name}</span>
        <span class="sep">·</span>
        <span>{badgeText}</span>
      </div>
      <h1 class="mhero-title">{rawModel.name}</h1>
      <p class="mhero-tagline">{rawModel.tagline ?? ''}</p>
    </div>
    {heroStats.length > 0 && (
      <div class="mhero-stats">
        <div class="container mhero-stats-inner">
          {heroStats.map((s) => (
            <div class="mstat">
              <div class="lab">{s.lab}</div>
              <div class="val">{s.val}</div>
            </div>
          ))}
          <div class="mhero-spacer"></div>
          <a class="btn btn-primary" href="/kontakt">Testovací jízda</a>
        </div>
      </div>
    )}
  </section>

