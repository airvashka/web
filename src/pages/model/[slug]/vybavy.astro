---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Disclaimer from '@components/Disclaimer.astro';
import { directusGet } from '@lib/directus';
import { getGroupedFeatures, CATEGORY_ORDER, CATEGORY_LABELS } from '@lib/features';
import type { Brand, Model, ModelYear, TrimLevel } from '@lib/types';

/* ============================================================
   Srovnávací matrice výbav pro model.

   URL: /model/[slug]/vybavy
   Layout: tabulka — sloupce = trimy, řádky = unikátní features
   napříč všemi trimy, seskupené po kategoriích.

   ============================================================ */

export async function getStaticPaths() {
  const models = await directusGet<Model>('models', { fields: ['slug'] });
  return models.map((m) => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;

const models = await directusGet<Model>('models', {
  filter: { slug: { _eq: slug } },
  limit: 1,
});
const rawModel = models[0];
if (!rawModel) return Astro.redirect('/404');

const brands = await directusGet<Brand>('brands', {
  filter: { id: { _eq: Number(rawModel.brand) } },
  limit: 1,
});
const brand = brands[0];
if (!brand) return Astro.redirect('/404');

// Nejnovější model_year (s pricelist_colors)
const modelYears = await directusGet<ModelYear & { pricelist_colors?: any }>('model_years', {
  filter: { model: { _eq: rawModel.id } },
  sort: ['-year'],
  limit: 1,
  fields: ['*'],
});
const latestYear = modelYears[0];

// Pricelist colors (z ceníku) — preferuje NOVÉ tabulkové fieldy, fallback na legacy JSON.
type PricelistColor = {
  name: string;
  code?: string;
  type?: string;
  material?: string;
  // pricing_per_trim může být buď object {slug: price} (legacy) nebo array [{trim_slug, price}] (nové)
  pricing_per_trim?: Record<string, number | string> | Array<{ trim_slug: string; price: number }>;
};
const pricelistColors: { exterior: PricelistColor[]; interior: PricelistColor[] } = (() => {
  const yr = latestYear as any;
  if (!yr) return { exterior: [], interior: [] };

  // Preferuj nové fieldy
  const newExt = Array.isArray(yr.pricelist_colors_exterior) ? yr.pricelist_colors_exterior : null;
  const newInt = Array.isArray(yr.pricelist_colors_interior) ? yr.pricelist_colors_interior : null;
  if (newExt || newInt) return { exterior: newExt ?? [], interior: newInt ?? [] };

  // Fallback: legacy JSON object pricelist_colors
  const raw = yr.pricelist_colors;
  if (!raw) return { exterior: [], interior: [] };
  const obj = typeof raw === 'string' ? (() => { try { return JSON.parse(raw); } catch { return null; } })() : raw;
  return {
    exterior: Array.isArray(obj?.exterior) ? obj.exterior : [],
    interior: Array.isArray(obj?.interior) ? obj.interior : [],
  };
})();

/** Universal pricing accessor — zkouší oba slug varianty (_ i -). */
function getPriceForTrim(pricing: PricelistColor['pricing_per_trim'], trimSlug: string): number | string | undefined {
  if (!pricing) return undefined;
  // Slug varianty: original, s _, s -
  const variants = [trimSlug, trimSlug.replace(/-/g, '_'), trimSlug.replace(/_/g, '-')];
  if (Array.isArray(pricing)) {
    for (const k of variants) {
      const found = pricing.find((p) => p.trim_slug === k);
      if (found) return found.price;
    }
    return undefined;
  }
  // Object tvar (legacy)
  for (const k of variants) {
    if (pricing[k] !== undefined) return pricing[k];
  }
  return undefined;
}

// VŠECHNY trimy (i unfeatured)
const trims: TrimLevel[] = latestYear
  ? await directusGet<TrimLevel>('trim_levels', {
      filter: { model_year: { _eq: latestYear.id }, status: { _eq: 'published' } },
      sort: ['sort'],
      fields: ['*'],
    })
  : [];

// Option packages
const optionPackages = latestYear
  ? await directusGet<any>('option_packages', {
      filter: { model_year: { _eq: latestYear.id } },
      sort: ['name'],
      fields: ['*'],
    })
  : [];

/* ============================================================
   Build comparison matrix — zachovává pořadí kategorií z adminu
   a podporuje optional_items per trim (zobrazí cenu v buňce).
   ============================================================ */

// Cell value: 'standard' (✓), 'unavailable' (—), { price } (číslo Kč), nebo { packageName } (jen v paketu)
type CellValue = 'standard' | 'unavailable' | { price: number } | { packageName: string };

interface CompareRow {
  feature: string;
  code?: string;
  cells: Record<string, CellValue>; // trim.id → cell
}
interface CompareCategory {
  key: string;
  label: string;
  rows: CompareRow[];
}

// ── Sjednocený build matice (zrcadlí admin /admin/cenik) ──
// Zdroje: features (✓), optional_items (cena), package_items (paket).
// Pořadí i zařazení do sekcí = jako v adminu: first-occurrence + uložená category.
const OTHER_SECTION = 'Ostatní';
type OptItem = { name: string; price: number; category?: string };
type PkgItem = { name: string; label: string; category?: string };
const trimFeatures = new Map<string, Array<{ section: string; items: string[] }>>();
const trimOptionals = new Map<string, OptItem[]>();
const trimPackages = new Map<string, PkgItem[]>();

const featureToSection = new Map<string, string>();
const sectionOrder: string[] = [];
const seenSec = new Set<string>();
const ensureSectionInOrder = (s: string) => { if (s && !seenSec.has(s)) { seenSec.add(s); sectionOrder.push(s); } };

// 1) features určují sekce a jejich pořadí
for (const t of trims) {
  const groups = getGroupedFeatures((t as any).features)
    .map((g: any) => ({ section: String(g.key ?? '').trim(), items: (g.items || []).map((x: any) => String(x)) }))
    .filter((g) => g.section);
  trimFeatures.set(String(t.id), groups);
  for (const g of groups) {
    ensureSectionInOrder(g.section);
    for (const it of g.items) { const fn = it.trim(); if (fn && !featureToSection.has(fn)) featureToSection.set(fn, g.section); }
  }
  const opts: OptItem[] = (Array.isArray((t as any).optional_items) ? (t as any).optional_items : [])
    .filter((o: any) => o && o.name && Number.isFinite(Number(o.price)))
    .map((o: any) => ({ name: String(o.name).trim(), price: Number(o.price), category: o.category ? String(o.category).trim() : '' }));
  trimOptionals.set(String(t.id), opts);
  const pkgs: PkgItem[] = (Array.isArray((t as any).package_items) ? (t as any).package_items : [])
    .filter((p: any) => p && p.name)
    .map((p: any) => ({ name: String(p.name).trim(), label: String(p.package_name || p.package_code || '').trim(), category: p.category ? String(p.category).trim() : '' }))
    .filter((p: PkgItem) => p.label);
  trimPackages.set(String(t.id), pkgs);
}

// 2) optional/package doplní sekci (dle category) + pořadí
for (const t of trims) {
  for (const o of trimOptionals.get(String(t.id)) || []) {
    if (o.name && !featureToSection.has(o.name)) { const s = o.category || OTHER_SECTION; featureToSection.set(o.name, s); ensureSectionInOrder(s); }
  }
  for (const p of trimPackages.get(String(t.id)) || []) {
    if (p.name && !featureToSection.has(p.name)) { const s = p.category || OTHER_SECTION; featureToSection.set(p.name, s); ensureSectionInOrder(s); }
  }
}

// 3) řádky per sekce (first-occurrence pořadí)
const sectionRows = new Map<string, string[]>();
const addRow = (s: string, fn: string) => { if (!sectionRows.has(s)) sectionRows.set(s, []); const a = sectionRows.get(s)!; if (!a.includes(fn)) a.push(fn); };
for (const t of trims) {
  for (const g of trimFeatures.get(String(t.id)) || []) for (const it of g.items) { const fn = it.trim(); if (fn) addRow(featureToSection.get(fn) || g.section, fn); }
}
for (const t of trims) {
  for (const o of trimOptionals.get(String(t.id)) || []) if (o.name) addRow(featureToSection.get(o.name) || OTHER_SECTION, o.name);
  for (const p of trimPackages.get(String(t.id)) || []) if (p.name) addRow(featureToSection.get(p.name) || OTHER_SECTION, p.name);
}

let finalSections = sectionOrder.filter((s) => sectionRows.has(s));
for (const s of sectionRows.keys()) if (!finalSections.includes(s)) finalSections.push(s);
finalSections = finalSections.filter((s) => s !== OTHER_SECTION);
if (sectionRows.has(OTHER_SECTION)) finalSections.push(OTHER_SECTION);

function cellFor(t: any, feature: string): CellValue {
  for (const g of (trimFeatures.get(String(t.id)) || [])) if (g.items.some((it) => it.trim() === feature)) return 'standard';
  const o = (trimOptionals.get(String(t.id)) || []).find((x) => x.name === feature);
  if (o) return { price: o.price };
  const p = (trimPackages.get(String(t.id)) || []).find((x) => x.name === feature);
  if (p) return { packageName: p.label };
  return 'unavailable';
}

const compareData: CompareCategory[] = finalSections.map((section) => ({
  key: section,
  label: CATEGORY_LABELS[section as keyof typeof CATEGORY_LABELS] ?? section,
  rows: (sectionRows.get(section) || []).map((feature) => {
    const cells: Record<string, CellValue> = {};
    for (const t of trims) cells[String(t.id)] = cellFor(t, feature);
    return { feature, cells } as CompareRow;
  }),
})).filter((c) => c.rows.length > 0);

// Cena trimu pro header
function trimPrice(t: TrimLevel): string {
  const p = (t.promo_price ?? t.list_price) as number | null;
  return p ? `${p.toLocaleString('cs-CZ')} Kč` : '—';
}
---

<BaseLayout
  title={`Srovnání výbavových stupňů — ${brand.name} ${rawModel.name}`}
  description={`Kompletní srovnání výbavových stupňů ${rawModel.name} — co je v jakém stupni, co je za příplatek, co v paketu.`}
>
  <Breadcrumbs items={[
    { label: brand.name, href: `/${brand.slug}` },
    { label: rawModel.name, href: `/model/${rawModel.slug}` },
    { label: 'Srovnání výbavových stupňů' },
  ]} />

  <section class="section">
    <div class="container">
      <div class="section-eyebrow">Srovnání výbavových stupňů</div>
      <h1 class="section-title" style="margin-bottom: 8px;">
        {brand.name} {rawModel.name} — co je v jakém stupni
      </h1>
      <p class="lead" style="max-width: 64ch; margin-bottom: 40px;">
        Matrice všech prvků výbavy. <strong>✓</strong> znamená v ceně, <span style="color: var(--text-muted);">—</span> není k dispozici, číslo je příplatek, <span style="color: var(--accent);">název paketu</span> = dostupné jen v daném paketu. Pokud chceš jen rychlý přehled, vrať se na <a href={`/model/${rawModel.slug}#ceny`}>karty výbavových stupňů</a>.
      </p>

      {trims.length === 0 ? (
        <p style="color: var(--text-muted);">Pro tento model zatím nejsou definované výbavové stupně.</p>
      ) : (
        <div class="compare-wrapper">
          <div class="compare-scroll">
            <table class="compare-table" style={`--trim-count: ${trims.length}`}>
              <thead>
                <tr>
                  <th class="compare-feature-head">Prvek výbavy</th>
                  {trims.map((t) => {
                    const isHighlighted = !!(t as any).is_highlighted;
                    const highlightLabel = ((t as any).highlight_label || '').trim() || 'Doporučujeme';
                    return (
                      <th class={`compare-trim-head${isHighlighted ? ' compare-trim-head--highlighted' : ''}`}>
                        {isHighlighted && (
                          <div class="compare-trim-badge" title={highlightLabel}>{highlightLabel}</div>
                        )}
                        <div class="compare-trim-name">{t.name}</div>
                        {t.promo_price && t.list_price && t.promo_price < t.list_price ? (
                          <div class="compare-trim-price-block">
                            <div class="compare-trim-list-strike">{t.list_price.toLocaleString('cs-CZ')} Kč</div>
                            <div class="compare-trim-price compare-trim-price--promo">{t.promo_price.toLocaleString('cs-CZ')} Kč</div>
                          </div>
                        ) : (
                          <div class="compare-trim-price">{trimPrice(t)}</div>
                        )}
                      </th>
                    );
                  })}
                </tr>
              </thead>
              <tbody>
                {compareData.map((cat) => (
                  <Fragment>
                    <tr class="compare-cat-row">
                      <td colspan={trims.length + 1}>{cat.label}</td>
                    </tr>
                    {cat.rows.map((row) => (
                      <tr>
                        <td class="compare-feature">
                          {row.feature}
                        </td>
                        {trims.map((t) => {
                          const v = row.cells[String(t.id)];
                          const hl = !!(t as any).is_highlighted ? ' compare-cell--highlighted' : '';
                          if (v === 'standard') {
                            return (
                              <td class={`compare-cell has${hl}`}>
                                <span class="compare-check">✓</span>
                              </td>
                            );
                          }
                          if (typeof v === 'object' && v && 'price' in v) {
                            return (
                              <td class={`compare-cell optional${hl}`}>
                                <span class="compare-price">{v.price.toLocaleString('cs-CZ')} Kč</span>
                              </td>
                            );
                          }
                          if (typeof v === 'object' && v && 'packageName' in v) {
                            return (
                              <td class={`compare-cell package${hl}`}>
                                <span class="compare-package">{v.packageName}</span>
                              </td>
                            );
                          }
                          return (
                            <td class={`compare-cell missing${hl}`}>
                              <span class="compare-dash">—</span>
                            </td>
                          );
                        })}
                      </tr>
                    ))}
                  </Fragment>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* Pakety s pricing_per_trim */}
      {optionPackages.length > 0 && (() => {
        const slugifyTrim = (s: string) => String(s ?? '')
          .toLowerCase().trim()
          .replace(/\+/g, '-plus').replace(/&/g, '-and')
          .normalize('NFD').replace(/[̀-ͯ]/g, '')
          .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'untitled';
        const trimSlugs = trims.map((t) => ({ name: t.name, slug: slugifyTrim(t.name) }));

        const fmtPkgCell = (v: any) => {
          if (v === 'standard' || v === 'S') return { text: 'V ceně', cls: 'pkg-cell-standard' };
          if (v === 'unavailable' || v === '-' || v === '–' || v == null || v === '') return { text: '—', cls: 'pkg-cell-unavailable' };
          if (typeof v === 'number') return { text: `${v.toLocaleString('cs-CZ')} Kč`, cls: 'pkg-cell-price' };
          const num = parseInt(String(v).replace(/\s/g, ''), 10);
          if (Number.isFinite(num)) return { text: `${num.toLocaleString('cs-CZ')} Kč`, cls: 'pkg-cell-price' };
          return { text: String(v), cls: 'pkg-cell-other' };
        };

        return (
          <div class="compare-packages">
            <h2 class="section-title" style="font-size: clamp(24px, 2.2vw, 32px); margin-top: 64px; margin-bottom: 16px;">
              Volitelné pakety
            </h2>
            <p style="color: var(--text-muted); margin-bottom: 32px;">
              Ceny pro výbavové stupně. <strong>V ceně</strong> = standardně, <strong>—</strong> = nedostupné, číslo = příplatek.
            </p>
            <div class="compare-packages-grid">
              {optionPackages.map((pkg: any) => (
                <article class="pkg-card">
                  <h3 class="pkg-name">{pkg.name}{pkg.code && <span class="pkg-code"> ({pkg.code})</span>}</h3>
                  {pkg.description && <p class="pkg-desc">{pkg.description}</p>}
                  {Array.isArray(pkg.features) && pkg.features.length > 0 && (
                    <ul class="pkg-list">
                      {pkg.features.map((f: string) => (
                        <li>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                          <span>{f}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                  {pkg.pricing_per_trim && typeof pkg.pricing_per_trim === 'object' && (
                    <div class="pkg-pricing">
                      <div class="pkg-pricing-label">Cena za paket:</div>
                      <ul class="pkg-pricing-list">
                        {trimSlugs.map((t) => {
                          // Zkus oba slug varianty (_ i -)
                          const variants = [t.slug, t.slug.replace(/-/g, '_'), t.slug.replace(/_/g, '-')];
                          let raw;
                          for (const k of variants) {
                            if (pkg.pricing_per_trim?.[k] !== undefined) { raw = pkg.pricing_per_trim[k]; break; }
                          }
                          const cell = fmtPkgCell(raw);
                          return (
                            <li>
                              <span class="pkg-pricing-trim">{t.name}</span>
                              <span class={`pkg-pricing-value ${cell.cls}`}>{cell.text}</span>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  )}
                </article>
              ))}
            </div>
          </div>
        );
      })()}

      {(pricelistColors.exterior.length > 0 || pricelistColors.interior.length > 0) && (() => {
        // Build slug → trim name map for pricing_per_trim keys
        const slugify = (s: string) => String(s ?? '')
          .toLowerCase().trim()
          .replace(/\+/g, '-plus').replace(/&/g, '-and')
          .normalize('NFD').replace(/[̀-ͯ]/g, '')
          .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'untitled';
        const trimSlugs = trims.map((t) => ({ name: t.name, slug: slugify(t.name) }));

        // Smart cell — vrátí { text, cls } pro různé hodnoty:
        //   number/numeric string → "14 900 Kč" (orange)
        //   "standard" / "s" / 0  → "V ceně" (green)
        //   "-" / null / "" / "unavailable" → "—" (gray)
        // Pozn.: žádné TS anotace tady — JSX expression je JS, ne TS.
        const fmtCell = (v) => {
          if (v === undefined || v === null || v === '' || v === '-' || v === '–') return { text: '—', cls: 'cell-unavail' };
          const s = typeof v === 'string' ? v.trim().toLowerCase() : '';
          if (s === 'unavailable' || s === 'nedostupné') return { text: '—', cls: 'cell-unavail' };
          if (s === 'standard' || s === 's' || s === 'v ceně' || s === 'v cene') return { text: 'V ceně', cls: 'cell-standard' };
          const num = typeof v === 'number' ? v : parseInt(String(v).replace(/\s/g, ''), 10);
          if (Number.isFinite(num)) {
            if (num === 0) return { text: 'V ceně', cls: 'cell-standard' };
            return { text: `${num.toLocaleString('cs-CZ')} Kč`, cls: 'cell-price' };
          }
          return { text: String(v), cls: 'cell-other' };
        };

        return (
          <section class="colors-pricelist" style="margin-top: 56px;">
            <div class="section-eyebrow">Barvy a příplatky</div>
            <h2 class="section-title">Barevné varianty a jejich cena</h2>
            <p class="muted" style="max-width: 720px;">Tabulkový přehled barev exteriéru a interiéru přesně dle aktuálního ceníku. Ceny v Kč včetně DPH.</p>

            {pricelistColors.exterior.length > 0 && (
              <div class="colors-table-wrap">
                <h3 class="colors-table-title">Exteriér</h3>
                <div class="table-scroll">
                  <table class="colors-table">
                    <thead>
                      <tr>
                        <th>Barva</th>
                        <th>Kód</th>
                        <th>Typ</th>
                        {trimSlugs.map((t) => <th class="num">{t.name}</th>)}
                      </tr>
                    </thead>
                    <tbody>
                      {pricelistColors.exterior.map((c) => (
                        <tr>
                          <td><strong>{c.name}</strong></td>
                          <td class="muted-cell">{c.code ?? '—'}</td>
                          <td>{c.type ?? '—'}</td>
                          {trimSlugs.map((t) => {
                            const r = fmtCell(getPriceForTrim(c.pricing_per_trim, t.slug));
                            return <td class={`num ${r.cls}`}>{r.text}</td>;
                          })}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {pricelistColors.interior.length > 0 && (
              <div class="colors-table-wrap" style="margin-top: 24px;">
                <h3 class="colors-table-title">Interiér</h3>
                <div class="table-scroll">
                  <table class="colors-table">
                    <thead>
                      <tr>
                        <th>Čalounění</th>
                        <th>Kód</th>
                        <th>Materiál</th>
                        {trimSlugs.map((t) => <th class="num">{t.name}</th>)}
                      </tr>
                    </thead>
                    <tbody>
                      {pricelistColors.interior.map((c) => (
                        <tr>
                          <td><strong>{c.name}</strong></td>
                          <td class="muted-cell">{c.code ?? '—'}</td>
                          <td>{c.material ?? '—'}</td>
                          {trimSlugs.map((t) => {
                            const r = fmtCell(getPriceForTrim(c.pricing_per_trim, t.slug));
                            return <td class={`num ${r.cls}`}>{r.text}</td>;
                          })}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            <p class="muted" style="font-size: 12px; margin-top: 12px;">Cena 0 = v základní ceně. „–" = pro daný stupeň výbavy nedostupné. Konkrétní dostupnost ověřte při poptávce.</p>
          </section>
        );
      })()}

      <Disclaimer kind="price" />

      <div style="margin-top: 48px;">
        <a class="btn btn-outline" href={`/model/${rawModel.slug}`}>← Zpět na {rawModel.name}</a>
      </div>

      <div style="margin-top: 24px; padding: 28px; background: var(--bg-soft); border-radius: var(--radius); display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
        <div style="flex: 1; min-width: 280px;">
          <h3 style="margin: 0 0 6px; font-family: var(--font-display); font-weight: 600; font-size: 18px;">
            Líbí se vám výbava? Vyberte si vůz skladem
          </h3>
          <p style="margin: 0; color: var(--text-muted); font-size: 14px;">
            Můžeme připravit nabídku financování nebo testovací jízdu.
          </p>
        </div>
        <div style="display: flex; gap: 10px;">
          <a class="btn btn-outline" href={`/sklad?model=${rawModel.slug}`}>Vozy skladem</a>
          <a class="btn btn-primary" href="/kontakt">Mám zájem</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* === Colors pricelist (sekce pod compare matrix) — sjednoceno s matice === */
  .colors-pricelist .colors-table-title {
    margin: 0;
    padding: 14px 16px 10px;
    background: var(--bg-soft);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
