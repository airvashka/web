---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import DirectusImage from '@components/DirectusImage.astro';
import { directusGet } from '@lib/directus';
import type { Brand, Model } from '@lib/types';

/* ============================================================
   Detail akční nabídky pro model.

   URL: /model/[slug]/akce
   Layout: bílé pozadí, klasický článek — promo obrázek, popis,
   pak 3 tlačítka: Zpět · Skladovky · Mám zájem.

   Render jen pokud promo_active=true (jinak redirect na /model).
   ============================================================ */

export async function getStaticPaths() {
  const models = await directusGet<Model>('models', { fields: ['slug'] });
  return models.map((m) => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params;

const models = await directusGet<Model>('models', {
  filter: { slug: { _eq: slug } },
  limit: 1,
  fields: ['*'],
});
const rawModel = models[0];
if (!rawModel) return Astro.rewrite('/404');

const brands = rawModel.brand
  ? await directusGet<Brand>('brands', { filter: { id: { _eq: rawModel.brand } }, limit: 1 })
  : [];
const brand = brands[0];
if (!brand) return Astro.rewrite('/404');

const todayDate = new Date().toISOString().slice(0, 10);
const promoActive: boolean = !!(rawModel as any).promo_active
  && (((rawModel as any).promo_label) || ((rawModel as any).promo_discount_amount))
  && (!(rawModel as any).promo_valid_to || String((rawModel as any).promo_valid_to) >= todayDate);

if (!promoActive) return Astro.redirect(`/model/${slug}`);

const promoLabel: string = ((rawModel as any).promo_label ?? '').toString().trim();
const promoDescription: string = (rawModel as any).promo_description ?? '';
const promoValidTo: string | null = (rawModel as any).promo_valid_to ?? null;
const promoImage: string | null = (rawModel as any).promo_image ?? null;
const promoImageTransparent: boolean = !!(rawModel as any).promo_image_transparent;
const promoDiscountAmount: number = Number((rawModel as any).promo_discount_amount ?? 0) || 0;

let promoDescriptionHtml = '';
if (promoDescription) {
  try {
    const { marked } = await import('marked');
    const { sanitizeHtml } = await import('@lib/sanitize');
    promoDescriptionHtml = sanitizeHtml(marked.parse(promoDescription) as string);
  } catch {
    promoDescriptionHtml = `<p>${String(promoDescription).replace(/[<>&]/g, '')}</p>`;
  }
}

const headline = promoLabel || (promoDiscountAmount > 0 ? `Sleva ${promoDiscountAmount.toLocaleString('cs-CZ')} Kč` : 'Aktuální akce');
---

<BaseLayout
  title={`Akce — ${brand.name} ${rawModel.name} | SFR Motor`}
  description={headline}
>
  <Breadcrumbs items={[
    { label: brand.name, href: `/${brand.slug}` },
    { label: rawModel.name, href: `/model/${rawModel.slug}` },
    { label: 'Akce' },
  ]} />

  <section class="section akce-page">
    <div class="container" style="max-width: 920px;">
      <div class="section-eyebrow akce-eyebrow">
        Akční nabídka {promoValidTo && (
          <span style="font-weight: 400; text-transform: none; letter-spacing: 0.02em; opacity: 0.7;">
            · do {new Date(promoValidTo).toLocaleDateString('cs-CZ')}
          </span>
        )}
      </div>
      <h1 class="akce-headline">{headline}</h1>

      {promoImage && (
        <div class="akce-image" data-transparent={promoImageTransparent ? 'true' : null}>
          <DirectusImage src={promoImage} alt={headline} widths={[800, 1200, 1600, 2000]} loading="eager" />
        </div>
      )}

      {promoDescriptionHtml && (
        <div class="akce-body" set:html={promoDescriptionHtml} />
      )}

      <div class="akce-cta-row">
        <a class="btn btn-outline" href={`/model/${rawModel.slug}`}>← Zpět na {rawModel.name}</a>
        <a class="btn btn-primary" href={`/sklad?model=${rawModel.slug}`}>Vybrat z akčních vozů →</a>
        <a class="btn btn-outline" href={`/kontakt?form=akce&model=${rawModel.slug}&brand=${brand.slug}`}>Mám zájem o akci</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .akce-page { padding: 56px 0 80px; background: #fff; }
  .akce-eyebrow { color: var(--accent); margin-bottom: 10px; }
  .akce-headline {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(28px, 3.4vw, 44px);
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 24px;
  }
  .akce-image {
    width: 100%;
    margin: 8px 0 28px;
    border-radius: var(--radius);
    overflow: hidden;
    background: rgba(0, 0, 0, 0.04);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.10);
  }
  .akce-image img { display: block; width: 100%; height: auto; }
  .akce-image[data-transparent] { background: #fff; padding: 14px; box-sizing: border-box; }
  .akce-body {
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--ink);
    margin: 0 0 28px;
  }
  .akce-body p { margin: 0 0 14px; }
  .akce-body p:last-child { margin-bottom: 0; }
  .akce-body h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    margin: 28px 0 10px;
    color: var(--ink);
  }
  .akce-body h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    margin: 22px 0 8px;
    color: var(--ink);
  }
  .akce-body ul, .akce-body ol { margin: 0 0 14px 24px; padding: 0; }
  .akce-body li { margin: 4px 0; }
  .akce-body a { color: var(--accent); text-decoration: underline; }
  .akce-body strong { color: var(--ink); font-weight: 700; }
  .akce-cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }
  @media (max-width: 600px) {
    .akce-cta-row .btn { width: 100%; justify-content: center; }
  }
</style>
