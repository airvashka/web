          <div class="a-toolbar">
            <div class="a-result" data-result-count>
              <strong>{vehicles.length}</strong> vozů
            </div>
            <label class="a-sort">
              Seřadit:
              <select class="a-select" data-sort>
                <option value="newest">Nejnovější</option>
                <option value="price-asc">Cena ↑</option>
                <option value="price-desc">Cena ↓</option>
