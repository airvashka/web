---
import BaseLayout from '@layouts/BaseLayout.astro';
import DirectusImage from '@components/DirectusImage.astro';
import FuelIcon from '@components/FuelIcon.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { directusGet } from '@lib/directus';
import { buildStockSlug } from '@lib/stockSlug';
import type { Brand, StockVehicle } from '@lib/types';

/* ============================================================
   /sklad-1 — Design preview "Modern Authorized Dealer" v2
   Reálná data z Directusu + plný filter sidebar + sort.
   Cíl: posoudit jestli tenhle look nahradí /sklad.
   ============================================================ */
export const prerender = false;
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow');

type V = StockVehicle & {
  brand?: { name: string; slug: string };
  model?: { name: string; slug: string; fuel_type?: string;
    promo_active?: boolean; promo_label?: string; promo_discount_amount?: number; promo_valid_to?: string };
  trim_level?: { name: string } | null;
  model_year?: { year: number } | null;
  photos?: Array<{ directus_files_id: string }> | string[];
  transmission?: string;
  drivetrain?: string;
  highlighted?: boolean;
  highlight_label?: string;
  listed_at?: string;
};

const brands = await directusGet<Brand>('brands', { sort: ['sort'], fields: ['id', 'slug', 'name'] }, true);

const vehicles = await directusGet<V>('stock_vehicles', {
  filter: { status: { _eq: 'published' }, availability: { _neq: 'sold' } },
  sort: ['-listed_at', 'sort'],
  fields: [
    'id', 'vin', 'list_price', 'promo_price', 'lowest_price_30d', 'km',
    'condition', 'availability', 'color_code',
    'transmission', 'drivetrain',
    'highlighted', 'highlight_label', 'listed_at',
    'trim_level_snapshot',
    'photos.directus_files_id',
    'brand.name', 'brand.slug',
    'model.name', 'model.slug', 'model.fuel_type',
    'model.promo_active', 'model.promo_label', 'model.promo_discount_amount', 'model.promo_valid_to',
    'model_year.year',
    'trim_level.name',
  ],
}, true);

const fuelLabels: Record<string, string> = { petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro' };

// Unique values pro filtry
const availableFuels = [...new Set(vehicles.map((v) => v.model?.fuel_type).filter(Boolean))] as string[];
const availableConditions = [...new Set(vehicles.map((v) => v.condition).filter(Boolean))] as string[];
const has4wd = vehicles.some((v) => v.drivetrain === '4wd' || v.drivetrain === 'awd');

// Modely seskupené podle značky
type ModelOpt = { slug: string; name: string };
const modelsByBrand = new Map<string, { brandName: string; models: ModelOpt[] }>();
vehicles.forEach((v) => {
  if (!v.brand?.slug || !v.model?.slug) return;
  const bSlug = v.brand.slug;
  if (!modelsByBrand.has(bSlug)) modelsByBrand.set(bSlug, { brandName: v.brand.name, models: [] });
  const group = modelsByBrand.get(bSlug)!;
  if (!group.models.find((m) => m.slug === v.model!.slug)) {
    group.models.push({ slug: v.model.slug, name: v.model.name });
  }
});
const modelGroups = Array.from(modelsByBrand.entries())
  .sort((a, b) => a[1].brandName.localeCompare(b[1].brandName))
  .map(([slug, group]) => ({ brandSlug: slug, brandName: group.brandName, models: group.models.sort((a, b) => a.name.localeCompare(b.name)) }));

const stats = {
  inStock: vehicles.filter(v => v.availability === 'in_stock').length,
  onWay: vehicles.filter(v => v.availability === 'on_the_way').length,
  onOrder: vehicles.filter(v => v.availability === 'on_order').length,
};

const fmtPrice = (n?: number | null) => n ? `${n.toLocaleString('cs-CZ')} Kč` : '—';
const fmtKm = (n?: number | null) => (n === 0 || !n) ? '0 km' : `${n.toLocaleString('cs-CZ')} km`;

function firstPhoto(v: V): string | null {
  if (!Array.isArray(v.photos) || v.photos.length === 0) return null;
  const f: any = v.photos[0];
  return typeof f === 'string' ? f : (f?.directus_files_id ?? null);
}
---

<BaseLayout title="Sklad — Design A v2" description="Preview design A v2">
  <Breadcrumbs items={[{ label: 'Skladové vozy (preview A)' }]} />

  <section class="a-page">
    <div class="a-container">
      <div class="a-preview-note">
        <strong>Náhled designu A — Modern Authorized Dealer (v2)</strong> · Reálná data · Po výběru smazat
      </div>

      <div class="a-hero">
        <h1>Skladové vozy</h1>
        <p>Vyberte si z nabídky {vehicles.length} vozů KGM, OMODA &amp; JAECOO a Farizon.</p>
        <div class="a-stats">
          <div class="a-stat"><span class="a-stat-val">{stats.inStock}</span><span class="a-stat-lbl">Skladem</span></div>
          <div class="a-stat"><span class="a-stat-val">{stats.onWay}</span><span class="a-stat-lbl">Na cestě</span></div>
          <div class="a-stat"><span class="a-stat-val">{stats.onOrder}</span><span class="a-stat-lbl">Na objednání</span></div>
        </div>
      </div>

      <div class="a-layout">
        <!-- SIDEBAR -->
        <aside class="a-sidebar" data-filters>
          <div class="a-sb-head">
            <strong>Filtry</strong>
            <button type="button" class="a-sb-clear" data-reset>Resetovat</button>
          </div>

          <div class="a-fblock">
            <h4>Dostupnost</h4>
            <label><input type="checkbox" value="in_stock" checked data-avail-cb /> Skladem v Praze <span class="a-cnt">{stats.inStock}</span></label>
            <label><input type="checkbox" value="on_the_way" checked data-avail-cb /> Na cestě <span class="a-cnt">{stats.onWay}</span></label>
            <label><input type="checkbox" value="on_order" data-avail-cb /> Na objednání <span class="a-cnt">{stats.onOrder}</span></label>
          </div>

          <div class="a-fblock">
            <h4>Značka</h4>
            <label><input type="radio" name="brand" value="all" checked /> Všechny</label>
            {brands.map((b) => (
              <label><input type="radio" name="brand" value={b.slug} /> {b.name}</label>
            ))}
          </div>

          {modelGroups.length > 0 && (
            <div class="a-fblock">
              <h4>Model</h4>
              <select class="a-select" data-filter-model>
                <option value="all">Všechny modely</option>
                {modelGroups.map((g) => (
                  <optgroup label={g.brandName} data-brand={g.brandSlug}>
                    {g.models.map((m) => (
                      <option value={m.slug} data-brand={g.brandSlug}>{m.name}</option>
                    ))}
                  </optgroup>
                ))}
              </select>
            </div>
          )}

          {availableFuels.length > 0 && (
            <div class="a-fblock">
              <h4>Palivo</h4>
              <label><input type="radio" name="fuel" value="all" checked /> Vše</label>
              {availableFuels.map((f) => (
                <label><input type="radio" name="fuel" value={f} /> {fuelLabels[f] ?? f}</label>
              ))}
            </div>
          )}

          {availableConditions.length > 0 && (
            <div class="a-fblock">
              <h4>Stav</h4>
              <label><input type="radio" name="condition" value="all" checked /> Vše</label>
              {availableConditions.includes('new') && <label><input type="radio" name="condition" value="new" /> Nové</label>}
              {availableConditions.includes('demo') && <label><input type="radio" name="condition" value="demo" /> Předváděcí</label>}
              {availableConditions.includes('used') && <label><input type="radio" name="condition" value="used" /> Ojeté</label>}
            </div>
          )}

          {has4wd && (
            <div class="a-fblock">
              <h4>Pohon</h4>
              <label><input type="radio" name="drivetrain" value="all" checked /> Vše</label>
              <label><input type="radio" name="drivetrain" value="4wd" /> Pouze 4×4</label>
            </div>
          )}
