---
import BaseLayout from '@layouts/BaseLayout.astro';
import DirectusImage from '@components/DirectusImage.astro';
import VideoStrip from '@components/VideoStrip.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { directusGet } from '@lib/directus';
import { buildStockSlug } from '@lib/stockSlug';
import type { Brand, Model } from '@lib/types';

/* ============================================================
   BRAND PAGE — 1:1 podle _design-draft/kgm.jsx
   Sections: BrandHero · WhyBrand · ModelGrid · BrandStrip
   ============================================================ */

export async function getStaticPaths() {
  const brands = await directusGet<Brand>('brands', { fields: ['slug'] });
  return brands.map((b) => ({ params: { brand: b.slug } }));
}

const { brand: brandSlug } = Astro.params;

const brands = await directusGet<Brand>('brands', {
  filter: { slug: { _eq: brandSlug } },
  limit: 1,
});
const brand = brands[0];

if (!brand) {
  return Astro.redirect('/404');
}

// Modely této značky
type ModelWithSub = Model & { sub_brand?: number | null; hero_image?: string; fuel_type?: string };
const allModels = await directusGet<ModelWithSub>('models', {
  filter: { brand: { _eq: brand.id }, status: { _eq: 'published' } },
  sort: ['sort'],
  fields: [
    'id', 'slug', 'name', 'tagline', 'price_from', 'fuel_type', 'body_type',
    'sub_brand', 'hero_image',
  ],
});

// Sub-brandy
const subBrandIds = [...new Set(allModels.map((m) => m.sub_brand).filter(Boolean))] as number[];
const subBrandsRaw = subBrandIds.length > 0
  ? await directusGet<{ id: number; slug: string; name: string }>('sub_brands', {
      filter: { id: { _in: subBrandIds } },
      fields: ['id', 'slug', 'name'],
    })
  : [];
const subBrandsById = new Map(subBrandsRaw.map((s) => [s.id, s]));

// Skladové vozy této značky — počet
const stockOfBrand = await directusGet<{ id: string }>('stock_vehicles', {
  filter: { brand: { _eq: brand.id }, status: { _eq: 'published' }, availability: { _in: ['in_stock', 'on_the_way'] } },
  fields: ['id'],
  limit: 200,
});
const stockCount = stockOfBrand.length;

// Skladové vozy této značky — 4 ukázkové na brand page
const stockSample = await directusGet<any>('stock_vehicles', {
  filter: { brand: { _eq: brand.id }, status: { _eq: 'published' }, availability: { _in: ['in_stock', 'on_the_way'] } },
  sort: ['-listed_at'],
  limit: 4,
  fields: [
    'id', 'condition', 'km', 'list_price', 'promo_price',
    'highlighted', 'highlight_label', 'trim_level_snapshot',
    'color_code', 'color_category',
    'photos.directus_files_id',
    'model.name', 'model.slug', 'model.fuel_type',
    'model.promo_active', 'model.promo_label', 'model.promo_discount_amount', 'model.promo_valid_to',
    'trim_level.name',
    'model_year.year',
  ],
});

// Brand videa (z brand.youtube_video_ids field — pokud existuje)
const brandVideoIds: string[] = Array.isArray((brand as any).youtube_video_ids)
  ? (brand as any).youtube_video_ids
  : [];

const fmtPrice = (n?: number | null) => (n ? `${n.toLocaleString('cs-CZ')} Kč` : '—');
const fmtKm = (n?: number | null) => (n === 0 || !n ? '0 km' : `${n.toLocaleString('cs-CZ')} km`);

// Ostatní brandy pro BrandStrip
const otherBrands = await directusGet<Brand>('brands', {
  filter: { status: { _eq: 'published' }, slug: { _neq: brandSlug } },
  sort: ['sort'],
  fields: ['id', 'slug', 'name', 'tagline'],
  limit: 3,
});

// Fuel mapping pro fuel-tag třídu
const fuelTagClass: Record<string, string> = {
  petrol: 'benzin',
  diesel: 'diesel',
  hybrid: 'hybrid',
  phev: 'phev',
  ev: 'elektro',
};
const fuelLabel: Record<string, string> = {
  petrol: 'Benzín',
  diesel: 'Diesel',
  hybrid: 'Hybrid',
  phev: 'PHEV',
  ev: 'Elektro',
};
const bodyLabel: Record<string, string> = {
  suv: 'SUV',
  hatchback: 'Hatchback',
  sedan: 'Sedan',
  pickup: 'Pick-up',
  van: 'Dodávka',
  mpv: 'MPV',
};

// "Why this brand" — primárně z admin brands fieldů, fallback prázdné/defaultní
type WhyItem = { icon: string; title: string; subtitle: string };
const b = brand as any;
const why = {
  eyebrow: [b.eyebrow_line1 ?? '', b.eyebrow_line2 ?? ''] as [string, string],
  tagline: [b.tagline_line1 ?? '', b.tagline_line2 ?? ''] as [string, string],
  whyEyebrow: b.why_eyebrow ?? `Proč ${brand.name}?`,
  whyTitle: b.why_title ?? '',
  whyIntro: b.why_intro ?? '',
  why: (Array.isArray(b.why_cards) ? b.why_cards : []) as WhyItem[],
  modelsHeadline: b.models_headline ?? `Modely ${brand.name}`,
  bannerTitle: b.banner_title ?? 'Pojďte si vůz vyzkoušet.',
  ctaSecondaryLabel: b.hero_cta_secondary_label ?? 'Modely',
  ctaSecondaryUrl: b.hero_cta_secondary_url ?? '#modely',
};
// Display name (např. "OMODA & JAECOO" velkými ručně)
const displayName = brand.name;

// Brand strip mapping (other brands)
const STRIP: Record<string, { tag: string; ds: string }> = {
  kgm: { tag: 'Korejské SUV', ds: '9 modelů. Spolehlivé pohony 4×4 a štědrá záruka.' },
  'omoda-jaecoo': { tag: 'Nová generace', ds: 'Odvážný design a velkorysá výbava v základu.' },
  farizon: { tag: 'Užitkové elektro', ds: 'Geely Group. SuperVan pro každodenní práci.' },
};

const activeBrand = Astro.params.brand;
---

<BaseLayout
  title={`${brand.name} | SFR Motor`}
  description={brand.description ?? brand.tagline ?? `${brand.name} — modely a skladové vozy u SFR Motor.`}
>
  <Breadcrumbs items={[{ label: brand.name }]} />

  <!-- ===== BRAND HERO ===== -->
  <section class="bhero" data-screen-label="01 Hero">
    <div class="bhero-bg">
      {brand.hero_image && <DirectusImage src={brand.hero_image} alt={`${brand.name} — hero`} aspectRatio="auto" />}
    </div>
    <div class="container bhero-inner">
      <div class="bhero-eyebrow">
        <span>{why.eyebrow[0]}</span>
        <span class="sep">·</span>
        <span>{why.eyebrow[1]}</span>
      </div>
      <h1 class="bhero-title">{displayName}</h1>
      <p class="bhero-tagline">
        {why.tagline[0]}<br />
        {why.tagline[1]}
      </p>
      <div class="bhero-actions">
        <a class="btn btn-primary" href={`/sklad?znacka=${brand.slug}`}>
          Vozy {brand.name} skladem ({stockCount})
        </a>
        {why.ctaSecondaryLabel && why.ctaSecondaryUrl && (
          <a class="btn btn-outline" href={why.ctaSecondaryUrl}>{why.ctaSecondaryLabel}</a>
        )}
      </div>
    </div>
  </section>

  <!-- ===== WHY BRAND ===== -->
  <section class="why" data-screen-label="02 Why">
    <div class="container why-grid">
      <div>
        <div class="section-eyebrow">{why.whyEyebrow}</div>
        <h2 class="why-title">{why.whyTitle}</h2>
      </div>
      <div>
        <p class="why-intro">{why.whyIntro}</p>
        <div class="why-cards">
          {why.why.map((w) => (
            <div class="why-card">
              <div class="icbox">
                {w.icon === 'shield' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>}
                {w.icon === 'axle' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><line x1="7" y1="6" x2="17" y2="6"/><line x1="7" y1="18" x2="17" y2="18"/><line x1="12" y1="6" x2="12" y2="18"/></svg>}
                {w.icon === 'bolt' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
                {w.icon === 'hook' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4"/><circle cx="12" cy="8" r="2"/><path d="M12 10v8a4 4 0 0 1-4 4 4 4 0 0 1-4-4"/></svg>}
                {w.icon === 'spark' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.94 14.06 2 22"/><path d="m13.94 10.06 8-8"/><path d="m17 5 2 2"/><path d="M14 8h6a2 2 0 0 1 2 2v6"/><path d="M8 14H2v6"/></svg>}
                {w.icon === 'globe' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>}
                {w.icon === 'cargo' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M21 3l-7 7"/><rect x="3" y="11" width="18" height="10" rx="1"/><line x1="9" y1="11" x2="9" y2="21"/></svg>}
              </div>
              <div>
                <div class="t">{w.title}</div>
                <div class="s">{w.subtitle}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MODELS GRID ===== -->
  <section class="models" id="modely" data-screen-label="03 Modely">
    <div class="container">
      <div class="models-head">
        <div class="section-eyebrow">Modelová řada</div>
        <h2 class="lead">{why.modelsHeadline}</h2>
      </div>
      {allModels.length === 0 ? (
        <div class="sklad-empty">Modely pro {brand.name} ještě nejsou připravené.</div>
      ) : subBrandsById.size > 0 ? (
        // Brand má sub-brandy (Omoda & Jaecoo) — render po sekcích
        <>
          {Array.from(subBrandsById.values()).map((sb) => {
            const sbModels = allModels.filter((m) => m.sub_brand === sb.id);
            if (sbModels.length === 0) return null;
            return (
              <div class="subbrand-block">
                <div class="subbrand-head">
                  <h3 class="subbrand-name">{sb.name}</h3>
                  <span class="subbrand-count">{sbModels.length} {sbModels.length === 1 ? 'model' : sbModels.length < 5 ? 'modely' : 'modelů'}</span>
                </div>
                <div class="models-grid">
                  {sbModels.map((m) => {
                    const fuelKey = m.fuel_type ?? '';
                    const tagClass = fuelTagClass[fuelKey] ?? 'benzin';
                    const tagLabel = fuelLabel[fuelKey] ?? '';
                    const body = bodyLabel[m.body_type ?? ''] ?? m.body_type ?? '';
                    return (
                      <a class="model-card" href={`/model/${m.slug}`}>
                        <div class="pic">
                          {tagLabel && <span class={`fuel-tag ${tagClass}`}>{tagLabel}</span>}
                          {m.hero_image && <DirectusImage src={m.hero_image} alt={`${brand.name} ${m.name}`} aspectRatio="4/3" />}
                        </div>
                        <div class="model-body">
                          <div class="model-name">{m.name}</div>
                          <p class="model-desc">{m.tagline ?? ''}</p>
                          <div class="model-meta">Karoserie: {body || '—'} · Palivo: {tagLabel || '—'}</div>
                          <div class="model-foot">
                            <div>
                              <div class="price-lab">Cena od</div>
                              <div class="price-val">{m.price_from ? `${m.price_from.toLocaleString('cs-CZ')} Kč` : '—'}</div>
                            </div>
                            <span class="more">
                              Prozkoumat
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                            </span>
                          </div>
                        </div>
                      </a>
                    );
                  })}
                </div>
              </div>
            );
          })}
          {/* Modely bez sub_brand */}
          {allModels.filter((m) => !m.sub_brand).length > 0 && (
            <div class="models-grid">
              {allModels.filter((m) => !m.sub_brand).map((m) => {
                const fuelKey = m.fuel_type ?? '';
                const tagClass = fuelTagClass[fuelKey] ?? 'benzin';
                const tagLabel = fuelLabel[fuelKey] ?? '';
                return (
                  <a class="model-card" href={`/model/${m.slug}`}>
                    <div class="pic">
                      {tagLabel && <span class={`fuel-tag ${tagClass}`}>{tagLabel}</span>}
                      {m.hero_image && <DirectusImage src={m.hero_image} alt={`${brand.name} ${m.name}`} aspectRatio="4/3" />}
                    </div>
                    <div class="model-body">
                      <div class="model-name">{m.name}</div>
                      <p class="model-desc">{m.tagline ?? ''}</p>
                      <div class="model-foot">
                        <div>
                          <div class="price-lab">Cena od</div>
                          <div class="price-val">{m.price_from ? `${m.price_from.toLocaleString('cs-CZ')} Kč` : '—'}</div>
                        </div>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          )}
        </>
      ) : (
        // Brand bez sub-brandů (KGM, Farizon) — jednoduchý grid
        <div class="models-grid">
          {allModels.map((m) => {
            const fuelKey = m.fuel_type ?? '';
            const tagClass = fuelTagClass[fuelKey] ?? 'benzin';
            const tagLabel = fuelLabel[fuelKey] ?? '';
            const body = bodyLabel[m.body_type ?? ''] ?? m.body_type ?? '';
            return (
              <a class="model-card" href={`/model/${m.slug}`}>
                <div class="pic">
                  {tagLabel && <span class={`fuel-tag ${tagClass}`}>{tagLabel}</span>}
                  {m.hero_image && <DirectusImage src={m.hero_image} alt={`${brand.name} ${m.name}`} aspectRatio="4/3" />}
                </div>
                <div class="model-body">
                  <div class="model-name">{m.name}</div>
                  <p class="model-desc">{m.tagline ?? ''}</p>
                  <div class="model-meta">Karoserie: {body || '—'} · Palivo: {tagLabel || '—'}</div>
                  <div class="model-foot">
                    <div>
                      <div class="price-lab">Cena od</div>
                      <div class="price-val">{m.price_from ? `${m.price_from.toLocaleString('cs-CZ')} Kč` : '—'}</div>
                    </div>
                    <span class="more">
                      Prozkoumat
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      )}
      <div class="models-banner">
        <h3>{why.bannerTitle}</h3>
        <div class="models-banner-actions">
          <a class="btn btn-primary" href="/kontakt">Testovací jízda</a>
          <a class="btn btn-outline" href="/kontakt">Poptat vůz</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SKLADOVÉ VOZY TÉTO ZNAČKY ===== -->
  {stockSample.length > 0 && (
    <section class="skladovka" data-screen-label="04 Skladovka">
      <div class="container">
        <div class="skladovka-head">
          <div>
            <div class="section-eyebrow">Skladovka {brand.name}</div>
            <h2>Vozy {brand.name} skladem</h2>
          </div>
          <a class="head-link" href={`/sklad?znacka=${brand.slug}`}>
            Všech {stockCount} vozů
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="skladovka-grid">
          {stockSample.map((v: any) => {
            const isNew = v.condition === 'new';
            const isHl = v.highlighted;
            const customLabel = (v.highlight_label ?? '').toString().trim();
            const today = new Date().toISOString().slice(0, 10);
            const modelPromoActive = !!v.model?.promo_active
              && (v.model.promo_label || v.model.promo_discount_amount)
              && (!v.model.promo_valid_to || String(v.model.promo_valid_to) >= today);
            const modelPromoLabel = (v.model?.promo_label ?? '').toString().trim();
            const modelPromoDiscount = Number(v.model?.promo_discount_amount ?? 0) || 0;
            const pillLabel = modelPromoActive && modelPromoLabel
              ? modelPromoLabel
              : isHl
                ? (customLabel || 'Novinka')
                : isNew ? 'Nové' : 'Skladem';
            const pillClass = (modelPromoActive || isHl || isNew) ? ' is-new' : '';
            const photoId = v.photos?.[0]?.directus_files_id;
            const trim = v.trim_level_snapshot?.name ?? '';
            const modelName = v.model?.name ?? 'Vůz';
            const carYear = v.model_year?.year ?? '';
            const conditionLabel = v.condition === 'new' ? 'Nové' : v.condition === 'demo' ? 'Předváděcí' : 'Ojeté';
            const price = v.promo_price ?? v.list_price;
            return (
              <a class="scard" href={`/sklad/${buildStockSlug(v, brand, v.model, v.trim_level ?? { name: trim })}`}>
                <div class="pic">
                  {photoId && <DirectusImage src={photoId} alt={`${brand.name} ${modelName}`} aspectRatio="4/3" />}
                </div>
                <div class="body">
                  <span class={`pill${pillClass}`}>{pillLabel}</span>
                  <div class="nm">{brand.name} {modelName}</div>
                  <div class="var">{trim}</div>
                  <div class="meta">
                    {carYear && <span>{carYear}</span>}
                    <span class="dot">{fmtKm(v.km)}</span>
                    <span class="dot">{conditionLabel}</span>
                  </div>
                  <div class="price">{fmtPrice(price)}</div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ===== BRAND VIDEA ===== -->
  <VideoStrip
    ids={brandVideoIds}
    eyebrow={`Videa ${brand.name}`}
    title={`${brand.name} v pohybu`}
    background="soft"
  />

  <!-- ===== BRAND STRIP (jiné značky) ===== -->
  <section class="brand-strip" data-screen-label="04 Ostatní značky">
    <div class="container">
      <div class="section-eyebrow">Další značky u SFR Motor</div>
      <h2 class="why-title" style="margin-bottom: 40px;">Tři značky pod jednou střechou.</h2>
      <div class="brand-strip-grid">
        {[brand, ...otherBrands].slice(0, 3).map((b) => {
          const strip = STRIP[b.slug] ?? { tag: '', ds: b.tagline ?? '' };
          const isActive = b.slug === activeBrand;
          return (
            <a class={`brand-tile${isActive ? ' is-active' : ''}`} href={`/${b.slug}`}>
              <div class="tag">{strip.tag}</div>
              <div class="nm">{b.name}</div>
              <div class="ds">{strip.ds}</div>
              <span class="more">
                {isActive ? 'Aktuální značka' : 'Prozkoumat'}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
