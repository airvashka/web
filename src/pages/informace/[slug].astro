---
import StaticPage from '@components/StaticPage.astro';
import { directusGet } from '@lib/directus';

/* Informační / právní stránky pod /informace/{slug}.
   Obsah z Directus kolekce `pages`, sekce "informace". */

interface PageItem { slug: string; }

export async function getStaticPaths() {
  const pages = await directusGet<PageItem>('pages', {
    filter: { status: { _eq: 'published' }, section: { _eq: 'informace' } },
    fields: ['slug'],
    limit: 100,
  });
  return pages.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
---

<StaticPage slug={slug} parent={{ label: 'Informace', href: '/informace/podminky' }} />
