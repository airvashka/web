---
/**
 * Ceník uploader — admin stránka (Stage 2: matrix view).
 *
 * Flow:
 *   1) Login Directus
 *   2) Brand → Model → Year cascade
 *   3) Upload PDF
 *   4) Analyzovat → AI vrátí matrix JSON (trims, sections, packages, colors, tech)
 *   5) Review matrix s color-coded buňkami, klik na cell = edit
 *   6) Uložit → server transform matrix → Directus tables
 */
export const prerender = false;

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? import.meta.env.DIRECTUS_URL ?? '';
---

<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Ceník uploader — SFR Motor admin</title>
  <style is:global>
    body { font-family: system-ui, -apple-system, sans-serif; max-width: 1400px; margin: 0 auto; padding: 24px; color: #1a1a1a; background: #fafafa; }
    h1 { font-size: 24px; margin-bottom: 8px; }
    h2 { font-size: 18px; margin: 0 0 12px; }
    .muted { color: #666; font-size: 14px; }
    .panel { background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 20px; margin-bottom: 16px; }
    label { display: block; font-weight: 500; font-size: 13px; margin-top: 8px; margin-bottom: 4px; }
    input[type="email"], input[type="password"], input[type="text"], input[type="number"], select {
      width: 100%; padding: 8px 12px; border: 1px solid #ccc; border-radius: 6px; font-size: 14px; box-sizing: border-box;
    }
    select:disabled { background: #f5f5f5; color: #999; }
    button { background: #1f6feb; color: white; border: 0; padding: 9px 18px; border-radius: 6px; cursor: pointer; font-size: 14px; font-weight: 500; }
    button:hover { background: #1858bb; }
    button:disabled { background: #ccc; cursor: not-allowed; }
    button.secondary { background: #6b6b72; }
    button.secondary:hover { background: #555; }
    .drop-zone { border: 2px dashed #aaa; border-radius: 8px; padding: 28px; text-align: center; cursor: pointer; }
    .drop-zone:hover, .drop-zone.dragover { background: #eef4ff; border-color: #1f6feb; }
    .drop-zone.has-file { background: #f0fff0; border-color: #2da64a; border-style: solid; }
    .error { color: #b43a2c; padding: 10px; background: #fef0ef; border-left: 4px solid #b43a2c; margin-top: 10px; white-space: pre-wrap; }
    .success { color: #1e7b5f; padding: 10px; background: #f0fdf6; border-left: 4px solid #1e7b5f; margin-top: 10px; }
    .hidden { display: none !important; }
    .row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    .meta { display: flex; gap: 8px; font-size: 12px; color: #555; margin-top: 8px; flex-wrap: wrap; }
    .meta span { background: #eef; padding: 2px 8px; border-radius: 4px; }

    /* Tabs */
    .tabs { display: flex; gap: 4px; border-bottom: 2px solid #e0e0e0; margin-bottom: 16px; overflow-x: auto; }
    .tab-btn { background: transparent; color: #666; border: 0; padding: 10px 16px; border-radius: 6px 6px 0 0; font-weight: 500; white-space: nowrap; }
    .tab-btn.active { background: #1f6feb; color: white; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    .save-bar { position: sticky; bottom: 0; background: white; border-top: 2px solid #e0e0e0; margin-top: 16px; padding: 14px 18px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 -2px 12px rgba(0,0,0,0.06); border-radius: 0 0 8px 8px; }
    .save-bar button { padding: 11px 22px; font-size: 14px; }

    pre.raw-json { background: #1e1e2e; color: #cdd6f4; padding: 14px; border-radius: 6px; overflow: auto; font-size: 11px; max-height: 600px; }

    /* Per-trim editor */
    .trim-tabs {
      display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px;
      border-bottom: 2px solid #e5e5e5; padding-bottom: 0;
    }
    .trim-tab-btn {
      background: #f5f5f7; border: 1px solid #d0d0d5; border-bottom: 2px solid transparent;
      padding: 10px 18px; cursor: pointer; border-radius: 6px 6px 0 0;
      display: flex; flex-direction: column; align-items: flex-start; gap: 2px;
      font-size: 14px; line-height: 1.2;
    }
    .trim-tab-btn:hover { background: #e8e8ed; }
    .trim-tab-btn.active {
      background: #1f6feb; color: white; border-color: #1f6feb;
      border-bottom-color: #1f6feb;
      transform: translateY(2px);
    }
    .trim-tab-btn strong { font-size: 14px; font-weight: 700; }
    .trim-tab-btn .trim-tab-price { font-size: 11px; font-weight: 500; opacity: 0.8; }
    .trim-pane { display: none; padding: 14px 0; }
    .trim-pane.active { display: block; }

    .trim-header-row {
      display: grid; grid-template-columns: 1fr 220px; gap: 14px;
      padding: 14px; background: #f9f9fc; border-radius: 6px;
      margin-bottom: 18px;
    }
    .trim-header-row input { width: 100%; box-sizing: border-box; padding: 8px 10px; font-size: 14px; border: 1px solid #d0d0d5; border-radius: 4px; }

    .trim-section-heading {
      font-size: 14px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.06em; color: #1a1a2e;
      margin: 22px 0 10px; padding: 8px 12px;
      background: linear-gradient(180deg, #2f9b5c 0%, #1e7b47 100%);
      color: white; border-radius: 5px;
    }
    .trim-section-heading .muted { color: rgba(255,255,255,0.8); font-weight: 400; }

    .feat-section {
      border: 1px solid #e0e0e0; border-radius: 6px; padding: 8px 12px;
      margin-bottom: 8px; background: white;
    }
    .feat-section[open] { border-color: #1f6feb33; }
    .feat-section summary {
      display: flex; align-items: center; gap: 10px; cursor: pointer;
      list-style: none;
    }
    .feat-section summary::-webkit-details-marker { display: none; }
    .feat-section summary::before {
      content: '▶'; color: #999; transition: transform .15s;
    }
    .feat-section[open] summary::before { transform: rotate(90deg); }
    .feat-section .section-title-input {
      flex: 1; border: none; background: transparent;
      font-weight: 700; font-size: 14px; padding: 4px 6px;
      text-transform: uppercase; letter-spacing: 0.04em; color: #1a1a2e;
    }
    .feat-section .section-title-input:focus { background: #eef6ff; outline: 1px solid #1f6feb; border-radius: 3px; }
    .feat-section .btn-remove-section,
    .opt-table .btn-remove-optional {
      background: transparent; border: none; color: #b43a2c;
      font-size: 18px; cursor: pointer; padding: 2px 8px;
      border-radius: 4px; line-height: 1;
    }
    .feat-section .btn-remove-section:hover,
    .opt-table .btn-remove-optional:hover { background: #fee; }
    .feat-section textarea {
      width: 100%; box-sizing: border-box; margin-top: 8px;
      padding: 8px 10px; font-size: 13px; line-height: 1.5;
      border: 1px solid #d0d0d5; border-radius: 4px;
      font-family: inherit; resize: vertical;
    }
    .feat-section textarea:focus { border-color: #1f6feb; outline: 2px solid #1f6feb33; }

    .btn-add-section, .btn-add-optional {
      background: #2f9b5c; color: white; border: none;
      padding: 7px 16px; border-radius: 4px; cursor: pointer;
      font-size: 13px; margin: 4px 0 12px;
    }
    .btn-add-section:hover, .btn-add-optional:hover { background: #267a47; }

    .opt-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 6px; }
    .opt-table th { background: #f5f5f7; padding: 8px 10px; text-align: left; font-weight: 600; }
    .opt-table td { padding: 4px 6px; border-bottom: 1px solid #f0f0f0; }
    .opt-table input { width: 100%; box-sizing: border-box; padding: 6px 8px; font-size: 13px; border: 1px solid transparent; background: transparent; border-radius: 3px; }
    .opt-table input:focus { background: white; border-color: #1f6feb; outline: none; }

    /* Cell coloring (used in packages pricing + colors tabs) */
    .cell {
      text-align: center; padding: 6px 8px;
      font-weight: 500; cursor: pointer; min-width: 100px;
      border-bottom: 1px solid #e7eef5;
    }
    .cell:hover { outline: 2px solid #1f6feb; outline-offset: -2px; }
    .cell-standard { background: #d6f5d6; color: #1e7b5f; }
    .cell-optional { background: #ffe8cc; color: #b27516; }
    .cell-package { background: #e8d6f5; color: #6f42c1; }
    .cell-unavailable { background: #f0f0f0; color: #999; }
    .cell-conditional { background: #d6e8f5; color: #1e5f7b; }
    .cell-choice { background: #fff4d6; color: #8b6914; }
    .cell-other { background: #ffd6d6; color: #b43a2c; }

    /* ── Maticový editor výbavy ── */
    .matrix-scroll { overflow: auto; max-height: 72vh; border: 1px solid #e0e0e0; border-radius: 8px; }
    .matrix-edit { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 13px; min-width: 560px; }
    .matrix-edit th, .matrix-edit td { border-bottom: 1px solid #eee; }
    .matrix-edit thead th { background: #fafafa; padding: 8px; vertical-align: top; position: sticky; top: 0; z-index: 5; box-shadow: 0 2px 0 #e0e0e0; }
    .me-feature-head { text-align: left; font-weight: 700; color: #555; min-width: 220px; }
    .me-trim-head { text-align: center; }
    .me-trim-name { width: 100%; box-sizing: border-box; font-weight: 700; text-align: center; border: 1px solid #d0d0d5; border-radius: 4px; padding: 4px 6px; margin-bottom: 3px; }
    .me-trim-move { display: flex; align-items: center; gap: 3px; margin-bottom: 3px; }
    .me-trim-move .me-trim-name { flex: 1 1 auto; min-width: 0; margin-bottom: 0; }
    .me-trim-left, .me-trim-right { flex: 0 0 auto; background: #eef4ff; color: #1f6feb; border: 1px solid #cfe0ff; border-radius: 4px; width: 20px; height: 24px; font-size: 10px; line-height: 1; cursor: pointer; padding: 0; }
    .me-trim-left:disabled, .me-trim-right:disabled { opacity: 0.3; cursor: default; }
    .me-trim-head { border-left: 1px solid #eef0f3; }
    .me-trim-price { width: 100%; box-sizing: border-box; font-size: 11px; text-align: center; border: 1px solid #e0e0e5; border-radius: 4px; padding: 3px 6px; color: #666; }
    .me-section-row td { background: #e8eefc; padding: 9px 8px; border-top: 2px solid #c7d6f5; border-bottom: 1px solid #c7d6f5; }
    .me-section-name { font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; font-size: 12px; color: #1f6feb; border: 1px solid transparent; background: transparent; border-radius: 4px; padding: 4px 6px; min-width: 200px; }
    .me-section-name:focus { background: #fff; border-color: #1f6feb; outline: none; }
    .me-add-row { margin-left: 8px; background: #eef4ff; color: #1f6feb; border: 1px solid #cfe0ff; border-radius: 4px; padding: 3px 9px; font-size: 11px; cursor: pointer; }
    .me-feature { padding: 4px 6px; }
    .me-feature-name { width: 100%; box-sizing: border-box; border: 1px solid transparent; background: transparent; border-radius: 4px; padding: 5px 6px; font-size: 13px; }
    .me-feature-name:focus { background: #fff; border-color: #1f6feb; outline: none; }
    .me-del-row { width: 20px; background: transparent; color: #c0392b; border: none; cursor: pointer; font-size: 15px; line-height: 1; opacity: 0.5; }
    .me-del-row:hover { opacity: 1; }
    .me-row-ctrls { display: flex; align-items: center; gap: 3px; margin-top: 4px; }
    .me-row-up, .me-row-down { background: #eef4ff; color: #1f6feb; border: 1px solid #cfe0ff; border-radius: 4px; width: 22px; height: 20px; font-size: 9px; line-height: 1; cursor: pointer; padding: 0; }
    .me-cell { text-align: center; vertical-align: middle; cursor: pointer; padding: 8px 6px !important; font-weight: 600; user-select: none; border-left: 1px solid #eef0f3; }
    .me-cell:hover { outline: 2px solid #1f6feb; outline-offset: -2px; }
    .me-add-section { background: #2f9b5c; color: #fff; border: none; border-radius: 5px; padding: 7px 16px; font-size: 12px; cursor: pointer; }

    /* ── Cell menu (popover) ── */
    .cell-menu { position: absolute; z-index: 1000; background: #fff; border: 1px solid #d0d0d5; border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.16); padding: 5px; min-width: 180px; display: flex; flex-direction: column; gap: 2px; }
    .cell-menu-btn { text-align: left; background: transparent; border: none; border-radius: 5px; padding: 8px 10px; font-size: 13px; cursor: pointer; color: #222; }
    .cell-menu-btn:hover { background: #f0f4ff; }
    .cell-menu-btn.cm-standard { color: #1e7b5f; font-weight: 600; }
    .cell-menu-btn.cm-price { color: #b27516; font-weight: 600; }
    .cell-menu-btn.cm-package { color: #6f42c1; }
    .cell-menu-btn.cm-none { color: #999; }
    .cell-menu-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: #999; padding: 6px 10px 2px; }

    /* Pakety editor */
    .pkg-card { border: 1px solid #e0e0e0; padding: 14px 16px; }
    .pkg-card[open] { border-color: #2f9b5c; }
    .pkg-lab {
      display: block; font-weight: 600; font-size: 12px;
      letter-spacing: 0.04em; text-transform: uppercase;
      color: #555; margin-bottom: 4px;
    }
    .pkg-card input[type="text"], .pkg-card textarea {
      width: 100%; box-sizing: border-box;
      padding: 7px 10px; font-size: 13px;
      border: 1px solid #d0d0d5; border-radius: 4px;
      font-family: inherit;
    }
    .pkg-card input[type="text"]:focus, .pkg-card textarea:focus {
      border-color: #1f6feb; outline: 2px solid #1f6feb33;
    }
    .pkg-card textarea { resize: vertical; min-height: 70px; line-height: 1.5; }
    .btn-link { background: none; border: none; color: #1f6feb; text-decoration: underline; cursor: pointer; padding: 0; font-size: inherit; }
  </style>
</head>
<body>
  <h1>Ceník uploader</h1>
  <p class="muted">PDF → AI extract → review po výbavových stupních → uložit do Directus. Pro každý výbavový stupeň: <em>co dostane zákazník</em> + <em>co si může dokoupit</em>.</p>

  <!-- LOGIN -->
  <div class="panel" id="login-panel">
    <h2>1. Přihlášení do Directus</h2>
    <label for="email">Email</label>
    <input type="email" id="email" placeholder="tvůj@email.cz" autocomplete="username" />
    <label for="password">Heslo</label>
    <input type="password" id="password" placeholder="zadej heslo" autocomplete="current-password" />
    <button id="login-btn" style="margin-top: 12px;">Přihlásit</button>
    <div id="login-error" class="error hidden"></div>
  </div>

  <!-- CONTEXT -->
  <div class="panel hidden" id="context-panel">
    <h2>2. Vybrat cíl (model + rok)</h2>
    <div class="row">
      <div>
        <label for="brand-select">Značka</label>
        <select id="brand-select"><option value="">— vyber —</option></select>
      </div>
      <div>
        <label for="model-select">Model</label>
        <select id="model-select" disabled><option value="">— nejdřív značka —</option></select>
      </div>
      <div>
        <label for="year-select">Modelový rok</label>
        <select id="year-select" disabled><option value="">— nejdřív model —</option></select>
      </div>
    </div>
    <div style="margin-top: 14px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
      <button id="load-existing-btn" class="secondary" disabled>Načíst uložený ceník</button>
      <span class="muted" id="load-existing-status">Vyber rok a edituj data přímo — bez nahrávání PDF.</span>
    </div>
  </div>

  <!-- UPLOAD -->
  <div class="panel hidden" id="upload-panel">
    <h2>3. Nahrát PDF ceník</h2>
    <div class="drop-zone" id="drop-zone">
      <p><strong>Drag & drop PDF zde</strong></p>
      <p class="muted">nebo klikni a vyber soubor (max 50 MB)</p>
      <input type="file" id="file-input" accept="application/pdf" style="display: none;" />
    </div>
    <button id="analyze-btn" disabled style="margin-top: 12px;">Analyzovat PDF</button>
    <div id="analyze-status" class="muted" style="margin-top: 8px;"></div>
    <div id="analyze-error" class="error hidden"></div>
  </div>

  <!-- REVIEW -->
  <div class="panel hidden" id="result-panel">
    <h2>4. Review extrahovaného obsahu</h2>
    <div id="result-summary" class="muted"></div>
    <div class="meta" id="result-meta"></div>

    <div class="tabs" id="tabs" style="margin-top: 20px;">
      <button class="tab-btn active" data-tab="trims">🚗 Výbavové stupně (<span id="count-trims">0</span>)</button>
      <button class="tab-btn" data-tab="packages">📦 Pakety (<span id="count-packages">0</span>)</button>
      <button class="tab-btn" data-tab="colors">🎨 Barvy (<span id="count-colors">0</span>)</button>
      <button class="tab-btn" data-tab="techdata">🔧 Tech data (<span id="count-techdata">0</span>)</button>
      <button class="tab-btn" data-tab="raw">Raw JSON</button>
    </div>

    <div class="tab-content active" data-tab="trims">
      <p class="muted">Pro každý výbavový stupeň: <strong>co dostane zákazník</strong> (features) + <strong>co si může dokoupit</strong> (optional). Klik = editovat.</p>
      <div id="trims-container"></div>
    </div>

    <div class="tab-content" data-tab="packages">
      <div id="packages-container"></div>
    </div>

    <div class="tab-content" data-tab="colors">
      <div id="colors-container"></div>
    </div>

    <div class="tab-content" data-tab="techdata">
      <table class="matrix-table" id="techdata-table">
        <thead><tr><th>Klíč</th><th>Hodnota</th></tr></thead>
        <tbody id="techdata-tbody"></tbody>
      </table>
    </div>

    <div class="tab-content" data-tab="raw">
      <pre class="raw-json" id="raw-json"></pre>
    </div>

    <div class="save-bar">
      <div class="save-summary muted" id="save-summary"></div>
      <div>
        <button class="secondary" id="discard-btn">Zahodit</button>
        <button id="save-btn">Uložit do Directus</button>
      </div>
    </div>

    <div id="save-result" class="hidden" style="margin-top: 16px;"></div>
  </div>

<script is:inline define:vars={{ DIRECTUS_URL }}>
console.log('[cenik] Script loaded. DIRECTUS_URL =', DIRECTUS_URL);

let TOKEN = null;
let REFRESH_TOKEN = null;
let SELECTED_PDF = null;
let CURRENT_DATA = null;

const $ = (id) => document.getElementById(id);
const $$ = (sel, parent = document) => [...parent.querySelectorAll(sel)];

// ─── Directus API ────────────────────────────────────────
async function api(path, opts = {}) {
  const r = await fetch(`${DIRECTUS_URL}${path}`, {
    ...opts,
    headers: {
      'Content-Type': 'application/json',
      ...(TOKEN ? { Authorization: `Bearer ${TOKEN}` } : {}),
      ...opts.headers,
    },
  });
  const text = await r.text();
  let j; try { j = JSON.parse(text); } catch { j = text; }
  if (!r.ok) throw new Error(`${r.status}: ${JSON.stringify(j?.errors ?? j)}`);
  return j;
}

async function refreshAccessToken() {
  if (!REFRESH_TOKEN) return false;
  try {
    const r = await fetch(`${DIRECTUS_URL}/auth/refresh`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ refresh_token: REFRESH_TOKEN, mode: 'json' }),
    });
    if (!r.ok) return false;
    const data = await r.json();
    TOKEN = data.data.access_token;
    REFRESH_TOKEN = data.data.refresh_token;
    sessionStorage.setItem('directus_token', TOKEN);
    sessionStorage.setItem('directus_refresh', REFRESH_TOKEN);
    return true;
  } catch { return false; }
}

// ─── LOGIN ────────────────────────────────────────────────
$('login-btn').addEventListener('click', async () => {
  const email = $('email').value.trim();
  const password = $('password').value;
  if (!email || !password) return;
  $('login-error').classList.add('hidden');
  TOKEN = null;
  REFRESH_TOKEN = null;
  sessionStorage.removeItem('directus_token');
  sessionStorage.removeItem('directus_refresh');
  try {
    const r = await api('/auth/login', { method: 'POST', body: JSON.stringify({ email, password }) });
    TOKEN = r.data.access_token;
    REFRESH_TOKEN = r.data.refresh_token;
    sessionStorage.setItem('directus_token', TOKEN);
    sessionStorage.setItem('directus_refresh', REFRESH_TOKEN);
    $('login-panel').classList.add('hidden');
    $('context-panel').classList.remove('hidden');
    $('upload-panel').classList.remove('hidden');
    await loadBrands();
  } catch (e) {
    $('login-error').textContent = `Login selhal: ${e.message}`;
    $('login-error').classList.remove('hidden');
  }
});

const savedToken = sessionStorage.getItem('directus_token');
const savedRefresh = sessionStorage.getItem('directus_refresh');
if (savedToken) {
  fetch(`${DIRECTUS_URL}/users/me`, { headers: { Authorization: `Bearer ${savedToken}` } })
    .then(async (r) => {
      if (r.ok) {
        TOKEN = savedToken;
        REFRESH_TOKEN = savedRefresh;
        $('login-panel').classList.add('hidden');
        $('context-panel').classList.remove('hidden');
        $('upload-panel').classList.remove('hidden');
        loadBrands();
      } else if (savedRefresh) {
        REFRESH_TOKEN = savedRefresh;
        if (await refreshAccessToken()) {
          $('login-panel').classList.add('hidden');
          $('context-panel').classList.remove('hidden');
          $('upload-panel').classList.remove('hidden');
          loadBrands();
        } else {
          sessionStorage.removeItem('directus_token');
          sessionStorage.removeItem('directus_refresh');
        }
      }
    });
}

// ─── Cascading dropdowns ─────────────────────────────────
async function loadBrands() {
  const r = await api('/items/brands?sort=name&fields=id,name&limit=50');
  const sel = $('brand-select');
  sel.innerHTML = '<option value="">— vyber —</option>';
  for (const b of r.data) sel.innerHTML += `<option value="${b.id}">${escapeHtml(b.name)}</option>`;
}

$('brand-select').addEventListener('change', async (e) => {
  const brandId = e.target.value;
  $('model-select').disabled = !brandId;
  $('year-select').disabled = true;
  $('model-select').innerHTML = '<option value="">— vyber —</option>';
  $('year-select').innerHTML = '<option value="">— nejdřív model —</option>';
  if (!brandId) return;
  const r = await api(`/items/models?filter[brand][_eq]=${brandId}&sort=name&fields=id,name&limit=100`);
  for (const m of r.data) $('model-select').innerHTML += `<option value="${m.id}">${escapeHtml(m.name)}</option>`;
});

$('model-select').addEventListener('change', async (e) => {
  const modelId = e.target.value;
  $('year-select').disabled = !modelId;
  $('year-select').innerHTML = '<option value="">— vyber —</option>';
  if (!modelId) return;
  const r = await api(`/items/model_years?filter[model][_eq]=${modelId}&sort=-year&fields=id,year,version&limit=20`);
  for (const y of r.data) {
    const label = `${y.year}${y.version ? ' ' + y.version : ''}`;
    $('year-select').innerHTML += `<option value="${y.id}">${escapeHtml(label)}</option>`;
  }
});

$('year-select').addEventListener('change', (e) => {
  $('load-existing-btn').disabled = !e.target.value;
});

// ─── Načíst uložený ceník z Directus (edit bez PDF) ──────
$('load-existing-btn').addEventListener('click', loadExisting);

async function loadExisting() {
  const yearId = $('year-select').value;
  if (!yearId) { alert('Vyber modelový rok'); return; }
  const btn = $('load-existing-btn');
  const status = $('load-existing-status');
  btn.disabled = true;
  status.textContent = '⏳ Načítám z Directus...';
  try {
    await refreshAccessToken();
    const [trimsR, pkgsR, yearR] = await Promise.all([
      api(`/items/trim_levels?filter[model_year][_eq]=${yearId}&sort=sort&fields=*&limit=50`),
      api(`/items/option_packages?filter[model_year][_eq]=${yearId}&sort=name&fields=*&limit=50`),
      api(`/items/model_years/${yearId}?fields=technical_data,pricelist_colors_exterior,pricelist_colors_interior`),
    ]);

    const pricingToObj = (p) => {
      if (!p) return {};
      if (Array.isArray(p)) {
        const o = {};
        for (const x of p) if (x && x.trim_slug) o[x.trim_slug] = x.price;
        return o;
      }
      return (typeof p === 'object') ? p : {};
    };

    const trims = (trimsR.data || []).map((t) => ({
      name: t.name,
      list_price: t.list_price,
      features: Array.isArray(t.features)
        ? t.features.map((fe) => ({ section: fe.category ?? fe.section ?? '', items: Array.isArray(fe.items) ? fe.items : [] }))
        : [],
      optional_items: Array.isArray(t.optional_items) ? t.optional_items : [],
      package_items: Array.isArray(t.package_items) ? t.package_items : [],
    }));

    const packages = (pkgsR.data || []).map((p) => ({
      name: p.name,
      code: p.code ?? '',
      contents: Array.isArray(p.features) ? p.features : [],
      pricing_per_trim: pricingToObj(p.pricing_per_trim),
    }));

    const tdRaw = yearR.data?.technical_data;
    const technical_data = {};
    if (Array.isArray(tdRaw)) {
      for (const row of tdRaw) if (row && row.label) technical_data[row.label] = row.value;
    } else if (tdRaw && typeof tdRaw === 'object') {
      Object.assign(technical_data, tdRaw);
    }

    const mapColors = (arr) => (Array.isArray(arr) ? arr : []).map((c) => ({ ...c, pricing_per_trim: pricingToObj(c.pricing_per_trim) }));
    const colors_exterior = mapColors(yearR.data?.pricelist_colors_exterior);
    const colors_interior = mapColors(yearR.data?.pricelist_colors_interior);

    if (!trims.length && !packages.length) {
      status.textContent = '⚠ Pro tento rok zatím nejsou v Directus žádné výbavové stupně ani pakety.';
      btn.disabled = false;
      return;
    }

    const data = {
      detected: { model_name: $('model-select').selectedOptions[0]?.textContent || '' },
      trims, packages, colors_exterior, colors_interior, technical_data,
    };
    CURRENT_DATA = data;
    showReview(data);
    status.textContent = `✓ Načteno: ${trims.length} stupňů, ${packages.length} paketů. Edituj a ulož.`;
  } catch (e) {
    status.textContent = `✗ Načtení selhalo: ${e.message}`;
  } finally {
    btn.disabled = false;
  }
}


// ─── Upload ─────────────────────────────────────────────
const dz = $('drop-zone');
const fi = $('file-input');
dz.addEventListener('click', () => fi.click());
dz.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('dragover'); });
dz.addEventListener('dragleave', () => dz.classList.remove('dragover'));
dz.addEventListener('drop', (e) => { e.preventDefault(); dz.classList.remove('dragover'); if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); });
fi.addEventListener('change', (e) => { if (e.target.files[0]) handleFile(e.target.files[0]); });

function handleFile(f) {
  if (!f.name.toLowerCase().endsWith('.pdf')) { alert('Musí být PDF'); return; }
  SELECTED_PDF = f;
  dz.classList.add('has-file');
  dz.innerHTML = `<p><strong>✓ ${escapeHtml(f.name)}</strong></p><p class="muted">${(f.size / 1024 / 1024).toFixed(2)} MB · klikni pro výměnu</p>`;
  $('analyze-btn').disabled = false;
}

// ─── Analyze ─────────────────────────────────────────────
$('analyze-btn').addEventListener('click', async () => {
  if (!SELECTED_PDF) return;
  const brand = $('brand-select').selectedOptions[0]?.textContent;
  const model = $('model-select').selectedOptions[0]?.textContent;
  const year = $('year-select').selectedOptions[0]?.textContent;
  const yearId = $('year-select').value;
  if (!yearId) { alert('Vyber nejdřív model_year'); return; }
  $('analyze-error').classList.add('hidden');
  $('analyze-btn').disabled = true;

  await refreshAccessToken();

  // 1) Upload PDF do Directus (bypass Vercel body limit)
  $('analyze-status').textContent = '⏳ Uploaduji PDF do Directus...';
  const uploadFd = new FormData();
  uploadFd.append('title', `Cenik ${model || ''} ${year || ''} ${new Date().toISOString().substring(0, 10)}`.trim());
  uploadFd.append('file', SELECTED_PDF);

  let fileId;
  try {
    const upResp = await fetch(`${DIRECTUS_URL}/files`, {
      method: 'POST',
      headers: { Authorization: `Bearer ${TOKEN}` },
      body: uploadFd,
    });
    if (!upResp.ok) throw new Error(`Directus upload ${upResp.status}`);
    const upData = await upResp.json();
    fileId = upData.data?.id;
  } catch (e) {
    $('analyze-error').textContent = `Upload selhal: ${e.message}`;
    $('analyze-error').classList.remove('hidden');
    $('analyze-btn').disabled = false;
    $('analyze-status').textContent = '';
    return;
  }

  // 2) AI parsing
  $('analyze-status').textContent = '⏳ AI parsing běží (~30-90s)...';
  try {
    const r = await fetch('/api/cenik/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${TOKEN}` },
      body: JSON.stringify({ file_id: fileId, context: { brand, model, year, year_id: yearId } }),
    });
    const data = await r.json();
    if (!r.ok) {
      $('analyze-error').textContent = `Chyba: ${data.error || 'unknown'}\n\n${JSON.stringify(data, null, 2).substring(0, 2000)}`;
      $('analyze-error').classList.remove('hidden');
      return;
    }
    CURRENT_DATA = data;
    showReview(data);
  } catch (e) {
    $('analyze-error').textContent = `Chyba: ${e.message}`;
    $('analyze-error').classList.remove('hidden');
  } finally {
    $('analyze-btn').disabled = false;
    $('analyze-status').textContent = '';
  }
});

// ─── REVIEW UI ───────────────────────────────────────────
function showReview(data) {
  $('result-panel').classList.remove('hidden');
  $('save-result').classList.add('hidden');

  // Defensive: tools sometimes return stringified arrays
  const parseIf = (v, fb) => { if (typeof v === 'string') { try { return JSON.parse(v); } catch { return fb; } } return v ?? fb; };
  data.trims = parseIf(data.trims, []);
  data.sections = parseIf(data.sections, []);
  data.packages = parseIf(data.packages, []);
  data.colors_exterior = parseIf(data.colors_exterior, []);
  data.colors_interior = parseIf(data.colors_interior, []);
  data.technical_data = parseIf(data.technical_data, {});
  if (!Array.isArray(data.trims)) data.trims = [];
  if (!Array.isArray(data.sections)) data.sections = [];
  if (!Array.isArray(data.packages)) data.packages = [];

  // Defensive defaults — per-trim schema z analyze
  data.trims          = Array.isArray(data.trims) ? data.trims : [];
  data.packages       = Array.isArray(data.packages) ? data.packages : [];
  data.colors_exterior = Array.isArray(data.colors_exterior) ? data.colors_exterior : [];
  data.colors_interior = Array.isArray(data.colors_interior) ? data.colors_interior : [];

  const totalFeatures = data.trims.reduce((acc, t) =>
    acc + (Array.isArray(t.features) ? t.features.reduce((a, s) => a + (s.items?.length ?? 0), 0) : 0), 0);
  const totalOptional = data.trims.reduce((acc, t) => acc + (t.optional_items?.length ?? 0), 0);
  const tdKeys = Object.keys(data.technical_data ?? {}).length;
  const colorsTotal = data.colors_exterior.length + data.colors_interior.length;

  $('count-trims').textContent = data.trims.length;
  $('count-packages').textContent = data.packages.length;
  $('count-colors').textContent = colorsTotal;
  $('count-techdata').textContent = tdKeys;

  $('result-summary').innerHTML = `
    <strong>Detekováno:</strong>
    ${data.trims.length} výbavových stupňů (${data.trims.map((t) => escapeHtml(t.name)).join(' · ')}),
    ${totalFeatures} features celkem, ${totalOptional} dokoupitelných,
    ${data.packages.length} paketů,
    ${colorsTotal} barev,
    ${tdKeys} tech klíčů.
    ${data.detected?.model_name ? `Model hint: <em>${escapeHtml(data.detected.model_name)}</em>.` : ''}
  `;
  if (data.meta?.usage) {
    $('result-meta').innerHTML = `
      <span>Input: ${data.meta.usage.input_tokens} tok</span>
      <span>Output: ${data.meta.usage.output_tokens} tok</span>
      <span>~$${((data.meta.usage.input_tokens * 0.003 + data.meta.usage.output_tokens * 0.015) / 1000).toFixed(3)}</span>
    `;
  }
  $('save-summary').textContent = `Uloží se do "${$('year-select').selectedOptions[0]?.textContent}"`;

  // Reset transientní matice stav pro novou review session
  MATRIX_DECLARED = [];
  MATRIX_EXTRA_SECTIONS = [];
  renderMatrix();
  renderPackages(data.packages, data.trims);
  renderColors(data.colors_exterior, data.colors_interior, data.trims);
  renderTechData(data.technical_data);
  $('raw-json').textContent = JSON.stringify(data, null, 2);

  $('result-panel').scrollIntoView({ behavior: 'smooth' });
}

/* ════════════════════════════════════════════════════════════
   MATICOVÝ EDITOR výbavy
   Řádky = prvky (po sekcích), sloupce = výbavové stupně.
   Jeden zdroj pravdy = CURRENT_DATA.trims (per-trim pole features /
   optional_items / package_items). Matice je jen derivovaný pohled,
   edity mutují přímo trims (konzistentní s tím, co čte save.ts).

   Stav buňky: standard (✓) | price (cena) | package (paket) | none (—)
   ════════════════════════════════════════════════════════════ */

// Řádky/sekce přidané v UI, které ještě nemají žádná data (jinak by zmizely při re-renderu).
// Transientní — žijí jen v rámci review session, neukládají se.
let MATRIX_DECLARED = [];        // [{ section, feature }]
let MATRIX_EXTRA_SECTIONS = [];  // [sectionName]
const MATRIX_OTHER_SECTION = 'Ostatní';

const featTrim = (s) => String(s ?? '').trim();

// Derivuj sekce + řádky z trims (+ deklarované)
function buildMatrixModel() {
  const trims = CURRENT_DATA.trims || [];
  const sectionOrder = [];
  const seenSec = new Set();
  const featureToSection = new Map();
  const ensureSec = (s) => { if (s && !seenSec.has(s)) { seenSec.add(s); sectionOrder.push(s); } };

  // 1) standardní features → sekce (+ pořadí sekcí)
  for (const t of trims) {
    for (const sec of (t.features || [])) {
      const name = featTrim(sec.section);
      if (!name) continue;
      ensureSec(name);
      for (const it of (sec.items || [])) {
        const f = featTrim(it);
        if (f && !featureToSection.has(f)) featureToSection.set(f, name);
      }
    }
  }
  // 2) optional/package → sekce dle uložené category (jen pokud ji ještě neznáme)
  for (const t of trims) {
    for (const o of (t.optional_items || [])) {
      const f = featTrim(o.name); if (!f) continue;
      if (!featureToSection.has(f)) { const s = featTrim(o.category) || MATRIX_OTHER_SECTION; featureToSection.set(f, s); ensureSec(s); }
    }
    for (const p of (t.package_items || [])) {
      const f = featTrim(p.name); if (!f) continue;
      if (!featureToSection.has(f)) { const s = featTrim(p.category) || MATRIX_OTHER_SECTION; featureToSection.set(f, s); ensureSec(s); }
    }
  }
  // 3) deklarované (+ řádek) PŘEPÍŠOU sekci prvku — explicitní umístění, žádné duplikáty
  for (const s of MATRIX_EXTRA_SECTIONS) ensureSec(s);
  for (const d of MATRIX_DECLARED) {
    if (!d.feature) continue;
    featureToSection.set(d.feature, d.section);
    ensureSec(d.section);
  }

  // 4) řádky — KAŽDÝ prvek právě jednou, do své (jediné) sekce
  const sectionRows = new Map();
  const addRow = (s, f) => {
    if (!sectionRows.has(s)) sectionRows.set(s, []);
    const arr = sectionRows.get(s);
    if (!arr.includes(f)) arr.push(f);
  };
  for (const [f, s] of featureToSection) addRow(s, f);

  let order = sectionOrder.filter((s) => sectionRows.has(s));
  for (const s of sectionRows.keys()) if (!order.includes(s)) order.push(s);
  order = order.filter((s) => s !== MATRIX_OTHER_SECTION);
  if (sectionRows.has(MATRIX_OTHER_SECTION)) order.push(MATRIX_OTHER_SECTION);

  return order.map((s) => ({ section: s, features: sectionRows.get(s) || [] }));
}

// Stav buňky pro daný trim + prvek
// Pořadí řádků — přerovnání podkladových polí, aby drželo i po reloadu a na webu
function applyRowOrder(order) {
  const idx = new Map(order.map((f, i) => [f, i]));
  const key = (name) => idx.has(name) ? idx.get(name) : 1e9;
  for (const t of (CURRENT_DATA.trims || [])) {
    for (const sec of (t.features || [])) {
      if (Array.isArray(sec.items)) sec.items.sort((a, b) => key(featTrim(a)) - key(featTrim(b)));
    }
    if (Array.isArray(t.optional_items)) t.optional_items.sort((a, b) => key(featTrim(a.name)) - key(featTrim(b.name)));
    if (Array.isArray(t.package_items)) t.package_items.sort((a, b) => key(featTrim(a.name)) - key(featTrim(b.name)));
  }
}
function moveRow(section, feature, dir) {
  const model = buildMatrixModel();
  const sec = model.find((s) => s.section === section);
  if (!sec) return;
  const i = sec.features.indexOf(feature);
  const j = i + dir;
  if (i < 0 || j < 0 || j >= sec.features.length) return;
  const secF = sec.features.slice();
  const tmp = secF[i]; secF[i] = secF[j]; secF[j] = tmp;
  const order = [];
  for (const s of model) {
    if (s.section === section) order.push(...secF);
    else order.push(...s.features);
  }
  applyRowOrder(order);
  renderMatrix();
}

function cellStateFor(t, feature) {
  for (const sec of (t.features || [])) {
    if ((sec.items || []).some((it) => featTrim(it) === feature)) return { state: 'standard' };
  }
  const o = (t.optional_items || []).find((x) => featTrim(x.name) === feature);
  if (o) return { state: 'price', price: o.price };
  const p = (t.package_items || []).find((x) => featTrim(x.name) === feature);
  if (p) return { state: 'package', package_code: p.package_code, package_name: p.package_name };
  return { state: 'none' };
}

// Odeber prvek ze všech tří polí daného trimu
function clearFeatureFromTrim(t, feature) {
  for (const sec of (t.features || [])) sec.items = (sec.items || []).filter((it) => featTrim(it) !== feature);
  t.optional_items = (t.optional_items || []).filter((o) => featTrim(o.name) !== feature);
  t.package_items = (t.package_items || []).filter((p) => featTrim(p.name) !== feature);
}

// Nastav stav buňky (mutuje CURRENT_DATA.trims[ti])
function setCell(ti, section, feature, newState, extra) {
  const t = CURRENT_DATA.trims[ti];
  if (!Array.isArray(t.features)) t.features = [];
  if (!Array.isArray(t.optional_items)) t.optional_items = [];
  if (!Array.isArray(t.package_items)) t.package_items = [];
  clearFeatureFromTrim(t, feature);
  if (newState === 'standard') {
    let sec = t.features.find((s) => featTrim(s.section) === section);
    if (!sec) { sec = { section, items: [] }; t.features.push(sec); }
    if (!Array.isArray(sec.items)) sec.items = [];
    if (!sec.items.includes(feature)) sec.items.push(feature);
  } else if (newState === 'price') {
    t.optional_items.push({ name: feature, code: '', price: extra.price, category: section });
  } else if (newState === 'package') {
    t.package_items.push({
      name: feature,
      package_code: extra.package_code || '',
      package_name: extra.package_name || extra.package_code || '',
      category: section,
    });
  }
  // 'none' → nic (už vyčištěno)
}

// Přejmenuj prvek napříč všemi stupni
function renameFeature(oldName, newName) {
  newName = featTrim(newName);
  if (!newName || newName === oldName) return;
  for (const t of CURRENT_DATA.trims) {
    for (const sec of (t.features || [])) sec.items = (sec.items || []).map((it) => (featTrim(it) === oldName ? newName : it));
    for (const o of (t.optional_items || [])) if (featTrim(o.name) === oldName) o.name = newName;
    for (const p of (t.package_items || [])) if (featTrim(p.name) === oldName) p.name = newName;
  }
  for (const d of MATRIX_DECLARED) if (d.feature === oldName) d.feature = newName;
}

function renameSection(oldName, newName) {
  newName = featTrim(newName);
  if (!newName || newName === oldName) return;
  for (const t of CURRENT_DATA.trims) for (const sec of (t.features || [])) if (featTrim(sec.section) === oldName) sec.section = newName;
  for (const d of MATRIX_DECLARED) if (d.section === oldName) d.section = newName;
  for (let i = 0; i < MATRIX_EXTRA_SECTIONS.length; i++) if (MATRIX_EXTRA_SECTIONS[i] === oldName) MATRIX_EXTRA_SECTIONS[i] = newName;
}

// Smaž prvek (řádek) ze všech stupňů
function deleteFeatureRow(feature) {
  for (const t of CURRENT_DATA.trims) clearFeatureFromTrim(t, feature);
  MATRIX_DECLARED = MATRIX_DECLARED.filter((d) => d.feature !== feature);
}

// ─── Cell menu (popover) ─────────────────────────────────
function closeCellMenu() {
  document.querySelectorAll('.cell-menu').forEach((m) => m.remove());
}

function openCellMenu(anchorEl, ti, section, feature) {
  closeCellMenu();
  const menu = document.createElement('div');
  menu.className = 'cell-menu';

  const act = (fn) => { fn(); closeCellMenu(); renderMatrix(); };
  const mk = (label, cls, fn) => {
    const b = document.createElement('button');
    b.type = 'button';
    b.className = 'cell-menu-btn ' + (cls || '');
    b.textContent = label;
    b.addEventListener('click', (e) => { e.stopPropagation(); act(fn); });
    return b;
  };

  menu.appendChild(mk('✓  V ceně', 'cm-standard', () => setCell(ti, section, feature, 'standard')));
  menu.appendChild(mk('Příplatek…', 'cm-price', () => {
    const cur = cellStateFor(CURRENT_DATA.trims[ti], feature);
    const curVal = (cur.state === 'price' && typeof cur.price === 'number') ? cur.price : '';
    const v = prompt('Cena příplatku v Kč:', curVal);
    if (v === null) return;
    const num = parseInt(String(v).replace(/\s/g, ''), 10);
    if (Number.isFinite(num)) setCell(ti, section, feature, 'price', { price: num });
  }));

  const pkgs = CURRENT_DATA.packages || [];
  const lbl = document.createElement('div');
  lbl.className = 'cell-menu-label';
  lbl.textContent = 'V paketu:';
  menu.appendChild(lbl);
  if (pkgs.length) {
    for (const p of pkgs) {
      const nm = p.name || p.code || '(paket)';
      menu.appendChild(mk(nm, 'cm-package', () => setCell(ti, section, feature, 'package', { package_code: p.code || '', package_name: p.name || p.code || '' })));
    }
  } else {
    menu.appendChild(mk('Zadat paket ručně…', 'cm-package', () => {
      const nm = prompt('Název paketu:');
      if (nm && nm.trim()) setCell(ti, section, feature, 'package', { package_code: '', package_name: nm.trim() });
    }));
  }

  menu.appendChild(mk('—  Nedostupné', 'cm-none', () => setCell(ti, section, feature, 'none')));

  document.body.appendChild(menu);
  // Fixed pozice ve viewport souřadnicích — robustní vůči scrollu i sticky prvkům.
  menu.style.position = 'fixed';
  const r = anchorEl.getBoundingClientRect();
  const mw = menu.offsetWidth || 200;
  const mh = menu.offsetHeight || 280;
  const vw = document.documentElement.clientWidth;
  const vh = window.innerHeight;
  let left = r.left;
  if (left + mw > vw - 8) left = vw - mw - 8;
  left = Math.max(8, left);
  let top = r.bottom + 4;
  // když se dole nevejde, překlop menu NAD buňku
  if (top + mh > vh - 8) {
    top = r.top - mh - 4;
    if (top < 8) top = Math.max(8, vh - mh - 8);
  }
  menu.style.top = top + 'px';
  menu.style.left = left + 'px';
  // zavři klikem mimo (po aktuálním clicku)
  setTimeout(() => document.addEventListener('click', closeCellMenu, { once: true }), 0);
}

// ─── Render matice ───────────────────────────────────────
function renderMatrix() {
  const trims = CURRENT_DATA.trims || [];
  const container = $('trims-container');
  if (!trims.length) {
    container.innerHTML = '<p class="muted">Žádné výbavové stupně detekovány.</p>';
    return;
  }
  const model = buildMatrixModel();
  const colspan = trims.length + 1;

  let html = '<p class="muted" style="margin-bottom:10px;">Klikni do buňky a zvol stav: <strong>✓ v ceně</strong> · <strong>příplatek</strong> · <strong>paket</strong> · <strong>— nedostupné</strong>. Název prvku přepíšeš přímo v řádku (změní se u všech stupňů).</p>';
  html += '<div class="matrix-scroll"><table class="matrix-edit"><thead><tr>';
  html += '<th class="me-feature-head">Prvek výbavy</th>';
  trims.forEach((t, ti) => {
    html += `<th class="me-trim-head">
      <div class="me-trim-move">
        <button type="button" class="me-trim-left" data-ti="${ti}" title="Posunout doleva"${ti === 0 ? ' disabled' : ''}>◀</button>
        <input class="me-trim-name" data-ti="${ti}" type="text" value="${escapeAttr(t.name ?? '')}" placeholder="Stupeň" />
        <button type="button" class="me-trim-right" data-ti="${ti}" title="Posunout doprava"${ti === trims.length - 1 ? ' disabled' : ''}>▶</button>
      </div>
      <input class="me-trim-price" data-ti="${ti}" type="text" value="${t.list_price ?? ''}" placeholder="cena Kč" />
    </th>`;
  });
  html += '</tr></thead><tbody>';

  for (const sec of model) {
    html += `<tr class="me-section-row"><td colspan="${colspan}">
      <input class="me-section-name" data-old="${escapeAttr(sec.section)}" type="text" value="${escapeAttr(sec.section)}" />
      <button type="button" class="me-add-row" data-section="${escapeAttr(sec.section)}">+ řádek</button>
    </td></tr>`;
    for (const feature of sec.features) {
      html += `<tr><td class="me-feature">
        <input class="me-feature-name" data-old="${escapeAttr(feature)}" type="text" value="${escapeAttr(feature)}" />
        <span class="me-row-ctrls">
          <button type="button" class="me-row-up" data-section="${escapeAttr(sec.section)}" data-feature="${escapeAttr(feature)}" title="Posunout nahoru">▲</button>
          <button type="button" class="me-row-down" data-section="${escapeAttr(sec.section)}" data-feature="${escapeAttr(feature)}" title="Posunout dolů">▼</button>
          <button type="button" class="me-del-row" data-feature="${escapeAttr(feature)}" title="Smazat řádek">×</button>
        </span>
      </td>`;
      trims.forEach((t, ti) => {
        const st = cellStateFor(t, feature);
        let cls = 'cell-unavailable', txt = '–';
        if (st.state === 'standard') { cls = 'cell-standard'; txt = '✓'; }
        else if (st.state === 'price') { cls = 'cell-optional'; txt = (typeof st.price === 'number' ? st.price.toLocaleString('cs-CZ') : st.price) + ' Kč'; }
        else if (st.state === 'package') { cls = 'cell-package'; txt = st.package_name || st.package_code || 'paket'; }
        html += `<td class="cell me-cell ${cls}" data-ti="${ti}" data-section="${escapeAttr(sec.section)}" data-feature="${escapeAttr(feature)}" title="Klik = změnit">${escapeHtml(txt)}</td>`;
      });
      html += '</tr>';
    }
  }
  html += `<tr><td colspan="${colspan}" style="padding-top:10px;"><button type="button" class="me-add-section">+ Přidat sekci</button></td></tr>`;
  html += '</tbody></table></div>';
  // Zachovej scroll pozici — re-render jinak skočí nahoru po každé úpravě
  const _prevBox = container.querySelector('.matrix-scroll');
  const _prevTop = _prevBox ? _prevBox.scrollTop : 0;
  const _prevWin = window.scrollY;
  container.innerHTML = html;
  wireMatrix(container);
  const _newBox = container.querySelector('.matrix-scroll');
  if (_newBox) _newBox.scrollTop = _prevTop;
  window.scrollTo(0, _prevWin);
  $('count-trims').textContent = trims.length;
}

function wireMatrix(container) {
  // Trim název / cena — live mutace bez re-renderu (zachová focus)
  container.querySelectorAll('.me-trim-name').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const ti = parseInt(e.target.dataset.ti, 10);
      CURRENT_DATA.trims[ti].name = e.target.value;
    });
  });
  container.querySelectorAll('.me-trim-price').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const ti = parseInt(e.target.dataset.ti, 10);
      const v = parseInt(e.target.value.replace(/\s/g, ''), 10);
      CURRENT_DATA.trims[ti].list_price = Number.isFinite(v) ? v : undefined;
    });
  });

  // Posun sloupce (stupně) doleva/doprava
  const moveTrim = (from, to) => {
    if (to < 0 || to >= CURRENT_DATA.trims.length) return;
    const arr = CURRENT_DATA.trims;
    const [m] = arr.splice(from, 1);
    arr.splice(to, 0, m);
    renderMatrix();
  };
  container.querySelectorAll('.me-trim-left').forEach((btn) => {
    btn.addEventListener('click', (e) => { e.preventDefault(); const ti = parseInt(btn.dataset.ti, 10); moveTrim(ti, ti - 1); });
  });
  container.querySelectorAll('.me-trim-right').forEach((btn) => {
    btn.addEventListener('click', (e) => { e.preventDefault(); const ti = parseInt(btn.dataset.ti, 10); moveTrim(ti, ti + 1); });
  });

  // Přejmenování sekce (na blur/change)
  container.querySelectorAll('.me-section-name').forEach((inp) => {
    inp.addEventListener('change', (e) => {
      renameSection(e.target.dataset.old, e.target.value);
      renderMatrix();
    });
  });

  // Přejmenování prvku (na blur/change) — napříč stupni
  container.querySelectorAll('.me-feature-name').forEach((inp) => {
    inp.addEventListener('change', (e) => {
      renameFeature(e.target.dataset.old, e.target.value);
      renderMatrix();
    });
  });

  // Klik do buňky → menu
  container.querySelectorAll('.me-cell').forEach((td) => {
    td.addEventListener('click', (e) => {
      e.stopPropagation();
      const ti = parseInt(td.dataset.ti, 10);
      openCellMenu(td, ti, td.dataset.section, td.dataset.feature);
    });
  });

  // Přidat řádek do sekce
  container.querySelectorAll('.me-add-row').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const section = btn.dataset.section;
      const name = prompt('Název nového prvku výbavy:');
      if (!name || !name.trim()) return;
      const f = name.trim();
      if (!MATRIX_DECLARED.some((d) => d.section === section && d.feature === f)) {
        MATRIX_DECLARED.push({ section, feature: f });
      }
      renderMatrix();
    });
  });

  // Posun řádku nahoru/dolů (v rámci sekce)
  container.querySelectorAll('.me-row-up').forEach((btn) => {
    btn.addEventListener('click', (e) => { e.preventDefault(); moveRow(btn.dataset.section, btn.dataset.feature, -1); });
  });
  container.querySelectorAll('.me-row-down').forEach((btn) => {
    btn.addEventListener('click', (e) => { e.preventDefault(); moveRow(btn.dataset.section, btn.dataset.feature, 1); });
  });

  // Smazat řádek
  container.querySelectorAll('.me-del-row').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const f = btn.dataset.feature;
      if (!confirm(`Smazat prvek "${f}" ze všech stupňů?`)) return;
      deleteFeatureRow(f);
      renderMatrix();
    });
  });

  // Přidat sekci
  const addSec = container.querySelector('.me-add-section');
  if (addSec) addSec.addEventListener('click', (e) => {
    e.preventDefault();
    const name = prompt('Název nové sekce:');
    if (!name || !name.trim()) return;
    const s = name.trim();
    if (!MATRIX_EXTRA_SECTIONS.includes(s)) MATRIX_EXTRA_SECTIONS.push(s);
    renderMatrix();
  });
}

// Počet řádků matice (pro Save confirm)
// Dopočítej a zapiš sekci (category) ke všem optional/package položkám podle toho,
// kde reálně v matici jsou (vč. posunů přes "+ řádek"). Volá se před uložením,
// aby umístění drželo i bez re-kliknutí do buňky.
function syncItemCategories() {
  const trims = CURRENT_DATA.trims || [];
  const featureToSection = new Map();
  for (const t of trims) for (const sec of (t.features || [])) {
    const name = featTrim(sec.section); if (!name) continue;
    for (const it of (sec.items || [])) { const f = featTrim(it); if (f && !featureToSection.has(f)) featureToSection.set(f, name); }
  }
  for (const t of trims) {
    for (const o of (t.optional_items || [])) { const f = featTrim(o.name); if (f && !featureToSection.has(f)) featureToSection.set(f, featTrim(o.category) || MATRIX_OTHER_SECTION); }
    for (const p of (t.package_items || [])) { const f = featTrim(p.name); if (f && !featureToSection.has(f)) featureToSection.set(f, featTrim(p.category) || MATRIX_OTHER_SECTION); }
  }
  for (const d of MATRIX_DECLARED) if (d.feature) featureToSection.set(d.feature, d.section);
  for (const t of trims) {
    for (const o of (t.optional_items || [])) { const s = featureToSection.get(featTrim(o.name)); if (s) o.category = s; }
    for (const p of (t.package_items || [])) { const s = featureToSection.get(featTrim(p.name)); if (s) p.category = s; }
  }
}

// Propaguje matrix-level názvy sekcí do features[].section napříč všemi trims.
// Bez normalizace: Style trim má "MOTORIZACE", Elegant má "NOVÁ SEKCE" pro stejný
// řádek matrixu — UI to skryje (zobrazí matrix-level název přes buildMatrixModel,
// kde první trim co má feature vyhraje), ale v DB to zůstane rozdílné.
function syncFeatureSectionsFromMatrix() {
  const model = buildMatrixModel();
  const featureToSection = new Map();
  for (const sec of model) {
    for (const f of sec.features) {
      const cleanF = featTrim(f);
      if (cleanF) featureToSection.set(cleanF, sec.section);
    }
  }
  console.log('[syncFeatureSections] map size:', featureToSection.size, 'entries (sample):', Array.from(featureToSection.entries()).slice(0, 3));
  if (featureToSection.size === 0) { console.warn('[syncFeatureSections] EMPTY MAP — skipping'); return; }

  let changedCount = 0;
  for (const t of (CURRENT_DATA.trims || [])) {
    if (!Array.isArray(t.features)) continue;
    const beforeNames = t.features.map(s => s.section);
    const itemsBySection = new Map();
    const sectionOrder = [];
    for (const sec of t.features) {
      const oldSection = featTrim(sec.section);
      for (const item of (sec.items || [])) {
        const cleanItem = featTrim(item);
        if (!cleanItem) continue;
        const targetSection = featureToSection.get(cleanItem) || oldSection;
        if (!targetSection) continue;
        if (!itemsBySection.has(targetSection)) { itemsBySection.set(targetSection, []); sectionOrder.push(targetSection); }
        itemsBySection.get(targetSection).push(item);
      }
    }
    t.features = sectionOrder.map((s) => ({ section: s, items: itemsBySection.get(s) }));
    const afterNames = t.features.map(s => s.section);
    if (JSON.stringify(beforeNames) !== JSON.stringify(afterNames)) {
      changedCount++;
      console.log(`[syncFeatureSections] ${t.name}: ${JSON.stringify(beforeNames)} -> ${JSON.stringify(afterNames)}`);
    }
  }
  console.log('[syncFeatureSections] changed trims:', changedCount, '/', (CURRENT_DATA.trims || []).length);
}

function matrixRowCount() {
  return buildMatrixModel().reduce((a, s) => a + s.features.length, 0);
}

function renderPackages(packages, trims) {
