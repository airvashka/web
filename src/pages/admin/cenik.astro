function addPackage() {
  const pricing_per_trim = {};
  for (const t of CURRENT_DATA.trims) pricing_per_trim[slugifyJs(t.name)] = 'unavailable';
  const newPkg = { name: 'Nový paket', code: '', contents: [], pricing_per_trim };
  CURRENT_DATA.packages.push(newPkg);
  renderPackages(CURRENT_DATA.packages, CURRENT_DATA.trims);
  $('count-packages').textContent = CURRENT_DATA.packages.length;
  const cards = document.querySelectorAll('#packages-container details');
  if (cards.length) {
    cards.forEach((c, i) => c.open = (i === cards.length - 1));
    cards[cards.length - 1].scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
}

function escapeAttr(s) {
  return String(s ?? '').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

// JS-side slugify (matches save.ts slugify výsledkem pro běžné trim názvy)
function slugifyJs(s) {
  return String(s ?? '').toLowerCase().trim()
    .replace(/\+/g, '-plus').replace(/&/g, '-and')
    .normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'untitled';
}

// Pricing hodnota → třída cellu (barva)
function openPkgMenu(anchorEl, pi, slug) {
  closeCellMenu();
  const pkg = CURRENT_DATA.packages[pi];
  if (!pkg) return;
  if (!pkg.pricing_per_trim || typeof pkg.pricing_per_trim !== 'object') pkg.pricing_per_trim = {};
  const menu = document.createElement('div');
  menu.className = 'cell-menu';
  const act = (fn) => { fn(); closeCellMenu(); renderPackages(CURRENT_DATA.packages, CURRENT_DATA.trims); };
  const mk = (label, cls, fn) => { const b = document.createElement('button'); b.type = 'button'; b.className = 'cell-menu-btn ' + (cls || ''); b.textContent = label; b.addEventListener('click', (e) => { e.stopPropagation(); act(fn); }); return b; };
  menu.appendChild(mk('✓  V ceně', 'cm-standard', () => { pkg.pricing_per_trim[slug] = 'standard'; }));
  menu.appendChild(mk('Cena…', 'cm-price', () => {
    const cur = pkg.pricing_per_trim[slug];
    const curVal = (typeof cur === 'number') ? cur : '';
    const v = prompt('Cena paketu v Kč:', curVal);
    if (v === null) return;
    const num = parseInt(String(v).replace(/\s/g, ''), 10);
    if (Number.isFinite(num)) pkg.pricing_per_trim[slug] = num;
  }));
  menu.appendChild(mk('—  Nedostupné', 'cm-none', () => { pkg.pricing_per_trim[slug] = 'unavailable'; }));
  document.body.appendChild(menu);
  menu.style.position = 'fixed';
  const r = anchorEl.getBoundingClientRect();
  const mw = menu.offsetWidth || 200, mh = menu.offsetHeight || 160;
  const vw = document.documentElement.clientWidth, vh = window.innerHeight;
  let left = r.left; if (left + mw > vw - 8) left = vw - mw - 8; left = Math.max(8, left);
  let top = r.bottom + 4; if (top + mh > vh - 8) { top = r.top - mh - 4; if (top < 8) top = Math.max(8, vh - mh - 8); }
  menu.style.top = top + 'px'; menu.style.left = left + 'px';
  setTimeout(() => document.addEventListener('click', closeCellMenu, { once: true }), 0);
}

function pricingCellClass(v) {
  if (v === 'standard') return 'cell-standard';
  if (v === 'unavailable' || v == null) return 'cell-unavailable';
  if (typeof v === 'number') return 'cell-optional';
  return 'cell-other';
}
function formatPricingValue(v) {
  if (v === 'standard') return 'standard';
  if (v === 'unavailable' || v == null) return '–';
  if (typeof v === 'number') return v.toLocaleString('cs-CZ');
  return String(v);
}

function renderColors(ext, int, trims) {
  const container = $('colors-container');
  let html = '<p class="muted" style="margin-bottom:10px;">Texty (název, kód, typ) přepiš přímo v poli. Klikni do buňky s cenou a zvol: <strong>✓ V ceně</strong> · <strong>cena</strong> · <strong>— nedostupné</strong>.</p>';

  const dispCell = (v) => {
    if (v === undefined || v === null || v === '' || v === '-' || v === '–') return { cls: 'cell-unavailable', txt: '–' };
    const s = (typeof v === 'string') ? v.trim().toLowerCase() : '';
    if (s === 'unavailable' || s === 'nedostupné') return { cls: 'cell-unavailable', txt: '–' };
    if (s === 'standard' || s === 's' || s === 'v ceně' || s === 'v cene') return { cls: 'cell-standard', txt: 'V ceně' };
    const num = (typeof v === 'number') ? v : parseInt(String(v).replace(/\s/g, ''), 10);
    if (Number.isFinite(num)) return (num === 0) ? { cls: 'cell-standard', txt: 'V ceně' } : { cls: 'cell-optional', txt: num.toLocaleString('cs-CZ') + ' Kč' };
    return { cls: 'cell-standard', txt: String(v) };
  };
  const priceCell = (c, t, grp, idx) => {
    const slug = slugifyJs(t.name);
    let v = c.pricing_per_trim?.[slug];
    if (v === undefined && Array.isArray(c.cells)) v = c.cells[trims.indexOf(t)];
    const d = dispCell(v);
    return `<td class="cell color-cell ${d.cls}" data-cgroup="${grp}" data-cidx="${idx}" data-slug="${slug}" title="Klik = změnit" style="cursor:pointer;">${d.txt}</td>`;
  };
  const txtCell = (val, grp, idx, field, extra) => `<td style="padding:4px 6px;"><input class="col-txt" data-cgroup="${grp}" data-cidx="${idx}" data-field="${field}" type="text" value="${escapeAttr(val ?? '')}" style="width:100%;box-sizing:border-box;border:1px solid transparent;background:transparent;border-radius:4px;padding:5px 6px;${extra || ''}" /></td>`;

  if (ext?.length) {
    html += '<h3>Exteriér</h3><table style="width:100%;border-collapse:collapse;font-size:13px;"><thead><tr><th style="text-align:left;padding:6px;background:#f5f5f7;">Barva</th><th style="padding:6px;background:#f5f5f7;">Kód</th><th style="padding:6px;background:#f5f5f7;">Typ</th>';
    for (const t of trims) html += `<th style="padding:6px;background:#f5f5f7;text-align:center;">${escapeHtml(t.name)}</th>`;
    html += '</tr></thead><tbody>';
    for (let i = 0; i < ext.length; i++) {
      const c = ext[i];
      html += `<tr>${txtCell(c.name, 'ext', i, 'name')}${txtCell(c.code, 'ext', i, 'code', 'color:#999;')}${txtCell(c.type, 'ext', i, 'type')}`;
      for (const t of trims) html += priceCell(c, t, 'ext', i);
      html += '</tr>';
    }
    html += '</tbody></table>';
  }
  if (int?.length) {
    html += '<h3 style="margin-top:16px;">Interiér</h3><table style="width:100%;border-collapse:collapse;font-size:13px;"><thead><tr><th style="text-align:left;padding:6px;background:#f5f5f7;">Barva</th><th style="padding:6px;background:#f5f5f7;">Kód</th><th style="padding:6px;background:#f5f5f7;">Materiál</th>';
    for (const t of trims) html += `<th style="padding:6px;background:#f5f5f7;text-align:center;">${escapeHtml(t.name)}</th>`;
    html += '</tr></thead><tbody>';
    for (let i = 0; i < int.length; i++) {
      const c = int[i];
      html += `<tr>${txtCell(c.name, 'int', i, 'name')}${txtCell(c.code, 'int', i, 'code', 'color:#999;')}${txtCell(c.material, 'int', i, 'material')}`;
      for (const t of trims) html += priceCell(c, t, 'int', i);
      html += '</tr>';
    }
    html += '</tbody></table>';
  }
  if (!ext?.length && !int?.length) html = '<p class="muted">Žádné barvy v ceníku.</p>';
  container.innerHTML = html;

  container.querySelectorAll('.color-cell').forEach((td) => {
    td.addEventListener('click', (e) => {
      e.stopPropagation();
      openColorMenu(td, td.dataset.cgroup, parseInt(td.dataset.cidx, 10), td.dataset.slug);
    });
  });
  container.querySelectorAll('.col-txt').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const grp = e.target.dataset.cgroup;
      const arr = grp === 'ext' ? CURRENT_DATA.colors_exterior : CURRENT_DATA.colors_interior;
      const c = arr && arr[parseInt(e.target.dataset.cidx, 10)];
      if (c) c[e.target.dataset.field] = e.target.value;
    });
    inp.addEventListener('focus', (e) => { e.target.style.background = '#fff'; e.target.style.borderColor = '#1f6feb'; });
    inp.addEventListener('blur', (e) => { e.target.style.background = 'transparent'; e.target.style.borderColor = 'transparent'; });
  });
}

function openColorMenu(anchorEl, grp, idx, slug) {
  closeCellMenu();
  const arr = grp === 'ext' ? CURRENT_DATA.colors_exterior : CURRENT_DATA.colors_interior;
  const c = arr && arr[idx];
  if (!c) return;
  if (!c.pricing_per_trim || typeof c.pricing_per_trim !== 'object' || Array.isArray(c.pricing_per_trim)) c.pricing_per_trim = {};
  const menu = document.createElement('div');
  menu.className = 'cell-menu';
  const act = (fn) => { fn(); closeCellMenu(); renderColors(CURRENT_DATA.colors_exterior, CURRENT_DATA.colors_interior, CURRENT_DATA.trims); };
  const mk = (label, cls, fn) => { const b = document.createElement('button'); b.type = 'button'; b.className = 'cell-menu-btn ' + (cls || ''); b.textContent = label; b.addEventListener('click', (e) => { e.stopPropagation(); act(fn); }); return b; };
  menu.appendChild(mk('✓  V ceně', 'cm-standard', () => { c.pricing_per_trim[slug] = 'standard'; }));
  menu.appendChild(mk('Cena…', 'cm-price', () => {
    const cur = c.pricing_per_trim[slug];
    const curVal = (typeof cur === 'number') ? cur : '';
    const v = prompt('Cena v Kč:', curVal);
    if (v === null) return;
    const num = parseInt(String(v).replace(/\s/g, ''), 10);
    if (Number.isFinite(num)) c.pricing_per_trim[slug] = num;
  }));
  menu.appendChild(mk('—  Nedostupné', 'cm-none', () => { c.pricing_per_trim[slug] = 'unavailable'; }));
  document.body.appendChild(menu);
  menu.style.position = 'fixed';
  const r = anchorEl.getBoundingClientRect();
  const mw = menu.offsetWidth || 200, mh = menu.offsetHeight || 160;
  const vw = document.documentElement.clientWidth, vh = window.innerHeight;
  let left = r.left; if (left + mw > vw - 8) left = vw - mw - 8; left = Math.max(8, left);
  let top = r.bottom + 4; if (top + mh > vh - 8) { top = r.top - mh - 4; if (top < 8) top = Math.max(8, vh - mh - 8); }
  menu.style.top = top + 'px'; menu.style.left = left + 'px';
  setTimeout(() => document.addEventListener('click', closeCellMenu, { once: true }), 0);
}

function renderTechData(td) {
  const tbody = $('techdata-tbody');
  const tbl = $('techdata-table'); if (tbl) tbl.style.width = '100%';
  if (!td || typeof td !== 'object' || Array.isArray(td)) { td = {}; CURRENT_DATA.technical_data = td; }
  tbody.innerHTML = '';
  for (const [k, v] of Object.entries(td)) {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td style="padding:4px 6px;width:34%;"><input class="td-key" data-key="${escapeAttr(k)}" type="text" value="${escapeAttr(k)}" style="width:100%;box-sizing:border-box;border:1px solid transparent;background:transparent;border-radius:4px;padding:5px 6px;font-weight:500;" /></td>
      <td style="padding:4px 6px;"><input class="td-val" data-key="${escapeAttr(k)}" type="text" value="${escapeAttr(String(v))}" style="width:100%;box-sizing:border-box;border:1px solid transparent;background:transparent;border-radius:4px;padding:5px 6px;" /></td>
      <td style="padding:4px 6px;width:40px;text-align:center;"><button type="button" class="td-del" data-key="${escapeAttr(k)}" title="Smazat" style="background:transparent;color:#c0392b;border:none;cursor:pointer;font-size:15px;">×</button></td>`;
    tbody.appendChild(tr);
  }
  const addTr = document.createElement('tr');
  addTr.innerHTML = `<td colspan="3" style="padding:8px 6px;"><button type="button" id="td-add" style="background:#eef4ff;color:#1f6feb;border:1px solid #cfe0ff;border-radius:5px;padding:6px 14px;font-size:12px;cursor:pointer;">+ řádek</button></td>`;
  tbody.appendChild(addTr);

  tbody.querySelectorAll('.td-val').forEach((inp) => {
    inp.addEventListener('input', (e) => { CURRENT_DATA.technical_data[e.target.dataset.key] = e.target.value; });
    inp.addEventListener('focus', (e) => { e.target.style.background = '#fff'; e.target.style.borderColor = '#1f6feb'; });
    inp.addEventListener('blur', (e) => { e.target.style.background = 'transparent'; e.target.style.borderColor = 'transparent'; });
  });
  tbody.querySelectorAll('.td-key').forEach((inp) => {
    inp.addEventListener('focus', (e) => { e.target.style.background = '#fff'; e.target.style.borderColor = '#1f6feb'; });
    inp.addEventListener('blur', (e) => { e.target.style.background = 'transparent'; e.target.style.borderColor = 'transparent'; });
    inp.addEventListener('change', (e) => {
      const oldK = e.target.dataset.key;
      const newK = e.target.value.trim();
      if (!newK || newK === oldK) return;
      const obj = CURRENT_DATA.technical_data;
      const rebuilt = {};
      for (const [k, v] of Object.entries(obj)) rebuilt[k === oldK ? newK : k] = v;
      CURRENT_DATA.technical_data = rebuilt;
      renderTechData(CURRENT_DATA.technical_data);
    });
  });
  tbody.querySelectorAll('.td-del').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      delete CURRENT_DATA.technical_data[btn.dataset.key];
      renderTechData(CURRENT_DATA.technical_data);
    });
  });
  const addBtn = $('td-add');
  if (addBtn) addBtn.addEventListener('click', () => {
    const obj = CURRENT_DATA.technical_data;
    let n = 1, key = 'Nový údaj';
    while (Object.prototype.hasOwnProperty.call(obj, key)) { n++; key = 'Nový údaj ' + n; }
    obj[key] = '';
    renderTechData(obj);
  });
}

// ─── Tabs ────────────────────────────────────────────────
$$('#tabs .tab-btn').forEach((btn) => {
  btn.addEventListener('click', () => {
    const tab = btn.dataset.tab;
    $$('#tabs .tab-btn').forEach((b) => b.classList.toggle('active', b === btn));
    $$('.tab-content').forEach((c) => c.classList.toggle('active', c.dataset.tab === tab));
  });
});

// ─── SAVE ────────────────────────────────────────────────
$('save-btn').addEventListener('click', async () => {
  if (!CURRENT_DATA) return;
  const yearId = $('year-select').value;
  if (!yearId) { alert('Vyber model_year'); return; }
  const totalRows = matrixRowCount();
  if (!confirm(`Uložit do "${$('year-select').selectedOptions[0]?.textContent}":\n${CURRENT_DATA.trims.length} výbavových stupňů, ${totalRows} řádků, ${CURRENT_DATA.packages.length} paketů.\n\nPokračovat?`)) return;

  syncItemCategories();
  syncFeatureSectionsFromMatrix();
  $('save-btn').disabled = true;
  $('save-btn').textContent = '⏳ Ukládám...';

  try {
    await refreshAccessToken();
    let r = await fetch('/api/cenik/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ model_year_id: yearId, directus_token: TOKEN, data: CURRENT_DATA }),
    });
    let result = await r.json();
    if (!r.ok && JSON.stringify(result).includes('TOKEN_EXPIRED')) {
      if (await refreshAccessToken()) {
        r = await fetch('/api/cenik/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ model_year_id: yearId, directus_token: TOKEN, data: CURRENT_DATA }),
        });
        result = await r.json();
      }
    }
    showSaveResult(r.ok, result);
  } catch (e) {
    showSaveResult(false, { error: e.message });
  } finally {
    $('save-btn').disabled = false;
    $('save-btn').textContent = 'Uložit do Directus';
  }
});

function showSaveResult(ok, result) {
  const div = $('save-result');
  div.classList.remove('hidden');
  if (ok && result.ok) {
    const s = result.summary;
    div.className = 'success';
    div.innerHTML = `
      <strong>✓ Uloženo do Directus</strong><br>
      Výbavové stupně: ${s.trims_created} vytvořeno, ${s.trims_updated} aktualizováno<br>
      Pakety: ${s.packages_created} vytvořeno, ${s.packages_updated} aktualizováno<br>
      Barvy z ceníku: ${(s.colors_ext_updated ?? 0)} exteriér + ${(s.colors_int_updated ?? 0)} interiér → uloženo do model_years.pricelist_colors<br>
      Tech data: ${s.tech_data_updated ? 'updatováno' : 'beze změny'}<br>
      ${s.errors.length ? `<br><strong style="color:#b43a2c;">Chyby (${s.errors.length}):</strong><br>${s.errors.map((e) => escapeHtml(e)).join('<br>')}` : ''}
      <details style="margin-top:8px;"><summary class="muted">Detail (${s.details.length})</summary><pre style="font-size:11px;">${s.details.map((d) => escapeHtml(d)).join('\n')}</pre></details>
    `;
  } else {
    div.className = 'error';
    div.innerHTML = `<strong>✗ Save selhal</strong><br>${escapeHtml(result.error ?? 'Neznámá chyba')}`;
  }
  div.scrollIntoView({ behavior: 'smooth' });
}

$('discard-btn').addEventListener('click', () => {
  if (confirm('Zahodit review a začít znova?')) {
    CURRENT_DATA = null;
    $('result-panel').classList.add('hidden');
    SELECTED_PDF = null;
    dz.classList.remove('has-file');
    dz.innerHTML = `<p><strong>Drag & drop PDF zde</strong></p><p class="muted">nebo klikni a vyber soubor (max 50 MB)</p>`;
    $('analyze-btn').disabled = true;
  }
});

function escapeHtml(s) {
  return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
}
</script>
