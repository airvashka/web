---
/**
 * Ceník uploader — admin stránka (Stage 2: matrix view).
 *
 * Flow:
 *   1) Login Directus
 *   2) Brand → Model → Year cascade
 *   3) Upload PDF
 *   4) Analyzovat → AI vrátí matrix JSON (trims, sections, packages, colors, tech)
 *   5) Review matrix s color-coded buňkami, klik na cell = edit
 *   6) Uložit → server transform matrix → Directus tables
 */
export const prerender = false;

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? import.meta.env.DIRECTUS_URL ?? '';
---

<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Ceník uploader — SFR Motor admin</title>
  <style>
    body { font-family: system-ui, -apple-system, sans-serif; max-width: 1400px; margin: 0 auto; padding: 24px; color: #1a1a1a; background: #fafafa; }
    h1 { font-size: 24px; margin-bottom: 8px; }
    h2 { font-size: 18px; margin: 0 0 12px; }
    .muted { color: #666; font-size: 14px; }
    .panel { background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 20px; margin-bottom: 16px; }
    label { display: block; font-weight: 500; font-size: 13px; margin-top: 8px; margin-bottom: 4px; }
    input[type="email"], input[type="password"], input[type="text"], input[type="number"], select {
      width: 100%; padding: 8px 12px; border: 1px solid #ccc; border-radius: 6px; font-size: 14px; box-sizing: border-box;
    }
    select:disabled { background: #f5f5f5; color: #999; }
    button { background: #1f6feb; color: white; border: 0; padding: 9px 18px; border-radius: 6px; cursor: pointer; font-size: 14px; font-weight: 500; }
    button:hover { background: #1858bb; }
    button:disabled { background: #ccc; cursor: not-allowed; }
    button.secondary { background: #6b6b72; }
    button.secondary:hover { background: #555; }
    .drop-zone { border: 2px dashed #aaa; border-radius: 8px; padding: 28px; text-align: center; cursor: pointer; }
    .drop-zone:hover, .drop-zone.dragover { background: #eef4ff; border-color: #1f6feb; }
    .drop-zone.has-file { background: #f0fff0; border-color: #2da64a; border-style: solid; }
    .error { color: #b43a2c; padding: 10px; background: #fef0ef; border-left: 4px solid #b43a2c; margin-top: 10px; white-space: pre-wrap; }
    .success { color: #1e7b5f; padding: 10px; background: #f0fdf6; border-left: 4px solid #1e7b5f; margin-top: 10px; }
    .hidden { display: none !important; }
    .row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    .meta { display: flex; gap: 8px; font-size: 12px; color: #555; margin-top: 8px; flex-wrap: wrap; }
    .meta span { background: #eef; padding: 2px 8px; border-radius: 4px; }

    /* Tabs */
    .tabs { display: flex; gap: 4px; border-bottom: 2px solid #e0e0e0; margin-bottom: 16px; overflow-x: auto; }
    .tab-btn { background: transparent; color: #666; border: 0; padding: 10px 16px; border-radius: 6px 6px 0 0; font-weight: 500; white-space: nowrap; }
    .tab-btn.active { background: #1f6feb; color: white; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    .save-bar { position: sticky; bottom: 0; background: white; border-top: 2px solid #e0e0e0; margin-top: 16px; padding: 14px 18px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 -2px 12px rgba(0,0,0,0.06); border-radius: 0 0 8px 8px; }
    .save-bar button { padding: 11px 22px; font-size: 14px; }

    pre.raw-json { background: #1e1e2e; color: #cdd6f4; padding: 14px; border-radius: 6px; overflow: auto; font-size: 11px; max-height: 600px; }

    /* Per-trim editor */
    .trim-tabs {
      display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px;
      border-bottom: 2px solid #e5e5e5; padding-bottom: 0;
    }
    .trim-tab-btn {
      background: #f5f5f7; border: 1px solid #d0d0d5; border-bottom: 2px solid transparent;
      padding: 10px 18px; cursor: pointer; border-radius: 6px 6px 0 0;
      display: flex; flex-direction: column; align-items: flex-start; gap: 2px;
      font-size: 14px; line-height: 1.2;
    }
    .trim-tab-btn:hover { background: #e8e8ed; }
    .trim-tab-btn.active {
      background: #1f6feb; color: white; border-color: #1f6feb;
      border-bottom-color: #1f6feb;
      transform: translateY(2px);
    }
    .trim-tab-btn strong { font-size: 14px; font-weight: 700; }
    .trim-tab-btn .trim-tab-price { font-size: 11px; font-weight: 500; opacity: 0.8; }
    .trim-pane { display: none; padding: 14px 0; }
    .trim-pane.active { display: block; }

    .trim-header-row {
      display: grid; grid-template-columns: 1fr 220px; gap: 14px;
      padding: 14px; background: #f9f9fc; border-radius: 6px;
      margin-bottom: 18px;
    }
    .trim-header-row input { width: 100%; box-sizing: border-box; padding: 8px 10px; font-size: 14px; border: 1px solid #d0d0d5; border-radius: 4px; }

    .trim-section-heading {
      font-size: 14px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.06em; color: #1a1a2e;
      margin: 22px 0 10px; padding: 8px 12px;
      background: linear-gradient(180deg, #2f9b5c 0%, #1e7b47 100%);
      color: white; border-radius: 5px;
    }
    .trim-section-heading .muted { color: rgba(255,255,255,0.8); font-weight: 400; }

    .feat-section {
      border: 1px solid #e0e0e0; border-radius: 6px; padding: 8px 12px;
      margin-bottom: 8px; background: white;
    }
    .feat-section[open] { border-color: #1f6feb33; }
    .feat-section summary {
      display: flex; align-items: center; gap: 10px; cursor: pointer;
      list-style: none;
    }
    .feat-section summary::-webkit-details-marker { display: none; }
    .feat-section summary::before {
      content: '▶'; color: #999; transition: transform .15s;
    }
    .feat-section[open] summary::before { transform: rotate(90deg); }
    .feat-section .section-title-input {
      flex: 1; border: none; background: transparent;
      font-weight: 700; font-size: 14px; padding: 4px 6px;
      text-transform: uppercase; letter-spacing: 0.04em; color: #1a1a2e;
    }
    .feat-section .section-title-input:focus { background: #eef6ff; outline: 1px solid #1f6feb; border-radius: 3px; }
    .feat-section .btn-remove-section,
    .opt-table .btn-remove-optional {
      background: transparent; border: none; color: #b43a2c;
      font-size: 18px; cursor: pointer; padding: 2px 8px;
      border-radius: 4px; line-height: 1;
    }
    .feat-section .btn-remove-section:hover,
    .opt-table .btn-remove-optional:hover { background: #fee; }
    .feat-section textarea {
      width: 100%; box-sizing: border-box; margin-top: 8px;
      padding: 8px 10px; font-size: 13px; line-height: 1.5;
      border: 1px solid #d0d0d5; border-radius: 4px;
      font-family: inherit; resize: vertical;
    }
    .feat-section textarea:focus { border-color: #1f6feb; outline: 2px solid #1f6feb33; }

    .btn-add-section, .btn-add-optional {
      background: #2f9b5c; color: white; border: none;
      padding: 7px 16px; border-radius: 4px; cursor: pointer;
      font-size: 13px; margin: 4px 0 12px;
    }
    .btn-add-section:hover, .btn-add-optional:hover { background: #267a47; }

    .opt-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 6px; }
    .opt-table th { background: #f5f5f7; padding: 8px 10px; text-align: left; font-weight: 600; }
    .opt-table td { padding: 4px 6px; border-bottom: 1px solid #f0f0f0; }
    .opt-table input { width: 100%; box-sizing: border-box; padding: 6px 8px; font-size: 13px; border: 1px solid transparent; background: transparent; border-radius: 3px; }
    .opt-table input:focus { background: white; border-color: #1f6feb; outline: none; }

    /* Cell coloring (used in packages pricing + colors tabs) */
    .cell {
      text-align: center; padding: 6px 8px;
      font-weight: 500; cursor: pointer; min-width: 100px;
      border-bottom: 1px solid #e7eef5;
    }
    .cell:hover { outline: 2px solid #1f6feb; outline-offset: -2px; }
    .cell-standard { background: #d6f5d6; color: #1e7b5f; }
    .cell-optional { background: #ffe8cc; color: #b27516; }
    .cell-package { background: #e8d6f5; color: #6f42c1; }
    .cell-unavailable { background: #f0f0f0; color: #999; }
    .cell-conditional { background: #d6e8f5; color: #1e5f7b; }
    .cell-choice { background: #fff4d6; color: #8b6914; }
    .cell-other { background: #ffd6d6; color: #b43a2c; }

    /* Pakety editor */
    .pkg-card { border: 1px solid #e0e0e0; padding: 14px 16px; }
    .pkg-card[open] { border-color: #2f9b5c; }
    .pkg-lab {
      display: block; font-weight: 600; font-size: 12px;
      letter-spacing: 0.04em; text-transform: uppercase;
      color: #555; margin-bottom: 4px;
    }
    .pkg-card input[type="text"], .pkg-card textarea {
      width: 100%; box-sizing: border-box;
      padding: 7px 10px; font-size: 13px;
      border: 1px solid #d0d0d5; border-radius: 4px;
      font-family: inherit;
    }
    .pkg-card input[type="text"]:focus, .pkg-card textarea:focus {
      border-color: #1f6feb; outline: 2px solid #1f6feb33;
    }
    .pkg-card textarea { resize: vertical; min-height: 70px; line-height: 1.5; }
    .btn-link { background: none; border: none; color: #1f6feb; text-decoration: underline; cursor: pointer; padding: 0; font-size: inherit; }
  </style>
</head>
<body>
  <h1>Ceník uploader</h1>
  <p class="muted">PDF → AI extract → review po výbavových stupních → uložit do Directus. Pro každý výbavový stupeň: <em>co dostane zákazník</em> + <em>co si může dokoupit</em>.</p>

  <!-- LOGIN -->
  <div class="panel" id="login-panel">
    <h2>1. Přihlášení do Directus</h2>
    <label for="email">Email</label>
    <input type="email" id="email" placeholder="tvůj@email.cz" autocomplete="username" />
    <label for="password">Heslo</label>
    <input type="password" id="password" placeholder="zadej heslo" autocomplete="current-password" />
    <button id="login-btn" style="margin-top: 12px;">Přihlásit</button>
    <div id="login-error" class="error hidden"></div>
  </div>

  <!-- CONTEXT -->
  <div class="panel hidden" id="context-panel">
    <h2>2. Vybrat cíl (model + rok)</h2>
    <div class="row">
      <div>
        <label for="brand-select">Značka</label>
        <select id="brand-select"><option value="">— vyber —</option></select>
      </div>
      <div>
        <label for="model-select">Model</label>
        <select id="model-select" disabled><option value="">— nejdřív značka —</option></select>
      </div>
      <div>
        <label for="year-select">Modelový rok</label>
        <select id="year-select" disabled><option value="">— nejdřív model —</option></select>
      </div>
    </div>
  </div>

  <!-- UPLOAD -->
  <div class="panel hidden" id="upload-panel">
    <h2>3. Nahrát PDF ceník</h2>
    <div class="drop-zone" id="drop-zone">
      <p><strong>Drag & drop PDF zde</strong></p>
      <p class="muted">nebo klikni a vyber soubor (max 50 MB)</p>
      <input type="file" id="file-input" accept="application/pdf" style="display: none;" />
    </div>
    <button id="analyze-btn" disabled style="margin-top: 12px;">Analyzovat PDF</button>
    <div id="analyze-status" class="muted" style="margin-top: 8px;"></div>
    <div id="analyze-error" class="error hidden"></div>
  </div>

  <!-- REVIEW -->
  <div class="panel hidden" id="result-panel">
    <h2>4. Review extrahovaného obsahu</h2>
    <div id="result-summary" class="muted"></div>
    <div class="meta" id="result-meta"></div>

    <div class="tabs" id="tabs" style="margin-top: 20px;">
      <button class="tab-btn active" data-tab="trims">🚗 Výbavové stupně (<span id="count-trims">0</span>)</button>
      <button class="tab-btn" data-tab="packages">📦 Pakety (<span id="count-packages">0</span>)</button>
      <button class="tab-btn" data-tab="colors">🎨 Barvy (<span id="count-colors">0</span>)</button>
      <button class="tab-btn" data-tab="techdata">🔧 Tech data (<span id="count-techdata">0</span>)</button>
      <button class="tab-btn" data-tab="raw">Raw JSON</button>
    </div>

    <div class="tab-content active" data-tab="trims">
      <p class="muted">Pro každý výbavový stupeň: <strong>co dostane zákazník</strong> (features) + <strong>co si může dokoupit</strong> (optional). Klik = editovat.</p>
      <div id="trims-container"></div>
    </div>

    <div class="tab-content" data-tab="packages">
      <div id="packages-container"></div>
    </div>

    <div class="tab-content" data-tab="colors">
      <div id="colors-container"></div>
    </div>

    <div class="tab-content" data-tab="techdata">
      <table class="matrix-table" id="techdata-table">
        <thead><tr><th>Klíč</th><th>Hodnota</th></tr></thead>
        <tbody id="techdata-tbody"></tbody>
      </table>
    </div>

    <div class="tab-content" data-tab="raw">
      <pre class="raw-json" id="raw-json"></pre>
    </div>

    <div class="save-bar">
      <div class="save-summary muted" id="save-summary"></div>
      <div>
        <button class="secondary" id="discard-btn">Zahodit</button>
        <button id="save-btn">Uložit do Directus</button>
      </div>
    </div>

    <div id="save-result" class="hidden" style="margin-top: 16px;"></div>
  </div>

<script is:inline define:vars={{ DIRECTUS_URL }}>
console.log('[cenik] Script loaded. DIRECTUS_URL =', DIRECTUS_URL);

let TOKEN = null;
let REFRESH_TOKEN = null;
let SELECTED_PDF = null;
let CURRENT_DATA = null;

const $ = (id) => document.getElementById(id);
const $$ = (sel, parent = document) => [...parent.querySelectorAll(sel)];

// ─── Directus API ────────────────────────────────────────
async function api(path, opts = {}) {
  const r = await fetch(`${DIRECTUS_URL}${path}`, {
    ...opts,
    headers: {
      'Content-Type': 'application/json',
      ...(TOKEN ? { Authorization: `Bearer ${TOKEN}` } : {}),
      ...opts.headers,
    },
  });
  const text = await r.text();
  let j; try { j = JSON.parse(text); } catch { j = text; }
  if (!r.ok) throw new Error(`${r.status}: ${JSON.stringify(j?.errors ?? j)}`);
  return j;
}

async function refreshAccessToken() {
  if (!REFRESH_TOKEN) return false;
  try {
    const r = await fetch(`${DIRECTUS_URL}/auth/refresh`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ refresh_token: REFRESH_TOKEN, mode: 'json' }),
    });
    if (!r.ok) return false;
    const data = await r.json();
    TOKEN = data.data.access_token;
    REFRESH_TOKEN = data.data.refresh_token;
    sessionStorage.setItem('directus_token', TOKEN);
    sessionStorage.setItem('directus_refresh', REFRESH_TOKEN);
    return true;
  } catch { return false; }
}

// ─── LOGIN ────────────────────────────────────────────────
$('login-btn').addEventListener('click', async () => {
  const email = $('email').value.trim();
  const password = $('password').value;
  if (!email || !password) return;
  $('login-error').classList.add('hidden');
  TOKEN = null;
  REFRESH_TOKEN = null;
  sessionStorage.removeItem('directus_token');
  sessionStorage.removeItem('directus_refresh');
  try {
    const r = await api('/auth/login', { method: 'POST', body: JSON.stringify({ email, password }) });
    TOKEN = r.data.access_token;
    REFRESH_TOKEN = r.data.refresh_token;
    sessionStorage.setItem('directus_token', TOKEN);
    sessionStorage.setItem('directus_refresh', REFRESH_TOKEN);
    $('login-panel').classList.add('hidden');
    $('context-panel').classList.remove('hidden');
    $('upload-panel').classList.remove('hidden');
    await loadBrands();
  } catch (e) {
    $('login-error').textContent = `Login selhal: ${e.message}`;
    $('login-error').classList.remove('hidden');
  }
});

const savedToken = sessionStorage.getItem('directus_token');
const savedRefresh = sessionStorage.getItem('directus_refresh');
if (savedToken) {
  fetch(`${DIRECTUS_URL}/users/me`, { headers: { Authorization: `Bearer ${savedToken}` } })
    .then(async (r) => {
      if (r.ok) {
        TOKEN = savedToken;
        REFRESH_TOKEN = savedRefresh;
        $('login-panel').classList.add('hidden');
        $('context-panel').classList.remove('hidden');
        $('upload-panel').classList.remove('hidden');
        loadBrands();
      } else if (savedRefresh) {
        REFRESH_TOKEN = savedRefresh;
        if (await refreshAccessToken()) {
          $('login-panel').classList.add('hidden');
          $('context-panel').classList.remove('hidden');
          $('upload-panel').classList.remove('hidden');
          loadBrands();
        } else {
          sessionStorage.removeItem('directus_token');
          sessionStorage.removeItem('directus_refresh');
        }
      }
    });
}

// ─── Cascading dropdowns ─────────────────────────────────
async function loadBrands() {
  const r = await api('/items/brands?sort=name&fields=id,name&limit=50');
  const sel = $('brand-select');
  sel.innerHTML = '<option value="">— vyber —</option>';
  for (const b of r.data) sel.innerHTML += `<option value="${b.id}">${escapeHtml(b.name)}</option>`;
}

$('brand-select').addEventListener('change', async (e) => {
  const brandId = e.target.value;
  $('model-select').disabled = !brandId;
  $('year-select').disabled = true;
  $('model-select').innerHTML = '<option value="">— vyber —</option>';
  $('year-select').innerHTML = '<option value="">— nejdřív model —</option>';
  if (!brandId) return;
  const r = await api(`/items/models?filter[brand][_eq]=${brandId}&sort=name&fields=id,name&limit=100`);
  for (const m of r.data) $('model-select').innerHTML += `<option value="${m.id}">${escapeHtml(m.name)}</option>`;
});

$('model-select').addEventListener('change', async (e) => {
  const modelId = e.target.value;
  $('year-select').disabled = !modelId;
  $('year-select').innerHTML = '<option value="">— vyber —</option>';
  if (!modelId) return;
  const r = await api(`/items/model_years?filter[model][_eq]=${modelId}&sort=-year&fields=id,year,version&limit=20`);
  for (const y of r.data) {
    const label = `${y.year}${y.version ? ' ' + y.version : ''}`;
    $('year-select').innerHTML += `<option value="${y.id}">${escapeHtml(label)}</option>`;
  }
});

// ─── Upload ─────────────────────────────────────────────
const dz = $('drop-zone');
const fi = $('file-input');
dz.addEventListener('click', () => fi.click());
dz.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('dragover'); });
dz.addEventListener('dragleave', () => dz.classList.remove('dragover'));
dz.addEventListener('drop', (e) => { e.preventDefault(); dz.classList.remove('dragover'); if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); });
fi.addEventListener('change', (e) => { if (e.target.files[0]) handleFile(e.target.files[0]); });

function handleFile(f) {
  if (!f.name.toLowerCase().endsWith('.pdf')) { alert('Musí být PDF'); return; }
  SELECTED_PDF = f;
  dz.classList.add('has-file');
  dz.innerHTML = `<p><strong>✓ ${escapeHtml(f.name)}</strong></p><p class="muted">${(f.size / 1024 / 1024).toFixed(2)} MB · klikni pro výměnu</p>`;
  $('analyze-btn').disabled = false;
}

// ─── Analyze ─────────────────────────────────────────────
$('analyze-btn').addEventListener('click', async () => {
  if (!SELECTED_PDF) return;
  const brand = $('brand-select').selectedOptions[0]?.textContent;
  const model = $('model-select').selectedOptions[0]?.textContent;
  const year = $('year-select').selectedOptions[0]?.textContent;
  const yearId = $('year-select').value;
  if (!yearId) { alert('Vyber nejdřív model_year'); return; }
  $('analyze-error').classList.add('hidden');
  $('analyze-btn').disabled = true;

  await refreshAccessToken();

  // 1) Upload PDF do Directus (bypass Vercel body limit)
  $('analyze-status').textContent = '⏳ Uploaduji PDF do Directus...';
  const uploadFd = new FormData();
  uploadFd.append('title', `Cenik ${model || ''} ${year || ''} ${new Date().toISOString().substring(0, 10)}`.trim());
  uploadFd.append('file', SELECTED_PDF);

  let fileId;
  try {
    const upResp = await fetch(`${DIRECTUS_URL}/files`, {
      method: 'POST',
      headers: { Authorization: `Bearer ${TOKEN}` },
      body: uploadFd,
    });
    if (!upResp.ok) throw new Error(`Directus upload ${upResp.status}`);
    const upData = await upResp.json();
    fileId = upData.data?.id;
  } catch (e) {
    $('analyze-error').textContent = `Upload selhal: ${e.message}`;
    $('analyze-error').classList.remove('hidden');
    $('analyze-btn').disabled = false;
    $('analyze-status').textContent = '';
    return;
  }

  // 2) AI parsing
  $('analyze-status').textContent = '⏳ AI parsing běží (~30-90s)...';
  try {
    const r = await fetch('/api/cenik/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${TOKEN}` },
      body: JSON.stringify({ file_id: fileId, context: { brand, model, year, year_id: yearId } }),
    });
    const data = await r.json();
    if (!r.ok) {
      $('analyze-error').textContent = `Chyba: ${data.error || 'unknown'}\n\n${JSON.stringify(data, null, 2).substring(0, 2000)}`;
      $('analyze-error').classList.remove('hidden');
      return;
    }
    CURRENT_DATA = data;
    showReview(data);
  } catch (e) {
    $('analyze-error').textContent = `Chyba: ${e.message}`;
    $('analyze-error').classList.remove('hidden');
  } finally {
    $('analyze-btn').disabled = false;
    $('analyze-status').textContent = '';
  }
});

// ─── REVIEW UI ───────────────────────────────────────────
function showReview(data) {
  $('result-panel').classList.remove('hidden');
  $('save-result').classList.add('hidden');

  // Defensive: tools sometimes return stringified arrays
  const parseIf = (v, fb) => { if (typeof v === 'string') { try { return JSON.parse(v); } catch { return fb; } } return v ?? fb; };
  data.trims = parseIf(data.trims, []);
  data.sections = parseIf(data.sections, []);
  data.packages = parseIf(data.packages, []);
  data.colors_exterior = parseIf(data.colors_exterior, []);
  data.colors_interior = parseIf(data.colors_interior, []);
  data.technical_data = parseIf(data.technical_data, {});
  if (!Array.isArray(data.trims)) data.trims = [];
  if (!Array.isArray(data.sections)) data.sections = [];
  if (!Array.isArray(data.packages)) data.packages = [];

  // Defensive defaults — per-trim schema z analyze
  data.trims          = Array.isArray(data.trims) ? data.trims : [];
  data.packages       = Array.isArray(data.packages) ? data.packages : [];
  data.colors_exterior = Array.isArray(data.colors_exterior) ? data.colors_exterior : [];
  data.colors_interior = Array.isArray(data.colors_interior) ? data.colors_interior : [];

  const totalFeatures = data.trims.reduce((acc, t) =>
    acc + (Array.isArray(t.features) ? t.features.reduce((a, s) => a + (s.items?.length ?? 0), 0) : 0), 0);
  const totalOptional = data.trims.reduce((acc, t) => acc + (t.optional_items?.length ?? 0), 0);
  const tdKeys = Object.keys(data.technical_data ?? {}).length;
  const colorsTotal = data.colors_exterior.length + data.colors_interior.length;

  $('count-trims').textContent = data.trims.length;
  $('count-packages').textContent = data.packages.length;
  $('count-colors').textContent = colorsTotal;
  $('count-techdata').textContent = tdKeys;

  $('result-summary').innerHTML = `
    <strong>Detekováno:</strong>
    ${data.trims.length} výbavových stupňů (${data.trims.map((t) => escapeHtml(t.name)).join(' · ')}),
    ${totalFeatures} features celkem, ${totalOptional} dokoupitelných,
    ${data.packages.length} paketů,
    ${colorsTotal} barev,
    ${tdKeys} tech klíčů.
    ${data.detected?.model_name ? `Model hint: <em>${escapeHtml(data.detected.model_name)}</em>.` : ''}
  `;
  if (data.meta?.usage) {
    $('result-meta').innerHTML = `
      <span>Input: ${data.meta.usage.input_tokens} tok</span>
      <span>Output: ${data.meta.usage.output_tokens} tok</span>
      <span>~$${((data.meta.usage.input_tokens * 0.003 + data.meta.usage.output_tokens * 0.015) / 1000).toFixed(3)}</span>
    `;
  }
  $('save-summary').textContent = `Uloží se do "${$('year-select').selectedOptions[0]?.textContent}"`;

  renderTrims(data.trims);
  renderPackages(data.packages, data.trims);
  renderColors(data.colors_exterior, data.colors_interior, data.trims);
  renderTechData(data.technical_data);
  $('raw-json').textContent = JSON.stringify(data, null, 2);

  $('result-panel').scrollIntoView({ behavior: 'smooth' });
}

function renderTrims(trims) {
  const container = $('trims-container');
  if (!trims || !trims.length) {
    container.innerHTML = '<p class="muted">Žádné výbavové stupně detekovány.</p>';
    return;
  }

  let html = `<div class="trim-tabs">`;
  for (let ti = 0; ti < trims.length; ti++) {
    const t = trims[ti];
    const priceFmt = t.list_price ? `${t.list_price.toLocaleString('cs-CZ')} Kč` : '';
    html += `<button class="trim-tab-btn ${ti === 0 ? 'active' : ''}" data-trim-idx="${ti}">
      <strong>${escapeHtml(t.name || '(bez názvu)')}</strong>
      ${priceFmt ? `<span class="trim-tab-price">${priceFmt}</span>` : ''}
    </button>`;
  }
  html += `</div>`;

  for (let ti = 0; ti < trims.length; ti++) {
    const t = trims[ti];
    html += `<div class="trim-pane ${ti === 0 ? 'active' : ''}" data-trim-idx="${ti}">${renderTrimPane(t, ti)}</div>`;
  }
  container.innerHTML = html;

  // Tab switching
  container.querySelectorAll('.trim-tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = btn.dataset.trimIdx;
      container.querySelectorAll('.trim-tab-btn').forEach((b) => b.classList.toggle('active', b.dataset.trimIdx === idx));
      container.querySelectorAll('.trim-pane').forEach((p) => p.classList.toggle('active', p.dataset.trimIdx === idx));
    });
  });

  // Wire trim-level editors (name, price)
  container.querySelectorAll('.trim-name-input').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const i = parseInt(e.target.dataset.trimIdx, 10);
      CURRENT_DATA.trims[i].name = e.target.value;
      const btn = container.querySelector(`.trim-tab-btn[data-trim-idx="${i}"] strong`);
      if (btn) btn.textContent = e.target.value || '(bez názvu)';
    });
  });
  container.querySelectorAll('.trim-price-input').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const i = parseInt(e.target.dataset.trimIdx, 10);
      const v = parseInt(e.target.value.replace(/\s/g, ''), 10);
      CURRENT_DATA.trims[i].list_price = Number.isFinite(v) ? v : undefined;
      const priceEl = container.querySelector(`.trim-tab-btn[data-trim-idx="${i}"] .trim-tab-price`);
      if (priceEl) priceEl.textContent = Number.isFinite(v) ? `${v.toLocaleString('cs-CZ')} Kč` : '';
    });
  });

  // Section title edit
  container.querySelectorAll('.section-title-input').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const ti = parseInt(e.target.dataset.trimIdx, 10);
      const si = parseInt(e.target.dataset.sectionIdx, 10);
      CURRENT_DATA.trims[ti].features[si].section = e.target.value;
    });
  });

  // Feature items textarea — one per line
  container.querySelectorAll('.section-items-textarea').forEach((ta) => {
    ta.addEventListener('input', (e) => {
      const ti = parseInt(e.target.dataset.trimIdx, 10);
      const si = parseInt(e.target.dataset.sectionIdx, 10);
      CURRENT_DATA.trims[ti].features[si].items = e.target.value
        .split('\n').map((l) => l.trim()).filter((l) => l.length > 0);
    });
  });

  // Add section
  container.querySelectorAll('.btn-add-section').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const ti = parseInt(e.target.dataset.trimIdx, 10);
      if (!Array.isArray(CURRENT_DATA.trims[ti].features)) CURRENT_DATA.trims[ti].features = [];
      CURRENT_DATA.trims[ti].features.push({ section: 'NOVÁ SEKCE', items: [] });
      renderTrims(CURRENT_DATA.trims);
      // Re-aktivuj ten tab
      const tabBtn = container.querySelector(`.trim-tab-btn[data-trim-idx="${ti}"]`);
      if (tabBtn) tabBtn.click();
    });
  });

  // Remove section
  container.querySelectorAll('.btn-remove-section').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const ti = parseInt(e.target.dataset.trimIdx, 10);
      const si = parseInt(e.target.dataset.sectionIdx, 10);
      const sec = CURRENT_DATA.trims[ti].features[si];
      if (sec.items.length > 0 && !confirm(`Smazat sekci "${sec.section}" (${sec.items.length} položek)?`)) return;
      CURRENT_DATA.trims[ti].features.splice(si, 1);
      renderTrims(CURRENT_DATA.trims);
      const tabBtn = container.querySelector(`.trim-tab-btn[data-trim-idx="${ti}"]`);
      if (tabBtn) tabBtn.click();
    });
  });

  // Optional items inline edit (name, code, price)
  container.querySelectorAll('.opt-name').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const ti = parseInt(e.target.dataset.trimIdx, 10);
      const oi = parseInt(e.target.dataset.optIdx, 10);
      CURRENT_DATA.trims[ti].optional_items[oi].name = e.target.value;
    });
  });
  container.querySelectorAll('.opt-code').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const ti = parseInt(e.target.dataset.trimIdx, 10);
      const oi = parseInt(e.target.dataset.optIdx, 10);
      CURRENT_DATA.trims[ti].optional_items[oi].code = e.target.value;
    });
  });
  container.querySelectorAll('.opt-price').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const ti = parseInt(e.target.dataset.trimIdx, 10);
      const oi = parseInt(e.target.dataset.optIdx, 10);
      const v = parseInt(e.target.value.replace(/\s/g, ''), 10);
      CURRENT_DATA.trims[ti].optional_items[oi].price = Number.isFinite(v) ? v : 0;
    });
  });
  container.querySelectorAll('.btn-add-optional').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const ti = parseInt(e.target.dataset.trimIdx, 10);
      if (!Array.isArray(CURRENT_DATA.trims[ti].optional_items)) CURRENT_DATA.trims[ti].optional_items = [];
      CURRENT_DATA.trims[ti].optional_items.push({ name: 'Nová položka', code: '', price: 0 });
      renderTrims(CURRENT_DATA.trims);
      const tabBtn = container.querySelector(`.trim-tab-btn[data-trim-idx="${ti}"]`);
      if (tabBtn) tabBtn.click();
    });
  });
  container.querySelectorAll('.btn-remove-optional').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const ti = parseInt(e.target.dataset.trimIdx, 10);
      const oi = parseInt(e.target.dataset.optIdx, 10);
      CURRENT_DATA.trims[ti].optional_items.splice(oi, 1);
      renderTrims(CURRENT_DATA.trims);
      const tabBtn = container.querySelector(`.trim-tab-btn[data-trim-idx="${ti}"]`);
      if (tabBtn) tabBtn.click();
    });
  });
}

function renderTrimPane(t, ti) {
  const features = Array.isArray(t.features) ? t.features : [];
  const optional = Array.isArray(t.optional_items) ? t.optional_items : [];

  let html = `
    <div class="trim-header-row">
      <div>
        <label class="pkg-lab">Název výbavového stupně</label>
        <input class="trim-name-input" data-trim-idx="${ti}" type="text" value="${escapeAttr(t.name ?? '')}" />
      </div>
      <div>
        <label class="pkg-lab">Ceníková cena (Kč)</label>
        <input class="trim-price-input" data-trim-idx="${ti}" type="text" value="${t.list_price ?? ''}" placeholder="např. 669000" />
      </div>
    </div>

    <h3 class="trim-section-heading">Co dostane zákazník <span class="muted">(${features.reduce((a, s) => a + (s.items?.length ?? 0), 0)} položek)</span></h3>
  `;

  for (let si = 0; si < features.length; si++) {
    const sec = features[si];
    const itemsText = (sec.items ?? []).join('\n');
    html += `
      <details class="feat-section" open>
        <summary>
          <input class="section-title-input" data-trim-idx="${ti}" data-section-idx="${si}" type="text" value="${escapeAttr(sec.section ?? '')}" placeholder="Název sekce" />
          <button class="btn-remove-section" data-trim-idx="${ti}" data-section-idx="${si}" title="Smazat sekci">×</button>
        </summary>
        <textarea class="section-items-textarea" data-trim-idx="${ti}" data-section-idx="${si}" rows="${Math.max(3, (sec.items ?? []).length + 1)}" placeholder="Jedna položka na řádek">${escapeHtml(itemsText)}</textarea>
      </details>
    `;
  }
  html += `<button class="btn-add-section" data-trim-idx="${ti}">+ Přidat sekci</button>`;

  html += `<h3 class="trim-section-heading">Co si zákazník může dokoupit <span class="muted">(${optional.length} položek)</span></h3>`;
  if (optional.length === 0) {
    html += `<p class="muted">Žádné dokoupitelné položky.</p>`;
  } else {
    html += `<table class="opt-table"><thead><tr><th>Název</th><th style="width:120px;">Kód</th><th style="width:140px;">Cena (Kč)</th><th style="width:40px;"></th></tr></thead><tbody>`;
    for (let oi = 0; oi < optional.length; oi++) {
      const o = optional[oi];
      html += `<tr>
        <td><input class="opt-name" data-trim-idx="${ti}" data-opt-idx="${oi}" type="text" value="${escapeAttr(o.name ?? '')}" /></td>
        <td><input class="opt-code" data-trim-idx="${ti}" data-opt-idx="${oi}" type="text" value="${escapeAttr(o.code ?? '')}" placeholder="—" /></td>
        <td><input class="opt-price" data-trim-idx="${ti}" data-opt-idx="${oi}" type="text" value="${o.price ?? ''}" /></td>
        <td><button class="btn-remove-optional" data-trim-idx="${ti}" data-opt-idx="${oi}" title="Smazat">×</button></td>
      </tr>`;
    }
    html += `</tbody></table>`;
  }
  html += `<button class="btn-add-optional" data-trim-idx="${ti}">+ Přidat dokoupitelnou položku</button>`;

  return html;
}

function renderPackages(packages, trims) {
  const container = $('packages-container');
  if (!packages.length) {
    container.innerHTML = '<p class="muted">Žádné pakety v ceníku. <button id="add-package-empty" class="btn-link">+ Přidat paket ručně</button></p>';
    const addBtn = document.getElementById('add-package-empty');
    if (addBtn) addBtn.addEventListener('click', () => { addPackage(); });
    return;
  }

  let html = '';
  for (let pi = 0; pi < packages.length; pi++) {
    const p = packages[pi];
    const contentsText = (p.contents ?? []).join('\n');
    html += `
    <details class="panel pkg-card" style="margin-bottom:10px;" ${pi === 0 ? 'open' : ''}>
      <summary style="cursor:pointer;font-weight:700;display:flex;align-items:center;gap:10px;">
        <span class="pkg-summary-name">${escapeHtml(p.name || '(bez názvu)')}</span>
        ${p.code ? `<code style="color:#888;font-weight:400;">(${escapeHtml(p.code)})</code>` : ''}
        <button class="pkg-remove" data-pkg-idx="${pi}" title="Smazat paket" style="margin-left:auto;background:#fee;color:#b43a2c;border:1px solid #f5b4b4;padding:3px 9px;font-size:12px;border-radius:4px;cursor:pointer;">Smazat</button>
      </summary>

      <div class="pkg-row" style="display:grid;grid-template-columns:1fr 200px;gap:10px;margin-top:10px;">
        <div>
          <label class="pkg-lab">Název paketu</label>
          <input class="pkg-name-input" data-pkg-idx="${pi}" type="text" value="${escapeAttr(p.name ?? '')}" placeholder="např. CLUB+, BLACK, SAFETY" />
        </div>
        <div>
          <label class="pkg-lab">Kód (volitelný)</label>
          <input class="pkg-code-input" data-pkg-idx="${pi}" type="text" value="${escapeAttr(p.code ?? '')}" placeholder="např. CGK" />
        </div>
      </div>

      <p class="pkg-lab" style="margin-top:14px;">Ceny pro výbavové stupně <span class="muted">(klik do buňky — zadej číslo Kč / <code>standard</code> / <code>unavailable</code>)</span></p>
      <table class="pkg-pricing" data-pkg-idx="${pi}" style="width:100%;border-collapse:collapse;font-size:13px;margin-top:4px;">
        <thead><tr>${trims.map((t) => `<th style="padding:7px;background:#f5f5f7;text-align:center;">${escapeHtml(t.name)}</th>`).join('')}</tr></thead>
        <tbody><tr>${trims.map((t) => {
          const slug = slugifyJs(t.name);
          const v = p.pricing_per_trim?.[slug];
          return `<td class="cell ${pricingCellClass(v)}" data-pkg-trim-slug="${slug}" title="Klik pro úpravu">${formatPricingValue(v)}</td>`;
        }).join('')}</tr></tbody>
      </table>

      <label class="pkg-lab" style="margin-top:14px;">Obsah paketu <span class="muted">(jedna položka na řádek)</span></label>
      <textarea class="pkg-contents-input" data-pkg-idx="${pi}" rows="${Math.max(3, (p.contents ?? []).length + 1)}" placeholder="Vyhřívaný volant\nVyhřívání předních sedadel\nVnitřní zpětné zrcátko s automatickým stmíváním">${escapeHtml(contentsText)}</textarea>
    </details>`;
  }

  html += `<div style="margin-top:14px;"><button id="add-package-btn" style="background:#2f9b5c;color:white;padding:8px 18px;font-size:13px;border:none;border-radius:5px;cursor:pointer;">+ Přidat paket</button></div>`;
  container.innerHTML = html;

  // Wire up event handlers — name/code/contents inputs
  container.querySelectorAll('.pkg-name-input').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const i = parseInt(e.target.dataset.pkgIdx, 10);
      CURRENT_DATA.packages[i].name = e.target.value;
      const summary = e.target.closest('.pkg-card')?.querySelector('.pkg-summary-name');
      if (summary) summary.textContent = e.target.value || '(bez názvu)';
    });
  });
  container.querySelectorAll('.pkg-code-input').forEach((inp) => {
    inp.addEventListener('input', (e) => {
      const i = parseInt(e.target.dataset.pkgIdx, 10);
      CURRENT_DATA.packages[i].code = e.target.value;
    });
  });
  container.querySelectorAll('.pkg-contents-input').forEach((ta) => {
    ta.addEventListener('input', (e) => {
      const i = parseInt(e.target.dataset.pkgIdx, 10);
      CURRENT_DATA.packages[i].contents = e.target.value
        .split('\n')
        .map((l) => l.trim())
        .filter((l) => l.length > 0);
    });
  });

  // Pricing cells inline edit (pricing_per_trim object)
  container.querySelectorAll('.pkg-pricing td.cell').forEach((td) => {
    td.addEventListener('click', () => {
      if (td.querySelector('input')) return;
      const tbl = td.closest('.pkg-pricing');
      const pi = parseInt(tbl.dataset.pkgIdx, 10);
      const slug = td.dataset.pkgTrimSlug;
      if (!CURRENT_DATA.packages[pi].pricing_per_trim) CURRENT_DATA.packages[pi].pricing_per_trim = {};
      const cur = CURRENT_DATA.packages[pi].pricing_per_trim[slug];
      const curStr = (typeof cur === 'number') ? String(cur) : (cur ?? '');
      const input = document.createElement('input');
      input.type = 'text';
      input.value = curStr;
      input.placeholder = 'číslo / standard / unavailable';
      input.style.cssText = 'width:100%;box-sizing:border-box;border:2px solid #1f6feb;padding:4px 6px;font-size:13px;text-align:center;border-radius:3px;';
      td.textContent = '';
      td.appendChild(input);
      input.focus(); input.select();
      const commit = (save) => {
        if (save) {
          const v = input.value.trim();
          let parsed;
          if (v === '' || v === '-' || v === '–') parsed = 'unavailable';
          else if (v.toLowerCase() === 'standard' || v === 'S') parsed = 'standard';
          else if (v.toLowerCase() === 'unavailable') parsed = 'unavailable';
          else {
            const num = parseInt(v.replace(/\s/g, ''), 10);
            parsed = Number.isFinite(num) ? num : v;
          }
          CURRENT_DATA.packages[pi].pricing_per_trim[slug] = parsed;
        }
        const v = CURRENT_DATA.packages[pi].pricing_per_trim[slug];
        td.textContent = formatPricingValue(v);
        td.className = `cell ${pricingCellClass(v)}`;
      };
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); commit(true); }
        else if (e.key === 'Escape') { e.preventDefault(); commit(false); }
      });
      input.addEventListener('blur', () => commit(true));
    });
  });

  // Remove package
  container.querySelectorAll('.pkg-remove').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const i = parseInt(e.target.dataset.pkgIdx, 10);
      if (!confirm(`Smazat paket "${CURRENT_DATA.packages[i].name}"?`)) return;
      CURRENT_DATA.packages.splice(i, 1);
      renderPackages(CURRENT_DATA.packages, CURRENT_DATA.trims);
      $('count-packages').textContent = CURRENT_DATA.packages.length;
    });
  });

  // Add package
  const addBtn = document.getElementById('add-package-btn');
  if (addBtn) addBtn.addEventListener('click', () => { addPackage(); });
}

function addPackage() {
  const pricing_per_trim = {};
  for (const t of CURRENT_DATA.trims) pricing_per_trim[slugifyJs(t.name)] = 'unavailable';
  const newPkg = { name: 'Nový paket', code: '', contents: [], pricing_per_trim };
  CURRENT_DATA.packages.push(newPkg);
  renderPackages(CURRENT_DATA.packages, CURRENT_DATA.trims);
  $('count-packages').textContent = CURRENT_DATA.packages.length;
  const cards = document.querySelectorAll('#packages-container details');
  if (cards.length) {
    cards.forEach((c, i) => c.open = (i === cards.length - 1));
    cards[cards.length - 1].scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
}

function escapeAttr(s) {
  return String(s ?? '').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

// JS-side slugify (matches save.ts slugify výsledkem pro běžné trim názvy)
function slugifyJs(s) {
  return String(s ?? '').toLowerCase().trim()
    .replace(/\+/g, '-plus').replace(/&/g, '-and')
    .normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'untitled';
}

// Pricing hodnota → třída cellu (barva)
function pricingCellClass(v) {
  if (v === 'standard') return 'cell-standard';
  if (v === 'unavailable' || v == null) return 'cell-unavailable';
  if (typeof v === 'number') return 'cell-optional';
  return 'cell-other';
}
function formatPricingValue(v) {
  if (v === 'standard') return 'standard';
  if (v === 'unavailable' || v == null) return '–';
  if (typeof v === 'number') return v.toLocaleString('cs-CZ');
  return String(v);
}

function renderColors(ext, int, trims) {
  const container = $('colors-container');
  let html = '';
  const colorPriceCell = (c, trim) => {
    const slug = slugifyJs(trim.name);
    // Akceptuj jak pricing_per_trim object, tak fallback array cells (legacy)
    let v = c.pricing_per_trim?.[slug];
    if (v === undefined && Array.isArray(c.cells)) v = c.cells[trims.indexOf(trim)];
    if (v === undefined || v === '' || v === '-' || v === '–') return `<td class="cell cell-unavailable">–</td>`;
    if (typeof v === 'number') return `<td class="cell cell-optional">${v.toLocaleString('cs-CZ')}</td>`;
    const num = parseInt(String(v).replace(/\s/g, ''), 10);
    if (Number.isFinite(num)) return `<td class="cell cell-optional">${num.toLocaleString('cs-CZ')}</td>`;
    return `<td class="cell cell-standard">${escapeHtml(String(v))}</td>`;
  };

  if (ext?.length) {
    html += '<h3>Exteriér</h3><table style="width:100%;border-collapse:collapse;font-size:13px;"><thead><tr><th style="text-align:left;padding:6px;background:#f5f5f7;">Barva</th><th style="padding:6px;background:#f5f5f7;">Kód</th><th style="padding:6px;background:#f5f5f7;">Typ</th>';
    for (const t of trims) html += `<th style="padding:6px;background:#f5f5f7;text-align:center;">${escapeHtml(t.name)}</th>`;
    html += '</tr></thead><tbody>';
    for (const c of ext) {
      html += `<tr><td style="padding:6px;">${escapeHtml(c.name ?? '')}</td><td style="padding:6px;color:#999;">${escapeHtml(c.code ?? '')}</td><td style="padding:6px;">${escapeHtml(c.type ?? '')}</td>`;
      for (const t of trims) html += colorPriceCell(c, t);
      html += '</tr>';
    }
    html += '</tbody></table>';
  }
  if (int?.length) {
    html += '<h3 style="margin-top:16px;">Interiér</h3><table style="width:100%;border-collapse:collapse;font-size:13px;"><thead><tr><th style="text-align:left;padding:6px;background:#f5f5f7;">Barva</th><th style="padding:6px;background:#f5f5f7;">Kód</th><th style="padding:6px;background:#f5f5f7;">Materiál</th>';
    for (const t of trims) html += `<th style="padding:6px;background:#f5f5f7;text-align:center;">${escapeHtml(t.name)}</th>`;
    html += '</tr></thead><tbody>';
    for (const c of int) {
      html += `<tr><td style="padding:6px;">${escapeHtml(c.name ?? '')}</td><td style="padding:6px;color:#999;">${escapeHtml(c.code ?? '')}</td><td style="padding:6px;">${escapeHtml(c.material ?? '')}</td>`;
      for (const t of trims) html += colorPriceCell(c, t);
      html += '</tr>';
    }
    html += '</tbody></table>';
  }
  if (!html) html = '<p class="muted">Žádné barvy v ceníku.</p>';
  container.innerHTML = html;
}

function renderTechData(td) {
  const tbody = $('techdata-tbody');
  tbody.innerHTML = '';
  for (const [k, v] of Object.entries(td ?? {})) {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td style="padding:6px;font-weight:500;">${escapeHtml(k)}</td><td style="padding:6px;">${escapeHtml(String(v))}</td>`;
    tbody.appendChild(tr);
  }
}

// ─── Tabs ────────────────────────────────────────────────
$$('#tabs .tab-btn').forEach((btn) => {
  btn.addEventListener('click', () => {
    const tab = btn.dataset.tab;
    $$('#tabs .tab-btn').forEach((b) => b.classList.toggle('active', b === btn));
    $$('.tab-content').forEach((c) => c.classList.toggle('active', c.dataset.tab === tab));
  });
});

// ─── SAVE ────────────────────────────────────────────────
$('save-btn').addEventListener('click', async () => {
  if (!CURRENT_DATA) return;
  const yearId = $('year-select').value;
  if (!yearId) { alert('Vyber model_year'); return; }
  const totalRows = CURRENT_DATA.sections.reduce((a, s) => a + s.rows.length, 0);
  if (!confirm(`Uložit do "${$('year-select').selectedOptions[0]?.textContent}":\n${CURRENT_DATA.trims.length} výbavových stupňů, ${totalRows} řádků, ${CURRENT_DATA.packages.length} paketů.\n\nPokračovat?`)) return;

  $('save-btn').disabled = true;
  $('save-btn').textContent = '⏳ Ukládám...';

  try {
    await refreshAccessToken();
    let r = await fetch('/api/cenik/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ model_year_id: yearId, directus_token: TOKEN, data: CURRENT_DATA }),
    });
    let result = await r.json();
    if (!r.ok && JSON.stringify(result).includes('TOKEN_EXPIRED')) {
      if (await refreshAccessToken()) {
        r = await fetch('/api/cenik/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ model_year_id: yearId, directus_token: TOKEN, data: CURRENT_DATA }),
        });
        result = await r.json();
      }
    }
    showSaveResult(r.ok, result);
  } catch (e) {
    showSaveResult(false, { error: e.message });
  } finally {
    $('save-btn').disabled = false;
    $('save-btn').textContent = 'Uložit do Directus';
  }
});

function showSaveResult(ok, result) {
  const div = $('save-result');
  div.classList.remove('hidden');
  if (ok && result.ok) {
    const s = result.summary;
    div.className = 'success';
    div.innerHTML = `
      <strong>✓ Uloženo do Directus</strong><br>
      Výbavové stupně: ${s.trims_created} vytvořeno, ${s.trims_updated} aktualizováno<br>
      Pakety: ${s.packages_created} vytvořeno, ${s.packages_updated} aktualizováno<br>
      Barvy z ceníku: ${(s.colors_ext_updated ?? 0)} exteriér + ${(s.colors_int_updated ?? 0)} interiér → uloženo do model_years.pricelist_colors<br>
      Tech data: ${s.tech_data_updated ? 'updatováno' : 'beze změny'}<br>
      ${s.errors.length ? `<br><strong style="color:#b43a2c;">Chyby (${s.errors.length}):</strong><br>${s.errors.map((e) => escapeHtml(e)).join('<br>')}` : ''}
      <details style="margin-top:8px;"><summary class="muted">Detail (${s.details.length})</summary><pre style="font-size:11px;">${s.details.map((d) => escapeHtml(d)).join('\n')}</pre></details>
    `;
  } else {
    div.className = 'error';
    div.innerHTML = `<strong>✗ Save selhal</strong><br>${escapeHtml(result.error ?? 'Neznámá chyba')}`;
  }
  div.scrollIntoView({ behavior: 'smooth' });
}

$('discard-btn').addEventListener('click', () => {
  if (confirm('Zahodit review a začít znova?')) {
    CURRENT_DATA = null;
    $('result-panel').classList.add('hidden');
    SELECTED_PDF = null;
    dz.classList.remove('has-file');
    dz.innerHTML = `<p><strong>Drag & drop PDF zde</strong></p><p class="muted">nebo klikni a vyber soubor (max 50 MB)</p>`;
    $('analyze-btn').disabled = true;
  }
});

function escapeHtml(s) {
  return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
}
</script>
</body>
</html>
