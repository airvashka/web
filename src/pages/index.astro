---
import BaseLayout from '@layouts/BaseLayout.astro';
import DirectusImage from '@components/DirectusImage.astro';
import VideoStrip from '@components/VideoStrip.astro';
import InstagramStrip from '@components/InstagramStrip.astro';
import JsonLd from '@components/JsonLd.astro';
import GoogleReviews from '@components/GoogleReviews.astro';
import BrandLogo from '@components/BrandLogo.astro';
import { directusGet } from '@lib/directus';
import { buildStockSlug } from '@lib/stockSlug';
import { autoDealerSchema, websiteSchema } from '@lib/schemas';
import googleReviews from '../data/google-reviews.json';
import type { Brand, StockVehicle, Model } from '@lib/types';

/* ============================================================
   HOMEPAGE — 1:1 podle _design-draft/home.jsx
   Sections: Hero · BrandTiles · Skladovka · ServisEshop · Magazín
   ============================================================ */

// Brandy
const brands = await directusGet<Brand>('brands', {
  sort: ['sort'],
  fields: ['id', 'slug', 'name', 'tagline', 'description', 'hero_image', 'status'],
  filter: { status: { _eq: 'published' } },
});

// Skladové vozy (4 nejnovější)
const stockVehicles = await directusGet<any>('stock_vehicles', {
  limit: 4,
  sort: ['-listed_at'],
  fields: [
    'id', 'condition', 'availability', 'km', 'list_price', 'promo_price',
    'highlighted', 'highlight_label', 'listed_at', 'trim_level_snapshot',
    'color_code', 'color_category',
    'photos.directus_files_id',
    'model.id', 'model.name', 'model.slug',
    'model.promo_active', 'model.promo_label', 'model.promo_discount_amount', 'model.promo_valid_to',
    'brand.id', 'brand.name', 'brand.slug',
    'trim_level.name',
    'model_year.year',
  ],
  filter: { status: { _eq: 'published' }, availability: { _in: ['in_stock', 'on_the_way'] } },
});

const totalStockResult = await directusGet<StockVehicle>('stock_vehicles', {
  fields: ['id', 'condition'],
  filter: { status: { _eq: 'published' }, availability: { _in: ['in_stock', 'on_the_way'] } },
  limit: 200,
});
const totalStockCount = totalStockResult.length;
const demoStockCount = totalStockResult.filter((v) => v.condition === 'demo').length;

const BRAND_DISPLAY: Record<string, { name: string; tag: string }> = {
  'kgm': { name: 'KGM', tag: 'Korejský charakter, evropský komfort' },
  'omoda-jaecoo': { name: 'Omoda & Jaecoo', tag: 'Nová éra SUV' },
  'farizon': { name: 'Farizon', tag: 'Elektrická logistika' },
};

const fmtPrice = (n?: number | null) => (n ? `${n.toLocaleString('cs-CZ')} Kč` : '—');
const fmtKm = (n?: number | null) => (n === 0 || !n ? '0 km' : `${n.toLocaleString('cs-CZ')} km`);

// Site settings — admin editovatelná titulka
const settingsList = await directusGet<any>('site_settings', { limit: 1, fields: ['*'] });
const settings = settingsList?.[0] ?? {};

// Hero — priorita admin (Site Settings) > hardcoded fallback
const heroTitleLines = (settings.homepage_hero_title ?? 'Tři značky.\nJeden servis.\nBez kompromisů.')
  .split(/\n/).filter((l: string) => l.trim());
const heroSub = settings.homepage_hero_subtitle ?? 'Autorizovaný prodej a servis vozů KGM, OMODA & JAECOO a FARIZON.';
const heroCtaLabel = settings.homepage_hero_cta_label ?? 'Prohlédnout skladovku';
const heroCtaUrl = settings.homepage_hero_cta_url ?? '/sklad';
const heroCtaSecondaryLabel = settings.homepage_hero_cta_secondary_label ?? 'Objednat servis';
const heroCtaSecondaryUrl = settings.homepage_hero_cta_secondary_url ?? '/servis';
const heroImageId: string | null = settings.homepage_hero_image ?? null;
const youtubeIds: string[] = Array.isArray(settings.homepage_youtube_video_ids)
  ? settings.homepage_youtube_video_ids
  : ['piG8UO24WUk', 'eSfJXjNV8Mg', 'SybpHjEJP1s', 'S9tdBpkwX_4'];
const youtubeChannelUrl = settings.youtube_channel_url ?? 'https://www.youtube.com/@sfrmotor';
const instagramUrl = settings.instagram_url ?? 'https://www.instagram.com/sfrmotor/';

// Servis split — TODO: load from a "service_pricing" collection in Directus
const services = [
  { nm: 'Servis klimatizace', price: '1 590 Kč' },
  { nm: 'Výměna oleje vč. filtru', price: '2 490 Kč' },
  { nm: 'Geometrie náprav', price: '1 190 Kč' },
  { nm: 'Přezutí a uskladnění', price: '1 490 Kč' },
];

// Magazín — 4 nejnovější published články z Directusu
const articlesRaw = await directusGet<any>('articles', {
  filter: { status: { _eq: 'published' } },
  sort: ['-date_published', '-id'],
  limit: 4,
  fields: ['id', 'slug', 'title', 'category', 'date_published', 'cover_image'],
});

// Mapování category enum → user-friendly tag label
const CATEGORY_LABELS: Record<string, string> = {
  recenze: 'Recenze',
  test: 'Test',
  novinka: 'Novinky',
  srovnani: 'Srovnání',
  technologie: 'Technologie',
  servis: 'Servis',
  znacka: 'Značka',
  zpravy: 'Zprávy',
};

const articles = articlesRaw.map((a) => {
  let dateStr = '';
  if (a.date_published) {
    const d = new Date(a.date_published);
    dateStr = `${d.getDate()}. ${d.getMonth() + 1}. ${d.getFullYear()}`;
  }
  return {
    slug: a.slug,
    title: a.title,
    tag: CATEGORY_LABELS[a.category] ?? a.category ?? '',
    date: dateStr,
    cover: a.cover_image ?? null,
  };
});
---

<BaseLayout
  title="SFR Motor"
  description="SFR Motor — autorizovaný dealer KGM, OMODA & JAECOO a Farizon. Skladové vozy, servis pro všechny značky, prodej a doplňkové služby. Praha-Ďáblice."
>
  <JsonLd data={[autoDealerSchema(googleReviews.prodej), websiteSchema()]} />
  <!-- ===== HERO =====
       Foto + texty z Directus Site Settings (admin → Site Settings).
       Fallback: /hero-home.jpg pokud nic v adminu. -->
  <section class="hhero" data-screen-label="01 Hero">
    <div class="hhero-bg">
      {heroImageId ? (
        <DirectusImage src={heroImageId} alt="" fill widths={[1280, 1920, 2560, 3200]} sizes="100vw" loading="eager" fetchpriority="high" />
      ) : (
        <img src="/hero-home.jpg" alt="" onerror="this.style.display='none'" />
      )}
    </div>
    <div class="container hhero-inner">
      <h1 class="hhero-title">
        {heroTitleLines.map((line: string) => (<Fragment>{line}<br /></Fragment>))}
      </h1>
      <p class="hhero-sub">{heroSub}</p>
      <div class="hhero-actions">
        <a class="btn btn-primary" href={heroCtaUrl}>
          {heroCtaLabel}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a class="btn btn-outline" href={heroCtaSecondaryUrl}>{heroCtaSecondaryLabel}</a>
      </div>
    </div>
  </section>

  <!-- ===== BRAND TILES (2x2) ===== -->
  <section class="brand-tiles" data-screen-label="02 Značky">
    <div class="container">
      <div class="brand-tiles-head">
        <div>
          <div class="section-eyebrow">Naše značky</div>
          <h2>Auta, která dávají smysl pro každý styl jízdy</h2>
        </div>
        <a class="head-link" href="/sklad">
          Všechny vozy skladem
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="brand-tiles-grid">
        {brands.map((b) => {
          const meta = BRAND_DISPLAY[b.slug] ?? { name: b.name, tag: b.tagline ?? '' };
          return (
            <div class="btile">
              <div class="btile-bg">
                {b.hero_image && <DirectusImage src={b.hero_image} alt={`${b.name} — hero`} aspectRatio="16/10" />}
              </div>
              <div class="btile-body">
                <div class="btile-name btile-name--logo">
                  <BrandLogo slug={b.slug} variant="light" class="btile-logo" />
                  <span class="sr-only">{meta.name}</span>
                </div>
                <div class="btile-tag">{meta.tag}</div>
                <div class="btile-actions">
                  <a href={`/${b.slug}`}>
                    Modely
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                  <a href={`/sklad?znacka=${b.slug}`}>
                    Skladem
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              </div>
            </div>
          );
        })}
        <!-- 4. dlaždice — Promo skladovka (live status redesign + watermark) -->
        <div class="btile is-promo">
          <div class="btile-stripes" aria-hidden="true"></div>
          <span class="btile-watermark" aria-hidden="true">SKLADOVÉ<br/>VOZY</span>
          <div class="btile-body">
            <div class="btile-live">
              <span class="live-dot" aria-hidden="true"></span>
              <span>Aktualizováno dnes</span>
            </div>
            <div class="btile-name">K odjezdu dnes.</div>
            <p class="btile-lead">Přes {totalStockCount} vozů na skladu napříč všemi značkami — kompletně připravené k převzetí.</p>
            <div class="btile-stats">
              <div class="btile-stat">
                <div class="v">{totalStockCount}</div>
                <div class="l">vozů skladem</div>
              </div>
              <div class="btile-stat-divider" aria-hidden="true"></div>
              <div class="btile-stat">
                <div class="v">{demoStockCount}</div>
                <div class="l">předváděcích</div>
              </div>
            </div>
            <div class="btile-actions">
              <a href="/sklad">
                Prohlédnout skladovku
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SKLADOVKA ===== -->
  <section class="skladovka" data-screen-label="03 Skladovka">
    <div class="container">
      <div class="skladovka-head">
        <div>
          <div class="section-eyebrow">Skladovka</div>
          <h2>Odjet můžete dnes</h2>
        </div>
        <a class="head-link" href="/sklad">
          Všech {totalStockCount}+ vozů
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      {stockVehicles.length === 0 ? (
        <div class="sklad-empty">Skladovka se právě plní — koukněte se za chvíli, nebo nám zavolejte +420 771 235 458.</div>
      ) : (
        <div class="skladovka-grid">
          {stockVehicles.map((v: any) => {
            const isNew = v.condition === 'new';
            const isHighlighted = v.highlighted;
            const customLabel = (v.highlight_label ?? '').toString().trim();
            const today = new Date().toISOString().slice(0, 10);
            const modelPromoActive = !!v.model?.promo_active
              && (v.model.promo_label || v.model.promo_discount_amount)
              && (!v.model.promo_valid_to || String(v.model.promo_valid_to) >= today);
            const modelPromoLabel = (v.model?.promo_label ?? '').toString().trim();
            const modelPromoDiscount = Number(v.model?.promo_discount_amount ?? 0) || 0;
            const pillLabel = modelPromoActive && modelPromoLabel
              ? modelPromoLabel
              : isHighlighted
                ? (customLabel || 'Novinka')
                : isNew ? 'Nové' : 'Skladem';
            const pillClass = (modelPromoActive || isHighlighted || isNew) ? ' is-new' : '';
            const photoId = v.photos?.[0]?.directus_files_id;
            const trim = v.trim_level_snapshot?.name ?? '';
            const modelName = v.model?.name ?? 'Vůz';
            const brandName = v.brand?.name ?? '';
            const carYear = v.model_year?.year ?? '';
            const conditionLabel = v.condition === 'new' ? 'Nové' : v.condition === 'demo' ? 'Předváděcí' : 'Ojeté';
            const fuelLabel = v.trim_level_snapshot?.fuel_label ?? '';
            // Cena s ohledem na model promo
            const baseList = v.list_price;
            let price = v.promo_price ?? baseList;
            let priceBefore: number | null = null;
            if (v.promo_price && baseList && v.promo_price < baseList) {
              priceBefore = baseList;
            } else if (modelPromoActive && modelPromoDiscount > 0 && baseList) {
              price = baseList - modelPromoDiscount;
              priceBefore = baseList;
            }
            return (
              <a class="scard" href={`/sklad/${buildStockSlug(v, v.brand, v.model, v.trim_level ?? { name: trim })}`}>
                <div class="pic">
                  {photoId && <DirectusImage src={photoId} alt={`${brandName} ${modelName}`} aspectRatio="4/3" />}
                </div>
                <div class="body">
                  <span class={`pill${pillClass}`}>{pillLabel}</span>
                  <div class="nm">{brandName} {modelName}</div>
                  <div class="var">{trim}</div>
                  <div class="meta">
                    {fuelLabel && <span>{fuelLabel}</span>}
                    {carYear && <span class="dot">{carYear}</span>}
                    <span class="dot">{fmtKm(v.km)}</span>
                    <span class="dot">{conditionLabel}</span>
                  </div>
                  <div class="price">{fmtPrice(price)}</div>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- ===== SERVIS + E-SHOP SPLIT ===== -->
  <section class="split" data-screen-label="04 Servis a E-shop">
    <div class="container split-grid">
      <div class="split-card split-card--servis">
        <div class="split-card-bg" aria-hidden="true">
          <img src="/servis_main.jpg" alt="" loading="lazy" decoding="async" />
        </div>
        <div class="split-card-content">
          <div class="split-card-top">
            <div class="eyebrow">Servis pro všechny značky</div>
            <h3>Online objednání servisu</h3>
            <div class="svc-list">
              {services.map((s) => (
                <div class="svc-row">
                  <span class="svc-name">{s.nm}</span>
                  <span class="dots"></span>
                  <span class="svc-price">{s.price}</span>
                </div>
              ))}
            </div>
          </div>
          <a class="btn btn-primary" href="/servis">Online objednání</a>
        </div>
      </div>
      <div class="split-card split-card--eshop">
        <div class="split-card-bg" aria-hidden="true">
          <img src="/eshop-bg.jpg" alt="" loading="lazy" decoding="async" />
        </div>
        <div class="split-card-content">
          <div class="split-card-top">
            <div class="eyebrow">E-shop</div>
            <h3>Originální příslušenství</h3>
            <p class="lead">Střešní boxy, nosiče kol, gumové koberce, alu kola — vše originál a v perfektní kvalitě.</p>
          </div>
          <a class="btn btn-primary" href="#">
            Otevřít e-shop
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== GOOGLE RECENZE — social proof před community sekcí ===== -->
  <section class="reviews-section" data-screen-label="05 Recenze">
    <div class="container">
      <div class="section-eyebrow">⭐ Google hodnocení</div>
      <GoogleReviews business="prodej" layout="cards" limit={4} headingText="Co o nás říkají naši zákazníci" />
    </div>
  </section>

  <!-- ===== YOUTUBE — IDs z Site Settings ===== -->
  <VideoStrip
    ids={youtubeIds}
    title="Naše videa"
    eyebrow="YouTube"
    count={4}
    channelUrl={youtubeChannelUrl}
  />

  <!-- ===== INSTAGRAM ===== -->
  <InstagramStrip />

  <!-- ===== MAGAZÍN ===== -->
  {articles.length > 0 && (
    <section class="magazin" data-screen-label="05 Magazín">
      <div class="container">
        <div class="magazin-head">
          <div>
            <div class="section-eyebrow">Magazín</div>
            <h2>Co u nás právě jede</h2>
          </div>
          <a class="head-link" href="/magazin">
            Všechny články
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="mag-grid">
          {articles.map((a) => (
            <a class="mag-card" href={`/magazin/${a.slug}`}>
              <div class="pic">
                {a.cover && <DirectusImage src={a.cover} alt={a.title} aspectRatio="4/3" />}
              </div>
              <div class="mag-meta">
                <span>{a.date}</span>
                {a.tag && <span class="tag">{a.tag}</span>}
              </div>
              <div class="mag-title">{a.title}</div>
              <span class="mag-link">
                Číst článek
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
