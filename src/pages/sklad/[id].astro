---
import BaseLayout from '@layouts/BaseLayout.astro';
import FuelIcon from '@components/FuelIcon.astro';
import DirectusImage from '@components/DirectusImage.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import JsonLd from '@components/JsonLd.astro';
import TurnstileWidget from '@components/TurnstileWidget.astro';
import { directusGet, directusAsset } from '@lib/directus';
import { FALLBACK_SALES_PHONE, telLink } from '@lib/contacts';
import { getGroupedFeatures, CATEGORY_LABELS } from '@lib/features';
import { vehicleSchema } from '@lib/schemas';
import { buildStockSlug, parseStockId } from '@lib/stockSlug';
import { tdToMap } from '@lib/technicalData';
import type { Brand, Model, StockVehicle, TrimLevel, ModelYear } from '@lib/types';

/* ============================================================
   STOCK DETAIL — 1:1 podle _design-draft/app.jsx
   Sections: Hero gallery + info · TrustStrip · About + highlights ·
   Equipment (grouped 4 cols) · Specs · Finance · Similar cars ·
   Contact form · Sticky CTA

   URL: /sklad/{brand}-{model}-{trim}-{color}-{id}
   ID je vždy na konci (last numeric segment).
   ============================================================ */

// SSR — data se tahají při requestu, ne při buildu.
// Důvod: skladovka se mění (cena, status, dostupnost). Static build by:
//   1) trval moc dlouho (každý vůz = 1 Directus call při buildu)
//   2) ukazoval stale data dokud admin nezdřejmí redeploy
//   3) padal pokud Directus má performance issue během buildu (právě se nám stalo)
// SSR: každý request = 1 Directus call (~100ms), data vždy fresh.
export const prerender = false;

// (getStaticPaths smazán — viz git historie pokud potřebuješ reaktivovat static prerender)

// POZN.: filename je [id].astro (legacy), ale hodnota je teď SLUG string
// (např. "kgm-tivoli-style-bila-3"). Skutečné numerické ID parsujeme z konce.
const { id: slug } = Astro.params;
const numericId = parseStockId(slug ?? '');
if (Number.isNaN(numericId)) return Astro.redirect('/404');
const id = String(numericId);

// Vercel Edge cache — 60s pro CDN, stale-while-revalidate 300s.
// User uvidí cached version okamžitě (~50ms), CDN revaliduje na pozadí.
// Po prodeji vozu trvá max 60s než cached version exspiruje.
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');

type VehicleFull = StockVehicle & {
  photos?: Array<{ directus_files_id: string }>;
  transmission?: string;
  drivetrain?: string;
  color_category?: string;
};
const vehicles = await directusGet<VehicleFull>('stock_vehicles', {
  filter: { id: { _eq: Number(id) }, status: { _eq: 'published' } },
  limit: 1,
  fields: [
    '*',
    'photos.directus_files_id',
    // M2O na konkrétní barvu modelu (cascading dropdown)
    'color_ref.id',
    'color_ref.name',
    'color_ref.hex',
    'color_ref.photo',
    'interior_color_ref.id',
    'interior_color_ref.name',
    'interior_color_ref.material',
    'interior_color_ref.hex',
    'interior_color_ref.photo',
    // M2M na option_packages (přes junction)
    'option_packages.option_packages_id.id',
    'option_packages.option_packages_id.name',
    'option_packages.option_packages_id.slug',
    'option_packages.option_packages_id.description',
    'option_packages.option_packages_id.features',
    'option_packages.option_packages_id.pricing_per_trim',
  ],
});
const v = vehicles[0];
if (!v) return Astro.redirect('/404');

// Vybrané option packages (M2M junction → unwrap)
const vehiclePackages: any[] = Array.isArray((v as any).option_packages)
  ? ((v as any).option_packages as any[])
      .map((j) => (typeof j === 'object' ? j?.option_packages_id : null))
      .filter(Boolean)
  : [];

// Všech 6 navazujících queries paralelně přes Promise.all.
// Sériově by trvaly 6×1s = 6s. Paralelně ~1s (max ze 6).
// Celkový page load: 1× vehicle + 1× parallel batch = 2 round-tripy.
const [brands, models, trims, modelYears, siteSettingsResult, similarResult] = await Promise.all([
  v.brand
    ? directusGet<Brand>('brands', { filter: { id: { _eq: Number(v.brand) } }, limit: 1 })
    : Promise.resolve([]),
  v.model
    ? directusGet<any>('models', {
        filter: { id: { _eq: Number(v.model) } },
        limit: 1,
        fields: ['*', 'technical_data', 'promo_active', 'promo_label', 'promo_discount_amount', 'promo_valid_to', 'promo_description'],
      })
    : Promise.resolve([]),
  v.trim_level
    ? directusGet<TrimLevel>('trim_levels', { filter: { id: { _eq: Number(v.trim_level) } }, limit: 1 })
    : Promise.resolve([]),
  v.model_year
    ? directusGet<any>('model_years', {
        filter: { id: { _eq: Number(v.model_year) } },
        limit: 1,
        fields: ['*', 'technical_data'],
      })
    : Promise.resolve([]),
  directusGet<any>('site_settings', {
    fields: ['stock_highlights'],
    limit: 1,
  }).catch(() => [] as any[]),
  v.model
    ? directusGet<any>('stock_vehicles', {
        filter: {
          id: { _neq: Number(v.id) },
          model: { _eq: Number(v.model) },
          status: { _eq: 'published' },
          availability: { _in: ['in_stock', 'on_the_way'] },
        },
        limit: 4,
        fields: [
          'id', 'condition', 'km', 'list_price', 'promo_price', 'color_code', 'color_category',
          'transmission', 'drivetrain', 'highlighted', 'highlight_label',
          'trim_level_snapshot', 'photos.directus_files_id', 'trim_level.name',
          'model_year.year', 'model.fuel_type', 'model.promo_active', 'model.promo_label', 'model.promo_discount_amount', 'model.promo_valid_to',
          'brand.name', 'brand.slug', 'model.name', 'model.slug',
        ],
      })
    : Promise.resolve([]),
]);

const brand = brands[0];
const model = models[0];
const trim = trims[0];
const modelYear = modelYears[0];

// Fotky M2M junction
const photoIds: string[] = Array.isArray(v.photos)
  ? (v.photos as any[]).map((p) => typeof p === 'string' ? p : p?.directus_files_id).filter(Boolean) as string[]
  : [];
const heroPhoto = photoIds[0] ?? null;
const thumbIds = photoIds.slice(1, 5);
const extraPhotos = Math.max(0, photoIds.length - 5);

// Akce na modelu (manuální, z admin)
const todayDate = new Date().toISOString().slice(0, 10);
const modelPromoActive: boolean = !!(model as any)?.promo_active
  && ((model as any)?.promo_label || (model as any)?.promo_discount_amount)
  && (!(model as any)?.promo_valid_to || String((model as any)?.promo_valid_to) >= todayDate);
const modelPromoLabel: string = ((model as any)?.promo_label ?? '').toString().trim();
const modelPromoDiscount: number = Number((model as any)?.promo_discount_amount ?? 0) || 0;
const modelPromoValidTo: string | null = (model as any)?.promo_valid_to ?? null;

// Cena — priorita:
//   1) stock.promo_price (specifická akce na konkrétním voze)
//   2) stock.list_price − model.promo_discount_amount (modelová akce)
//   3) stock.list_price (běžná cena)
const baseListPrice = v.list_price;
const stockPromoApplied = v.promo_price ?? null;
const modelDiscountApplied = modelPromoActive && modelPromoDiscount > 0 && baseListPrice
  ? baseListPrice - modelPromoDiscount
  : null;

let finalPrice: number | null = baseListPrice ?? null;
let priceBeforePromo: number | null = null;
let savings: number = 0;
let promoSource: 'stock' | 'model' | null = null;

if (stockPromoApplied && baseListPrice && stockPromoApplied < baseListPrice) {
  finalPrice = stockPromoApplied;
  priceBeforePromo = baseListPrice;
  savings = baseListPrice - stockPromoApplied;
  promoSource = 'stock';
} else if (modelDiscountApplied && baseListPrice) {
  finalPrice = modelDiscountApplied;
  priceBeforePromo = baseListPrice;
  savings = modelPromoDiscount;
  promoSource = 'model';
}
const hasPromo = priceBeforePromo !== null && savings > 0;

// Financování "od X Kč" — auto výpočet nejnižší možné splátky:
// 60% akontace, 72 měsíců, 4.9% p.a.
// Anuita: M = P × r / (1 − (1+r)^−n)
function computeMinMonthly(price: number | null | undefined): number | null {
  if (!price || price <= 0) return null;
  const dpPct = 0.6;
  const months = 72;
  const ratePa = 0.049;
  const r = ratePa / 12;
  const financed = price * (1 - dpPct);
  if (financed <= 0) return null;
  const m = (financed * r) / (1 - Math.pow(1 + r, -months));
  return Math.round(m);
}
const monthlyPayment = v.monthly_payment_from ?? computeMinMonthly(finalPrice);

// Labels
const conditionLabels: Record<string, string> = { new: 'Nový', demo: 'Předváděcí', used: 'Ojetý' };
const availabilityLabels: Record<string, string> = { in_stock: 'Skladem', on_the_way: 'Na cestě', reserved: 'Rezervováno', sold: 'Prodáno' };
const transmissionLabels: Record<string, string> = { manual: 'Manuál', automatic: 'Automat', dct: 'DCT', cvt: 'CVT', dht: 'Hybridní' };
const drivetrainLabels: Record<string, string> = { fwd: 'FWD', rwd: 'RWD', awd: 'AWD', '4wd': '4×4' };
const fuelLabels: Record<string, string> = { petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro' };

const trimDisplay = trim?.name ?? (v.trim_level_snapshot as any)?.name ?? (v.trim_level_snapshot as any)?.raw_name ?? '';
const title = `${brand?.name ?? ''} ${model?.name ?? ''}${trimDisplay ? ' ' + trimDisplay : ''}`.trim();
const fuelLabel = model ? (fuelLabels[(model as any).fuel_type] ?? '—') : '—';
const transmissionLabel = v.transmission ? (transmissionLabels[v.transmission] ?? v.transmission) : null;
const drivetrainLabel = v.drivetrain ? (drivetrainLabels[v.drivetrain] ?? v.drivetrain) : null;
const year = (v.trim_level_snapshot as any)?.year ?? modelYear?.year ?? (v.first_registration ? new Date(v.first_registration).getFullYear() : null);

// Barva karoserie — priorita: color_ref (M2O) > color_code (legacy text)
const colorRef = (v as any).color_ref ?? null;
const colorName = colorRef?.name ?? v.color_code ?? null;
const colorHex = colorRef?.hex ?? (v.color_code && /^#[0-9a-fA-F]{6}$/.test(v.color_code) ? v.color_code : null);
// Čitelný název barvy z feedu — KGM "LATTE béžová [EBL]" → bez [kódu]; OMODA "bílá".
// color_code je jen surový kód (WAA/EBL), proto čteme název ze snapshotu.
const _colorRaw = colorRef?.name ?? (v.trim_level_snapshot as any)?.color ?? null;
const _colorStripped = _colorRaw ? String(_colorRaw).replace(/\s*\[[^\]]*\]\s*$/, '').trim() : '';
const colorClean = _colorStripped ? _colorStripped.charAt(0).toUpperCase() + _colorStripped.slice(1) : null;

// Barva interiéru — M2O na model_color_interior
const interiorRef = (v as any).interior_color_ref ?? null;
const interiorName = interiorRef?.name ?? null;
const interiorMaterial = interiorRef?.material ?? null;

// Custom badge text (highlight_label override)
const highlightLabel: string = ((v as any).highlight_label ?? '').toString().trim() || 'Novinka';

// Status badge
const statusBadge = v.availability === 'in_stock' ? { cls: 'dark', label: 'Skladem' }
  : v.availability === 'reserved' ? { cls: 'outline', label: 'Rezervováno' }
  : v.availability === 'sold' ? { cls: 'outline', label: 'Prodáno' }
  : { cls: 'outline', label: 'Na cestě' };

// Equipment grouped — funguje pro nové groupy ({category, items}) i legacy flat array
const rawFeatures = (trim as any)?.features ?? [];
// Standardní výbava: PRIMÁRNĚ z feedu/scrapu konkrétního vozu, jinak z napojeného trimu.
//   OMODA/JAECOO feed → snapshot.equip   = [{ title, items: [{ title }] }]
//   KGM scrape        → snapshot.features = { kategorie: [string] }
//   ruční / legacy    → trim.features (getGroupedFeatures)
const _snap = (v.trim_level_snapshot as any) ?? {};
let feedGrouped: Array<{ label: string; items: string[] }> = [];
if (Array.isArray(_snap.equip)) {
  feedGrouped = _snap.equip
    .map((g: any) => ({
      label: g?.title ?? g?.category ?? 'Výbava',
      items: Array.isArray(g?.items)
        ? g.items.map((it: any) => (typeof it === 'string' ? it : it?.title)).filter(Boolean)
        : [],
    }))
    .filter((g: any) => g.items.length > 0);
} else if (_snap.features && typeof _snap.features === 'object' && !Array.isArray(_snap.features)) {
  feedGrouped = Object.entries(_snap.features)
    .map(([label, items]) => ({ label, items: Array.isArray(items) ? (items as any[]).map(String).filter(Boolean) : [] }))
    .filter((g) => g.items.length > 0);
}
let grouped = feedGrouped.length > 0 ? feedGrouped : getGroupedFeatures(rawFeatures);
// Flat seznam pro highlights heuristiku (čte se napříč skupinami)
const features: string[] = grouped.flatMap((g) => g.items);

// Specs — dědičnost: models.technical_data (base) ← model_year.technical_data (override)
// Base = aktuální spec modelu. Year-specific data jen přepisují odlišnosti
// (např. starší emisní normu pro 2024 oproti 2026).
const snapshot = (v.trim_level_snapshot as any) ?? {};
// Normalizace: tdToMap zvládne flat JSON objekt I new {label, value} repeater
const modelTd = tdToMap((model as any)?.technical_data);
const yearTd = tdToMap((modelYear as any)?.technical_data);
const td: any = { ...modelTd, ...yearTd };

// Dynamický výpis: vezmi všechno co user vyplnil v Models → Technical Data,
// plus přidej "Převodovka", "Palivo", "Pohon" z odznaků na konkrétním voze
// (pokud nejsou v td už uvedené).
// Feed specs (importované vozy OMODA/JAECOO) — per-VIN technická data ze snapshotu
// ve tvaru [{ title, value }]. Když feed specs jsou, mají přednost před obecnými
// technical_data modelu (jsou konkrétní pro tento vůz).
const feedSpecs: Array<[string, string]> = Array.isArray(snapshot.specs)
  ? snapshot.specs
      .map((s: any) => [String(s?.title ?? '').trim(), String(s?.value ?? '').trim()] as [string, string])
      .filter(([k, val]) => k && val)
  : [];
const curatedEntries: Array<[string, string]> = Object.entries(td)
  .filter(([, v]) => v !== null && v !== undefined && String(v).trim() !== '')
  .map(([k, v]) => [k, String(v)] as [string, string]);
// Bohatší zdroj vyhrává: KGM má bohatá kurátorská tech data (z /model dle roku),
// OMODA/JAECOO bohatý per-vůz feed. Vozy bez model_year padnou na feed (snapshot.specs).
const tdEntries: Array<[string, string]> = curatedEntries.length >= feedSpecs.length
  ? curatedEntries
  : feedSpecs;

// Vehicle-specific specs (jen pokud nejsou už v td)
const vehicleSpecs: Array<[string, string]> = [];
const hasKey = (re: RegExp) => tdEntries.some(([k]) => re.test(k));
if (transmissionLabel && !hasKey(/převod|transmiss/i)) vehicleSpecs.push(['Převodovka', transmissionLabel]);
if (fuelLabel && fuelLabel !== '—' && !hasKey(/palivo|fuel/i)) vehicleSpecs.push(['Palivo', fuelLabel]);
if (drivetrainLabel && !hasKey(/pohon|drivetrain/i)) vehicleSpecs.push(['Pohon', drivetrainLabel]);

const allSpecs = [...tdEntries, ...vehicleSpecs];

// ── Hero boxy: unifikovaný lookup hodnot napříč kurátorskými (td) i feed daty ──
const _specSearch: Array<[string, string]> = [...curatedEntries, ...feedSpecs];
const specFind = (re: RegExp): string | null => {
  for (const [k, val] of _specSearch) {
    if (re.test(k) && val && String(val).trim() !== '') return String(val).trim();
  }
  return null;
};
// Výkon: přímý klíč (kW), jinak vytáhni z "Motorizace … (120kW/163k)"
const _motor = specFind(/motorizace|^motor/i) ?? String(snapshot.motorization ?? '');
const _pwKwDirect = (specFind(/čist[ýy].*v[ýy]kon|max.*v[ýy]kon|v[ýy]kon.*kw|^kw$/i) ?? '').match(/\d+(?:[.,]\d+)?/)?.[0] ?? null;
const _pwKwMotor = _motor.match(/(\d+(?:[.,]\d+)?)\s*kw/i)?.[1] ?? null;
const _pwKsMotor = _motor.match(/(\d+)\s*k\b/i)?.[1] ?? null;
const _pwKw = _pwKwDirect ?? _pwKwMotor;
const heroPower: string | null = _pwKw
  ? (_pwKsMotor ? `${_pwKw} kW / ${_pwKsMotor} k` : `${_pwKw} kW`)
  : null;
// Počet míst / sedadel
const heroSeats: string | null = specFind(/po[čc]et\s*(m[íi]st|sedadel)/i)
  ?? (snapshot.seats ? (String(snapshot.seats).replace(/[^0-9]/g, '') || null) : null);
// Rozděl na dva sloupce zhruba půl na půl
const half = Math.ceil(allSpecs.length / 2);
const specsLeft = allSpecs.slice(0, half);
const specsRight = allSpecs.slice(half);

// Příplatková výbava tohoto konkrétního vozu = ruční extra_features + to, co
// scraper našel v sekci "Příplatková výbava" (trim_level_snapshot.optional_packages).
const extraListUniq: string[] = [...new Set([
  ...(Array.isArray((v as any).extra_features) ? (v as any).extra_features : []),
  ...(Array.isArray(snapshot.optional_packages) ? snapshot.optional_packages : []),
].map((s: any) => String(s).trim()).filter(Boolean))];

// Highlights — fetch z site_settings (editovatelné v adminu), fallback na hardcoded.
type Highlight = { icon: string; title: string; subtitle: string };
const HARDCODED_HIGHLIGHTS: Highlight[] = [
  { icon: 'shield', title: 'Záruka výrobce', subtitle: 'Plná tovární záruka 5–7 let dle modelu, kompletní servisní historie.' },
  { icon: 'swap', title: 'Výkup vašeho vozu', subtitle: 'Protiúčtem zaplatíte jen rozdíl. Online ocenění do hodiny.' },
  { icon: 'wallet', title: 'Financování a pojištění', subtitle: 'Zařídíme leasing, úvěr i pojištění na míru. Vy si jen vyzvednete klíče.' },
  { icon: 'badge', title: 'Autorizovaný prodejce', subtitle: 'KGM · OMODA & JAECOO · FARIZON. Originální díly a servis ve vlastní dílně.' },
];

// highlights + similar zpracovány z výsledků Promise.all nahoře (eliminace sériových calls)
let highlights: Highlight[] = HARDCODED_HIGHLIGHTS;
const fromAdmin = siteSettingsResult?.[0]?.stock_highlights;
if (Array.isArray(fromAdmin) && fromAdmin.length > 0) {
  highlights = fromAdmin
    .filter((h: any) => h?.title)
    .map((h: any) => ({
      icon: String(h.icon ?? 'star'),
      title: String(h.title),
      subtitle: String(h.subtitle ?? ''),
    }));
}

const similar = similarResult ?? [];

const conditionLabel = v.condition ? conditionLabels[v.condition] : '—';
const availabilityLabel = v.availability ? availabilityLabels[v.availability] : '—';
const description = (v.description ?? '').split(/\n\s*\n/).filter(Boolean);

// Dynamický prodejní telefon (z middleware, fallback)
const salesContact = (Astro.locals as any).salesContact;
const salesPhone = salesContact?.phone ?? FALLBACK_SALES_PHONE;
const salesPhoneLink = telLink(salesPhone);
---

<BaseLayout title={title || 'Skladový vůz'} description={`${title} — skladový vůz u SFR Motor Praha-Ďáblice.`}>
  <JsonLd data={vehicleSchema({
    url: `https://sfr-motor.cz${Astro.url.pathname}`,
    brand: brand?.name ?? 'KGM',
    model: model?.name ?? 'Vůz',
    trim: trim?.name,
    year: year ?? null,
    vin: v.vin ?? null,
    km: v.km ?? null,
    condition: (v.condition ?? 'new') as 'new' | 'demo' | 'used',
    fuelType: fuelLabel !== '—' ? fuelLabel : undefined,
    transmission: transmissionLabel,
    drivetrain: drivetrainLabel,
    color: colorName,
    priceCzk: finalPrice,
    listPriceCzk: priceBeforePromo,
    availability: (v.availability ?? 'in_stock') as 'in_stock' | 'on_the_way' | 'reserved' | 'sold',
    photoUrls: photoIds.slice(0, 5).map((id) => directusAsset(id, { width: 1200, format: 'jpg', quality: 85 })),
    description: (v.description ?? '').slice(0, 500) || undefined,
  })} />
  <Breadcrumbs items={[
    { label: 'Skladové vozy', href: '/sklad' },
    ...(brand ? [{ label: brand.name, href: `/${brand.slug}` }] : []),
    ...(model ? [{ label: model.name, href: `/model/${model.slug}` }] : []),
    { label: trim?.name ?? title },
  ]} />
  <main>
    <div class="container">

      <!-- ===== HERO ===== -->
      <section class="hero" data-screen-label="Hero">
        <div>
          <button class="gallery-main" type="button" data-gallery-trigger data-index="0" aria-label="Otevřít galerii">
            <div class="badges">
              <span class={`badge ${statusBadge.cls}`}>{statusBadge.label}</span>
              {/* Model promo má prioritu (např. "JARNÍ AKCE -50K") */}
              {modelPromoActive && modelPromoLabel && (
                <span class="badge accent">{modelPromoLabel}</span>
              )}
              {/* Stock highlight jen pokud není model promo nebo má jiný text */}
              {v.highlighted && (!modelPromoActive || !modelPromoLabel) && (
                <span class="badge accent">{highlightLabel}</span>
              )}
              {year && <span class="badge outline">Model {year}</span>}
            </div>
            {photoIds.length > 0 && <div class="gallery-counter">01 / {String(photoIds.length).padStart(2, '0')}</div>}
            {v.gallery_360_url && (
              <a class="gallery-360" href={v.gallery_360_url} target="_blank" rel="noopener" onclick="event.stopPropagation()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
                360° pohled
              </a>
            )}
            {heroPhoto ? (
              <DirectusImage src={heroPhoto} alt={title} aspectRatio="auto" widths={[800, 1600]} loading="eager" fetchpriority="high" />
            ) : (
              <div style="padding: 40px; text-align: center; color: var(--text-dim);">Foto bude doplněno</div>
            )}
          </button>
          {(thumbIds.length > 0 || extraPhotos > 0) && (
            <div class="thumbs">
              {thumbIds.map((id, i) => (
                <button class="thumb" type="button" data-gallery-trigger data-index={i + 1} aria-label={`Foto ${i + 2}`}>
                  <DirectusImage src={id} alt={`Foto ${i + 2}`} aspectRatio="4/3" widths={[200, 400]} />
                </button>
              ))}
              {extraPhotos > 0 && (
                <button class="thumb thumb-more" type="button" data-gallery-trigger data-index="5" aria-label="Zobrazit všechny fotky">
                  +{extraPhotos} fotek
                </button>
              )}
            </div>
          )}
          <div class="under-gallery">
            {availabilityLabel && availabilityLabel !== '—' && (
              <span class="ug-avail"><span class="ug-dot"></span>{availabilityLabel}{v.availability === 'in_stock' ? ' v Praze' : ''}</span>
            )}
            {conditionLabel && conditionLabel !== '—' && (
              <span class={`ug-cond ug-cond--${v.condition ?? 'new'}`}>{conditionLabel}</span>
            )}
          </div>
        </div>

        <!-- Info side -->
        <div class="info">
          <div class="info-eyebrow">
            <span class="info-brand">{brand?.name ?? ''}</span>
          </div>
          <h1 class="info-title">{model?.name ?? title}</h1>
          {trimDisplay && <p class="info-trim">{trimDisplay}</p>}
          {model?.tagline && <p class="info-tagline">{model.tagline}</p>}

          <div class="info-price">
            {finalPrice ? (
              <span class="amount">{finalPrice.toLocaleString('cs-CZ')} Kč</span>
            ) : (
              <span class="amount">Cena na dotaz</span>
            )}
            <span class="vat">vč. DPH</span>
          </div>
          {hasPromo && priceBeforePromo && (
            <div class="info-price-before">
              <span class="strike">{priceBeforePromo.toLocaleString('cs-CZ')} Kč</span>
              <span class="save">Ušetříte {savings.toLocaleString('cs-CZ')} Kč</span>
              {promoSource === 'model' && modelPromoLabel && (
                <span class="promo-source-tag">{modelPromoLabel}</span>
              )}
            </div>
          )}
          {monthlyPayment && brand.slug === 'kgm' && (
            <div class="info-finance">
              Financování od <strong style="color: var(--text);">{monthlyPayment.toLocaleString('cs-CZ')} Kč / měsíc</strong> &nbsp;—&nbsp;
              <a href="#finance">kalkulačka →</a>
            </div>
          )}
          <div class="spec-grid">
            {year && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </span>
                <div>
                  <span class="lab">Rok</span>
                  <span class="val">{year}</span>
                </div>
              </div>
            )}
            <div class="spec-card">
              <span class="ic">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 14v-4"/><path d="M3.69 17A9 9 0 1 1 20.31 17"/><circle cx="12" cy="14" r="2"/></svg>
              </span>
              <div>
                <span class="lab">Nájezd</span>
                <span class="val">{(v.km ?? 0).toLocaleString('cs-CZ')} km</span>
              </div>
            </div>
            <div class="spec-card">
              <span class="ic">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="22" x2="15" y2="22"/><line x1="4" y1="9" x2="14" y2="9"/><path d="M14 22V4a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v18"/><path d="M14 13h2a2 2 0 0 1 2 2v2a2 2 0 0 0 2 2 2 2 0 0 0 2-2V9.83a2 2 0 0 0-.59-1.42L18 5"/></svg>
              </span>
              <div>
                <span class="lab">Palivo</span>
                <span class="val">{fuelLabel}</span>
              </div>
            </div>
            {transmissionLabel && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2.5"/><path d="M12 6V3.5"/><path d="M12 20.5V18"/><path d="M18 12h2.5"/><path d="M3.5 12H6"/></svg>
                </span>
                <div>
                  <span class="lab">Převodovka</span>
                  <span class="val">{transmissionLabel}</span>
                </div>
              </div>
            )}
            {drivetrainLabel && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="6.5" r="2.5"/><circle cx="6.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/><line x1="6.5" y1="9" x2="6.5" y2="15"/><line x1="17.5" y1="9" x2="17.5" y2="15"/><line x1="9" y1="6.5" x2="15" y2="6.5"/><line x1="9" y1="17.5" x2="15" y2="17.5"/></svg>
                </span>
                <div>
                  <span class="lab">Pohon</span>
                  <span class="val">{drivetrainLabel}</span>
                </div>
              </div>
            )}
            {colorClean && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="1.5"/><circle cx="17.5" cy="10.5" r="1.5"/><circle cx="8.5" cy="7.5" r="1.5"/><circle cx="6.5" cy="12.5" r="1.5"/><path d="M12 2C6.5 2 2 6 2 11.5S6 21 12 21a2 2 0 0 0 2-2c0-.5-.2-1-.5-1.3-.3-.4-.5-.8-.5-1.2a1.5 1.5 0 0 1 1.5-1.5H16a5 5 0 0 0 5-5C21 5.6 17 2 12 2z"/></svg>
                </span>
                <div>
                  <span class="lab">Barva</span>
                  <span class="val">{colorClean}</span>
                </div>
              </div>
            )}
                        {heroPower && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                </span>
                <div>
                  <span class="lab">Výkon</span>
                  <span class="val">{heroPower}</span>
                </div>
              </div>
            )}
            {heroSeats && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </span>
                <div>
                  <span class="lab">Míst</span>
                  <span class="val">{heroSeats}</span>
                </div>
              </div>
            )}
            {(v as any).battery_capacity_kwh && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="18" height="10" rx="2" ry="2"/><line x1="22" y1="11" x2="22" y2="13"/><line x1="6" y1="10" x2="6" y2="14"/><line x1="10" y1="10" x2="10" y2="14"/><line x1="14" y1="10" x2="14" y2="14"/></svg>
                </span>
                <div>
                  <span class="lab">Baterie</span>
                  <span class="val">{(v as any).battery_capacity_kwh} kWh</span>
                </div>
              </div>
            )}
            {(v as any).range_wltp_km && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/></svg>
                </span>
                <div>
                  <span class="lab">Dojezd</span>
                  <span class="val">{(v as any).range_wltp_km} km</span>
                </div>
              </div>
            )}
            {(v as any).cargo_volume_m3 && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                </span>
                <div>
                  <span class="lab">Náklad. prostor</span>
                  <span class="val">{Number((v as any).cargo_volume_m3).toLocaleString('cs-CZ', { maximumFractionDigits: 2 })} m³</span>
                </div>
              </div>
            )}
            {(v as any).body_config && (
              <div class="spec-card">
                <span class="ic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 19 16 19"/><circle cx="5.5" cy="19.5" r="2.5"/><circle cx="18.5" cy="19.5" r="2.5"/></svg>
                </span>
                <div>
                  <span class="lab">Konfigurace</span>
                  <span class="val">{(v as any).body_config}</span>
                </div>
              </div>
            )}
          </div>

          <div class="cta-stack">
            <a class="btn btn-primary" href="#poptavka">
              Mám zájem
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <div class="cta-row">
              <a class="btn btn-outline" href="#poptavka">Rezervovat</a>
              <a class="btn btn-outline" href={`tel:${salesPhoneLink}`} data-sales-phone>Zavolat <span data-sales-phone-text>{salesPhone}</span></a>
            </div>
          </div>

        </div>
      </section>
    </div>

    <!-- ===== ABOUT ===== -->
    <section class="section">
      <div class="container">
        <div class="about-grid" data-screen-label="About">
          <div>
            <div class="section-eyebrow">O tomto voze</div>
            <h2 class="section-title">Připravený k převzetí</h2>
            <div class="about-copy">
              {description.length > 0 ? (
                description.map((p) => <p>{p}</p>)
              ) : (
                <>
                  <p>{title} v provedení skladem a ihned k převzetí v Praze. {year ? `Modelový rok ${year}.` : ''} Bohatá výbava, vysoká úroveň komfortu i bezpečnosti.</p>
                  <p>Tento model spojuje výrazný design s praktickým prostorem a moderními technologiemi pro každodenní radost z jízdy.</p>
                  <p>Exkluzivně skladem v Praze — připravený k okamžitému převzetí a první jízdě.</p>
                </>
              )}
            </div>
            {v.vin && (
              <dl class="about-meta">
                <div><dt>VIN</dt><dd>{v.vin}</dd></div>
              </dl>
            )}
          </div>
          <div class="about-highlights">
            {highlights.map((h) => (
              <div class="highlight">
                <div class="highlight-icon">
                  {h.icon === 'shield' && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  )}
                  {h.icon === 'swap' && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                  )}
                  {h.icon === 'wallet' && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V8H6a2 2 0 0 1 0-4h12v4"/><path d="M4 6v12a2 2 0 0 0 2 2h14v-4"/><circle cx="18" cy="14" r="1"/></svg>
                  )}
                  {h.icon === 'badge' && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                  )}
                  {h.icon === 'star' && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  )}
                  {h.icon === 'key' && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
                  )}
                  {h.icon === 'car' && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17h14M5 17v3M19 17v3M5 17l-1.5-5.5h17L19 17M3.5 11.5L5 7h14l1.5 4.5"/><circle cx="7.5" cy="14.5" r="1"/><circle cx="16.5" cy="14.5" r="1"/></svg>
                  )}
                  {h.icon === 'phone' && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.86 19.86 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  )}
                  {h.icon === 'clock' && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  )}
                </div>
                <div class="highlight-body">
                  <div class="highlight-title">{h.title}</div>
                  <div class="highlight-subtitle">{h.subtitle}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== EQUIPMENT (grouped — všechny features, žádný cap) ===== -->
    {grouped.length > 0 && (
      <section class="section equip">
        <div class="container">
          <div class="section-eyebrow">Výbava</div>
          <h2 class="section-title">
            {trimDisplay ? `Co je v ceně — ${trimDisplay}` : 'Co je v ceně'}
          </h2>
          <div class="equip-grid equip-grid-full">
            {grouped.map((cat) => (
              <div class="equip-col">
                <h4>{cat.label}</h4>
                <ul>
                  {cat.items.map((it) => (
                    <li>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      <span>{it}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          {/* Příplatková výbava / extra — konkrétní výbava TOHOTO vozu mimo standard */}
          {extraListUniq.length > 0 && (
            <div class="extra-features">
              <div class="extra-features-head">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                <h3>Tento konkrétní vůz má navíc</h3>
              </div>
              <ul class="extra-features-list">
                {extraListUniq.map((f) => (
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    {/* ===== OPTION PACKAGES (volitelné balíčky tohoto vozu) ===== */}
    {vehiclePackages.length > 0 && (
      <section class="section equip" style="background: var(--bg-soft);">
        <div class="container">
          <div class="section-eyebrow">Volitelné balíčky</div>
          <h2 class="section-title">
            {vehiclePackages.length === 1 ? 'Tento vůz má 1 paket navíc' : `Tento vůz má ${vehiclePackages.length} paketů navíc`}
          </h2>
          <div class="packets-grid">
            {vehiclePackages.map((p) => (
              <article class="packet-card">
                <header class="packet-head">
                  <h3 class="packet-name">{p.name}</h3>
                </header>
                {p.description && <p class="packet-desc">{p.description}</p>}
                {Array.isArray(p.features) && p.features.length > 0 && (
                  <ul class="packet-features">
                    {p.features.map((f: string) => (
                      <li>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        <span>{f}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ===== SPECS ===== -->
    <section class="section">
      <div class="container">
        <div class="section-eyebrow">Technická data</div>
        <h2 class="section-title">Specifikace</h2>
        <div class="specs-grid">
          <div>
            {specsLeft.map(([k, val]) => (
              <div class="spec-row"><span class="k">{k}</span><span class="v">{val}</span></div>
            ))}
          </div>
          <div>
            {specsRight.map(([k, val]) => (
              <div class="spec-row"><span class="k">{k}</span><span class="v">{val}</span></div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FINANCE (dark) — JEN KGM (lokální orientační kalkulačka) ===== -->
    {brand.slug === 'kgm' && (
    <section class="section finance" id="finance" data-vehicle-brand={brand.name} data-vehicle-model={model?.name ?? title} data-vehicle-price={finalPrice ?? 0} data-directus-url={import.meta.env.PUBLIC_DIRECTUS_URL ?? ''} data-ucl-proxy={import.meta.env.PUBLIC_UCL_PROXY_URL ?? '/api/leasing'}>
      <div class="container">
        <div class="section-eyebrow">Financování</div>
        <h2 class="section-title">Spočítáme za 30 vteřin</h2>
        <div class="finance-grid">
          <div class="calc">
            <!-- Doba splácení -->
            <div class="calc-row">
              <div class="calc-label">Doba splácení</div>
              <div class="chips" data-duration-chips>
                <button type="button" class="chip" data-duration="24">24 měs</button>
                <button type="button" class="chip" data-duration="36">36 měs</button>
                <button type="button" class="chip" data-duration="48">48 měs</button>
                <button type="button" class="chip active" data-duration="60">60 měs</button>
                <button type="button" class="chip" data-duration="72">72 měs</button>
              </div>
            </div>

            <!-- Akontace slider -->
            <div class="calc-row">
              <div class="calc-head">
                <div class="calc-label" style="margin: 0;">Akontace</div>
                <div class="val">
                  <span data-dp-percent>20 %</span>
                  <span style="opacity:0.6; font-size:14px; margin-left:8px;">
                    (<span data-dp-amount-inline>—</span> Kč)
                  </span>
                </div>
              </div>
              <input
                type="range"
                min="10"
                max="60"
                value="20"
                step="5"
                data-dp-slider
                style="width:100%; accent-color: var(--accent);"
              />
              <div class="ticks">
                <span>10 %</span><span>20 %</span><span>35 %</span><span>50 %</span><span>60 %</span>
              </div>
            </div>

            <!-- Info bloky pod nastavením -->
            <div class="calc-info-grid">
              <div class="calc-info-tile">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <div>
                  <div class="calc-info-title">Bez navýšení</div>
                  <div class="calc-info-desc">Akontace 10–60 %, doba 24–72 měs. Standardní úroková sazba dle ceníku UCL.</div>
                </div>
              </div>
              <div class="calc-info-tile">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <div>
                  <div class="calc-info-title">UniCredit Leasing</div>
                  <div class="calc-info-desc">Naše partnerská leasingovka. Schválení do 24 h, splátky beze srážek.</div>
                </div>
              </div>
              <div class="calc-info-tile">
