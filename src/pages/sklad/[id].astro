              // Pill: promo akce z modelu (jen pro nové)
              const today = new Date().toISOString().slice(0, 10);
              const modelPromoActive = !!s.model?.promo_active
                && (s.model.promo_label || s.model.promo_discount_amount)
                && (!s.model.promo_valid_to || String(s.model.promo_valid_to) >= today);
              const modelPromoLabel = (s.model?.promo_label ?? '').toString().trim();
