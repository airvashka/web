  <script is:inline>
    // ===== Finance kalkulačka — UCL Leasing API (reálný výpočet) =====
    // Volá `${UCL_PROXY_URL}/calculate` — produkce: https://api.sfr-motor.cz/leasing
    // (VPS s fixní IP, kterou UCL whitelistne). Fallback `/api/leasing` zachovává
    // dev kompatibilitu. Hodnoty se předávají přes data-atributy na #finance sekci
    // (is:inline scripty nelze parametrizovat přes define:vars, viz feedback memo).

    const financeSection = document.querySelector('#finance');
    const vehicleBrand = financeSection ? financeSection.dataset.vehicleBrand || 'KGM' : 'KGM';
    const vehicleModel = financeSection ? financeSection.dataset.vehicleModel || '' : '';
    const vehiclePrice = Number(financeSection?.dataset.vehiclePrice || 0);
    const DIRECTUS_URL = financeSection?.dataset.directusUrl || '';
    const UCL_PROXY_URL = financeSection?.dataset.uclProxy || '/api/leasing';

    const dpPctEl = document.querySelector('[data-dp-percent]');
    const dpPctSubEl = document.querySelector('[data-dp-percent-sub]');
    const dpAmountEl = document.querySelector('[data-dp-amount]');
    const dpAmountInlineEl = document.querySelector('[data-dp-amount-inline]');
    const monthlyEl = document.querySelector('[data-monthly]');
    const financedEl = document.querySelector('[data-financed]');
    const totalEl = document.querySelector('[data-total]');
    const rpsnEl = document.querySelector('[data-rpsn]');
    const slider = document.querySelector('[data-dp-slider]');
    const durationChips = document.querySelectorAll('[data-duration-chips] .chip');

    let duration = 60;
    let dpPercent = 20;

    const fmt = (n) => Math.round(n).toLocaleString('cs-CZ');
    let lastCallId = 0;

    async function recalc() {
      const callId = ++lastCallId;
      const dpAmt = Math.round(vehiclePrice * dpPercent / 100);
      const financed = vehiclePrice - dpAmt;

      // Okamžitě update lokální hodnoty (akontace, financovaná částka)
      if (dpPctEl) dpPctEl.textContent = dpPercent + ' %';
      if (dpPctSubEl) dpPctSubEl.textContent = dpPercent + ' %';
      if (dpAmountEl) dpAmountEl.textContent = fmt(dpAmt) + ' Kč';
      if (dpAmountInlineEl) dpAmountInlineEl.textContent = fmt(dpAmt);
      if (financedEl) financedEl.textContent = fmt(financed) + ' Kč';
      if (monthlyEl) monthlyEl.textContent = '…';
      if (rpsnEl) rpsnEl.textContent = '…';
      if (totalEl) totalEl.textContent = '…';

      try {
        const r = await fetch(`${UCL_PROXY_URL}/calculate`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            assetPrice: vehiclePrice,
            downPaymentPercent: dpPercent / 100,
            numberOfInstallments: duration,
            brand: vehicleBrand,
            model: vehicleModel,
            isUsed: false,
            groupCode: 'OA',
          }),
        });
        if (callId !== lastCallId) return;
        const j = await r.json();
        if (!r.ok || j.error) {
          const err = new Error(j.error || ('HTTP ' + r.status));
          err.userMessage = j.userMessage || null;
          throw err;
        }
        // Vrátit normální velikost fontu po úspěšném výpočtu (po předchozí chybě mohl být zmenšený)
        if (monthlyEl) monthlyEl.style.fontSize = '';
        if (monthlyEl) monthlyEl.textContent = fmt(j.monthlyPayment) + ' Kč';
        if (rpsnEl) rpsnEl.textContent = j.apr.toFixed(2).replace('.', ',') + ' %';
        if (totalEl) totalEl.textContent = fmt(j.totalToPay) + ' Kč';
        // Vyplň UCL disclaimery (legalData z response)
        if (j.disclaimers) {
          const providerEl = document.querySelector('[data-ucl-provider]');
          const partnerInfoEl = document.querySelector('[data-ucl-partner-info]');
          const arrangementEl = document.querySelector('[data-ucl-arrangement]');
          if (providerEl && j.disclaimers.provider) providerEl.textContent = j.disclaimers.provider;
          if (partnerInfoEl && j.disclaimers.calc) partnerInfoEl.textContent = j.disclaimers.calc;
          if (arrangementEl && j.disclaimers.contract) arrangementEl.textContent = j.disclaimers.contract;
        }
      } catch (e) {
        if (callId !== lastCallId) return;
        if (monthlyEl) monthlyEl.textContent = 'výpočet nedostupný';
        if (rpsnEl) rpsnEl.textContent = '—';
        if (totalEl) totalEl.textContent = '—';
        // Pokud UCL vrátil čitelný důvod, ukaž ho pod tlačítkem
        const errMsg = (e && e.message) || '';
        const userMsg = (e && e.userMessage) || '';
        let displayMsg = userMsg;
        if (!displayMsg && errMsg.includes('UCL')) {
          displayMsg = 'Pro tuto kombinaci akontace a délky splácení není dostupná sazba. Zkuste jinou.';
        }
        if (displayMsg && monthlyEl) {
          monthlyEl.style.fontSize = '15px';
          monthlyEl.textContent = displayMsg;
        }
        console.warn('Leasing calc error:', e);
      }
    }

    if (slider) {
      slider.addEventListener('input', (e) => {
        dpPercent = Number(e.target.value);
        recalc();
      });
    }
    durationChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        durationChips.forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        duration = Number(chip.dataset.duration);
        recalc();
      });
    });

    if (vehiclePrice > 0) recalc();

    // ===== Gallery lightbox =====
    (function () {
      const modal = document.querySelector('[data-gallery-modal]');
      const slides = document.querySelectorAll('[data-slide-index]');
      const counter = document.querySelector('[data-gallery-counter]');
      const total = slides.length;
      if (!modal || total === 0) return;

      let current = 0;

      function showSlide(idx) {
        current = ((idx % total) + total) % total;
        slides.forEach((s) => { s.hidden = Number(s.dataset.slideIndex) !== current; });
        if (counter) counter.textContent = `${String(current + 1).padStart(2, '0')} / ${String(total).padStart(2, '0')}`;
      }

      function openModal(idx) {
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        showSlide(idx);
      }

      function closeModal() {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      document.querySelectorAll('[data-gallery-trigger]').forEach((el) => {
        el.addEventListener('click', () => openModal(Number(el.dataset.index ?? 0)));
      });
      document.querySelector('[data-gallery-close]')?.addEventListener('click', closeModal);
      document.querySelector('[data-gallery-prev]')?.addEventListener('click', () => showSlide(current - 1));
      document.querySelector('[data-gallery-next]')?.addEventListener('click', () => showSlide(current + 1));
      modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
      document.addEventListener('keydown', (e) => {
        if (!modal.classList.contains('is-open')) return;
        if (e.key === 'Escape') closeModal();
        if (e.key === 'ArrowLeft') showSlide(current - 1);
        if (e.key === 'ArrowRight') showSlide(current + 1);
      });
    })();

    // Sticky CTA — zobrazit po 700px scrollu
    const sticky = document.querySelector('[data-sticky-cta]');
    if (sticky) {
      const onScroll = () => {
        if (window.scrollY > 700) sticky.classList.add('is-visible');
        else sticky.classList.remove('is-visible');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // Lead form submit → /api/lead (server-side endpoint)
    document.querySelectorAll('[data-lead-form]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const statusEl = form.querySelector('[data-lead-status]');
        const submitBtn = form.querySelector('button[type=submit]');
        if (statusEl) statusEl.textContent = 'Odesílám...';

        const data = new FormData(form);
        const turnstileInput = form.querySelector('input[name="cf-turnstile-response"]');
        const payload = {
          form_type: form.dataset.formType,
          customer_name: data.get('customer_name'),
          customer_email: data.get('customer_email'),
          customer_phone: data.get('customer_phone'),
          message: data.get('message'),
          source_page: window.location.pathname,
          source_url: window.location.href,
          _hp_website: data.get('_hp_website') || '',
          turnstile_token: turnstileInput ? turnstileInput.value : '',
        };
        if (form.dataset.modelId) payload.source_model = Number(form.dataset.modelId);
        if (form.dataset.modelSlug) payload.source_model_slug = form.dataset.modelSlug;
        if (form.dataset.brandId) payload.source_brand = Number(form.dataset.brandId);
        if (form.dataset.vehicleId) payload.source_vehicle = Number(form.dataset.vehicleId);
        if (form.dataset.vehicleVin) payload.source_vehicle_vin = form.dataset.vehicleVin;

        try {
          const res = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const result = await res.json().catch(() => ({ ok: false, error: 'Network error' }));
          if (!res.ok || !result.ok) throw new Error(result.error || ('HTTP ' + res.status));
          if (statusEl) { statusEl.textContent = '✓ Děkujeme! Brzy se vám ozveme.'; statusEl.style.color = 'var(--ok)'; }
          if (submitBtn) submitBtn.disabled = true;
          if (window.dataLayer) window.dataLayer.push({ event: 'generate_lead', form_name: form.dataset.formType });
        } catch (err) {
          if (statusEl) {
            statusEl.textContent = err.message
              ? '✗ ' + err.message
              : 'Něco se nepodařilo. Zkuste znovu, nebo zavolejte +420 771 235 458.';
            statusEl.style.color = 'var(--danger)';
          }
        }
      });
    });
  </script>
