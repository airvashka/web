---
import BaseLayout from '@layouts/BaseLayout.astro';
import FuelIcon from '@components/FuelIcon.astro';
import DirectusImage from '@components/DirectusImage.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { directusGet } from '@lib/directus';
import { buildStockSlug } from '@lib/stockSlug';
import type { Brand, StockVehicle } from '@lib/types';

/* ============================================================
   SKLAD LISTING — design extends Skladovka section z home.jsx
   Sidebar filtrů (vlevo) + .scard grid (vpravo)
   SSR (prerender=false) — skladovka je vždy živá, nový/prodaný vůz se
   projeví hned bez rebuildu. Edge cache 60s drží výkon.
   ============================================================ */
export const prerender = false;

Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');

// forceLive (3. param) = vždy čerstvý fetch z Directusu, žádná build-time cache.
const brands = await directusGet<Brand>('brands', { sort: ['sort'], fields: ['id', 'slug', 'name'] }, true);

type VehicleListItem = StockVehicle & {
  brand?: { name: string; slug: string };
  model?: { name: string; slug: string; fuel_type?: string };
  trim_level?: { name: string } | null;
  model_year?: { year: number } | null;
  photos?: Array<{ directus_files_id: string }>;
  transmission?: string;
  drivetrain?: string;
  color_category?: string;
};

const vehicles = await directusGet<VehicleListItem>('stock_vehicles', {
  filter: { status: { _eq: 'published' }, availability: { _neq: 'sold' } },
  sort: ['-listed_at', 'sort'],
  fields: [
    'id', 'vin', 'list_price', 'promo_price', 'lowest_price_30d', 'km',
    'condition', 'availability', 'color_code', 'color_category',
    'transmission', 'drivetrain',
    'highlighted', 'highlight_label', 'listed_at',
    'trim_level_snapshot',
    'photos.directus_files_id',
    'brand.name', 'brand.slug',
    'model.name', 'model.slug', 'model.fuel_type',
    'model.promo_active', 'model.promo_label', 'model.promo_discount_amount', 'model.promo_valid_to',
    'model_year.year',
    'trim_level.name',
  ],
}, true);

function firstPhoto(v: VehicleListItem): string | null {
  if (!Array.isArray(v.photos) || v.photos.length === 0) return null;
  const f: any = v.photos[0];
  return typeof f === 'string' ? f : (f?.directus_files_id ?? null);
}

const fuelLabels: Record<string, string> = { petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro' };
const conditionLabels: Record<string, string> = { new: 'Nové', demo: 'Předváděcí', used: 'Ojeté' };
const colorCategoryLabels: Record<string, string> = {
  white: 'Bílá', black: 'Černá', gray: 'Šedá', silver: 'Stříbrná',
  blue: 'Modrá', red: 'Červená', green: 'Zelená', yellow: 'Žlutá',
  orange: 'Oranžová', brown: 'Hnědá', other: 'Jiná',
};

// Unique values pro filtry
const availableFuels = [...new Set(vehicles.map((v) => v.model?.fuel_type).filter(Boolean))] as string[];
const availableConditions = [...new Set(vehicles.map((v) => v.condition).filter(Boolean))] as string[];
const has4wd = vehicles.some((v) => v.drivetrain === '4wd' || v.drivetrain === 'awd');

// Modely seskupené podle značky — pro <select> s <optgroup>
type ModelOpt = { slug: string; name: string };
const modelsByBrand = new Map<string, { brandName: string; models: ModelOpt[] }>();
vehicles.forEach((v) => {
  if (!v.brand?.slug || !v.model?.slug) return;
  const bSlug = v.brand.slug;
  if (!modelsByBrand.has(bSlug)) {
    modelsByBrand.set(bSlug, { brandName: v.brand.name, models: [] });
  }
  const group = modelsByBrand.get(bSlug)!;
  if (!group.models.find((m) => m.slug === v.model!.slug)) {
    group.models.push({ slug: v.model.slug, name: v.model.name });
  }
});
const modelGroups = Array.from(modelsByBrand.entries())
  .sort((a, b) => a[1].brandName.localeCompare(b[1].brandName))
  .map(([slug, group]) => ({ brandSlug: slug, brandName: group.brandName, models: group.models.sort((a, b) => a.name.localeCompare(b.name)) }));

// Non-breaking space mezi číslem a jednotkou — zabrání zalomení "849 900\nKč" v úzkých kartách.
const NBSP = String.fromCharCode(160);
const fmtPrice = (n?: number | null) => (n ? `${n.toLocaleString('cs-CZ')} Kč` : '—');
const fmtKm = (n?: number | null) => (n === 0 || !n ? '0 km' : `${n.toLocaleString('cs-CZ')} km`);
---

<BaseLayout title="Skladové vozy" description="Aktuální nabídka skladových vozů KGM, OMODA & JAECOO, Farizon u SFR Motor Praha-Ďáblice.">
  <Breadcrumbs items={[{ label: 'Skladové vozy' }]} />
  <section class="sklad-page">
    <div class="container">

      <div class="sklad-head">
        <div>
          <div class="section-eyebrow">Skladovka</div>
          <h1>Vozy ihned k odběru</h1>
        </div>
        <div class="sklad-count" data-result-count>
          {vehicles.length > 0
            ? `${vehicles.length} ${vehicles.length === 1 ? 'vůz' : vehicles.length < 5 ? 'vozy' : 'vozů'} skladem`
            : 'Skladovka se právě plní'}
        </div>
      </div>

      {vehicles.length === 0 ? (
        <div class="sklad-empty">
          <p>Žádné vozy v adminu zatím nejsou. Napište nám, najdeme tu pravou.</p>
          <a href="/kontakt" class="btn btn-primary" style="margin-top: 16px;">Napište nám</a>
        </div>
      ) : (
        <div class="sklad-layout">
          <!-- ===== FILTERS SIDEBAR ===== -->
          <aside class="sklad-filters" data-filters>
            <h3>Filtry</h3>

            <div class="fblock">
              <h4>Značka</h4>
              <label><input type="radio" name="brand" value="all" checked /> Všechny</label>
              {brands.map((b) => (
                <label><input type="radio" name="brand" value={b.slug} /> {b.name}</label>
              ))}
            </div>

            {modelGroups.length > 0 && (
              <div class="fblock">
                <h4>Model</h4>
                <select name="model" class="filter-select" data-filter-model>
                  <option value="all">Všechny modely</option>
                  {modelGroups.map((g) => (
                    <optgroup label={g.brandName} data-brand={g.brandSlug}>
                      {g.models.map((m) => (
                        <option value={m.slug} data-brand={g.brandSlug}>{m.name}</option>
                      ))}
                    </optgroup>
                  ))}
                </select>
              </div>
            )}

            {availableFuels.length > 0 && (
              <div class="fblock">
                <h4>Palivo</h4>
                <label><input type="radio" name="fuel" value="all" checked /> Vše</label>
                {availableFuels.map((f) => (
                  <label><input type="radio" name="fuel" value={f} /> {fuelLabels[f] ?? f}</label>
                ))}
              </div>
            )}

            {availableConditions.length > 0 && (
              <div class="fblock">
                <h4>Stav</h4>
                <label><input type="radio" name="condition" value="all" checked /> Vše</label>
                {availableConditions.map((c) => (
                  <label><input type="radio" name="condition" value={c} /> {conditionLabels[c] ?? c}</label>
                ))}
              </div>
            )}

            {has4wd && (
              <div class="fblock">
                <h4>Pohon</h4>
                <label><input type="radio" name="drivetrain" value="all" checked /> Vše</label>
                <label><input type="radio" name="drivetrain" value="4wd" /> Pouze 4×4</label>
              </div>
            )}

            <button type="button" class="btn btn-outline" data-reset style="width:100%; margin-top:8px;">Resetovat</button>
          </aside>

          <!-- ===== GRID ===== -->
          <div>
            <!-- Sort bar nad gridem -->
            <div class="sort-bar">
              <label class="sort-label">
                Seřadit:
                <select data-sort class="filter-select">
                  <option value="newest">Nejnovější</option>
                  <option value="price-asc">Cena ↑</option>
                  <option value="price-desc">Cena ↓</option>
                </select>
              </label>
            </div>
            <div class="skladovka-grid" data-grid>
              {vehicles.map((v) => {
                const isNew = v.condition === 'new';
                const isHighlighted = v.highlighted;
                const customLabel = ((v as any).highlight_label ?? '').toString().trim();
                // Akce na úrovni modelu
                const today = new Date().toISOString().slice(0, 10);
                const modelPromoActive = !!(v.model as any)?.promo_active
                  && ((v.model as any)?.promo_label || (v.model as any)?.promo_discount_amount)
                  && (!(v.model as any)?.promo_valid_to || String((v.model as any).promo_valid_to) >= today);
                const modelPromoLabel = ((v.model as any)?.promo_label ?? '').toString().trim();
                const modelPromoDiscount = Number((v.model as any)?.promo_discount_amount ?? 0) || 0;

                // Pill: POUZE pro reálný důvod (Akce nebo Highlight s vlastním labelem).
                // "Skladem"/"Nové" se nezobrazuje — všechny vozy zde jsou skladem,
                // stav (Nové/Předváděcí/Ojeté) je v info chips dole.
                let pillLabel = '';
                if (modelPromoActive && modelPromoLabel) pillLabel = modelPromoLabel;
                else if (isHighlighted && customLabel) pillLabel = customLabel;
                else if (isHighlighted) pillLabel = 'Novinka';

                const photoId = firstPhoto(v);
                const trimName = v.trim_level?.name ?? (v.trim_level_snapshot as any)?.name ?? (v.trim_level_snapshot as any)?.raw_name ?? '';
                const carYear = v.model_year?.year ?? '';
                const conditionLabel = conditionLabels[v.condition ?? ''] ?? '';
                const fuelLabel = fuelLabels[v.model?.fuel_type ?? ''] ?? '';
                const transmissionLabel = v.transmission === 'manual' ? 'Manuál' : v.transmission === 'automatic' ? 'Automat' : '';
                const is4wd = v.drivetrain === '4wd' || v.drivetrain === 'awd';
                const conditionCls = v.condition === 'new' ? 'new' : v.condition === 'demo' ? 'demo' : 'used';
                // Cena: stock.promo > model promo (jen u nových vozů) > list
                const baseList = v.list_price;
                let displayPrice = v.promo_price ?? baseList;
                let priceBefore: number | null = null;
                if (v.promo_price && baseList && v.promo_price < baseList) {
                  priceBefore = baseList;
                } else if (modelPromoActive && modelPromoDiscount > 0 && baseList && isNew) {
                  // Model-level promo se aplikuje JEN na nové vozy (ojeté a předváděcí mají vlastní cenu)
                  displayPrice = baseList - modelPromoDiscount;
                  priceBefore = baseList;
                }
                return (
                  <a
                    class="scard"
                    href={`/sklad/${buildStockSlug(v, v.brand, v.model, v.trim_level ?? { name: trimName })}`}
                    data-brand={v.brand?.slug ?? ''}
                    data-model={v.model?.slug ?? ''}
                    data-fuel={v.model?.fuel_type ?? ''}
                    data-condition={v.condition ?? ''}
                    data-drivetrain={v.drivetrain ?? ''}
                    data-price={displayPrice ?? 0}
                    data-listed-at={(v as any).listed_at ?? ''}
                  >
                    <div class="pic">
                      {photoId && <DirectusImage src={photoId} alt={`${v.brand?.name ?? ''} ${v.model?.name ?? ''}`} aspectRatio="4/3" />}
                      <div class="pill-stack">
                        {pillLabel && <span class="pill pill--promo">{pillLabel}</span>}
                        {conditionLabel && <span class={`pill pill--${conditionCls}`}>{conditionLabel}</span>}
                      </div>
                      <FuelIcon type={v.model?.fuel_type ?? ''} />
                    </div>
                    <div class="body">
                      <div class="brand">{v.brand?.name ?? ''}</div>
                      <div class="nm">{v.model?.name ?? ''}</div>
                      {trimName && <div class="var">{trimName}</div>}
                      <div class="specs">
                        {fuelLabel && <span class="fuel">{fuelLabel}</span>}
                        {transmissionLabel && <span>{transmissionLabel}</span>}
                        {is4wd && <span>4×4</span>}
                      </div>
                      <div class="foot">
                        <span class="km">{fmtKm(v.km)}</span>
                        <div class="price">
                          {priceBefore && (
                            <span class="price-before">{fmtPrice(priceBefore)}</span>
                          )}
                          <span>{fmtPrice(displayPrice)}</span>
                        </div>
                      </div>
                      <div class="stock-state">Skladem v Praze</div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <script>
    // ===== Klient-side multi-filtr + sort =====
    const filters = {
      brand: 'all', model: 'all', fuel: 'all', condition: 'all', drivetrain: 'all',
    };
    let sortMode = 'newest';

    // Zapíše aktuální stav filtrů do URL query parametrů (bookmarkable + sdílatelné)
    function syncURL() {
      const url = new URL(location.href);
      const map = { brand: 'znacka', model: 'model', fuel: 'palivo', condition: 'stav', drivetrain: 'pohon' };
      Object.entries(map).forEach(([key, q]) => {
        const val = filters[key];
        if (val && val !== 'all') url.searchParams.set(q, val);
        else url.searchParams.delete(q);
      });
      if (sortMode && sortMode !== 'newest') url.searchParams.set('razeni', sortMode);
      else url.searchParams.delete('razeni');
      history.replaceState({}, '', url);
    }

    function applyFilters() {
      const grid = document.querySelector('[data-grid]');
      if (!grid) return;
      const cards = Array.from(grid.querySelectorAll('.scard'));
      let visible = 0;
      cards.forEach((c) => {
        const el = c;
        const dt = el.dataset.drivetrain ?? '';
        const drivetrainOk = filters.drivetrain === 'all' || (filters.drivetrain === '4wd' && (dt === '4wd' || dt === 'awd'));
        const ok =
          (filters.brand === 'all' || el.dataset.brand === filters.brand) &&
          (filters.model === 'all' || el.dataset.model === filters.model) &&
          (filters.fuel === 'all' || el.dataset.fuel === filters.fuel) &&
          (filters.condition === 'all' || el.dataset.condition === filters.condition) &&
          drivetrainOk;
        if (ok) { el.style.display = ''; visible++; }
        else { el.style.display = 'none'; }
      });
      // Sort — řazení DOM children podle data-price / data-listed-at
      const visibleCards = cards.filter((c) => c.style.display !== 'none');
      visibleCards.sort((a, b) => {
        if (sortMode === 'price-asc') return Number(a.dataset.price ?? 0) - Number(b.dataset.price ?? 0);
        if (sortMode === 'price-desc') return Number(b.dataset.price ?? 0) - Number(a.dataset.price ?? 0);
        // 'newest' default: descending by listed_at
        return (b.dataset.listedAt ?? '').localeCompare(a.dataset.listedAt ?? '');
      });
      visibleCards.forEach((c) => grid.appendChild(c));
      syncURL();
      // Update čítače
      const count = document.querySelector('[data-result-count]');
      if (count) {
        const noun = visible === 1 ? 'vůz' : visible < 5 ? 'vozy' : 'vozů';
        count.textContent = visible === 0 ? 'Žádné vozy nesplňují filtr' : `${visible} ${noun} skladem`;
      }
      // Model select — dynamicky skryj/ukaž optgroup podle vybrané značky
      const modelSelect = document.querySelector('[data-filter-model]');
      if (modelSelect) {
        modelSelect.querySelectorAll('optgroup').forEach((og) => {
          const ogBrand = og.dataset.brand ?? '';
          og.hidden = !(filters.brand === 'all' || filters.brand === ogBrand);
        });
        // Pokud aktuálně zvolený model nepatří k vybrané značce, reset model na "all"
        if (filters.model !== 'all' && modelSelect.value) {
          const opt = modelSelect.querySelector(`option[value="${modelSelect.value}"]`);
          if (opt && opt.dataset.brand && filters.brand !== 'all' && opt.dataset.brand !== filters.brand) {
            modelSelect.value = 'all';
            filters.model = 'all';
          }
        }
      }
    }

    // Radio button changes (brand, fuel, condition, drivetrain)
    document.querySelectorAll('[data-filters] input[type=radio]').forEach((input) => {
      input.addEventListener('change', (e) => {
        const t = e.target;
        if (t.name in filters) {
          filters[t.name] = t.value;
          applyFilters();
        }
      });
    });

    // Model select change
    document.querySelector('[data-filter-model]')?.addEventListener('change', (e) => {
      filters.model = e.target.value;
      // Pokud vybraný model patří k jiné značce, auto-set brand
      const opt = e.target.selectedOptions[0];
      const optBrand = opt?.dataset.brand;
      if (optBrand && filters.brand !== optBrand && filters.model !== 'all') {
        filters.brand = optBrand;
        const radio = document.querySelector(`[data-filters] input[name=brand][value="${optBrand}"]`);
        if (radio) radio.checked = true;
      }
      applyFilters();
    });

    // Sort select change
    document.querySelector('[data-sort]')?.addEventListener('change', (e) => {
      sortMode = e.target.value;
      applyFilters();
    });

    // Reset
    document.querySelector('[data-reset]')?.addEventListener('click', () => {
      Object.keys(filters).forEach((k) => { filters[k] = 'all'; });
      document.querySelectorAll('[data-filters] input[value=all]').forEach((i) => (i.checked = true));
      const ms = document.querySelector('[data-filter-model]');
      if (ms) ms.value = 'all';
      applyFilters();
    });

    // URL query params — ?znacka=kgm&model=torres&palivo=elektro&stav=novy&pohon=4wd&razeni=price-asc
    const params = new URLSearchParams(window.location.search);
    const URL_MAP = [
      { qs: ['znacka', 'brand'], key: 'brand', radio: 'brand' },
      { qs: ['palivo', 'fuel'], key: 'fuel', radio: 'fuel' },
      { qs: ['stav', 'condition'], key: 'condition', radio: 'condition' },
      { qs: ['pohon', 'drivetrain'], key: 'drivetrain', radio: 'drivetrain' },
    ];
    let hasAnyParam = false;
    URL_MAP.forEach(({ qs, key, radio: rname }) => {
      const v = qs.map((q) => params.get(q)).find(Boolean);
      if (!v) return;
      const r = document.querySelector(`[data-filters] input[name=${rname}][value="${v}"]`);
      if (r) { r.checked = true; filters[key] = v; hasAnyParam = true; }
    });
    const modelParam = params.get('model');
    if (modelParam) {
      const ms = document.querySelector('[data-filter-model]');
      if (ms) {
        const opt = ms.querySelector(`option[value="${modelParam}"]`);
        if (opt) { ms.value = modelParam; filters.model = modelParam; hasAnyParam = true; }
      }
    }
    const sortParam = params.get('razeni') ?? params.get('sort');
    if (sortParam) {
      const ss = document.querySelector('[data-sort]');
      if (ss) {
        const o = ss.querySelector(`option[value="${sortParam}"]`);
        if (o) { ss.value = sortParam; sortMode = sortParam; hasAnyParam = true; }
      }
    }
    if (hasAnyParam) applyFilters();
  </script>

  <style>
    .sklad-filters label {
      display: flex; align-items: center; gap: 10px;
      padding: 6px 0;
      font-size: 14px;
      cursor: pointer;
      color: var(--text);
    }
    .sklad-filters label:hover { color: var(--accent); }

    /* Filter select (Model + Sort) — konzistentní s designem */
    .filter-select {
      width: 100%;
      padding: 8px 10px;
      font-size: 14px;
      font-family: inherit;
      color: var(--text);
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 6px;
      cursor: pointer;
      transition: border-color .15s;
    }
    .filter-select:hover, .filter-select:focus {
      border-color: var(--accent);
      outline: none;
    }

    /* Sort bar nad gridem */
    .sort-bar {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 16px;
    }
    .sort-label {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--text-muted);
      letter-spacing: 0.02em;
    }
    .sort-label .filter-select {
      width: auto;
      min-width: 140px;
      font-size: 13px;
      padding: 6px 8px;
    }
  </style>
</BaseLayout>
