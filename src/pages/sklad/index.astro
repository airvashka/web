---
import BaseLayout from '@layouts/BaseLayout.astro';
import DirectusImage from '@components/DirectusImage.astro';
import { directusGet } from '@lib/directus';
import type { Brand, StockVehicle } from '@lib/types';

const brands = await directusGet<Brand>('brands', { sort: ['sort'], fields: ['id', 'slug', 'name'] });

type VehicleListItem = StockVehicle & {
  brand: { name: string; slug: string };
  model: { name: string; slug: string };
  trim_level?: { name: string } | null;
  photos?: Array<{ directus_files_id: string }>;
};

const vehicles = await directusGet<VehicleListItem>('stock_vehicles', {
  filter: { status: { _eq: 'published' }, availability: { _neq: 'sold' } },
  sort: ['-listed_at', 'sort'],
  fields: [
    'id', 'vin', 'list_price', 'promo_price', 'lowest_price_30d', 'km',
    'condition', 'availability', 'color_code', 'highlighted',
    'photos.directus_files_id',
    'brand.name', 'brand.slug', 'model.name', 'model.slug', 'trim_level.name'
  ],
});

// Helper — extrakt prvního foto UUID z M2M junction
function firstPhotoUuid(v: VehicleListItem): string | null {
  if (!Array.isArray(v.photos) || v.photos.length === 0) return null;
  const first = v.photos[0];
  return typeof first === 'string' ? first : (first?.directus_files_id ?? null);
}

const fuelLabels: Record<string, string> = {
  petrol: 'Benzín', diesel: 'Diesel', hybrid: 'Hybrid', phev: 'PHEV', ev: 'Elektro',
};
const conditionLabels: Record<string, string> = {
  new: 'Nový', demo: 'Předváděcí', used: 'Ojetý',
};
const availabilityLabels: Record<string, string> = {
  in_stock: 'Skladem', on_the_way: 'Na cestě', reserved: 'Rezervováno', sold: 'Prodáno',
};
---

<BaseLayout title="Skladové vozy" description="Aktuální nabídka skladových vozů KGM, OMODA & JAECOO, Farizon u SFR Motor Praha-Ďáblice.">
  <section class="section sklad__hero">
    <div class="container">
      <p class="eyebrow">Skladové vozy</p>
      <h1>Vozy ihned k odběru</h1>
      <p class="lead">
        {vehicles.length > 0
          ? `Aktuálně ${vehicles.length} ${vehicles.length === 1 ? 'vůz' : vehicles.length < 5 ? 'vozy' : 'vozů'} skladem v Praze-Ďáblicích.`
          : 'Skladovka se právě plní. Sleduj nás nebo nám napiš — najdeme ti tu pravou.'}
      </p>
    </div>
  </section>

  <section class="container">
    <!-- Filtry — zatím statické, brzy interaktivní -->
    <div class="filters">
      <button class="filter-chip is-active" data-filter="all">Všechny</button>
      {brands.map(brand => (
        <button class="filter-chip" data-filter={brand.slug}>{brand.name}</button>
      ))}
    </div>

    {vehicles.length === 0 ? (
      <div class="empty-stock">
        <h3>Zatím žádné vozy v adminu</h3>
        <p class="text-muted">
          Skladovka je momentálně prázdná. Po přidání prvních vozů do Directus adminu se objeví zde automaticky.
        </p>
        <a href="/kontakt" class="btn btn--primary" style="margin-top: 16px;">Napište nám</a>
      </div>
    ) : (
      <div class="stock__grid">
        {vehicles.map(v => {
          const hasPromo = v.promo_price && v.list_price && v.promo_price < v.list_price;
          const photoCount = Array.isArray(v.photos) ? v.photos.length : 0;
          const firstPhoto = firstPhotoUuid(v);
          return (
            <a href={`/sklad/${v.id}`} class="stock-card">
              <div class="stock-card__media" aria-hidden="true">
                <DirectusImage
                  src={firstPhoto}
                  alt={`${v.brand.name} ${v.model.name}`}
                  aspectRatio="4/3"
                  widths={[400, 800]}
                  sizes="(max-width: 600px) 100vw, 33vw"
                  fallbackGradient="linear-gradient(135deg, #2a2a30, #56565d)"
                />
                {v.highlighted && <span class="stock-card__badge">⭐ Doporučujeme</span>}
                {photoCount === 0 && <span class="stock-card__no-photo">Foto brzy</span>}
              </div>
              <div class="stock-card__body">
                <div class="stock-card__meta">
                  <span class="chip">{conditionLabels[v.condition] ?? v.condition}</span>
                  <span class="chip chip--success">{availabilityLabels[v.availability] ?? v.availability}</span>
                </div>
                <h4>{v.brand.name} {v.model.name}</h4>
                {v.trim_level?.name && <p class="text-muted">{v.trim_level.name}</p>}
                <div class="stock-card__details">
                  {v.km !== undefined && v.km !== null && (
                    <span class="font-mono">{v.km.toLocaleString('cs-CZ')} km</span>
                  )}
                  {v.color_code && <span class="font-mono">{v.color_code}</span>}
                </div>
                <div class="stock-card__price">
                  {hasPromo ? (
                    <>
                      <span class="stock-card__price-list">{v.list_price?.toLocaleString('cs-CZ')} Kč</span>
                      <span class="stock-card__price-promo">{v.promo_price?.toLocaleString('cs-CZ')} Kč</span>
                    </>
                  ) : (
                    <span class="stock-card__price-promo">
                      {(v.promo_price ?? v.list_price)?.toLocaleString('cs-CZ')} Kč
                    </span>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .sklad__hero { padding-block: clamp(40px, 6vw, 80px) clamp(24px, 4vw, 40px); }
  .sklad__hero h1 { margin: 8px 0 16px; }
  .sklad__hero .lead { max-width: 60ch; }

  .filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }
  .filter-chip {
    padding: 8px 16px;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    background: white;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink-soft);
    cursor: pointer;
    transition: all 160ms ease;
  }
  .filter-chip:hover { border-color: var(--ink); }
  .filter-chip.is-active { background: var(--ink); color: white; border-color: var(--ink); }

  .empty-stock {
    padding: clamp(40px, 6vw, 80px);
    text-align: center;
    background: var(--bg-soft);
    border-radius: var(--radius-lg);
    border: 1px dashed var(--line);
    margin-bottom: var(--section-pad);
  }
  .empty-stock h3 { margin-bottom: 8px; }

  .stock__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    padding-bottom: var(--section-pad);
  }
  @media (min-width: 600px) { .stock__grid { grid-template-columns: repeat(2, 1fr); gap: 20px; } }
  @media (min-width: 1000px) { .stock__grid { grid-template-columns: repeat(3, 1fr); } }

  .stock-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .stock-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }

  .stock-card__media { aspect-ratio: 4/3; position: relative; overflow: hidden; }
  .stock-card__bg {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #2a2a30, #56565d);
  }
  .stock-card__badge {
    position: absolute; top: 12px; left: 12px;
    background: var(--accent); color: white;
    padding: 4px 10px; border-radius: var(--radius);
    font-size: 0.75rem; font-weight: 600;
  }
  .stock-card__no-photo {
    position: absolute; bottom: 12px; left: 12px;
    background: rgba(0,0,0,0.6); color: white;
    padding: 4px 10px; border-radius: var(--radius);
    font-size: 0.7rem;
  }

  .stock-card__body { padding: 16px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .stock-card__meta { display: flex; gap: 6px; flex-wrap: wrap; }
  .chip { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; background: var(--bg-soft); padding: 4px 8px; border-radius: 4px; color: var(--ink-soft); }
  .chip--success { background: rgba(30, 123, 95, 0.1); color: var(--success); }

  .stock-card h4 { font-size: 1.05rem; margin-top: 2px; }
  .stock-card__details { display: flex; gap: 12px; flex-wrap: wrap; font-size: 0.85rem; color: var(--muted); }

  .stock-card__price { margin-top: auto; padding-top: 8px; display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
  .stock-card__price-list { font-size: 0.85rem; color: var(--muted); text-decoration: line-through; }
  .stock-card__price-promo { font-size: 1.15rem; font-weight: 700; color: var(--accent); }
</style>
