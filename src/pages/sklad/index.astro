---
import BaseLayout from '@layouts/BaseLayout.astro';
import DirectusImage from '@components/DirectusImage.astro';
import FuelIcon from '@components/FuelIcon.astro';
import StockCard from '@components/StockCard.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { directusGet } from '@lib/directus';
import { buildStockSlug } from '@lib/stockSlug';
import type { Brand, StockVehicle } from '@lib/types';

/* /sklad — finální layout (Modern Authorized Dealer). Reálná data z Directusu,
   filter sidebar (značka/model/palivo/stav/pohon/dostupnost) + sort + URL sync. */
export const prerender = false;
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');

type V = StockVehicle & {
  brand?: { name: string; slug: string };
  model?: { name: string; slug: string; fuel_type?: string;
    promo_active?: boolean; promo_label?: string; promo_discount_amount?: number; promo_valid_to?: string };
  trim_level?: { name: string } | null;
  model_year?: { year: number } | null;
  photos?: Array<{ directus_files_id: string }> | string[];
  transmission?: string;
  drivetrain?: string;
  highlighted?: boolean;
  highlight_label?: string;
  listed_at?: string;
};

const brands = await directusGet<Brand>('brands', { sort: ['sort'], fields: ['id', 'slug', 'name'] }, true);

const vehicles = await directusGet<V>('stock_vehicles', {
  filter: { status: { _eq: 'published' }, availability: { _neq: 'sold' } },
  sort: ['-listed_at', 'sort'],
  fields: [
    'id', 'vin', 'list_price', 'promo_price', 'lowest_price_30d', 'km',
    'condition', 'availability', 'color_code',
    'transmission', 'drivetrain',
    'highlighted', 'highlight_label', 'listed_at',
    'trim_level_snapshot',
    'photos.directus_files_id',
    'brand.name', 'brand.slug',
    'model.name', 'model.slug', 'model.fuel_type',
    'model.promo_active', 'model.promo_label', 'model.promo_discount_amount', 'model.promo_valid_to',
    'model_year.year',
    'trim_level.name',
    'first_registration',
  ],
}, true);

const fuelLabels: Record<string, string> = { petrol: 'Benzín', diesel: 'Diesel', hybrid: 'HEV', phev: 'PHEV', ev: 'Elektro' };

const availableFuels = [...new Set(vehicles.map((v) => v.model?.fuel_type).filter(Boolean))] as string[];
const availableConditions = [...new Set(vehicles.map((v) => v.condition).filter(Boolean))] as string[];
const has4wd = vehicles.some((v) => v.drivetrain === '4wd' || v.drivetrain === 'awd');

type ModelOpt = { slug: string; name: string };
const modelsByBrand = new Map<string, { brandName: string; models: ModelOpt[] }>();
vehicles.forEach((v) => {
  if (!v.brand?.slug || !v.model?.slug) return;
  const bSlug = v.brand.slug;
  if (!modelsByBrand.has(bSlug)) modelsByBrand.set(bSlug, { brandName: v.brand.name, models: [] });
  const group = modelsByBrand.get(bSlug)!;
  if (!group.models.find((m) => m.slug === v.model!.slug)) {
    group.models.push({ slug: v.model.slug, name: v.model.name });
  }
});
const modelGroups = Array.from(modelsByBrand.entries())
  .sort((a, b) => a[1].brandName.localeCompare(b[1].brandName))
  .map(([slug, group]) => ({ brandSlug: slug, brandName: group.brandName, models: group.models.sort((a, b) => a.name.localeCompare(b.name)) }));

const stats = {
  inStock: vehicles.filter(v => v.availability === 'in_stock').length,
  onWay: vehicles.filter(v => v.availability === 'on_the_way').length,
  onOrder: vehicles.filter(v => v.availability === 'on_order').length,
};

const fmtPrice = (n?: number | null) => n ? `${n.toLocaleString('cs-CZ')} Kč` : '—';
const fmtKm = (n?: number | null) => (n === 0 || !n) ? '0 km' : `${n.toLocaleString('cs-CZ')} km`;

function firstPhoto(v: V): string | null {
  if (!Array.isArray(v.photos) || v.photos.length === 0) return null;
  const f: any = v.photos[0];
  return typeof f === 'string' ? f : (f?.directus_files_id ?? null);
}

---

<BaseLayout title="Skladové vozy" description="Aktuální nabídka skladových vozů KGM, OMODA & JAECOO, Farizon u SFR Motor Praha-Ďáblice.">
  <Breadcrumbs items={[{ label: 'Skladové vozy' }]} />

  <section class="a-page">
    <div class="a-container">
      <div class="a-hero">
        <h1>Skladové vozy</h1>
        <p>Vyberte si z nabídky {vehicles.length} vozů KGM, OMODA &amp; JAECOO a Farizon.</p>
        <div class="a-stats">
          <div class="a-stat"><span class="a-stat-val">{stats.inStock}</span><span class="a-stat-lbl">Skladem</span></div>
          <div class="a-stat"><span class="a-stat-val">{stats.onWay}</span><span class="a-stat-lbl">Na cestě</span></div>
          <div class="a-stat"><span class="a-stat-val">{stats.onOrder}</span><span class="a-stat-lbl">Na objednání</span></div>
        </div>
      </div>

      <div class="a-layout">
        <aside class="a-sidebar" data-filters>
          <div class="a-sb-head">
            <button type="button" class="a-sb-toggle" data-filter-toggle aria-expanded="false">
              <strong>Filtry</strong>
              <svg class="a-sb-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <button type="button" class="a-sb-clear" data-reset>Resetovat</button>
          </div>

          <div class="a-fblock">
            <h4>Dostupnost</h4>
            <label><input type="checkbox" value="in_stock" checked data-avail-cb /> Skladem v Praze <span class="a-cnt">{stats.inStock}</span></label>
            <label><input type="checkbox" value="on_the_way" checked data-avail-cb /> Na cestě <span class="a-cnt">{stats.onWay}</span></label>
            <label><input type="checkbox" value="on_order" data-avail-cb /> Na objednání <span class="a-cnt">{stats.onOrder}</span></label>
          </div>

          <div class="a-fblock">
            <h4>Značka</h4>
            <label><input type="radio" name="brand" value="all" checked /> Všechny</label>
            {brands.map((b) => (
              <label><input type="radio" name="brand" value={b.slug} /> {b.name}</label>
            ))}
          </div>

          {modelGroups.length > 0 && (
            <div class="a-fblock">
              <h4>Model</h4>
              <select class="a-select" data-filter-model>
                <option value="all">Všechny modely</option>
                {modelGroups.map((g) => (
                  <optgroup label={g.brandName} data-brand={g.brandSlug}>
                    {g.models.map((m) => (
                      <option value={m.slug} data-brand={g.brandSlug}>{m.name}</option>
                    ))}
                  </optgroup>
                ))}
              </select>
            </div>
          )}

          {availableFuels.length > 0 && (
            <div class="a-fblock">
              <h4>Palivo</h4>
              <label><input type="radio" name="fuel" value="all" checked /> Vše</label>
              {availableFuels.map((f) => (
                <label><input type="radio" name="fuel" value={f} /> {fuelLabels[f] ?? f}</label>
              ))}
            </div>
          )}

          {availableConditions.length > 0 && (
            <div class="a-fblock">
              <h4>Stav</h4>
              <label><input type="radio" name="condition" value="all" checked /> Vše</label>
              {availableConditions.includes('new') && <label><input type="radio" name="condition" value="new" /> Nové</label>}
              {availableConditions.includes('demo') && <label><input type="radio" name="condition" value="demo" /> Předváděcí</label>}
              {availableConditions.includes('used') && <label><input type="radio" name="condition" value="used" /> Ojeté</label>}
            </div>
          )}

          {has4wd && (
            <div class="a-fblock">
              <h4>Pohon</h4>
              <label><input type="radio" name="drivetrain" value="all" checked /> Vše</label>
              <label><input type="radio" name="drivetrain" value="4wd" /> Pouze 4×4</label>
            </div>
          )}
        </aside>

        <div>
          <div class="a-toolbar">
            <div class="a-result" data-result-count>
              <strong>{vehicles.length}</strong> vozů
            </div>
            <label class="a-sort">
              Seřadit:
              <select class="a-select" data-sort>
                <option value="newest">Nejnovější</option>
                <option value="price-asc">Cena ↑</option>
                <option value="price-desc">Cena ↓</option>
              </select>
            </label>
          </div>

          <div class="a-grid" data-grid>
            {vehicles.map((v: any) => <StockCard v={v} />)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const filters = { brand: 'all', model: 'all', fuel: 'all', condition: 'all', drivetrain: 'all' };
      const availabilitySet = new Set(['in_stock', 'on_the_way']);
      let sortMode = 'newest';

      function syncURL() {
        const url = new URL(location.href);
        const map = { brand: 'znacka', model: 'model', fuel: 'palivo', condition: 'stav', drivetrain: 'pohon' };
        Object.entries(map).forEach(([key, q]) => {
          const val = filters[key];
          if (val && val !== 'all') url.searchParams.set(q, val);
          else url.searchParams.delete(q);
        });
        if (sortMode && sortMode !== 'newest') url.searchParams.set('razeni', sortMode);
        else url.searchParams.delete('razeni');
        history.replaceState({}, '', url);
      }

      function applyFilters() {
        const grid = document.querySelector('[data-grid]');
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll('.a-card'));
        let visible = 0;
        cards.forEach((c) => {
          const el = c;
          const dt = el.dataset.drivetrain || '';
          const drivetrainOk = filters.drivetrain === 'all' || (filters.drivetrain === '4wd' && (dt === '4wd' || dt === 'awd'));
          const av = el.dataset.availability || 'in_stock';
          const availabilityOk = availabilitySet.size === 0 || availabilitySet.has(av);
          const ok =
            (filters.brand === 'all' || el.dataset.brand === filters.brand) &&
            (filters.model === 'all' || el.dataset.model === filters.model) &&
            (filters.fuel === 'all' || el.dataset.fuel === filters.fuel) &&
            (filters.condition === 'all' || el.dataset.condition === filters.condition) &&
            drivetrainOk && availabilityOk;
          if (ok) { el.style.display = ''; visible++; } else { el.style.display = 'none'; }
        });
        const visibleCards = cards.filter((c) => c.style.display !== 'none');
        visibleCards.sort((a, b) => {
          if (sortMode === 'price-asc') return Number(a.dataset.price || 0) - Number(b.dataset.price || 0);
          if (sortMode === 'price-desc') return Number(b.dataset.price || 0) - Number(a.dataset.price || 0);
          return (b.dataset.listedAt || '').localeCompare(a.dataset.listedAt || '');
        });
        visibleCards.forEach((c) => grid.appendChild(c));
        syncURL();
        const count = document.querySelector('[data-result-count]');
        if (count) {
          const noun = visible === 1 ? 'vůz' : visible < 5 ? 'vozy' : 'vozů';
          count.innerHTML = visible === 0 ? '<strong>Žádné vozy</strong> nesplňují filtr' : '<strong>' + visible + '</strong> ' + noun;
        }
        const modelSelect = document.querySelector('[data-filter-model]');
        if (modelSelect) {
          modelSelect.querySelectorAll('optgroup').forEach((og) => {
            const ogBrand = og.dataset.brand || '';
            og.hidden = !(filters.brand === 'all' || filters.brand === ogBrand);
          });
        }
      }

      document.querySelectorAll('[data-filters] input[type=radio]').forEach((input) => {
        input.addEventListener('change', (e) => {
          const t = e.target;
          if (t.name in filters) { filters[t.name] = t.value; applyFilters(); }
        });
      });
      document.querySelectorAll('[data-avail-cb]').forEach((input) => {
        input.addEventListener('change', (e) => {
          const t = e.target;
          if (t.checked) availabilitySet.add(t.value); else availabilitySet.delete(t.value);
          applyFilters();
        });
      });
      document.querySelector('[data-filter-model]')?.addEventListener('change', (e) => {
        filters.model = e.target.value;
        const opt = e.target.selectedOptions[0];
        const optBrand = opt && opt.dataset ? opt.dataset.brand : null;
        if (optBrand && filters.brand !== optBrand && filters.model !== 'all') {
          filters.brand = optBrand;
          const radio = document.querySelector('[data-filters] input[name=brand][value="' + optBrand + '"]');
          if (radio) radio.checked = true;
        }
        applyFilters();
      });
      document.querySelector('[data-sort]')?.addEventListener('change', (e) => { sortMode = e.target.value; applyFilters(); });
      document.querySelector('[data-reset]')?.addEventListener('click', () => {
        Object.keys(filters).forEach((k) => { filters[k] = 'all'; });
        document.querySelectorAll('[data-filters] input[value=all]').forEach((i) => (i.checked = true));
        availabilitySet.clear();
        availabilitySet.add('in_stock');
        availabilitySet.add('on_the_way');
        document.querySelectorAll('[data-avail-cb]').forEach((cb) => {
          cb.checked = ['in_stock', 'on_the_way'].includes(cb.value);
        });
        const ms = document.querySelector('[data-filter-model]');
        if (ms) ms.value = 'all';
        const ss = document.querySelector('[data-sort]');
        if (ss) ss.value = 'newest';
        sortMode = 'newest';
        applyFilters();
      });

      // Mobilní akordeon filtru — toggle .is-open na sidebaru (na desktopu bez efektu)
      document.querySelector('[data-filter-toggle]')?.addEventListener('click', function () {
        const sb = document.querySelector('[data-filters]');
        if (!sb) return;
        const open = sb.classList.toggle('is-open');
        this.setAttribute('aria-expanded', String(open));
      });

      const params = new URLSearchParams(window.location.search);
      const availParam = params.get('dostupnost') || params.get('availability');
      if (availParam) {
        const wanted = availParam.split(',').map((s) => s.trim()).filter(Boolean);
        availabilitySet.clear();
        document.querySelectorAll('[data-avail-cb]').forEach((cb) => {
          const on = wanted.includes(cb.value);
          cb.checked = on;
          if (on) availabilitySet.add(cb.value);
        });
      }
      const URL_MAP = [
        ['znacka', 'brand', 'brand'], ['palivo', 'fuel', 'fuel'],
        ['stav', 'condition', 'condition'], ['pohon', 'drivetrain', 'drivetrain'],
      ];
      URL_MAP.forEach(([q, key, rname]) => {
        const v = params.get(q);
        if (!v) return;
        const r = document.querySelector('[data-filters] input[name=' + rname + '][value="' + v + '"]');
        if (r) { r.checked = true; filters[key] = v; }
      });
      const modelParam = params.get('model');
      if (modelParam) {
        const ms = document.querySelector('[data-filter-model]');
        if (ms && ms.querySelector('option[value="' + modelParam + '"]')) { ms.value = modelParam; filters.model = modelParam; }
      }
      const sortParam = params.get('razeni') || params.get('sort');
      if (sortParam) {
        const ss = document.querySelector('[data-sort]');
        if (ss && ss.querySelector('option[value="' + sortParam + '"]')) { ss.value = sortParam; sortMode = sortParam; }
      }
      applyFilters();
    })();
  </script>
</BaseLayout>
